translate spanish baibeachdate_caf334cd:

    # "I pick Bai up and we drive out towards the beach."
    "Recojo a Bai y nos dirigimos hacia la playa."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:21
translate spanish baibeachdate_8ebfb187:

    # pc "Have you been out here before?"
    pc "¿Has estado aquí antes?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:22
translate spanish baibeachdate_64336c0b:

    # bai "Yeah, I sometimes come out here to run in the mornings."
    bai "Sí, a veces vengo aquí a correr por las mañanas."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:23
translate spanish baibeachdate_5f0b57d2:

    # bai "But I've never been out here with a cute guy before."
    bai "Pero nunca había venido aquí con un chico guapo."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:29
translate spanish baibeachdate_e914bd34:

    # "When we get to the beach, Bai pulls his shirt off."
    "Cuando llegamos a la playa, Bai se quita la camiseta."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:30
translate spanish baibeachdate_835e0f75:

    # "He's already put suntan lotion on and his skin glistens in the light."
    "Ya se ha puesto crema solar y su piel brilla a la luz."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:31
translate spanish baibeachdate_4cb4deb6:

    # bai "Ready to get in the water?"
    bai "¿Listo para meterte en el agua?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:32
translate spanish baibeachdate_39757b54:

    # pc "Yeah, let's do it."
    pc "Sí, vamos."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:35
translate spanish baibeachdate_67fe8962:

    # "We swim around for a while. Bai gets really into it."
    "Nadamos un rato. A Bai le encanta."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:36
translate spanish baibeachdate_eaa7bafe:

    # "We try racing a bit, but even though I'm a good swimmer, Bai is way too fast for me to keep up with."
    "Intentamos hacer una carrera, pero aunque soy buen nadador, Bai es demasiado rápido para que pueda seguirle el ritmo."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:39
translate spanish baibeachdate_c4765999:

    # "After a while, we're both tired from swimming and the sun is starting to set, so we lie on the beach and dry off."
    "Al cabo de un rato, los dos estamos cansados de nadar y el sol empieza a ponerse, así que nos tumbamos en la playa y nos secamos."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:40
translate spanish baibeachdate_3d2f7709:

    # "We lean back and talk for a while about whatever comes to mind."
    "Nos recostamos y hablamos un rato de lo que se nos ocurre."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:47
translate spanish baibeachdate_fb5239af:

    # bai "Well, I guess we should head back."
    bai "Bueno, supongo que deberíamos volver."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:48
translate spanish baibeachdate_e0511e98:

    # bai "This was fun though, man. Maybe next time there will be more girls out here, you know?"
    bai "Aunque esto ha sido divertido, tío. Quizás la próxima vez haya más chicas por aquí, ¿sabes?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:51
translate spanish baibeachdate_9291d328:

    # "I drive Bai back to his apartment, then leave to go on with the rest of my day."
    "Llevo a Bai de vuelta a su apartamento y luego me voy para seguir con el resto de mi día."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:62
translate spanish baibeachdate_67f91a9e:

    # "When the sun starts to dip below the horizon, we take a moment to watch it together."
    "Cuando el sol empieza a hundirse en el horizonte, nos tomamos un momento para contemplarlo juntos."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:64
translate spanish baibeachdate_c710bd77:

    # bai "This is so beautiful."
    bai "Esto es tan bonito."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:65
translate spanish baibeachdate_409aa835:

    # "I can see his eyes tear up a bit."
    "Veo que se le humedecen un poco los ojos."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:66
translate spanish baibeachdate_7a029997:

    # bai "You make me feel so safe."
    bai "Me haces sentir tan seguro."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:67
translate spanish baibeachdate_fe07fc02:

    # pc "You're always safe with me."
    pc "Conmigo siempre estás a salvo."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:72
translate spanish baibeachdate_e1672a1f:

    # bai "I'm so happy that we found each other."
    bai "Estoy tan feliz de que nos hayamos encontrado."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:73
translate spanish baibeachdate_afdaf298:

    # bai "I can't wait to get you back to my place."
    bai "Estoy deseando llevarte a mi casa."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:78
translate spanish baibeachdate_123df4e4:

    # bai "After the sun sets though."
    bai "Pero después de que se ponga el sol."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:79
translate spanish baibeachdate_63409295:

    # bai "I'm really enjoying this moment."
    bai "Estoy disfrutando mucho este momento."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:83
translate spanish baibeachdate_67ce83d2:

    # "After the sun sets, I drive us back to his apartment."
    "Después de que se ponga el sol, nos llevo en coche a su apartamento."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:84
translate spanish baibeachdate_64712708:

    # bai "Are you coming inside?"
    bai "¿Vas a entrar?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:89
translate spanish baibeachdate_0ac06427:

    # bai "Cool. Let's go."
    bai "Genial. Vamos."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:92
translate spanish baibeachdate_b7437714:

