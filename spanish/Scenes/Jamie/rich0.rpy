# game/Scenes/Jamie/rich0.rpy:11
translate spanish rich0_cfa93e6c:

    # "I walk over to Jamie's house and knock on the door."
    "Me acerco a la casa de Jamie y llamo a la puerta."

# game/Scenes/Jamie/rich0.rpy:14
translate spanish rich0_3517dc2a:

    # "Jamie's dad answers the door and looks at me with a visible snarl."
    "El padre de Jamie abre la puerta y me mira con un gruñido visible."

# game/Scenes/Jamie/rich0.rpy:15
translate spanish rich0_f8843cde:

    # pc "Is Jamie home?"
    pc "¿Está Jamie en casa?"

# game/Scenes/Jamie/rich0.rpy:16
translate spanish rich0_8dae1bff:

    # jd "Look [pcname], I don't know why you're back and I don't really care, you just leave my Jamie out of it."
    jd "Mira [pcname], no sé por qué has vuelto y realmente no me importa, pero deja a mi Jamie fuera de esto."

# game/Scenes/Jamie/rich0.rpy:17
translate spanish rich0_b43e0748:

    # jd "I don't want you talking to her. I don't want you looking at her. I don't want you even thinking about her."
    jd "No quiero que le hables. No quiero que la mires. Ni siquiera quiero que pienses en ella."

# game/Scenes/Jamie/rich0.rpy:18
translate spanish rich0_fdac7df1:

    # jd "Now get the hell off my porch and don't come back over here again."
    jd "Ahora lárgate de mi porche y no vuelvas por aquí nunca más."

# game/Scenes/Jamie/rich0.rpy:20
translate spanish rich0_0c9032ac:

    # "Before I can even formulate a response, he slams the door in my face."
    "Antes de que pueda siquiera formular una respuesta, me da un portazo en las narices."

# game/Scenes/Jamie/rich0.rpy:21
translate spanish rich0_b20e176c:

    # "I'm so confused. I have no idea what I did to him that made him hate me so much."
    "Estoy muy confundido. No tengo ni idea de qué le hice para que me odie tanto."

# game/Scenes/Jamie/rich0.rpy:22
translate spanish rich0_849077d5:

    # "I'll just have to talk to Jamie sometime when he's not here."
    "Tendré que hablar con Jamie algún día cuando él no esté aquí."

translate spanish strings:

    # game/Scenes/Jamie/rich0.rpy:2
    old "After the first time you hang out with Jamie at her house,"
    new "Después de la primera vez que quedes con Jamie en su casa,"

    # game/Scenes/Jamie/rich0.rpy:3
    old "go to Jamie's house on the weekend or in the morning, when her dad is home."
    new "ve a casa de Jamie el fin de semana o por la mañana, cuando su padre esté en casa."

