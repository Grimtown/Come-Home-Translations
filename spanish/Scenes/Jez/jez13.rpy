translate spanish jez13_ce637d21:

    # "Jez and her mamá come to the table and Jez puts a plate of food in front of me."
    "Jez y su mamá se acercan a la mesa y Jez pone un plato de comida delante de mí."

# game/Scenes/Jez/jez13.rpy:197
translate spanish jez13_e02b004c:

    # "Before I get a chance to even look at it though, Mamá sits across from me and looks me in the eyes, like she's weighing me up."
    "Pero antes de que tenga tiempo siquiera de mirarlo, mamá se sienta frente a mí y me mira a los ojos, como si me estuviera evaluando."

# game/Scenes/Jez/jez13.rpy:198
translate spanish jez13_0711ba82:

    # mama "So, [pcname], how old are you?"
    mama "Bueno, [pcname], ¿cuántos años tienes?"

# game/Scenes/Jez/jez13.rpy:200
translate spanish jez13_c2113814:

    # pc "Twenty-two."
    pc "Veintidós."

# game/Scenes/Jez/jez13.rpy:202
translate spanish jez13_a6d70d6c:

    # mama "So young. You're younger than Jesabela."
    mama "Qué joven. Eres más joven que Jesabela."

# game/Scenes/Jez/jez13.rpy:205
translate spanish jez13_d41d8cd9_16:

    # voice 'voices/jez_13_17.mp3'
    voice 'voices/jez_13_17.mp3'

# game/Scenes/Jez/jez13.rpy:206
translate spanish jez13_8cc38855:

    # det "Ay Mamá!"
    det "¡Ay, mamá!"

# game/Scenes/Jez/jez13.rpy:208
translate spanish jez13_1da93989:

    # mama "Do you have a job?"
    mama "¿Tienes trabajo?"

# game/Scenes/Jez/jez13.rpy:210
translate spanish jez13_748e9a7f:

    # pc "Yes, as an assistant at a law office."
    pc "Sí, soy asistente en un bufete de abogados."

# game/Scenes/Jez/jez13.rpy:212
translate spanish jez13_23a217be:

    # mama "Do you have any children?"
    mama "¿Tienes hijos?"

# game/Scenes/Jez/jez13.rpy:214
translate spanish jez13_4219f3ee:

    # pc "No."
    pc "No."

# game/Scenes/Jez/jez13.rpy:216
translate spanish jez13_5dc9c07e:

    # mama "Do you do drugs?"
    mama "¿Consumes drogas?"

# game/Scenes/Jez/jez13.rpy:218
translate spanish jez13_4219f3ee_1:

    # pc "No."
    pc "No."

# game/Scenes/Jez/jez13.rpy:220
translate spanish jez13_af0ca811:

    # mama "Do you live with your parents?"
    mama "¿Vives con tus padres?"

# game/Scenes/Jez/jez13.rpy:222
translate spanish jez13_9af16977:

    # pc "I live with my [mother] at the moment."
    pc "Ahora mismo vivo con mi [mother]."

# game/Scenes/Jez/jez13.rpy:224
translate spanish jez13_6b1ebe90:

    # mama "How many other girlfriends do you have?"
    mama "¿Cuántas otras novias tienes?"

# game/Scenes/Jez/jez13.rpy:227
translate spanish jez13_d41d8cd9_17:

    # voice 'voices/jez_13_17b.mp3'
    voice 'voices/jez_13_17b.mp3'

# game/Scenes/Jez/jez13.rpy:228
translate spanish jez13_5296d8b8:

    # det "Ay Mamá, be nice!"
    det "¡Ay, mamá, sé buena!"

# game/Scenes/Jez/jez13.rpy:229
translate spanish jez13_5faa2282:

    # mama "Que?"
    mama "¿Qué?"

# game/Scenes/Jez/jez13.rpy:230
translate spanish jez13_fd390a20:

    # mama "Quiero saber acerca de este chico con el que estás saliendo."
    mama "Quiero saber sobre este chico con el que estás saliendo."

# game/Scenes/Jez/jez13.rpy:232
translate spanish jez13_d41d8cd9_18:

    # voice 'voices/jez_13_18.mp3'
    voice 'voices/jez_13_18.mp3'

# game/Scenes/Jez/jez13.rpy:233
translate spanish jez13_1e7215a5:

    # det "Ya te hablé de él. Es un buen chico y me gusta. ¿No confías en mi juicio?"
    det "Ya te hablé de él. Es un buen chico y me gusta. ¿No confías en mi criterio?"

# game/Scenes/Jez/jez13.rpy:234
translate spanish jez13_28dfbcd6:

    # mama "No lo hiciste tan bien la primera vez."
    mama "No lo hiciste tan bien la primera vez."

# game/Scenes/Jez/jez13.rpy:235
translate spanish jez13_1847687a:

    # det "Mamá!"
    det "¡Mamá!"

# game/Scenes/Jez/jez13.rpy:237
translate spanish jez13_a9618f8c:

    # mama "Do you have any brothers or sisters?"
    mama "¿Tienes hermanos o hermanas?"

# game/Scenes/Jez/jez13.rpy:239
translate spanish jez13_b0e9cb79:

    # pc "Just Suzy, my [sister]."
    pc "Solo a Suzy, mi [sister]."

# game/Scenes/Jez/jez13.rpy:241
translate spanish jez13_0acf000d:

    # mama "What are you going to school for?"
    mama "¿Para qué vas a la universidad?"

# game/Scenes/Jez/jez13.rpy:243
translate spanish jez13_04c35adf:

    # pc "Quantum physics. To be a scientist."
    pc "Física cuántica. Para ser científico."

# game/Scenes/Jez/jez13.rpy:245
translate spanish jez13_36e29056:

    # det "That's enough, Mamá, the food is getting cold while you're grilling him."
    det "Ya basta, Mamá, la comida se está enfriando mientras lo estás interrogando."

# game/Scenes/Jez/jez13.rpy:246
translate spanish jez13_9fda17f8:

    # mama "You seem like a good boy, I suppose."
    mama "Pareces un buen chico, supongo."

# game/Scenes/Jez/jez13.rpy:247
translate spanish jez13_45d2cbc0:

    # det "He is. He helped me out a lot last night."
    det "Lo es. Me ayudó mucho anoche."

# game/Scenes/Jez/jez13.rpy:248
translate spanish jez13_f3a75866:

    # mama "I'm sure he did."
    mama "Seguro que sí."

# game/Scenes/Jez/jez13.rpy:250
translate spanish jez13_d41d8cd9_19:

    # voice 'voices/jez_13_20.mp3'
    voice 'voices/jez_13_20.mp3'

# game/Scenes/Jez/jez13.rpy:251
translate spanish jez13_b535f103:

    # det "Mamá! Cuida lo que dices delante de Javi."
    det "¡Mamá! Cuida lo que dices delante de Javi."

# game/Scenes/Jez/jez13.rpy:252
translate spanish jez13_c913be1a:

    # mama "No dije nada en absoluto!"
    mama "¡No he dicho nada en absoluto!"

# game/Scenes/Jez/jez13.rpy:255
translate spanish jez13_c5ef0cc4:

    # mama "If Jesabela likes you enough to introduce you to me, you must be something special."
    mama "Si a Jesabela le gustas lo suficiente como para presentárteme, debes de ser alguien especial."

# game/Scenes/Jez/jez13.rpy:256
translate spanish jez13_48aa3884:

    # mama "You just be good to her."
    mama "Solo sé bueno con ella."

# game/Scenes/Jez/jez13.rpy:257
translate spanish jez13_f31ca3be:

    # pc "Yes ma'am, I will."
    pc "Sí, señora, lo seré."

# game/Scenes/Jez/jez13.rpy:258
translate spanish jez13_8faa40cf:

    # mama "No ma'am. You call me Mamá, or Ivelisse."
    mama "No, señora. Llámame Mamá, o Ivelisse."

# game/Scenes/Jez/jez13.rpy:259
translate spanish jez13_49e790d0:

    # jav "Or Abuelita."
    jav "O Abuelita."

# game/Scenes/Jez/jez13.rpy:262
translate spanish jez13_f9207776:

    # mama "No, mi guapo, you're the only one that gets to call me abuelita."
    mama "No, mi guapo, tú eres el único que puede llamarme abuelita."

# game/Scenes/Jez/jez13.rpy:263
translate spanish jez13_8d2fe2d9:

    # jav "Oh okay. Sorry, [pcname], you can't call her that."
    jav "Ah, vale. Lo siento, [pcname], no puedes llamarla así."

# game/Scenes/Jez/jez13.rpy:266
translate spanish jez13_196bac72:

    # "We chit-chat a little more while we eat."
    "Charlamos un poco más mientras comemos."

# game/Scenes/Jez/jez13.rpy:267
translate spanish jez13_dedcdede:

    # "Ivelisse is a little intimidating, but after a while, she smiles a lot and she seems pretty funny."
    "Ivelisse da un poco de respeto, pero al cabo de un rato sonríe mucho y parece bastante divertida."

# game/Scenes/Jez/jez13.rpy:268
translate spanish jez13_0ba3754f:

    # "And I can feel so much love between the three of them."
    "Y se nota mucho el cariño que hay entre los tres."

# game/Scenes/Jez/jez13.rpy:271
translate spanish jez13_81657b80:

    # "Javi talks a lot about school and the base that he and his friends are building in Minecraft."
    "Javi habla mucho del colegio y de la base que él y sus amigos están construyendo en Minecraft."

# game/Scenes/Jez/jez13.rpy:272
translate spanish jez13_c3923da8:

    # "Meanwhile, Jez looks at me with a shy smile while her foot rubs against my leg under the table."
    "Mientras tanto, Jez me mira con una sonrisa tímida mientras me roza la pierna con el pie debajo de la mesa."

# game/Scenes/Jez/jez13.rpy:275
translate spanish jez13_c332134e:

    # "When we finish eating, I tell Javi and Ivelisse goodbye."
    "Cuando terminamos de comer, me despido de Javi e Ivelisse."

# game/Scenes/Jez/jez13.rpy:276
translate spanish jez13_eac1a598:

    # mama "It was very nice to meet you, [pcname]."
    mama "Ha sido un placer conoceros, [pcname]."

# game/Scenes/Jez/jez13.rpy:277
translate spanish jez13_a7f3d1fc:

    # pc "Nice to meet you too. Thank you for the amazing breakfast."
    pc "Igualmente. Gracias por el desayuno tan increíble."

# game/Scenes/Jez/jez13.rpy:278
translate spanish jez13_6ad487d2:

    # jav "Bye, [pcname]!"
    jav "¡Adiós, [pcname]!"

# game/Scenes/Jez/jez13.rpy:279
translate spanish jez13_5f653b3b:

    # pc "Bye, Javi. I'll be back for you to teach me about Minecraft sometime, okay?"
    pc "Adiós, Javi. Volveré para que me enseñes sobre Minecraft algún día, ¿vale?"

# game/Scenes/Jez/jez13.rpy:280
translate spanish jez13_930b665f:

    # jav "Okay!"
    jav "¡Vale!"

# game/Scenes/Jez/jez13.rpy:283
translate spanish jez13_12a645a9:

    # pc "Do you think I did okay?"
    pc "¿Crees que lo hice bien?"

# game/Scenes/Jez/jez13.rpy:284
translate spanish jez13_e66be0b3:

    # det "You did wonderful."
    det "Lo hiciste de maravilla."

# game/Scenes/Jez/jez13.rpy:287
translate spanish jez13_2a95c68b:

    # det "Seriously, [pcname]. Thank you for everything."
    det "En serio, [pcname]. Gracias por todo."

# game/Scenes/Jez/jez13.rpy:288
translate spanish jez13_a05c3ddb:

    # pc "You're welcome. Hope your day is better today."
    pc "De nada. Espero que hoy tengas un día mejor."

# game/Scenes/Jez/jez13.rpy:289
translate spanish jez13_37df78b6:

    # det "It will be. I already feel so much better."
    det "Lo tendré. Ya me siento mucho mejor."

# game/Scenes/Jez/jez13.rpy:290
translate spanish jez13_95715fb7:

    # det "You have a good day too. Let's spend some more time together soon, okay?"
    det "Que tú también tengas un buen día. Pasemos más tiempo juntos pronto, ¿vale?"

# game/Scenes/Jez/jez13.rpy:291
translate spanish jez13_2951ed74:

    # pc "Definitely."
    pc "Por supuesto."

# game/Scenes/Jez/jez13.rpy:294
translate spanish jez13_01f6f4f8:

    # "I leave her house and go home to change clothes and get my things, then head straight to school, barely getting there in time for my first class."
    "Salgo de su casa y me voy a casa a cambiarme de ropa y a coger mis cosas, luego me dirijo directamente al colegio, llegando apenas a tiempo para mi primera clase."

# game/Scenes/Jez/jez13.rpy:295
translate spanish jez13_24a3ded4:

    # "The whole time, I'm thinking about my relationship with Jez."
    "Todo el rato estoy pensando en mi relación con Jez."

# game/Scenes/Jez/jez13.rpy:296
translate spanish jez13_b509de35:

    # "She called me her boyfriend."
    "Me llamó su novio."

# game/Scenes/Jez/jez13.rpy:297
translate spanish jez13_b197b664:

    # "It seems like it's starting to get pretty serious. Meeting her kid and her mom like that."
    "Parece que la cosa empieza a ponerse bastante seria. Conocer a su hijo y a su madre así."

# game/Scenes/Jez/jez13.rpy:298
translate spanish jez13_4e167340:

    # "I have to think about if that's something I really want or not. She's amazing, but am I really ready to commit to something like that?"
    "Tengo que pensar si eso es algo que realmente quiero o no. Ella es increíble, pero ¿estoy realmente preparado para comprometerme con algo así?"

# game/Scenes/Jez/jez13.rpy:299
translate spanish jez13_3bf96260:

    # "I'll need to decide soon. I don't want to hurt her."
    "Tendré que decidirme pronto. No quiero hacerle daño."

# game/Scenes/Jez/jez13.rpy:300
translate spanish jez13_3c440e53:

    # "And I don't want her Mamá to hurt me."
    "Y no quiero que su mamá me haga daño a mí."

translate spanish strings:

    # game/Scenes/Jez/jez13.rpy:5
    old "Go on a few dates with Jez, including taking her out to eat at Luigi's."
    new "Sal con Jez un par de veces, incluso llevándola a comer a Luigi's."

    # game/Scenes/Jez/jez13.rpy:6
    old "Then she will send you a weird text when you are in your bedroom at night."
    new "Luego ella te enviará un mensaje raro cuando estés en tu habitación por la noche."

