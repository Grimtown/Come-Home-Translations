# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:24
translate spanish michamovietheaterstartdate_929c1af5:

    # "I head over to the movie theater to meet Mi-Cha."
    "Me dirijo al cine para encontrarme con Mi-Cha."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:27
translate spanish michamovietheaterstartdate_53aa213e:

    # "I meet Mi-Cha in the movie theater parking lot."
    "Me encuentro con Mi-Cha en el aparcamiento del cine."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:29
translate spanish michamovietheaterstartdate_1696084c:

    # pc "You look very cute."
    pc "Estás muy mona."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:32
translate spanish michamovietheaterstartdate_d41d8cd9:

    # voice 'voices/micha_thankyou1.mp3'
    voice 'voices/micha_thankyou1.mp3'

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:33
translate spanish michamovietheaterstartdate_bb0eeaf4:

    # mc "Thank you."
    mc "Gracias."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:34
translate spanish michamovietheaterstartdate_17670cf3:

    # mc "You look nice also."
    mc "Tú también estás muy guapo."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:37
translate spanish michamovietheaterstartdate_88edd4ad:

    # "Then we go inside and sit in the back."
    "Luego entramos y nos sentamos en la parte de atrás."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:39
translate spanish michamovietheaterstartdate_90b2b501:

    # "She's so quiet. I should try to start up a conversation."
    "Está muy callada. Debería intentar entablar una conversación."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:44
translate spanish michamovietheaterstartdate_56f38f5f:

    # "The movie starts and we go quiet."
    "Empieza la película y nos quedamos en silencio."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:45
translate spanish michamovietheaterstartdate_0a855fcc:

    # "Throughout the movie, it feels like she starts to relax some."
    "A lo largo de la película, parece que empieza a relajarse un poco."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:47
translate spanish michamovietheaterstartdate_914a9aa2:

    # "It's a fun movie and she's nice company, if a little quiet."
    "Es una película divertida y ella es buena compañía, aunque un poco callada."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:49
translate spanish michamovietheaterstartdate_0edfdae0:

    # "When it ends, she turns to me."
    "Cuando termina, se vuelve hacia mí."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:51
translate spanish michamovietheaterstartdate_bab5119d:

    # mc "Did you like the movie?"
    mc "¿Te ha gustado la película?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:52
translate spanish michamovietheaterstartdate_f4477343:

    # pc "Yeah I enjoyed it."
    pc "Sí, me ha gustado."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:53
translate spanish michamovietheaterstartdate_e4993620:

    # mc "Me too. I thought it was very good."
    mc "A mí también. Me ha parecido muy buena."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:54
translate spanish michamovietheaterstartdate_365db8f9:

    # "We hang out during the credits and chat a little bit more."
    "Nos quedamos charlando un rato más durante los créditos."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:59
translate spanish michamovietheaterstartdate_63e18d0b:

    # "When the credits end, we go outside to the parking lot and stand near her car."
    "Cuando terminan los créditos, salimos al aparcamiento y nos quedamos de pie junto a su coche."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:60
translate spanish michamovietheaterstartdate_725fffe9:

    # mc "I had a very good time. Thank you for taking me."
    mc "Me lo he pasado muy bien. Gracias por traerme."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:61
translate spanish michamovietheaterstartdate_07c9c5ab:

    # pc "You're welcome."
    pc "De nada."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:65
translate spanish michamovietheaterstartdate_5f014a7b:

    # "She rushes up to me, leans up and gives me a tiny peck of a kiss on the mouth, our lips barely touching."
    "Se acerca corriendo a mí, se inclina y me da un besito en la boca, nuestros labios apenas se tocan."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:67
translate spanish michamovietheaterstartdate_5ac477c2:

    # "Then she pulls back once again."
    "Luego se aparta una vez más."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:68
translate spanish michamovietheaterstartdate_50afc9a0:

    # mc "Okay goodbye, [pcname]."
    mc "Bueno, adiós, [pcname]."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:70
translate spanish michamovietheaterstartdate_0488daa1:

    # "And before I can say anything in response, she rushes to her car, starts it up, and drives away."
    "Y antes de que pueda decir nada en respuesta, corre hacia su coche, lo arranca y se marcha."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:72
translate spanish michamovietheaterstartdate_6cbf222e:

    # "Well, I guess we're making some progress at least?"
    "Bueno, supongo que al menos estamos avanzando un poco, ¿no?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:78
translate spanish michamovietheaterstartdate_2674be8c:

    # mc "Would you mind taking me back to my dorm?"
    mc "¿Te importaría llevarme de vuelta a mi residencia?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:79
translate spanish michamovietheaterstartdate_a274c9a4:

    # pc "Of course not."
    pc "Por supuesto que no."

