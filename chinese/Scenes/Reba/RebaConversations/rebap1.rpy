# TODO: Translation updated at 2026-04-15 14:26

# game/Scenes/Reba/RebaConversations/rebap1.rpy:12
translate chinese rebap1_33512a1b:

    # rb "I think you know the answer to that."
    rb "我想你知道答案。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:13
translate chinese rebap1_1b283206:

    # rb "No. I'm not happy. But what am I supposed to do?"
    rb "不。我不开心。但我又能怎么办呢？"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:14
translate chinese rebap1_9c9b6016:

    # rb "I don't make enough money to live by myself anyways, and even if I did..."
    rb "反正我赚的钱还不够独自生活，就算够了……"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:15
translate chinese rebap1_190acff7:

    # rb "... I can't leave Mama."
    rb "…… 我不能抛下妈妈。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:16
translate chinese rebap1_cb78bdc6:

    # pc "You could probably get some sort of financial aid if you went to college."
    pc "如果你去上大学，说不定能申请到某种经济援助。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:17
translate chinese rebap1_674b9eed:

    # pc "You could stay at the dorms."
    pc "你可以住在宿舍里。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:19
translate chinese rebap1_35288230:

    # rb "That's not a bad idea. Maybe I'd be able to do that and still go home and take care of Mama sometimes too."
    rb "这主意倒也不坏。也许我既能上大学，又能偶尔回家照顾妈妈。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:20
translate chinese rebap1_61f77a4c:

    # pc "Sure."
    pc "当然。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:22
translate chinese rebap1_58d87f84:

    # rb "Eventually though... I know I need to live my own life."
    rb "不过终究……我知道我得过自己的生活。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:24
translate chinese rebap1_9049ec3c:

    # rb "This is supposed to be the best time of my life, you know? I'm young, I'm pretty, and I got my whole life ahead of me."
    rb "这本该是我人生中最美好的时光，你知道吗？ 我年轻，我漂亮，未来还很长。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:25
translate chinese rebap1_44258c2a:

    # rb "I don't want to spend it all taking care of Mama."
    rb "我不想把一生都花在照顾妈妈身上。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:26
translate chinese rebap1_87c60ffa:

    # pc "Yeah, I get that."
    pc "是啊，我懂。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:28
translate chinese rebap1_015cec10:

    # rb "But I can't just abandon her either."
    rb "但我也不能就这样抛下她。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:30
translate chinese rebap1_a5b0020a:

    # rb "I just don't know what to do. It's so hard."
    rb "我真的不知道该怎么办。太难了。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:31
translate chinese rebap1_66f2eaa8:

    # pc "Well, whatever you want to do, I'm here for you."
    pc "不管你决定做什么，我都会支持你。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:33
translate chinese rebap1_7edfc2c9:

    # rb "Thanks, [pcname]."
    rb "谢谢，[pcname]。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:34
translate chinese rebap1_aa660344:

    # rb "I'm really glad that we met."
    rb "真的很高兴能遇到你。"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:35
translate chinese rebap1_03eaad50:

    # pc "Me too."
    pc "我也是。"

