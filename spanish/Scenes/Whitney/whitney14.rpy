# game/Scenes/Whitney/whitney14.rpy:18
translate spanish whitney14_50df7566:

    # "My phone buzzes in my pocket. Whitney's calling."
    "Mi teléfono vibra en el bolsillo. Es Whitney."

# game/Scenes/Whitney/whitney14.rpy:22
translate spanish whitney14_9baa4d84:

    # wt "Are you ready?"
    wt "¿Estás listo?"

# game/Scenes/Whitney/whitney14.rpy:23
translate spanish whitney14_8a4963b6:

    # pc "Ready for what?"
    pc "¿Listo para qué?"

# game/Scenes/Whitney/whitney14.rpy:24
translate spanish whitney14_ab83914e:

    # wt "To move forward with the next step of the plan."
    wt "Para dar el siguiente paso del plan."

# game/Scenes/Whitney/whitney14.rpy:25
translate spanish whitney14_191f52bf:

    # pc "What {i}is{/i} the next step?"
    pc "¿Cuál es el siguiente paso?"

# game/Scenes/Whitney/whitney14.rpy:27
translate spanish whitney14_d8555685:

    # wt "We need diamonds. Two large diamonds."
    wt "Necesitamos diamantes. Dos diamantes grandes."

# game/Scenes/Whitney/whitney14.rpy:28
translate spanish whitney14_6121f377:

    # pc "That's probably really expensive."
    pc "Eso debe de ser muy caro."

# game/Scenes/Whitney/whitney14.rpy:30
translate spanish whitney14_e03107d2:

    # wt "We're not going to pay for them."
    wt "No vamos a pagarlos."

# game/Scenes/Whitney/whitney14.rpy:31
translate spanish whitney14_5bb78b12:

    # pc "Wait, what?"
    pc "Espera, ¿qué?"

# game/Scenes/Whitney/whitney14.rpy:32
translate spanish whitney14_68482c5f:

    # wt "We're going to steal them, just like I did with your dad."
    wt "Vamos a robarlos, igual que hice con tu padre."

# game/Scenes/Whitney/whitney14.rpy:33
translate spanish whitney14_b16d9c4d:

    # pc "I thought you were really rich. Why can't you just buy them?"
    pc "Pensaba que eras muy rica. ¿Por qué no los compras simplemente?"

# game/Scenes/Whitney/whitney14.rpy:35
translate spanish whitney14_e7291356:

    # wt "The ones that we need, at the purity level that we require, are beyond even the money that I have available."
    wt "Los que necesitamos, con el nivel de pureza que requerimos, superan incluso el dinero del que dispongo."

# game/Scenes/Whitney/whitney14.rpy:36
translate spanish whitney14_18b47f23:

    # wt "Besides, these diamonds were not humanely harvested. I don't feel bad about stealing from these greedy companies."
    wt "Además, estos diamantes no se han extraído de forma ética. No me siento mal por robar a estas empresas codiciosas."

# game/Scenes/Whitney/whitney14.rpy:37
translate spanish whitney14_79651c65:

    # wt "What we are doing with them is far more important than some aristocrat wearing it on her finger."
    wt "Lo que vamos a hacer con ellos es mucho más importante que una aristócrata llevándolos en el dedo."

# game/Scenes/Whitney/whitney14.rpy:38
translate spanish whitney14_c5daad32:

    # pc "How are we going to pull this off? What if we get caught?"
    pc "¿Cómo vamos a llevar esto a cabo? ¿Y si nos pillan?"

# game/Scenes/Whitney/whitney14.rpy:40
translate spanish whitney14_09e85fe5:

    # wt "That's for me to take care of. I'll explain it to you before you go in."
    wt "De eso me encargo yo. Te lo explicaré antes de que entres."

# game/Scenes/Whitney/whitney14.rpy:41
translate spanish whitney14_30dd8227:

    # pc "I have to go in?"
    pc "¿Tengo que entrar?"

# game/Scenes/Whitney/whitney14.rpy:43
translate spanish whitney14_87885119:

    # wt "Of course you do. I'm in a wheelchair."
    wt "Por supuesto que sí. Yo estoy en silla de ruedas."

# game/Scenes/Whitney/whitney14.rpy:44
translate spanish whitney14_2416510e:

    # wt "But I've arranged everything. You won't get caught. Just like your father didn't get caught when he did this before."
    wt "Pero lo tengo todo preparado. No te pillarán. Igual que a tu padre no le pillaron cuando lo hizo antes."

# game/Scenes/Whitney/whitney14.rpy:45
translate spanish whitney14_f06e3a9b:

    # pc "We're robbing the same place?"
    pc "¿Vamos a robar en el mismo sitio?"

# game/Scenes/Whitney/whitney14.rpy:47
translate spanish whitney14_d1a56e79:

    # wt "Of course not. That would be dumb."
    wt "Por supuesto que no. Eso sería una tontería."

# game/Scenes/Whitney/whitney14.rpy:48
translate spanish whitney14_ed2f7d18:

    # wt "Just trust me. I know what I'm doing here. Come to my house and we'll get ready."
    wt "Confía en mí. Sé lo que hago. Ven a mi casa y nos prepararemos."

# game/Scenes/Whitney/whitney14.rpy:50
translate spanish whitney14_50df7566_1:

    # "My phone buzzes in my pocket. Whitney's calling."
    "Mi teléfono vibra en el bolsillo. Llama Whitney."

# game/Scenes/Whitney/whitney14.rpy:54
translate spanish whitney14_6b748407:

    # wt "Are you ready to take the diamonds?"
    wt "¿Estás listo para llevarte los diamantes?"

# game/Scenes/Whitney/whitney14.rpy:55
translate spanish whitney14_f8d534ae:

    # pc "Tonight?"
    pc "¿Esta noche?"

# game/Scenes/Whitney/whitney14.rpy:56
translate spanish whitney14_d9b8f3ae:

    # wt "No better time."
    wt "No hay mejor momento."

# game/Scenes/Whitney/whitney14.rpy:59
translate spanish whitney14_355c90d9:

    # rj "Whoa! Holupaminute!"
    rj "¡Eh! ¡Espera un momento!"

# game/Scenes/Whitney/whitney14.rpy:62
translate spanish rjwhitneywarning_73195949:

    # rj "I just want to let you know that doing this scene right now will cause you to miss out on Whitney's romance storyline."
    rj "Solo quiero avisarte de que si haces esta escena ahora mismo te perderás la trama romántica de Whitney."

# game/Scenes/Whitney/whitney14.rpy:63
translate spanish rjwhitneywarning_ba4a28b5:

    # rj "If you're not interested in Whitney romantically, no problem, do the diamond heist tonight."
    rj "Si no te interesa Whitney románticamente, no hay problema, haz el robo de los diamantes esta noche."

# game/Scenes/Whitney/whitney14.rpy:64
translate spanish rjwhitneywarning_3d1165e2:

    # rj "Otherwise, you might want to advance some with Whitney..."
    rj "De lo contrario, quizá quieras avanzar un poco con Whitney..."

# game/Scenes/Whitney/whitney14.rpy:66
translate spanish rjwhitneywarning_8f5726ba:

    # rj "... to the point where you cum all over her face..."
    rj "... hasta el punto de correrte en toda su cara..."

# game/Scenes/Whitney/whitney14.rpy:68
translate spanish rjwhitneywarning_9f0eac4a:

    # rj "... before doing the diamond heist."
    rj "... antes de hacer el robo de los diamantes."

# game/Scenes/Whitney/whitney14.rpy:69
translate spanish rjwhitneywarning_369e3555:

    # rj "It's up to you. If you tell her that you don't want to do it tonight, she'll call you again next Saturday night."
    rj "Tú decides. Si le dices que no quieres hacerlo esta noche, te volverá a llamar el próximo sábado por la noche."

# game/Scenes/Whitney/whitney14.rpy:70
translate spanish rjwhitneywarning_63505504:

    # rj "Did you get all that?"
    rj "¿Lo has entendido todo?"

# game/Scenes/Whitney/whitney14.rpy:76
translate spanish rjwhitneywarning_4ecb53ff:

    # rj "Fine, I'll repeat it."
    rj "Vale, te lo repetiré."

# game/Scenes/Whitney/whitney14.rpy:79
translate spanish rjwhitneywarning_3a9d25c3:

    # rj "Okay, that's it. Sorry to interrupt! See ya!"
    rj "Vale, eso es todo. ¡Perdona por interrumpir! ¡Nos vemos!"

# game/Scenes/Whitney/whitney14.rpy:84
translate spanish rjwhitneywarning_49e2edaf:

    # wt "Great, come over to my lab and we'll get ready."
    wt "Genial, ven a mi laboratorio y nos prepararemos."

# game/Scenes/Whitney/whitney14.rpy:85
translate spanish rjwhitneywarning_a7e78a4e:

    # pc "Okay, I'm leaving now."
    pc "Vale, me voy ya."

# game/Scenes/Whitney/whitney14.rpy:87
translate spanish rjwhitneywarning_19b39e94:

    # pc "I'm not ready yet."
    pc "Aún no estoy listo."

# game/Scenes/Whitney/whitney14.rpy:89
translate spanish rjwhitneywarning_76d673a0:

    # wt "Okay."
    wt "Vale."

# game/Scenes/Whitney/whitney14.rpy:90
translate spanish rjwhitneywarning_c22c8a75:

    # wt "We should do this soon though, if we are going to do it."
    wt "Pero deberíamos hacerlo pronto, si es que vamos a hacerlo."

# game/Scenes/Whitney/whitney14.rpy:91
translate spanish rjwhitneywarning_23677720:

    # wt "Your father cannot wait forever."
    wt "Tu padre no puede esperar eternamente."

# game/Scenes/Whitney/whitney14.rpy:92
translate spanish rjwhitneywarning_395cd6d9:

    # pc "I know. Soon."
    pc "Lo sé. Pronto."

# game/Scenes/Whitney/whitney14.rpy:94
translate spanish rjwhitneywarning_2adac8aa:

    # wt "Okay. We can try next week then."
    wt "Vale. Entonces lo intentamos la semana que viene."

# game/Scenes/Whitney/whitney14.rpy:95
translate spanish rjwhitneywarning_0db4d881:

    # wt "I'll talk to you later, [pcname]."
    wt "Hablamos luego, [pcname]."

# game/Scenes/Whitney/whitney14.rpy:96
translate spanish rjwhitneywarning_663246d7:

    # pc "Okay. Bye, Whitney."
    pc "Vale. Adiós, Whitney."

# game/Scenes/Whitney/whitney14.rpy:99
translate spanish rjwhitneywarning_012c7d57:

    # "We hang up. How am I supposed to steal diamonds?"
    "Colgamos. ¿Cómo se supone que voy a robar diamantes?"

# game/Scenes/Whitney/whitney14.rpy:100
translate spanish rjwhitneywarning_514c7ad2:

    # "This is all getting really serious."
    "Todo esto se está poniendo muy serio."

# game/Scenes/Whitney/whitney14.rpy:108
translate spanish rjwhitneywarning_8652a2fb:

    # "I arrive at her house and walk through the courtyard towards the front door."
    "Llego a su casa y cruzo el patio hacia la puerta principal."

# game/Scenes/Whitney/whitney14.rpy:109
translate spanish rjwhitneywarning_7bd312b7:

    # "Her voice startles me when it blares over the intercom."
    "Su voz me sobresalta cuando suena por el interfono."

# game/Scenes/Whitney/whitney14.rpy:110
translate spanish rjwhitneywarning_1bb0325b:

    # wt "Hi, [pcname]. I'm in the lab. The door is unlocked."
    wt "Hola, [pcname]. Estoy en el laboratorio. La puerta está abierta."

# game/Scenes/Whitney/whitney14.rpy:113
translate spanish rjwhitneywarning_dc712c6d:

    # "I make my way to the lab, where Whitney is waiting for me."
    "Me dirijo al laboratorio, donde Whitney me está esperando."

# game/Scenes/Whitney/whitney14.rpy:114
translate spanish rjwhitneywarning_5214e180:

    # wt "Your clothing is in the back of the van. Go ahead and get changed."
    wt "Tu ropa está en la parte trasera de la furgoneta. Ve y cámbiate."

# game/Scenes/Whitney/whitney14.rpy:115
translate spanish rjwhitneywarning_b37180b5:

    # pc "I have to wear different clothing?"
    pc "¿Tengo que ponerme otra ropa?"

# game/Scenes/Whitney/whitney14.rpy:116
translate spanish rjwhitneywarning_61bb1ca5:

    # wt "Yes, you do. Everybody is going to know it's you in that blue shirt."
    wt "Sí, claro. Todo el mundo sabrá que eres tú con esa camisa azul."

# game/Scenes/Whitney/whitney14.rpy:117
translate spanish rjwhitneywarning_c33734b6:

    # pc "Fine. But I like my blue shirt."
    pc "Vale. Pero me gusta mi camisa azul."

# game/Scenes/Whitney/whitney14.rpy:120
translate spanish rjwhitneywarning_a3f1d669:

    # "I go to the back of the van and change clothes."
    "Voy a la parte trasera de la furgoneta y me cambio de ropa."

# game/Scenes/Whitney/whitney14.rpy:123
translate spanish rjwhitneywarning_f46c6704:

    # pc "Is this really necessary?"
    pc "¿Es esto realmente necesario?"

# game/Scenes/Whitney/whitney14.rpy:124
translate spanish rjwhitneywarning_ec008765:

    # wt "Yes, if you don't want to be recognized on camera."
    wt "Sí, si no quieres que te reconozcan en las cámaras."

# game/Scenes/Whitney/whitney14.rpy:125
translate spanish rjwhitneywarning_56afcb31:

    # wt "I was able to plot a route that would avoid getting the van on camera, but I cannot do anything about the cameras inside the building."
    wt "He podido trazar una ruta para evitar que la furgoneta salga en las cámaras, pero no puedo hacer nada con respecto a las cámaras del interior del edificio."

# game/Scenes/Whitney/whitney14.rpy:126
translate spanish rjwhitneywarning_2c6002d9:

    # pc "So, fill me in. What is the crazy plan here?"
    pc "Bueno, ponme al corriente. ¿Cuál es el plan loco que tienes?"

# game/Scenes/Whitney/whitney14.rpy:129
translate spanish rjwhitneywarning_506ca14d:

    # wt "I am going to park over here where you will get out and make your way to the back entrance of the jewelry store..."
    wt "Voy a aparcar aquí, donde tú te bajarás y te dirigirás a la entrada trasera de la joyería..."

# game/Scenes/Whitney/whitney14.rpy:132
translate spanish rjwhitneywarning_6b7981aa:

    # wt "...here."
    wt "...aquí."

# game/Scenes/Whitney/whitney14.rpy:133
translate spanish rjwhitneywarning_c840c904:

    # wt "The store has a deadbolt that requires a key, but I have a solution for that."
    wt "La tienda tiene un cerrojo que requiere una llave, pero tengo una solución para eso."

# game/Scenes/Whitney/whitney14.rpy:136
translate spanish rjwhitneywarning_cb3653db:

    # wt "This is a lockpicking gun. You just put the end of it into the lock and squeeze the trigger."
    wt "Esto es una pistola para forzar cerraduras. Solo tienes que meter el extremo en la cerradura y apretar el gatillo."

# game/Scenes/Whitney/whitney14.rpy:137
translate spanish rjwhitneywarning_1ba42d5f:

    # wt "I'm sure it will work on the door there."
    wt "Estoy seguro de que funcionará en esa puerta."

# game/Scenes/Whitney/whitney14.rpy:138
translate spanish rjwhitneywarning_368080b9:

    # pc "Wait, is that a Nintendo gun? Like for Duck Hunt?"
    pc "Espera, ¿eso es una pistola de Nintendo? ¿Como la de Duck Hunt?"

# game/Scenes/Whitney/whitney14.rpy:139
translate spanish rjwhitneywarning_cb7a5d6f:

    # wt "It was. I modified it. Now it's a lockpicking gun."
    wt "Lo era. La modifiqué. Ahora es una pistola para forzar cerraduras."

# game/Scenes/Whitney/whitney14.rpy:140
translate spanish rjwhitneywarning_880b4aa8:

    # pc "Okay..."
    pc "Vale..."

# game/Scenes/Whitney/whitney14.rpy:141
translate spanish rjwhitneywarning_18b9d86b:

    # pc "So, that's it? Just zap the lock and I'm in?"
    pc "¿Y eso es todo? ¿Solo hay que dispararle a la cerradura y ya estoy dentro?"

# game/Scenes/Whitney/whitney14.rpy:144
translate spanish rjwhitneywarning_57ed69cc:

    # wt "Well, yes, you'll be able to get in the building then, but there is a security system."
    wt "Bueno, sí, podrás entrar en el edificio, pero hay un sistema de seguridad."

# game/Scenes/Whitney/whitney14.rpy:145
translate spanish rjwhitneywarning_b3ded7f6:

    # wt "Fortunately, you and I will be in contact the entire time and just before you go in, I will disable the alarms remotely."
    wt "Afortunadamente, tú y yo estaremos en contacto todo el tiempo y, justo antes de que entres, desactivaré las alarmas de forma remota."

# game/Scenes/Whitney/whitney14.rpy:146
translate spanish rjwhitneywarning_45436a60:

    # pc "You can do that?"
    pc "¿Puedes hacer eso?"

# game/Scenes/Whitney/whitney14.rpy:147
translate spanish rjwhitneywarning_ed1b329a:

    # wt "Of course I can do that."
    wt "Por supuesto que puedo."

# game/Scenes/Whitney/whitney14.rpy:150
translate spanish rjwhitneywarning_6e0c3693:

    # wt "When you first go in, you will be in the back storage area. You'll have to make your way through there to the office, where the safe is kept."
    wt "Cuando entres por primera vez, estarás en la zona de almacén trasera. Tendrás que atravesarla hasta llegar a la oficina, donde se guarda la caja fuerte."

# game/Scenes/Whitney/whitney14.rpy:151
translate spanish rjwhitneywarning_1547e2f3:

    # pc "A safe? How are we supposed to get into that? Do you know the combination?"
    pc "¿Una caja fuerte? ¿Cómo se supone que vamos a abrirla? ¿Sabes la combinación?"

# game/Scenes/Whitney/whitney14.rpy:152
translate spanish rjwhitneywarning_9778d18a:

    # wt "Yes, actually. I do."
    wt "Sí, de hecho, la sé."

# game/Scenes/Whitney/whitney14.rpy:153
translate spanish rjwhitneywarning_a7d1f229:

    # pc "How?"
    pc "¿Cómo?"

# game/Scenes/Whitney/whitney14.rpy:154
translate spanish rjwhitneywarning_284142b3:

    # wt "Don't worry about that. I told you I've been working on this. I haven't just been sitting over here the whole time, twiddling my thumbs."
    wt "No te preocupes por eso. Te dije que he estado trabajando en esto. No me he pasado todo este tiempo aquí sentado, sin hacer nada."

# game/Scenes/Whitney/whitney14.rpy:155
translate spanish rjwhitneywarning_b9a33198:

    # wt "The safe has a keypad combination. The code is 96678552."
    wt "La caja fuerte tiene un teclado numérico. El código es 96678552."

# game/Scenes/Whitney/whitney14.rpy:156
translate spanish rjwhitneywarning_c386084f:

    # wt "Don't write it down anywhere. I'll remind you over the radio if you forget."
    wt "No lo apuntes en ningún sitio. Te lo recordaré por radio si se te olvida."

# game/Scenes/Whitney/whitney14.rpy:159
translate spanish rjwhitneywarning_ddf4be87:

    # wt "Once you get the safe open, you're going to have to find the diamonds. This is the only part I'm not completely sure of."
    wt "Una vez que abras la caja fuerte, tendrás que encontrar los diamantes. Esta es la única parte de la que no estoy completamente seguro."

# game/Scenes/Whitney/whitney14.rpy:160
translate spanish rjwhitneywarning_d61f0ea5:

    # wt "They are diamonds that have not been inset into any jewelry yet."
    wt "Son diamantes que aún no se han engastado en ninguna joya."

# game/Scenes/Whitney/whitney14.rpy:161
translate spanish rjwhitneywarning_0bb7be7d:

    # wt "They need to be real diamonds too, not the synthetic ones. The hoop will only work on real diamonds."
    wt "Además, tienen que ser diamantes auténticos, no sintéticos. El aro solo funciona con diamantes auténticos."

# game/Scenes/Whitney/whitney14.rpy:162
translate spanish rjwhitneywarning_7b883c0e:

    # wt "They are large and clear and are likely stored wrapped in tissue paper or cloth and in individual bags."
    wt "Son grandes y transparentes, y es probable que estén guardados envueltos en papel de seda o tela y en bolsas individuales."

# game/Scenes/Whitney/whitney14.rpy:163
translate spanish rjwhitneywarning_c8a5f5b0:

    # wt "I believe they're going to be near the bottom shelf of the safe."
    wt "Creo que estarán cerca del estante inferior de la caja fuerte."

# game/Scenes/Whitney/whitney14.rpy:164
translate spanish rjwhitneywarning_ff090bab:

    # pc "How do you possibly know all of this?"
    pc "¿Cómo es posible que sepas todo esto?"

# game/Scenes/Whitney/whitney14.rpy:167
translate spanish rjwhitneywarning_52c41d0c:

    # wt "I have been monitoring this place for weeks."
    wt "Llevo semanas vigilando este lugar."

# game/Scenes/Whitney/whitney14.rpy:168
translate spanish rjwhitneywarning_c2154aa2:

    # wt "There is a building across the street that has an outside camera. I was able to move that camera to where it aims directly through the front windows of the jewelry shop."
    wt "Hay un edificio al otro lado de la calle que tiene una cámara exterior. Conseguí mover esa cámara para que apuntara directamente a través de los escaparates de la joyería."

# game/Scenes/Whitney/whitney14.rpy:169
translate spanish rjwhitneywarning_919dc7c4:

    # wt "Then, by changing the visual frequency a bit, I could look through the one-way mirror and into the back office where the safe is."
    wt "Luego, cambiando un poco la frecuencia visual, pude mirar a través del espejo unidireccional y ver el despacho trasero donde está la caja fuerte."

# game/Scenes/Whitney/whitney14.rpy:170
translate spanish rjwhitneywarning_9a1523a7:

    # wt "Then I just watched and gathered information."
    wt "Después, me limité a observar y recopilar información."

# game/Scenes/Whitney/whitney14.rpy:173
translate spanish rjwhitneywarning_a32a886a:

    # pc "You're quite scary sometimes, you know?"
    pc "A veces das bastante miedo, ¿lo sabes?"

# game/Scenes/Whitney/whitney14.rpy:174
translate spanish rjwhitneywarning_6c97b1cc:

    # pc "I'm really glad you're not evil. You could really cause some trouble."
    pc "Me alegro mucho de que no seas malvado. Podrías causar un buen lío."

# game/Scenes/Whitney/whitney14.rpy:175
translate spanish rjwhitneywarning_4e966f59:

    # wt "Yes. Yes, I could."
    wt "Sí. Sí, podría."

# game/Scenes/Whitney/whitney14.rpy:176
translate spanish rjwhitneywarning_f91c3d58:

    # wt "Let's go."
    wt "Vamos."

# game/Scenes/Whitney/whitney14.rpy:179
translate spanish rjwhitneywarning_a1b12283:

    # "Whitney drives us back to town, then takes a convoluted path to avoid the various cameras, before parking in the back area of a nearby store and turning the van off."
    "Whitney nos lleva de vuelta al pueblo, luego toma un camino tortuoso para evitar las distintas cámaras, antes de aparcar en la parte trasera de una tienda cercana y apagar la furgoneta."

# game/Scenes/Whitney/whitney14.rpy:180
translate spanish rjwhitneywarning_28d35bb9:

    # pc "I don't know about this. I'm really nervous."
    pc "No sé qué pensar. Estoy muy nerviosa."

# game/Scenes/Whitney/whitney14.rpy:181
translate spanish rjwhitneywarning_9b33cddb:

    # wt "You're going to be fine. I promise."
    wt "Todo va a salir bien. Te lo prometo."

# game/Scenes/Whitney/whitney14.rpy:182
translate spanish rjwhitneywarning_6e34f9e6:

    # wt "I don't know any other way for us to get these diamonds. And we need them for the hoop to work."
    wt "No conozco otra forma de conseguir estos diamantes. Y los necesitamos para que el aro funcione."

# game/Scenes/Whitney/whitney14.rpy:183
translate spanish rjwhitneywarning_f3f1ae24:

    # wt "If we don't get these, we can't help your father."
    wt "Si no los conseguimos, no podremos ayudar a tu padre."

# game/Scenes/Whitney/whitney14.rpy:186
translate spanish rjwhitneywarning_ab964844:

    # pc "Okay, yeah. You're right."
    pc "Vale, sí. Tienes razón."

# game/Scenes/Whitney/whitney14.rpy:187
translate spanish rjwhitneywarning_9745900d:

    # pc "I want to help my dad."
