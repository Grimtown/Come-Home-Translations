# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:13
translate spanish julianas1_55462013:

    # bn "Well, I like to read. A lot."
    bn "Bueno, me gusta leer. Mucho."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:14
translate spanish julianas1_b2693c6d:

    # pc "What kind of books do you read?"
    pc "¿Qué tipo de libros lees?"

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:15
translate spanish julianas1_e8d2341f:

    # bn "Pretty much everything. Mostly fiction."
    bn "Prácticamente de todo. Sobre todo ficción."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:16
translate spanish julianas1_87484a4d:

    # bn "I've read through the Oxford, the Harvard, and the New York Times recommended book list."
    bn "Me he leído la lista de libros recomendados por Oxford, Harvard y el New York Times."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:17
translate spanish julianas1_952fa315:

    # bn "Then I started reading more modern classics, mostly romances and dramas."
    bn "Después empecé a leer más clásicos modernos, sobre todo romances y dramas."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:18
translate spanish julianas1_a07870df:

    # bn "I also like writing too."
    bn "También me gusta escribir."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:19
translate spanish julianas1_99617830:

    # pc "Oh, you're a writer?"
    pc "Oh, ¿eres escritora?"

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:21
translate spanish julianas1_358addd6:

    # bn "I don't know that I'd call myself a writer, but I've done some fan fiction and started a novel."
    bn "No sé si me llamaría escritora, pero he escrito algo de fan fiction y he empezado una novela."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:22
translate spanish julianas1_93f03055:

    # pc "Sounds like a writer to me."
    pc "A mí me parece que eres escritora."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:23
translate spanish julianas1_23a4b862:

    # bn "I guess so."
    bn "Supongo que sí."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:24
translate spanish julianas1_f02f37e2:

    # pc "Well that's cool. I'd love to read your stories sometime."
    pc "Bueno, eso está genial. Me encantaría leer tus historias alguna vez."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:25
translate spanish julianas1_734efaf2:

    # bn "I don't know. I don't think they're very good."
    bn "No sé. No creo que sean muy buenas."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:26
translate spanish julianas1_1e97c739:

    # pc "I'm sure if they're anywhere near as good as your essays, they're amazing."
    pc "Estoy segura de que si se acercan un poco a lo buenos que son tus ensayos, son increíbles."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:27
translate spanish julianas1_23579629:

    # pc "You're a fantastic writer."
    pc "Eres una escritora fantástica."

# game/Scenes/Juliana/JulianaConversations/julianas1.rpy:29
translate spanish julianas1_53ddd9f6:

    # bn "Thanks, [pcname]."
    bn "Gracias, [pcname]."

