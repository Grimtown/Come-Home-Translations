# game/Scenes/Mari/MariDates/maribeach.rpy:13
translate spanish maribeachdate_a63d5d5c:

    # fr "The beach sounds amazing! I'll go get in my swimsuit! Come get me."
    fr "¡La playa suena genial! ¡Voy a ponerme el bañador! Ven a recogerme."

# game/Scenes/Mari/MariDates/maribeach.rpy:14
translate spanish maribeachdate_8caa4a9c:

    # pc "On my way."
    pc "Voy para allá."

# game/Scenes/Mari/MariDates/maribeach.rpy:21
translate spanish maribeachdate_40c18b34:

    # "I pick Mari up and we drive out towards the beach."
    "Recojo a Mari y nos dirigimos hacia la playa."

# game/Scenes/Mari/MariDates/maribeach.rpy:23
translate spanish maribeachdate_427f3be4:

    # fr "I haven't been to the beach in forever."
    fr "Hace una eternidad que no voy a la playa."

# game/Scenes/Mari/MariDates/maribeach.rpy:24
translate spanish maribeachdate_e5624fc2:

    # fr "This is going to be so fun."
    fr "Esto va a ser muy divertido."

# game/Scenes/Mari/MariDates/maribeach.rpy:29
translate spanish maribeachdate_b9c9e980:

    # pc "You look incredible."
    pc "Estás increíble."

# game/Scenes/Mari/MariDates/maribeach.rpy:30
translate spanish maribeachdate_8a5a041f:

    # fr "Thanks, honey. The water is so pretty. Let's get in."
    fr "Gracias, cariño. El agua es preciosa. Vamos a meternos."

# game/Scenes/Mari/MariDates/maribeach.rpy:33
translate spanish maribeachdate_93419ef3:

    # "We spend some time swimming around and chatting."
    "Pasamos un rato nadando y charlando."

# game/Scenes/Mari/MariDates/maribeach.rpy:36
translate spanish maribeachdate_0e1a2c64:

    # "We spend a little longer making out, our bodies pressed against each other underwater."
    "Nos quedamos un rato más besándonos, con nuestros cuerpos apretados el uno contra el otro bajo el agua."

# game/Scenes/Mari/MariDates/maribeach.rpy:39
translate spanish maribeachdate_c4765999:

    # "After a while, we're both tired from swimming and the sun is starting to set, so we lie on the beach and dry off."
    "Al cabo de un rato, los dos estamos cansados de nadar y el sol empieza a ponerse, así que nos tumbamos en la playa y nos secamos."

# game/Scenes/Mari/MariDates/maribeach.rpy:40
translate spanish maribeachdate_3d2f7709:

    # "We lean back and talk for a while about whatever comes to mind."
    "Nos recostamos y hablamos un rato de lo que se nos ocurre."

# game/Scenes/Mari/MariDates/maribeach.rpy:50
translate spanish maribeachdate_67f91a9e:

    # "When the sun starts to dip below the horizon, we take a moment to watch it together."
    "Cuando el sol empieza a hundirse en el horizonte, nos tomamos un momento para contemplarlo juntos."

# game/Scenes/Mari/MariDates/maribeach.rpy:52
translate spanish maribeachdate_0b6982cc:

    # fr "It's so beautiful."
    fr "Es tan bonito."

# game/Scenes/Mari/MariDates/maribeach.rpy:53
translate spanish maribeachdate_91de8c28:

    # fr "Thanks for bringing me here."
    fr "Gracias por traerme aquí."

# game/Scenes/Mari/MariDates/maribeach.rpy:58
translate spanish maribeachdate_e10b5f4e:

    # "We kiss and it's like lightning between our lips. It warms me from my heart outward."
    "Nos besamos y es como un rayo entre nuestros labios. Me calienta desde el corazón hacia fuera."

# game/Scenes/Mari/MariDates/maribeach.rpy:63
translate spanish maribeachdate_4462906b:

    # fr "Are you ready to go back to my place?"
    fr "¿Estás lista para ir a mi casa?"

# game/Scenes/Mari/MariDates/maribeach.rpy:64
translate spanish maribeachdate_61f77a4c:

    # pc "Sure."
    pc "Claro."

# game/Scenes/Mari/MariDates/maribeach.rpy:65
translate spanish maribeachdate_63a75f93:

    # fr "Good, because I'm ready to get out of this swimsuit. And to get you out of yours."
    fr "Bien, porque estoy listo para quitarme este bañador. Y para quitarte el tuyo."

# game/Scenes/Mari/MariDates/maribeach.rpy:69
translate spanish maribeachdate_69da3812:

    # "When the sun sets, I drive us back to her house."
    "Cuando se pone el sol, conduzco de vuelta a su casa."

# game/Scenes/Mari/MariDates/maribeach.rpy:70
translate spanish maribeachdate_e3551ef8:

    # fr "So... are you coming inside?"
    fr "Bueno... ¿vas a entrar?"

# game/Scenes/Mari/MariDates/maribeach.rpy:73
translate spanish maribeachdate_b1aed98f:

    # fr "Good. Let's go."
    fr "Bien. Vamos."

# game/Scenes/Mari/MariDates/maribeach.rpy:80
translate spanish maribeachdate_b1aed98f_1:

    # fr "Good. Let's go."
    fr "Bien. Vamos."

# game/Scenes/Mari/MariDates/maribeach.rpy:88
translate spanish maribeachdate_92c16c18:

    # fr "Dang, really? Too busy for little ol' me tonight?"
    fr "Vaya, ¿en serio? ¿Demasiado ocupada para un pobre viejo como yo esta noche?"

# game/Scenes/Mari/MariDates/maribeach.rpy:89
translate spanish maribeachdate_ea7c5dae:

    # fr "Fine. Good night then."
    fr "Vale. Buenas noches, entonces."

# game/Scenes/Mari/MariDates/maribeach.rpy:92
translate spanish maribeachdate_8b93ebfd:

    # "I wait until she gets out and walks into her house before I drive away."
    "Espero a que salga y entre en su casa antes de marcharme."

translate spanish strings:

    # game/Scenes/Mari/MariDates/maribeach.rpy:3
    old "When you are able to ask Mari out on a date, and you have unlocked the beach through Suzy's path, invite Mari to the beach."
    new "Cuando puedas pedirle a Mari una cita y hayas desbloqueado la playa a través de la ruta de Suzy, invítala a la playa."

    # game/Scenes/Mari/MariDates/maribeach.rpy:4
    old "She is available to date any time before night on the weekends."
    new "Está disponible para salir en cualquier momento antes de que anochezca los fines de semana."

