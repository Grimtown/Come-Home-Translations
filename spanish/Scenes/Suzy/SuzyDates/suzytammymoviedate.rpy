# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:93
translate spanish suzytammymovietheaterstartdate_643c2201:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "Parece que mamá ya está dormida. Entonces, ¿quieres terminar la cita aquí, o subir a tu habitación y terminarla como es debido?"

