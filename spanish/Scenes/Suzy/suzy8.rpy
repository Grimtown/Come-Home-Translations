# game/Scenes/Suzy/suzy8.rpy:49
translate spanish suzy8_660f4989:

    # "I lie down in bed and try to get to sleep. I'm having a hard time with it, as I'm both annoyed at and worried about her."
    "Me acuesto en la cama e intento dormir. Me cuesta mucho, ya que estoy a la vez molesto y preocupado por ella."

# game/Scenes/Suzy/suzy8.rpy:50
translate spanish suzy8_6e6cee1b:

    # "Then I hear the bathroom door open."
    "Entonces oigo que se abre la puerta del baño."

