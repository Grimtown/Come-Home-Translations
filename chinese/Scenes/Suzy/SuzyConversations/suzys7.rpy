# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:25
translate chinese suzys7_c7406192:

    # pc "It does sound amazing."
    pc "确实听起来很棒。"

# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:28
translate chinese suzys7_ee1aba2e:

    # ss "I'm not talking about doing this with you, of course."
    ss "当然，我不是说要和你做这些。"

# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:29
translate chinese suzys7_c264ecd8:

    # pc "No?"
    pc "不是吗？"

# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:30
translate chinese suzys7_5e236ce4:

    # ss "No! Don't be weird! You're my [brother]!"
