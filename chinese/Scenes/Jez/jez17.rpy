    # pc "Hola!"
    pc "嗨！"

# game/Scenes/Jez/jez17.rpy:88
translate chinese jez17_3e2203df:

    # mama "Dinner is almost ready. Quince minutos!"
    mama "晚饭快好了。还有十五分钟！"

# game/Scenes/Jez/jez17.rpy:89
translate chinese jez17_d3c99d43:

    # pc "Okay! I can't wait."
    pc "好！我等不及了。"

# game/Scenes/Jez/jez17.rpy:92
