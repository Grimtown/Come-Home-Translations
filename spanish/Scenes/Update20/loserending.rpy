    # "I look at the crowd, but nobody is here for me."
    "Miro a la multitud, pero nadie está aquí por mí."

# game/Scenes/Update20/loserending.rpy:8
translate spanish loser_ending_e94592cd:

    # "I pick up a pizza, then go home and watch TV alone."
    "Cojo una pizza, luego me voy a casa y veo la tele solo."

# game/Scenes/Update20/loserending.rpy:11
translate spanish loser_ending_833bcf67:

    # "Then I watch some porn on the computer."
    "Después veo porno en el ordenador."

# game/Scenes/Update20/loserending.rpy:14
translate spanish loser_ending_e6e71336:

    # "I lie in bed that night and think about what the future might hold."
    "Esa noche me acuesto en la cama y pienso en lo que nos deparará el futuro."

# game/Scenes/Update20/loserending.rpy:17
translate spanish loser_ending_1b242190:

    # "I'll probably get a job in a lab somewhere."
    "Probablemente conseguiré un trabajo en algún laboratorio."

# game/Scenes/Update20/loserending.rpy:20
translate spanish loser_ending_4d4aa8f2:

    # "Maybe I'll find somebody to love one day."
    "Quizá algún día encuentre a alguien a quien amar."

# game/Scenes/Update20/loserending.rpy:21
translate spanish loser_ending_c3bf8e82:

    # "Maybe not."
    "Quizá no."

# game/Scenes/Update20/loserending.rpy:24
translate spanish loser_ending_9652d4a4:

    # "Maybe I'm too picky and nobody will ever be good enough for me."
    "Quizá soy demasiado exigente y nadie será nunca lo suficientemente bueno para mí."

# game/Scenes/Update20/loserending.rpy:27
translate spanish loser_ending_ec64b334:

    # "Maybe I'll go back to the other world."
    "Quizá vuelva al otro mundo."

# game/Scenes/Update20/loserending.rpy:30
translate spanish loser_ending_e3661b99:

    # "Maybe I'll live there with my mom and dad."
    "Quizá viva allí con mi madre y mi padre."

# game/Scenes/Update20/loserending.rpy:33
translate spanish loser_ending_f982e9ec:

    # "Either way, I have to find a way to be happy."
    "Sea como sea, tengo que encontrar la manera de ser feliz."

# game/Scenes/Update20/loserending.rpy:36
translate spanish loser_ending_b97a871d:

    # "What more could a person ask for?"
    "¿Qué más se puede pedir?"

