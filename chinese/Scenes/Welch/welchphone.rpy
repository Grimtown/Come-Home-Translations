# game/Scenes/Welch/welchphone.rpy:111
translate chinese welchdatesetup_e7bcdd16_1:

    # pc "Okay. See you there."
    pc "好的。到时候见。"

# game/Scenes/Welch/welchphone.rpy:116
translate chinese welchdatesetup_55b55948_2:

    # sst "Sounds good. I'll text you the movie and time and sit in the back and wait for you."
    sst "听起来不错。我会发消息告诉你电影名称和时间，然后坐在后面等你。"

# game/Scenes/Welch/welchphone.rpy:117
translate chinese welchdatesetup_e7bcdd16_2:

    # pc "Okay. See you there."
    pc "好的。到时候见。"

# game/Scenes/Welch/welchphone.rpy:151
translate chinese welchlakedatesetup_3f865ac1:

    # pc "Do you want to go swimming at the lake?"
    pc "想去湖里游泳吗？"

# game/Scenes/Welch/welchphone.rpy:152
translate chinese welchlakedatesetup_ddd580fb:

    # sst "That sounds amazing, but the beach is usually pretty busy. I'm afraid somebody will see us."
    sst "听起来很棒，但海滩通常人很多。我怕被人看到。"

# game/Scenes/Welch/welchphone.rpy:153
translate chinese welchlakedatesetup_336f5ac2:

    # pc "No, I know a more secluded place. I've never seen anybody out there."
    pc "不，我知道一个更隐蔽的地方。我从来没在那儿见过人。"

# game/Scenes/Welch/welchphone.rpy:154
translate chinese welchlakedatesetup_19f4338a:

    # sst "Okay sure, let's do it. But if anybody shows up, we might have to hide and leave."
    sst "好的，那就去吧。但如果有人出现，我们可能得躲起来然后离开。"

# game/Scenes/Welch/welchphone.rpy:155
translate chinese welchlakedatesetup_a248948f:

    # pc "Of course."
    pc "当然。"

# game/Scenes/Welch/welchphone.rpy:156
translate chinese welchlakedatesetup_ddf8a10e:

    # sst "Come pick me up then."
    sst "那来接我吧。"

# game/Scenes/Welch/welchphone.rpy:157
translate chinese welchlakedatesetup_3d8dfeb0:

    # pc "On my way right now."
    pc "我马上就到。"

# game/Scenes/Welch/welchphone.rpy:158
translate chinese welchlakedatesetup_8ccf66da:

    # sst "I'll go put on a bikini then."
    sst "那我去换比基尼。"

# game/Scenes/Welch/welchphone.rpy:159
translate chinese welchlakedatesetup_e7b554ea:

    # pc "Can't wait to see it."
    pc "等不及想看了。"

# game/Scenes/Welch/welchphone.rpy:161
translate chinese welchlakedatesetup_1e8d0bcd:

    # sst "That sounds great. Come pick me up."
    sst "听起来很棒。来接我吧。"

# game/Scenes/Welch/welchphone.rpy:162
translate chinese welchlakedatesetup_8caa4a9c:

    # pc "On my way."
    pc "我马上就到。"

