translate chinese jez17_7556f0d3:

    # jav "Everything in Minecraft is a square."
    jav "《我的世界》里的一切都是方块。"

# game/Scenes/Jez/jez17.rpy:143
translate chinese jez17_c054ad7e:

    # jav "I like the animals. There's chickens, and sheep, and pigs, and cows."
    jav "我喜欢里面的动物。有鸡、羊、猪和牛。"

# game/Scenes/Jez/jez17.rpy:144
translate chinese jez17_f226a448:

    # jav "Oh, and chickens."
    jav "哦，还有鸡。"

# game/Scenes/Jez/jez17.rpy:145
translate chinese jez17_ad94b886:

    # jav "Ah! Watch out for that creeper!"
    jav "啊！当心那个苦力怕！"

# game/Scenes/Jez/jez17.rpy:148
translate chinese jez17_7e18d945:

    # det "Honey, Abuela is leaving. It's time to say goodbye."
    det "亲爱的，阿布埃拉要走了。该说再见了。"

# game/Scenes/Jez/jez17.rpy:149
translate chinese jez17_c744666b:

    # jav "One second, Mom. I have to light some TNT."
    jav "等一下，妈妈。我得点燃一些TNT。"

# game/Scenes/Jez/jez17.rpy:150
translate chinese jez17_8d1a2811:

    # mama "Adios, Javito!"
    mama "再见啦，哈维托！"

