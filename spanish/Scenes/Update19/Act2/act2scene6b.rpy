# game/Scenes/Update19/Act2/act2scene6b.rpy:7
translate spanish u19a2s6b_d2e63c8f:

    # "I choose a path and walk towards where I feel the voice of Mari pulling me."
    "Elijo un camino y camino hacia donde siento que la voz de Mari me llama."

# game/Scenes/Update19/Act2/act2scene6b.rpy:27
translate spanish u19a2s6b_2499204d:

    # "The path leads into a sparse forest, with an overgrown trail winding through the trees."
    "El camino conduce a un bosque ralo, con un sendero cubierto de maleza que serpentea entre los árboles."

# game/Scenes/Update19/Act2/act2scene6b.rpy:33
translate spanish u19a2s6b_c2a55eb9:

    # "I come around a corner and spot a deer, munching some grass nearby."
    "Doblo una esquina y diviso un ciervo, comiendo hierba cerca de allí."

# game/Scenes/Update19/Act2/act2scene6b.rpy:34
translate spanish u19a2s6b_603ca19b:

    # "My stomach rumbles... I haven't had meat in a few days."
    "Me ruge el estómago... Hace unos días que no como carne."

# game/Scenes/Update19/Act2/act2scene6b.rpy:52
translate spanish u19a2s6b_df91ec3c:

    # sst "I might be able to catch it. I'm pretty fast."
    sst "Quizá pueda atraparlo. Soy bastante rápida."

# game/Scenes/Update19/Act2/act2scene6b.rpy:54
translate spanish u19a2s6b_abd10069:

    # rb "I could hit it with a rock."
    rb "Podría golpearlo con una piedra."

# game/Scenes/Update19/Act2/act2scene6b.rpy:56
translate spanish u19a2s6b_c24e7137:

    # cw "I bet I could hit it with my spear."
    cw "Apuesto a que podría alcanzarlo con mi lanza."

# game/Scenes/Update19/Act2/act2scene6b.rpy:58
translate spanish u19a2s6b_e884d3c5:

    # gg "Aw, cute deer... but I bet it's tasty and I am starving."
    gg "Ay, qué ciervo tan mono... pero apuesto a que está rico y me muero de hambre."

# game/Scenes/Update19/Act2/act2scene6b.rpy:60
translate spanish u19a2s6b_2cee53f8:

    # sg "I could eat on that for months."
    sg "Podría alimentarme de eso durante meses."

# game/Scenes/Update19/Act2/act2scene6b.rpy:62
translate spanish u19a2s6b_17ee08f9:

    # bn "I know several ways to cook deer, theoretically."
    bn "Conozco varias formas de cocinar ciervo, en teoría."

# game/Scenes/Update19/Act2/act2scene6b.rpy:63
translate spanish u19a2s6b_dc9ba364:

    # "I pull out my sword and take a step towards it."
    "Saco mi espada y doy un paso hacia él."

# game/Scenes/Update19/Act2/act2scene6b.rpy:66
translate spanish u19a2s6b_5872180d:

    # "Suddenly, a wolf runs in from the side, standing in front of the deer and snarling, as if protecting the creature."
    "De repente, un lobo entra corriendo por un lado, se planta delante del ciervo y gruñe, como si lo estuviera protegiendo."

# game/Scenes/Update19/Act2/act2scene6b.rpy:67
translate spanish u19a2s6b_1c02e924:

    # "The deer freezes, its eyes moving up towards me, fearfully."
    "El ciervo se queda paralizado, con los ojos fijos en mí, llenos de miedo."

# game/Scenes/Update19/Act2/act2scene6b.rpy:85
translate spanish u19a2s6b_68795d9a:

    # sst "A bit tougher fight, but we could still take them."
    sst "Una pelea un poco más dura, pero aún así podríamos con ellos."

# game/Scenes/Update19/Act2/act2scene6b.rpy:87
translate spanish u19a2s6b_40f9fb41:

    # rb "Get outta here you dang wolf! I'm hungry!"
    rb "¡Lárgate de aquí, maldito lobo! ¡Tengo hambre!"

# game/Scenes/Update19/Act2/act2scene6b.rpy:89
translate spanish u19a2s6b_41b5d561:

    # cw "Hold on. That is no ordinary wolf."
    cw "Un momento. Ese no es un lobo cualquiera."

# game/Scenes/Update19/Act2/act2scene6b.rpy:91
translate spanish u19a2s6b_6bff9c00:

    # gg "Whoa! Nice doggy."
    gg "¡Vaya! Bonito perrito."

# game/Scenes/Update19/Act2/act2scene6b.rpy:93
translate spanish u19a2s6b_7363ad6e:

    # sg "I wasn't that hungry anyways. Let's leave the deer alone."
    sg "De todos modos, no tenía tanta hambre. Dejemos al ciervo en paz."

# game/Scenes/Update19/Act2/act2scene6b.rpy:95
translate spanish u19a2s6b_c41dd69a:

    # bn "Why does the deer not run from the wolf? This makes no sense."
    bn "¿Por qué el ciervo no huye del lobo? Esto no tiene sentido."

# game/Scenes/Update19/Act2/act2scene6b.rpy:96
translate spanish u19a2s6b_f2ced0f1:

    # "I take a step back, holding my sword in front of me in case the wolf tries to attack."
    "Doy un paso atrás, sosteniendo mi espada delante de mí por si el lobo intenta atacar."

# game/Scenes/Update19/Act2/act2scene6b.rpy:99
translate spanish u19a2s6b_ba373f1b:

    # "But the wolf doesn't attack. Instead it begins to glow and change shape."
    "Pero el lobo no ataca. En cambio, empieza a brillar y a cambiar de forma."

# game/Scenes/Update19/Act2/act2scene6b.rpy:103
translate spanish u19a2s6b_cb74e7b1:

    # "When the transformation is complete, Mari stands before me, a stern look on her face."
    "Cuando la transformación se completa, Mari se yergue ante mí, con una mirada severa en su rostro."

# game/Scenes/Update19/Act2/act2scene6b.rpy:104
translate spanish u19a2s6b_1b338a95:

    # fr "No creatures will be harmed in my forest."
    fr "Ninguna criatura sufrirá daño alguno en mi bosque."

# game/Scenes/Update19/Act2/act2scene6b.rpy:106
translate spanish u19a2s6b_bd0a2877:

    # fr "Move along if you value your life."
    fr "Sigue tu camino si valoras tu vida."

# game/Scenes/Update19/Act2/act2scene6b.rpy:108
translate spanish u19a2s6b_48067b89:

    # fr "Move along if you value your lives."
    fr "Seguid vuestro camino si valoráis vuestras vidas."

# game/Scenes/Update19/Act2/act2scene6b.rpy:124
translate spanish u19a2s6b_f9182308:

    # "I quickly put my sword away and hold up my hands in surrender."
    "Rápidamente guardo mi espada y levanto las manos en señal de rendición."

# game/Scenes/Update19/Act2/act2scene6b.rpy:126
translate spanish u19a2s6b_52a85208:

    # pc "I'm sorry Mari. I didn't mean any harm. I'm just hungry."
    pc "Lo siento, Mari. No era mi intención hacer daño. Es que tengo hambre."

# game/Scenes/Update19/Act2/act2scene6b.rpy:128
translate spanish u19a2s6b_f47aaed1:

    # pc "I'm sorry Mari. We didn't mean any harm. We're just hungry."
    pc "Lo siento, Mari. No queríamos hacer daño. Es que tenemos hambre."

# game/Scenes/Update19/Act2/act2scene6b.rpy:129
translate spanish u19a2s6b_6a606e17:

    # fr "There are plenty of things to eat in this wood besides my friends."
    fr "Hay muchas cosas para comer en este bosque, aparte de mis amigos."

# game/Scenes/Update19/Act2/act2scene6b.rpy:132
translate spanish u19a2s6b_ee6a9f06:

    # fr "Wait, how did you know my name?"
    fr "Espera, ¿cómo sabías mi nombre?"

# game/Scenes/Update19/Act2/act2scene6b.rpy:133
translate spanish u19a2s6b_944b5ed3:

    # pc "Well..."
    pc "Bueno..."

# game/Scenes/Update19/Act2/act2scene6b.rpy:150
translate spanish u19a2s6b_74a307ae:

    # "I explain as best I can about the other world, about the bracelet, and about the Ice Queen."
    "Le explico lo mejor que puedo sobre el otro mundo, sobre el brazalete y sobre la Reina de Hielo."

# game/Scenes/Update19/Act2/act2scene6b.rpy:151
translate spanish u19a2s6b_fb240f03:

    # fr "Such a strange story. Yet, I feel the truth of it."
    fr "Qué historia tan extraña. Sin embargo, siento que es cierta."

# game/Scenes/Update19/Act2/act2scene6b.rpy:154
translate spanish u19a2s6b_dc5985e3:

    # "She steps foreward and sniffs me."
    "Da un paso adelante y me olisquea."

# game/Scenes/Update19/Act2/act2scene6b.rpy:155
translate spanish u19a2s6b_35634c06:

    # fr "Though we have never met before, your scent is a familiar one."
    fr "Aunque no nos hayamos visto antes, tu olor me resulta familiar."

# game/Scenes/Update19/Act2/act2scene6b.rpy:172
translate spanish u19a2s6b_526aa2f1:

    # fr "I will come with you. At least through the forest."
    fr "Iré contigo. Al menos a través del bosque."

# game/Scenes/Update19/Act2/act2scene6b.rpy:173
translate spanish u19a2s6b_318e467c:

    # fr "To ensure you bring no harm to the creatures here."
    fr "Para asegurarme de que no hagas daño a las criaturas de aquí."

# game/Scenes/Update19/Act2/act2scene6b.rpy:175
translate spanish u19a2s6b_3233da17:

    # pc "We are still pretty hungry though."
    pc "Aunque seguimos teniendo bastante hambre."

# game/Scenes/Update19/Act2/act2scene6b.rpy:177
translate spanish u19a2s6b_6ef2fd9b:

    # pc "I am still pretty hungry though."
    pc "Aunque yo sigo teniendo bastante hambre."

# game/Scenes/Update19/Act2/act2scene6b.rpy:178
translate spanish u19a2s6b_8c4aab2b:

    # fr "I will show you good plants to eat."
    fr "Te enseñaré buenas plantas para comer."

# game/Scenes/Update19/Act2/act2scene6b.rpy:181
translate spanish u19a2s6b_91682f12:

    # "We continue north together and Mari shows me some good places to forage for food along the way."
    "Seguimos juntos hacia el norte y Mari me muestra algunos buenos lugares para buscar comida por el camino."

# game/Scenes/Update19/Act2/act2scene6b.rpy:202
translate spanish u19a2s6b_ee6a0934:

    # "When we reach the edge of the forest, I half expect Mari to stay behind, but she looks at me with a smile."
    "Cuando llegamos al límite del bosque, casi espero que Mari se quede atrás, pero me mira con una sonrisa."

# game/Scenes/Update19/Act2/act2scene6b.rpy:203
translate spanish u19a2s6b_f58f7aeb:

    # fr "I think I will travel with you a little longer. I am curious where this path leads."
    fr "Creo que viajaré contigo un poco más. Tengo curiosidad por saber adónde lleva este camino."

# game/Scenes/Update19/Act2/act2scene6b.rpy:204
translate spanish u19a2s6b_2482c10d:

    # "And so we continue down the path together."
    "Y así seguimos juntos por el camino."

