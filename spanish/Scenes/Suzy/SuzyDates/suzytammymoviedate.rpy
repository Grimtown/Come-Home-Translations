# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:71
translate spanish suzytammymovietheaterstartdate_6aa1dad4:

    # ss "Yeah, okay."
    ss "Sí, vale."

# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:72
translate spanish suzytammymovietheaterstartdate_7661b3c0:

    # tm "I had fun though. Love you both. Have a good night without me."
    tm "Pero me lo he pasado bien. Os quiero a las dos. Que paséis una buena noche sin mí."

# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:74
translate spanish suzytammymovietheaterstartdate_091d5e9d:

    # ss "Oh we will."
    ss "Oh, lo haremos."

# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:77
translate spanish suzytammymovietheaterstartdate_fb8e986c:

    # pc "But not as much fun as if you were there too."
    pc "Pero no tan divertida como si tú también estuvieras allí."

# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:79
translate spanish suzytammymovietheaterstartdate_0603477e:

    # tm "Good night you two."
    tm "Buenas noches a las dos."

# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:82
translate spanish suzytammymovietheaterstartdate_05f57ea7:

