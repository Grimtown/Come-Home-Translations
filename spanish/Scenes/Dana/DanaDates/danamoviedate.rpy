    # cw "Oh my God, I can't remember the last movie that I went to see in the theater."
    cw "Dios mío, no recuerdo la última película que fui a ver al cine."

# game/Scenes/Dana/DanaDates/danamoviedate.rpy:18
translate spanish danamoviedate_28e36d10:

