# game/Scenes/Izzy/izzyconversations/izzys8.rpy:26
translate chinese izzys8_2fc9ea80:

    # gl "You want to smoke some weed, watch a show, or just fuck, I'm your girl."
    gl "你想抽点大麻、看场剧，或者干脆上床，我随时奉陪。"

# game/Scenes/Izzy/izzyconversations/izzys8.rpy:27
translate chinese izzys8_c025be05:

    # gl "But getting all dressed up and going to some restaurant or a walk on the promenade in the moonlight..."
