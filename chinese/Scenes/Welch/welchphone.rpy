translate chinese welchphone_a167d731:

    # "After a few rings, Ms. Welch picks up."
    "响了几声后，韦尔奇老师接了电话。"

# game/Scenes/Welch/welchphone.rpy:19
translate chinese welchphone_d41d8cd9:

    # voice 'voices/welch_hey1.mp3'
    voice 'voices/welch_hey1.mp3'

# game/Scenes/Welch/welchphone.rpy:20
translate chinese welchphone_07cefea7:

    # sst "Hey, [pcname]! I was hoping you would call."
    sst "嘿，[pcname]！我正盼着你打电话呢。"

# game/Scenes/Welch/welchphone.rpy:21
translate chinese welchphone_fbdf6074:

    # pc "Of course. Was there something you wanted to talk to me about."
    pc "当然。有什么想跟我聊的吗？"

# game/Scenes/Welch/welchphone.rpy:23
translate chinese welchphone_b6013596:

    # sst "No, nothing specific. Just..."
    sst "没有，没什么特别的。只是……"

# game/Scenes/Welch/welchphone.rpy:24
translate chinese welchphone_0e18554b:

    # sst "Well you know I said we'd wait until after you graduated and then see what happened?"
    sst "你还记得我说过，等你毕业后再看看会发生什么吗？"

# game/Scenes/Welch/welchphone.rpy:26
translate chinese welchphone_a2db96f4:

    # sst "I'm just having a hard time waiting."
    sst "我就是等不及了。"

# game/Scenes/Welch/welchphone.rpy:27
translate chinese welchphone_5e4b2f9e:

    # sst "I like talking to you. I just wanted to talk."
    sst "我喜欢跟你聊天。我只是想聊聊。"

# game/Scenes/Welch/welchphone.rpy:28
translate chinese welchphone_6e9ba7f2:

    # sst "I figure talking on the phone at night isn't going to hurt anything? Nobody is going to know about that."
    sst "我觉得晚上打个电话应该没关系吧？没人会知道的。"

# game/Scenes/Welch/welchphone.rpy:29
translate chinese welchphone_d0c89101:

    # pc "I guess that's true."
    pc "这话倒也没错。"

# game/Scenes/Welch/welchphone.rpy:30
translate chinese welchphone_b6bcfe3c:

    # sst "So we can talk about anything you'd like."
    sst "那我们可以聊任何你想聊的话题。"

# game/Scenes/Welch/welchphone.rpy:33
translate chinese welchphone_d41d8cd9_1:

    # voice 'voices/welch_hey2.mp3'
    voice 'voices/welch_hey2.mp3'

# game/Scenes/Welch/welchphone.rpy:34
translate chinese welchphone_5ad25ed7:

    # sst "Hey, [pcname]. Glad to hear from you."
    sst "嘿，[pcname]。听到你的声音真好。"

# game/Scenes/Welch/welchphone.rpy:36
translate chinese welchphone_8fcbff0a:

    # sst "Did you want to meet me somewhere, or just chat?"
    sst "你想约我见面，还是就这么聊聊？"

# game/Scenes/Welch/welchphone.rpy:47
translate chinese welchphone_ee6a99d8:

    # sst "Did you want to chat... or maybe come stay the night with me? My bed feels so empty right now."
    sst "你想聊聊……还是干脆来我这儿过夜？我现在的床感觉好空。"

# game/Scenes/Welch/welchphone.rpy:51
translate chinese welchphone_00c1542e:

    # sst "Good, I'll be waiting for you then."
    sst "好，那我就等你。"

# game/Scenes/Welch/welchphone.rpy:54
translate chinese welchphone_0ddcabe4:

    # "As soon as I get to her house, she opens the door, already stripped down to her underwear, and is all over me."
    "我刚到她家，她就开门了，已经脱得只剩内衣，还扑了上来。"

# game/Scenes/Welch/welchphone.rpy:55
translate chinese welchphone_9969adeb:

    # sst "Let's hurry and get upstairs. I need that dick so bad."
    sst "咱们快点上楼吧。我太想要那根肉棒了。"

# game/Scenes/Welch/welchphone.rpy:58
translate chinese welchphone_9a9bfdde:

    # sst "What do you feel like doing today, baby?"
    sst "今天你想干点什么，宝贝？"

# game/Scenes/Welch/welchphone.rpy:63
translate chinese welchphone_00c1542e_1:

    # sst "Good, I'll be waiting for you then."
    sst "好，那我就等着你。"

# game/Scenes/Welch/welchphone.rpy:66
translate chinese welchphone_0ddcabe4_1:

    # "As soon as I get to her house, she opens the door, already stripped down to her underwear, and is all over me."
    "我刚到她家，她就开门了，已经脱得只剩内衣，还扑了上来。"

# game/Scenes/Welch/welchphone.rpy:67
translate chinese welchphone_9969adeb_1:

    # sst "Let's hurry and get upstairs. I need that dick so bad."
    sst "“咱们快点上楼吧。我太想要那根肉棒了。”"

# game/Scenes/Welch/welchphone.rpy:70
translate chinese welchphone_9a9bfdde_1:

    # sst "What do you feel like doing today, baby?"
    sst "“今天你想干点什么，宝贝？”"

# game/Scenes/Welch/welchphone.rpy:80
translate chinese welchphone_41ee225d:

    # sst "Uh, okay. Bye then."
    sst "“呃，好吧。那我先挂了。”"

# game/Scenes/Welch/welchphone.rpy:84
translate chinese welchphone_f1c35fb8:

    # sst "Well, it was good talking to you, [pcname]. I should get some sleep though."
    sst "“嗯，和你聊天很开心，[pcname]。不过我该睡了。”"

# game/Scenes/Welch/welchphone.rpy:85
translate chinese welchphone_bf0c8718:

    # pc "Yeah me too. Good night, Nora."
    pc "“是啊，我也是。晚安，诺拉。”"

# game/Scenes/Welch/welchphone.rpy:88
translate chinese welchphone_52d6e3cf:

    # "We hang up and I get ready for bed."
    "我们挂了电话，我开始准备睡觉。"

# game/Scenes/Welch/welchphone.rpy:91
translate chinese welchphone_00837f1a:

    # sst "Well, it was good talking to you, [pcname]. I'll talk to you later, okay?"
    sst "“嗯，和你聊天很开心，[pcname]。” 待会儿再聊，行吗？"

# game/Scenes/Welch/welchphone.rpy:92
translate chinese welchphone_39cd78d0:

    # pc "Okay, see ya, Nora."
    pc "行，再见，诺拉。"

# game/Scenes/Welch/welchphone.rpy:96
translate chinese welchphone_a62f1110:

    # "There's no answer. Ms. Welch must be busy right now."
    "没人接。韦尔奇女士现在肯定很忙。"

# game/Scenes/Welch/welchphone.rpy:101
translate chinese welchdatesetup_5318235b:

    # sst "Cool. Where did you want to go?"
    sst "好啊。你想去哪儿？"

# game/Scenes/Welch/welchphone.rpy:104
translate chinese welchdatesetup_55b55948:

    # sst "Sounds good. I'll text you the movie and time and sit in the back and wait for you."
    sst "听起来不错。我会发消息告诉你电影和时间，然后坐在后面等你。"

# game/Scenes/Welch/welchphone.rpy:105
translate chinese welchdatesetup_e7bcdd16:

    # pc "Okay. See you there."
    pc "行。到时候见。"

# game/Scenes/Welch/welchphone.rpy:110
translate chinese welchdatesetup_55b55948_1:

    # sst "Sounds good. I'll text you the movie and time and sit in the back and wait for you."
