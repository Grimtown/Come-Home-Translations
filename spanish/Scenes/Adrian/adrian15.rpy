    ath "Quizá tengamos tiempo para una partida rápida, si nos damos prisa. No me costará mucho hacerte pedazos."

# game/Scenes/Adrian/adrian15.rpy:214
translate spanish adrian15_36bb3cc8:

    # gg "Let's go then, bitch!"
    gg "¡Vamos entonces, zorra!"

# game/Scenes/Adrian/adrian15.rpy:217
translate spanish adrian15_b7c027eb:

    # "Just then, a police car parks in front of the house and a man in a suit steps out, looking grim and official."
    "Justo en ese momento, un coche de policía aparca delante de la casa y sale un hombre con traje, con aspecto severo y oficial."

# game/Scenes/Adrian/adrian15.rpy:218
translate spanish adrian15_b3e6504f:

    # ath "Rain check, I guess. Time to go."
    ath "Lo dejaremos para otra vez, supongo. Es hora de irse."

# game/Scenes/Adrian/adrian15.rpy:221
translate spanish adrian15_d5f4dd84:

    # ath "I love you, cuz. I'll see you again soon."
    ath "Te quiero, primo. Nos vemos pronto."

# game/Scenes/Adrian/adrian15.rpy:222
translate spanish adrian15_b13e0d25:

    # gg "I love you too."
    gg "Yo también te quiero."

# game/Scenes/Adrian/adrian15.rpy:223
translate spanish adrian15_96dc14b2:

    # gg "I hate this so much. I don't want to let you go."
    gg "Odio esto tanto. No quiero dejarte ir."

# game/Scenes/Adrian/adrian15.rpy:224
translate spanish adrian15_1edb5510:

    # ath "I know. We'll be okay though."
    ath "Lo sé. Pero estaremos bien."

# game/Scenes/Adrian/adrian15.rpy:225
translate spanish adrian15_e2fe510e:

    # ath "And when I see you again, we'll hang out for days, okay?"
    ath "Y cuando te vuelva a ver, pasaremos días juntos, ¿vale?"

# game/Scenes/Adrian/adrian15.rpy:226
translate spanish adrian15_c5cc5eaf:

    # gg "Okay, but if there's anything I can do to help, please call me."
    gg "Vale, pero si hay algo en lo que pueda ayudarte, por favor, llámame."

# game/Scenes/Adrian/adrian15.rpy:227
translate spanish adrian15_20fcca99:

    # ath "I will."
    ath "Lo haré."

# game/Scenes/Adrian/adrian15.rpy:230
translate spanish adrian15_170b7c68:

    # ath "And [pcname], it was nice to meet you."
    ath "Y [pcname], me ha encantado conocerte."

# game/Scenes/Adrian/adrian15.rpy:231
translate spanish adrian15_61906ded:

    # pc "Nice to meet you too, Athena."
    pc "A mí también, Athena."

# game/Scenes/Adrian/adrian15.rpy:235
translate spanish adrian15_84825cda:

    # "Suddenly, she pulls my hand, yanking me closer, then whispers in my ear."
    "De repente, me tira de la mano, acercándome a ella, y luego me susurra al oído."

# game/Scenes/Adrian/adrian15.rpy:236
translate spanish adrian15_46517656:

    # ath "Be good to her. If you hurt my cousin, I will find you."
    ath "Sé bueno con ella. Si le haces daño a mi prima, te encontraré."

# game/Scenes/Adrian/adrian15.rpy:237
translate spanish adrian15_17a1cb32:

    # pc "Uh, I will."
    pc "Eh, lo seré."

# game/Scenes/Adrian/adrian15.rpy:240
translate spanish adrian15_05763882:

    # ath "Bye, Adrian! Love you!"
    ath "¡Adiós, Adrian! ¡Te quiero!"

# game/Scenes/Adrian/adrian15.rpy:241
translate spanish adrian15_11b6245f:

    # gg "Bye! Love you too!"
    gg "¡Adiós! ¡Yo también te quiero!"

# game/Scenes/Adrian/adrian15.rpy:242
translate spanish adrian15_fd99ecee:

    # ath "Tell your mom I love her too!"
    ath "¡Dile a tu madre que yo también la quiero!"

# game/Scenes/Adrian/adrian15.rpy:243
translate spanish adrian15_b909935e:

    # gg "I will!"
    gg "¡Lo haré!"

# game/Scenes/Adrian/adrian15.rpy:244
translate spanish adrian15_124dcc1b:

    # ath "I'll kick your pink Kirby ass real soon!"
    ath "¡Te daré una paliza con tu Kirby rosa muy pronto!"

# game/Scenes/Adrian/adrian15.rpy:248
translate spanish adrian15_4829e0da:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns towards me, tears in her eyes."
    "En cuanto Athena se sube al coche y este empieza a alejarse, Adrian se vuelve hacia mí, con lágrimas en los ojos."

# game/Scenes/Adrian/adrian15.rpy:249
translate spanish adrian15_5928d159:

    # gg "Ugh, this fucking sucks."
    gg "Uf, esto es una mierda."

# game/Scenes/Adrian/adrian15.rpy:250
translate spanish adrian15_72615de3:

    # gg "I'm sorry, [pcname]. I don't much feel like playing games anymore."
    gg "Lo siento, [pcname]. Ya no me apetece mucho seguir jugando."

# game/Scenes/Adrian/adrian15.rpy:251
translate spanish adrian15_fd83325a:

    # gg "I'll see you later, okay?"
    gg "Nos vemos luego, ¿vale?"

# game/Scenes/Adrian/adrian15.rpy:252
translate spanish adrian15_e576c8b5:

    # pc "Are you going to be all right."
    pc "¿Vas a estar bien?"

# game/Scenes/Adrian/adrian15.rpy:253
translate spanish adrian15_0da71ea1:

    # gg "Yeah. I'll have to be."
    gg "Sí. Tendré que estarlo."

# game/Scenes/Adrian/adrian15.rpy:254
translate spanish adrian15_4004410a:

    # gg "But I need some time alone now."
    gg "Pero ahora necesito un rato a solas."

# game/Scenes/Adrian/adrian15.rpy:255
translate spanish adrian15_b21f0baf:

    # pc "No problem. Let me know if I can help. See you later, Adrian."
    pc "No hay problema. Dime si puedo ayudarte. Nos vemos luego, Adrian."

# game/Scenes/Adrian/adrian15.rpy:256
translate spanish adrian15_9d092ee2:

    # gg "Thanks, [pcname]. See ya."
    gg "Gracias, [pcname]. Nos vemos."

# game/Scenes/Adrian/adrian15.rpy:259
translate spanish adrian15_25d8780e:

    # "I leave Adrian's house, hoping that she'll be okay."
    "Salgo de la casa de Adrian, esperando que esté bien."

# game/Scenes/Adrian/adrian15.rpy:267
translate spanish adrian15_d9f27044:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns and collapses into my arms, crying against my shoulder."
    "En cuanto Athena se sube al coche y este empieza a alejarse, Adrian se gira y se derrumba en mis brazos, llorando contra mi hombro."

# game/Scenes/Adrian/adrian15.rpy:268
translate spanish adrian15_0e12d7d2:

    # gg "This fucking sucks!!!"
    gg "¡Esto es una mierda!!!"

# game/Scenes/Adrian/adrian15.rpy:269
translate spanish adrian15_182f9ad8:

    # "I rub her back and hold her and let her cry it out."
    "Le froto la espalda, la abrazo y la dejo llorar hasta que se le pase."

# game/Scenes/Adrian/adrian15.rpy:272
translate spanish adrian15_8bf9515c:

    # "A few minutes later, she sniffs up her tears and looks at me."
    "Unos minutos más tarde, se seca las lágrimas y me mira."

# game/Scenes/Adrian/adrian15.rpy:273
translate spanish adrian15_3d955406:

    # gg "Okay, feeling slightly better."
    gg "Vale, me siento un poco mejor."

# game/Scenes/Adrian/adrian15.rpy:274
translate spanish adrian15_58a70a56:

    # gg "I want to go for a ride. Do you want to come with me?"
    gg "Quiero dar una vuelta. ¿Quieres venir conmigo?"

# game/Scenes/Adrian/adrian15.rpy:275
translate spanish adrian15_2b3b24ff:

    # "I think I probably should stay with her, with how upset she is."
    "Creo que probablemente debería quedarme con ella, por lo alterada que está."

# game/Scenes/Adrian/adrian15.rpy:276
translate spanish adrian15_2d17893f:

    # pc "Sure, let's do it, if you're okay to drive?"
    pc "Claro, hagámoslo, ¿si te sientes bien para conducir?"

# game/Scenes/Adrian/adrian15.rpy:277
translate spanish adrian15_28404c62:

    # gg "Yeah, I'm okay."
    gg "Sí, estoy bien."

# game/Scenes/Adrian/adrian15.rpy:280
translate spanish adrian15_58afc396:

    # gg "Here, I found her old helmet in the storage under the seat. You should probably wear it."
    gg "Toma, he encontrado su casco viejo en el compartimento debajo del asiento. Probablemente deberías ponértelo."

# game/Scenes/Adrian/adrian15.rpy:281
translate spanish adrian15_4fb22de7:

    # pc "Dear lord, this thing is huge."
    pc "Dios mío, esta cosa es enorme."

# game/Scenes/Adrian/adrian15.rpy:282
translate spanish adrian15_2409eb5c:

    # gg "That's what she... nevermind, let's just go."
    gg "Eso es lo que ella... da igual, vamos ya."

# game/Scenes/Adrian/adrian15.rpy:283
translate spanish adrian15_9b4e9f4c:

    # pc "You know how to ride this thing?"
    pc "¿Sabes cómo se conduce esto?"

# game/Scenes/Adrian/adrian15.rpy:284
translate spanish adrian15_12315e04:

    # gg "Yeah, Athena taught me when I visited her last time. We rode all over the place on it."
    gg "Sí, Athena me enseñó la última vez que la visité. Dimos vueltas por todas partes con ella."

# game/Scenes/Adrian/adrian15.rpy:285
translate spanish adrian15_c4bccc9f:

    # gg "I'm the only person she'd ever let drive it."
    gg "Soy la única persona a la que ella ha dejado conducirla."

# game/Scenes/Adrian/adrian15.rpy:289
translate spanish adrian15_65c8468c:

    # "I wrap my arms around her and hold on as she pulls out into the street."
    "La rodeo con mis brazos y me agarro fuerte mientras ella sale a la calle."

# game/Scenes/Adrian/adrian15.rpy:290
translate spanish adrian15_a4cc4d56:

    # pc "Where are we going?"
    pc "¿Adónde vamos?"

# game/Scenes/Adrian/adrian15.rpy:291
translate spanish adrian15_33da7917:

    # gg "I just feel like riding for a while. Clear my head, you know."
    gg "Me apetece dar una vuelta un rato. Aclararme las ideas, ya sabes."

# game/Scenes/Adrian/adrian15.rpy:292
translate spanish adrian15_61f77a4c:

    # pc "Sure."
    pc "Claro."

# game/Scenes/Adrian/adrian15.rpy:294
translate spanish adrian15_df03bfba:

    # "It feels like we're riding forever. We leave town and take a rarely used highway out towards the lake."
    "Parece que llevamos una eternidad conduciendo. Salimos de la ciudad y tomamos una carretera poco transitada hacia el lago."

# game/Scenes/Adrian/adrian15.rpy:295
translate spanish adrian15_ba48df36:

    # "After a while, I'm not even sure where we are anymore. Hopefully Adrian knows. I guess I have GPS on the phone if we get lost."
    "Al cabo de un rato, ya ni siquiera estoy segura de dónde estamos. Espero que Adrián lo sepa. Supongo que tengo el GPS del móvil por si nos perdemos."

# game/Scenes/Adrian/adrian15.rpy:296
translate spanish adrian15_0bac7b03:

    # "But I don't say anything. I just hold on and let Adrian clear her mind of everything."
    "Pero no digo nada. Solo me agarro fuerte y dejo que Adrian se despeje la mente."

# game/Scenes/Adrian/adrian15.rpy:297
translate spanish adrian15_76cd1d73:

    # "She seems calm now, like this is exactly what she needed to get through this."
    "Ahora parece tranquila, como si esto fuera justo lo que necesitaba para superar esto."

# game/Scenes/Adrian/adrian15.rpy:298
translate spanish adrian15_f0b56a2e:

    # "Then, after what must have been at least an hour, she pulls off the highway and drives a little ways up towards the cliffside near the lake."
    "Entonces, después de lo que debe de haber sido al menos una hora, sale de la carretera y conduce un poco hacia el acantilado cerca del lago."

# game/Scenes/Adrian/adrian15.rpy:301
translate spanish adrian15_135327af:

    # "We sit and I hold her close, trying to provide whatever comfort I can."
    "Nos sentamos y la abrazo fuerte, intentando darle todo el consuelo que puedo."

# game/Scenes/Adrian/adrian15.rpy:302
translate spanish adrian15_fa24fdf7:

    # gg "I'm sorry I'm being such a bummer. This was supposed to be a fun day."
    gg "Siento ser tan pesada. Se suponía que iba a ser un día divertido."

# game/Scenes/Adrian/adrian15.rpy:303
translate spanish adrian15_cfd80ee8:

    # pc "It's okay, Adrian. I'm here for you. Whatever you need."
    pc "No pasa nada, Adrian. Estoy aquí para ti. Lo que necesites."

# game/Scenes/Adrian/adrian15.rpy:304
translate spanish adrian15_64ee3ae6:

    # gg "Thanks, [pcname]. I just need a friend really."
    gg "Gracias, [pcname]. En realidad solo necesito una amiga."

# game/Scenes/Adrian/adrian15.rpy:306
translate spanish adrian15_d41d8cd9:

    # voice 'voices/adrian_whenitransitioned.mp3'
    voice 'voices/adrian_whenitransitioned.mp3'

# game/Scenes/Adrian/adrian15.rpy:307
translate spanish adrian15_ec81d936:

    # gg "When I transitioned, besides my mom, Athena was the only person who was there for me."
    gg "Cuando hice la transición, aparte de mi madre, Athena fue la única persona que estuvo ahí para mí."

# game/Scenes/Adrian/adrian15.rpy:309
translate spanish adrian15_d41d8cd9_1:

    # voice 'voices/adrian_nohesitation.mp3'
    voice 'voices/adrian_nohesitation.mp3'

# game/Scenes/Adrian/adrian15.rpy:310
translate spanish adrian15_b76e91f4:

    # gg "No hesitation, no questions, just a ton of support and love."
    gg "Sin dudar, sin preguntas, solo un montón de apoyo y amor."

# game/Scenes/Adrian/adrian15.rpy:312
translate spanish adrian15_d41d8cd9_2:

    # voice 'voices/adrian_shewastheonly.mp3'
    voice 'voices/adrian_shewastheonly.mp3'

# game/Scenes/Adrian/adrian15.rpy:313
translate spanish adrian15_5be20e3b:

    # gg "She was the only friend I had for a long time."
    gg "Fue la única amiga que tuve durante mucho tiempo."

# game/Scenes/Adrian/adrian15.rpy:317
translate spanish adrian15_d41d8cd9_3:

    # voice 'voices/adrian_untilyou.mp3'
    voice 'voices/adrian_untilyou.mp3'

# game/Scenes/Adrian/adrian15.rpy:318
translate spanish adrian15_b79560a9:

    # gg "Until you."
    gg "Hasta que apareciste tú."

# game/Scenes/Adrian/adrian15.rpy:320
translate spanish adrian15_d41d8cd9_4:

    # voice 'voices/adrian_missherlikecrazy.mp3'
    voice 'voices/adrian_missherlikecrazy.mp3'

# game/Scenes/Adrian/adrian15.rpy:321
translate spanish adrian15_65372d0d:

    # gg "So, I'm going to miss her like crazy, and I'm going to worry about her until I hear from her again."
    gg "Así que la voy a echar muchísimo de menos y voy a estar preocupada por ella hasta que vuelva a saber de ella."

# game/Scenes/Adrian/adrian15.rpy:323
translate spanish adrian15_d41d8cd9_5:

    # voice 'voices/adrian_butimsoglad.mp3'
    voice 'voices/adrian_butimsoglad.mp3'

# game/Scenes/Adrian/adrian15.rpy:324
translate spanish adrian15_4de0338c:

    # gg "But I'm so glad that you're here."
    gg "Pero me alegro mucho de que estés aquí."

# game/Scenes/Adrian/adrian15.rpy:326
translate spanish adrian15_d41d8cd9_6:

    # voice 'voices/adrian_iloveyou1.mp3'
    voice 'voices/adrian_iloveyou1.mp3'

# game/Scenes/Adrian/adrian15.rpy:327
translate spanish adrian15_9c8fbba1:

    # gg "I love you, [pcname]."
    gg "Te quiero, [pcname]."

# game/Scenes/Adrian/adrian15.rpy:330
translate spanish adrian15_456cffdf:

    # pc "I love you too, Adrian."
    pc "Yo también te quiero, Adrian."

# game/Scenes/Adrian/adrian15.rpy:333
translate spanish adrian15_e9e54f9a:

    # "We sit and watch the sun set, holding each other, enjoying the quiet evening."
    "Nos sentamos a ver la puesta de sol, abrazados, disfrutando de la tranquila tarde."

# game/Scenes/Adrian/adrian15.rpy:334
translate spanish adrian15_5a0d166e:

    # "I just want to be whatever she needs now."
    "Solo quiero ser lo que ella necesite ahora."

# game/Scenes/Adrian/adrian15.rpy:335
translate spanish adrian15_46b97a11:

    # "I realize how hard I've fallen for her. I'd do anything to make her happy."
    "Me doy cuenta de lo mucho que me he enamorado de ella. Haría cualquier cosa para hacerla feliz."

# game/Scenes/Adrian/adrian15.rpy:338
translate spanish adrian15_7f8ffd28:

    # "After the sun sets, we drive back to her house."
    "Después de que se pone el sol, volvemos en coche a su casa."

# game/Scenes/Adrian/adrian15.rpy:341
translate spanish adrian15_78e6be93:

    # gg "It looks like my mom is home now. I'm going to have to explain everything to her."
    gg "Parece que mi madre ya está en casa. Voy a tener que explicárselo todo."

# game/Scenes/Adrian/adrian15.rpy:342
translate spanish adrian15_f3610339:

    # gg "This is not going to be fun."
    gg "Esto no va a ser divertido."

# game/Scenes/Adrian/adrian15.rpy:343
translate spanish adrian15_20cd9dd9:

    # pc "Want some backup?"
    pc "¿Quieres que te acompañe?"

# game/Scenes/Adrian/adrian15.rpy:344
translate spanish adrian15_0c91a1a8:

    # gg "No, I think I better do this on my own."
    gg "No, creo que es mejor que lo haga solo."

# game/Scenes/Adrian/adrian15.rpy:345
translate spanish adrian15_cf913627:

    # gg "Thanks for everything though, [pcname]. You've been amazing."
    gg "Pero gracias por todo, [pcname]. Has estado increíble."

# game/Scenes/Adrian/adrian15.rpy:346
translate spanish adrian15_c46a0b54:

    # pc "Any time."
    pc "Cuando quieras."

# game/Scenes/Adrian/adrian15.rpy:347
translate spanish adrian15_ee13ba27:

    # gg "I'll call you soon, okay?"
    gg "Te llamaré pronto, ¿vale?"

# game/Scenes/Adrian/adrian15.rpy:350
translate spanish adrian15_1f2a71e7:

    # pc "Okay. Good night, Adrian."
    pc "Vale. Buenas noches, Adrian."

# game/Scenes/Adrian/adrian15.rpy:351
translate spanish adrian15_f27d9018:

    # gg "Good night, [pcname]."
    gg "Buenas noches, [pcname]."

# game/Scenes/Adrian/adrian15.rpy:352
translate spanish adrian15_80adb898:

    # "I kiss her goodbye."
    "Le doy un beso de despedida."

# game/Scenes/Adrian/adrian15.rpy:355
translate spanish adrian15_0cbac92b:

    # "Then I get in my car and drive away, hoping that everything will be okay."
    "Luego me subo al coche y me voy, con la esperanza de que todo salga bien."

# game/Scenes/Adrian/adrian15.rpy:356
translate spanish adrian15_339d053a:

    # "And if she needs me, I'll do anything I can to help her."
    "Y si me necesita, haré todo lo que pueda para ayudarla."

translate spanish strings:

    # game/Scenes/Adrian/adrian15.rpy:6
    old "After you have checked out a local arcade with Adrian,"
    new "Después de que hayas visitado una sala de juegos local con Adrian,"

    # game/Scenes/Adrian/adrian15.rpy:7
    old "she will call and invite you to hang out in the afternoon on the weekend."
    new "ella te llamará y te invitará a quedar por la tarde el fin de semana."

    # game/Scenes/Adrian/adrian15.rpy:28
    old "Oh heck yeah"
    new "¡Claro que sí!"

