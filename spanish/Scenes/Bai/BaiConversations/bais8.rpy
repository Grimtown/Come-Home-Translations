# game/Scenes/Bai/BaiConversations/bais8.rpy:13
translate spanish bais8_d217cd50:

    # bai "Pretty traditional."
    bai "Bastante tradicional."

# game/Scenes/Bai/BaiConversations/bais8.rpy:14
translate spanish bais8_0af84505:

    # bai "My parents are both strict and very interested in me doing well."
    bai "Mis padres son estrictos y les importa mucho que me vaya bien."

# game/Scenes/Bai/BaiConversations/bais8.rpy:15
translate spanish bais8_6f109caf:

    # bai "I have one older sister, who's a doctor, and a younger brother who qualified for a private school when he was 10 and graduated high school at age 15, a year before me."
    bai "Tengo una hermana mayor, que es médica, y un hermano menor que entró en un colegio privado cuando tenía 10 años y se graduó en el instituto a los 15, un año antes que yo."

# game/Scenes/Bai/BaiConversations/bais8.rpy:16
translate spanish bais8_1cbbec02:

    # pc "Sounds competitive."
    pc "Suena competitivo."

# game/Scenes/Bai/BaiConversations/bais8.rpy:18
translate spanish bais8_0b766f52:

    # bai "It sort of is."
    bai "En cierto modo lo es."

# game/Scenes/Bai/BaiConversations/bais8.rpy:19
translate spanish bais8_e3b5d935:

    # bai "I love my siblings, but it does feel like we're constantly competing for our parent's approval."
    bai "Quiero mucho a mis hermanos, pero parece que estamos compitiendo constantemente por la aprobación de nuestros padres."

# game/Scenes/Bai/BaiConversations/bais8.rpy:20
translate spanish bais8_c840f06f:

    # bai "And I'm losing, badly."
    bai "Y yo estoy perdiendo, y por goleada."

# game/Scenes/Bai/BaiConversations/bais8.rpy:22
translate spanish bais8_721a2c39:

    # bai "It would be even worse if they knew everything about me."
    bai "Sería aún peor si supieran todo sobre mí."

# game/Scenes/Bai/BaiConversations/bais8.rpy:23
translate spanish bais8_a2a6fb65:

    # pc "What do you mean?"
    pc "¿A qué te refieres?"

# game/Scenes/Bai/BaiConversations/bais8.rpy:25
translate spanish bais8_270bb5fd:

    # bai "You know. That I'm into guys."
    bai "Ya sabes. Que me gustan los chicos."

# game/Scenes/Bai/BaiConversations/bais8.rpy:26
translate spanish bais8_91b5dbc2:

    # pc "You don't think they would approve?"
    pc "¿No crees que lo aprobarían?"

# game/Scenes/Bai/BaiConversations/bais8.rpy:27
translate spanish bais8_8652bd37:

    # bai "I don't know for sure. Like I said, they're pretty traditional."
    bai "No lo sé con certeza. Como te dije, son bastante tradicionales."

# game/Scenes/Bai/BaiConversations/bais8.rpy:29
translate spanish bais8_0ee24748:

    # bai "Maybe I'll come out to them eventually, but for now I just want to see where things go."
    bai "Quizá se lo cuente algún día, pero por ahora solo quiero ver cómo van las cosas."

# game/Scenes/Bai/BaiConversations/bais8.rpy:30
translate spanish bais8_a11c288d:

    # pc "Well, I hope it all goes well for you."
    pc "Bueno, espero que todo te vaya bien."

# game/Scenes/Bai/BaiConversations/bais8.rpy:32
translate spanish bais8_badd9121:

    # bai "Thanks, [pcname]."
    bai "Gracias, [pcname]."

