# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:16
translate spanish suzyq1_bb39002d:

    # ss "What do you think happened to your dad?"
    ss "¿Qué crees que le pasó a tu padre?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:17
translate spanish suzyq1_0204b20e:

    # ss "You've been looking into it, right?"
    ss "Has estado investigando, ¿verdad?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:18
translate spanish suzyq1_124713d8:

    # pc "Yeah. I'm not exactly sure."
    pc "Sí. No estoy muy segura."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:19
translate spanish suzyq1_d5b03897:

    # ss "You have some theories though, right?"
    ss "Pero tienes algunas teorías, ¿no?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:20
translate spanish suzyq1_77c7a12b:

    # pc "Maybe..."
    pc "Quizás..."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:22
translate spanish suzyq1_1a24ba26:

    # ss "Well, what is it? Did he run off with another woman?"
    ss "Bueno, ¿qué es? ¿Se fugó con otra mujer?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:23
translate spanish suzyq1_84d5e1ca:

    # pc "No, it's more complicated than that."
    pc "No, es más complicado que eso."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:24
translate spanish suzyq1_4b4d0d9c:

    # ss "He ran off with {i}two{/i} other women?"
    ss "¿Se fugó con {i}dos{/i} otras mujeres?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:25
translate spanish suzyq1_6e8849ae:

    # pc "I think that he built a device that allowed him to travel to an alternate dimension."
    pc "Creo que construyó un dispositivo que le permitía viajar a una dimensión alternativa."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:27
translate spanish suzyq1_6d83864e:

    # ss "The fuck?"
    ss "¿Qué coño?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:28
translate spanish suzyq1_19e84ce5:

    # pc "I know it sounds crazy, but everything I'm finding is pointing in that direction."
    pc "Sé que suena a locura, pero todo lo que estoy descubriendo apunta en esa dirección."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:30
translate spanish suzyq1_0beb2ecb:

    # ss "Are you sure this isn't some stupid diversion he created before he just ran off with another woman?"
    ss "¿Estás seguro de que no es una estúpida distracción que se inventó antes de largarse con otra mujer?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:31
translate spanish suzyq1_b158b959:

    # pc "I don't think so. Why are you so caught up on that?"
    pc "No lo creo. ¿Por qué te obsesiona tanto eso?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:33
translate spanish suzyq1_12bdfbf5:

    # ss "Because men cheat. That's what they do."
    ss "Porque los hombres engañan. Es lo que hacen."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:34
translate spanish suzyq1_afe72560:

    # ss "And he was spending so much time in that basement before he disappeared."
    ss "Y él pasaba mucho tiempo en ese sótano antes de desaparecer."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:35
translate spanish suzyq1_6ac85a83:

    # ss "He and Mom hadn't even been sleeping together for months."
    ss "Él y mamá ni siquiera se habían acostado juntos en meses."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:37
translate spanish suzyq1_a95e50c5:

    # ss "She told me everything was okay, but I caught her crying more than once."
    ss "Ella me dijo que todo iba bien, pero la pillé llorando más de una vez."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:38
translate spanish suzyq1_5e4e411a:

    # ss "I'm tired of men making my mom cry. I thought he was different."
    ss "Estoy harta de que los hombres hagan llorar a mi madre. Pensaba que él era diferente."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:40
translate spanish suzyq1_45308832:

    # ss "It makes me so mad that he did this to her."
    ss "Me enfada mucho que le haya hecho esto."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:41
translate spanish suzyq1_d62ef4c6:

    # pc "Yeah. I don't think he ran off with another woman, but it does seem like he was not very good to Lisa."
    pc "Sí. No creo que se haya fugado con otra mujer, pero sí parece que no se portaba muy bien con Lisa."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:43
translate spanish suzyq1_d2bfe5e6:

    # ss "Do you think he'll come back?"
    ss "¿Crees que volverá?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:44
translate spanish suzyq1_e9895a32:

    # pc "I don't know. I'm working on it."
    pc "No lo sé. Estoy trabajando en ello."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:46
translate spanish suzyq1_5eb40a8b:

    # ss "You're working on bringing him back from an alternate universe."
    ss "Estás intentando traerlo de vuelta desde un universo paralelo."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:47
translate spanish suzyq1_a1d44b72:

    # pc "Well... yeah."
    pc "Bueno... sí."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:49
translate spanish suzyq1_a61a0198:

    # ss "You're just messing with me with all this junk, aren't you?"
    ss "Me estás tomando el pelo con todo este lío, ¿verdad?"

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:50
translate spanish suzyq1_e625962b:

    # pc "No, I'm serious."
    pc "No, lo digo en serio."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:52
translate spanish suzyq1_4cf2e329:

    # ss "Okay..."
    ss "Vale..."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:53
translate spanish suzyq1_d6d647a9:

    # ss "Well just be careful. I really don't want to lose you too."
    ss "Bueno, ten cuidado. De verdad que no quiero perderte a ti también."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:56
translate spanish suzyq1_d41d8cd9:

    # voice 'voices/suzy_iloveyou.mp3'
    voice 'voices/suzy_iloveyou.mp3'

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:57
translate spanish suzyq1_3054faea:

    # ss "I love you, [bro]."
    ss "Te quiero, [bro]."

# game/Scenes/Suzy/SuzyConversations/suzyq1.rpy:58
translate spanish suzyq1_2733b4a2:

    # pc "I love you too, [sis]."
    pc "Yo también te quiero, [sis]."

