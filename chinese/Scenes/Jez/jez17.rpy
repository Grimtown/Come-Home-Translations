translate chinese jez17_6666704d:

    # mama "No, gracias. You are sweet for offering though."
    mama "不用了，谢谢。不过你这么问真贴心。"

# game/Scenes/Jez/jez17.rpy:129
translate chinese jez17_f899b33f:

    # mama "This is what abuelas are for."
    mama "这就是奶奶存在的意义。"

