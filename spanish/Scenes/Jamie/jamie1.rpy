    new "Habla con ella por la mañana un día entre semana. Le gustaría salir a tomar un café contigo."

    # game/Scenes/Jamie/jamie1.rpy:176
    old "Yeah, I was an idiot."
    new "Sí, fui un idiota."

    # game/Scenes/Jamie/jamie1.rpy:180
    old "This is all middle school shit, what does it matter?"
    new "Todo esto son tonterías de instituto, ¿qué más da?"

    # game/Scenes/Jamie/jamie1.rpy:205
    old "Apologize"
    new "Pide perdón"

    # game/Scenes/Jamie/jamie1.rpy:208
    old "Don't apologize"
    new "No pidas perdón"

