# game/Scenes/Juliana/juliana2.rpy:13
translate spanish juliana2_ba25a872:

    # "The school day goes by normally until English class."
    "El día en el colegio transcurre con normalidad hasta la clase de inglés."

# game/Scenes/Juliana/juliana2.rpy:14
translate spanish juliana2_5631544c:

    # "Mrs. McGee lectures all period about the archetypes and subtext of the short story we are reading."
    "La Sra. McGee da toda la clase sobre los arquetipos y el subtexto del relato corto que estamos leyendo."

# game/Scenes/Juliana/juliana2.rpy:15
translate spanish juliana2_88daeb16:

    # "The entire time, I don't even look at Juliana, I'm still so annoyed with her."
    "Durante todo ese tiempo, ni siquiera miro a Juliana, sigo muy enfadado con ella."

# game/Scenes/Juliana/juliana2.rpy:18
translate spanish juliana2_1c2cecc3:

    # "When the class is over, I gather my things and get up to leave."
    "Cuando termina la clase, recojo mis cosas y me levanto para irme."

# game/Scenes/Juliana/juliana2.rpy:19
translate spanish juliana2_290ef46a:

    # bn "[pcname]?"
    bn "[pcname]?"

# game/Scenes/Juliana/juliana2.rpy:20
translate spanish juliana2_fc83ac13:

    # "I think about continuing to walk, but the nervousness in her voice makes me stop."
    "Pienso en seguir caminando, pero el nerviosismo en su voz me hace detenerme."

# game/Scenes/Juliana/juliana2.rpy:24
translate spanish juliana2_395d1511:

    # bn "[pcname], can you just talk to me for a second?"
    bn "[pcname], ¿puedes hablar conmigo un momento?"

# game/Scenes/Juliana/juliana2.rpy:25
translate spanish juliana2_63023601:

    # pc "Okay."
    pc "Vale."

# game/Scenes/Juliana/juliana2.rpy:28
translate spanish juliana2_9da0d89a:

    # bn "I'm sorry about the things I wrote on your essay."
    bn "Siento lo que escribí en tu redacción."

# game/Scenes/Juliana/juliana2.rpy:29
translate spanish juliana2_ec9b7d74:

    # bn "I know that sometimes I can be too harsh. Too blunt with my words."
    bn "Sé que a veces puedo ser demasiado dura. Demasiado directa con mis palabras."

# game/Scenes/Juliana/juliana2.rpy:30
translate spanish juliana2_e1eed4cc:

    # bn "I'm not good with talking to people. I get nervous and my words come out muddled."
    bn "No se me da bien hablar con la gente. Me pongo nerviosa y mis palabras salen confusas."

# game/Scenes/Juliana/juliana2.rpy:31
translate spanish juliana2_439f936e:

    # bn "When I was editing your essay, I failed to take into account that there was a person on the other side of the writing."
    bn "Cuando estaba corrigiendo tu redacción, no tuve en cuenta que había una persona al otro lado del texto."

# game/Scenes/Juliana/juliana2.rpy:32
translate spanish juliana2_828e0032:

    # bn "And I apologize for that. I should have been kinder."
    bn "Y te pido perdón por eso. Debería haber sido más amable."

# game/Scenes/Juliana/juliana2.rpy:33
translate spanish juliana2_6ac1535a:

    # "I look at her, genuinely sorry for what she had written."
    "La miro, sinceramente arrepentida por lo que había escrito."

# game/Scenes/Juliana/juliana2.rpy:34
translate spanish juliana2_4af91df8:

    # "It's difficult for me to stay mad after that."
    "Me cuesta seguir enfadada después de eso."

# game/Scenes/Juliana/juliana2.rpy:35
translate spanish juliana2_7836aabb:

    # pc "I forgive you."
    pc "Te perdono."

# game/Scenes/Juliana/juliana2.rpy:36
translate spanish juliana2_359954db:

    # pc "Besides, your input did help me get an A on that essay."
    pc "Además, tus comentarios me ayudaron a sacar un sobresaliente en ese ensayo."

# game/Scenes/Juliana/juliana2.rpy:39
translate spanish juliana2_49b20716:

    # bn "Good. I'm glad."
    bn "Bien. Me alegro."

# game/Scenes/Juliana/juliana2.rpy:40
translate spanish juliana2_36f62856:

    # bn "That was my intention. To help you fix your essay."
    bn "Esa era mi intención. Ayudarte a mejorar tu ensayo."

# game/Scenes/Juliana/juliana2.rpy:41
translate spanish juliana2_5d0adf4a:

    # pc "Well you did a good job there."
    pc "Pues lo hiciste muy bien."

# game/Scenes/Juliana/juliana2.rpy:44
translate spanish juliana2_a559e42c:

    # bn "I could help you more if you want."
    bn "Podría ayudarte más si quieres."

# game/Scenes/Juliana/juliana2.rpy:45
translate spanish juliana2_7e811564:

    # bn "If you want to maybe study together sometime?"
    bn "¿Si quieres, quizá podríamos estudiar juntos alguna vez?"

# game/Scenes/Juliana/juliana2.rpy:46
translate spanish juliana2_ff08c86f:

    # bn "I'm usually in the café here on campus in the morning."
    bn "Normalmente estoy en la cafetería del campus por las mañanas."

# game/Scenes/Juliana/juliana2.rpy:47
translate spanish juliana2_e4b8a84b:

    # bn "You could come by and study with me if you want."
    bn "Podrías pasarte y estudiar conmigo si quieres."

# game/Scenes/Juliana/juliana2.rpy:52
translate spanish juliana2_1abdf9b6:

    # bn "Good, I'm looking forward to it!"
    bn "¡Genial, estoy deseándolo!"

# game/Scenes/Juliana/juliana2.rpy:53
translate spanish juliana2_d63c89db:

    # bn "Okay, well I better get on to my next class."
    bn "Vale, bueno, mejor me voy a mi siguiente clase."

# game/Scenes/Juliana/juliana2.rpy:54
translate spanish juliana2_9c9c1091:

    # bn "I'm glad we talked."
    bn "Me alegro de que hayamos hablado."

# game/Scenes/Juliana/juliana2.rpy:57
translate spanish juliana2_b237b55e:

    # bn "Okay, well if you change your mind, I'll be there."
    bn "Vale, bueno, si cambias de opinión, allí estaré."

# game/Scenes/Juliana/juliana2.rpy:58
translate spanish juliana2_5dfb772a:

    # bn "I better get on to my next class."
    bn "Será mejor que me vaya a mi siguiente clase."

# game/Scenes/Juliana/juliana2.rpy:59
translate spanish juliana2_268fafe9:

    # bn "But I'm glad we talked."
    bn "Pero me alegro de haber hablado contigo."

# game/Scenes/Juliana/juliana2.rpy:62
translate spanish juliana2_fa503b05:

    # "With that, she walks out of Mrs. McGee's class and rushes down the hall."
    "Dicho esto, sale de la clase de la Sra. McGee y se apresura por el pasillo."

# game/Scenes/Juliana/juliana2.rpy:63
translate spanish juliana2_5b956f56:

    # "I head the opposite direction towards my own class."
    "Yo me dirijo en dirección opuesta, hacia mi propia clase."

# game/Scenes/Juliana/juliana2.rpy:64
translate spanish juliana2_02bf7eb2:

    # "The rest of the day passes quickly and without incident, then it's time to go to work."
    "El resto del día pasa rápido y sin incidentes, y luego llega la hora de ir al trabajo."

translate spanish strings:

    # game/Scenes/Juliana/juliana2.rpy:2
    old "After the scene where Juliana critiques your essay,"
    new "Después de la escena en la que Juliana critica tu redacción,"

    # game/Scenes/Juliana/juliana2.rpy:3
    old "this scene will happen automatically in English class."
    new "esta escena ocurrirá automáticamente en la clase de inglés."

    # game/Scenes/Juliana/juliana2.rpy:55
    old "Maybe, I don't know"
    new "Quizás, no lo sé."

