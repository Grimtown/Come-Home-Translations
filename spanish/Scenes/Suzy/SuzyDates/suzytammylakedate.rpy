# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:79
translate spanish suzytammylakedate_60c94072:

    # "We quietly go upstairs together, go into my bedroom, and lock the door."
    "Subimos juntos en silencio, entramos en mi dormitorio y cerramos la puerta con llave."

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:83
translate spanish suzytammylakedate_acfb634b:

    # ss "Okay, well I had a fun date, [bro]."
    ss "Vale, bueno, he tenido una cita divertida, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:84
translate spanish suzytammylakedate_be17834a:

    # tm "Yeah, me too."
    tm "Sí, yo también."

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:85
translate spanish suzytammylakedate_644a5289:

    # ss "Sleep well. See you tomorrow."
    ss "Que duermas bien. Nos vemos mañana."

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:86
translate spanish suzytammylakedate_d35669a0:

