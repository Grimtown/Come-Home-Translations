# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:23
translate spanish adrianarcadestartdate_93cbf6b1:

    # "I drive over to Adrian's house to pick her up, then she gives me directions to get to this arcade she wants to visit."
    "Conduzco hasta la casa de Adrian para recogerla, y luego ella me da indicaciones para llegar a la sala de juegos a la que quiere ir."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:25
translate spanish adrianarcadestartdate_ef349499:

    # "I drive over to Adrian's house and pick her up, then we head out to the arcade."
    "Conduzco hasta la casa de Adrian y la recojo, y luego nos dirigimos a la sala de juegos."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:30
translate spanish adrianarcadestartdate_049af941:

    # gg "Wow, look at this place! It's so retro and trashy."
    gg "¡Vaya, mira qué sitio! Es tan retro y cutre."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:31
translate spanish adrianarcadestartdate_ca89a42d:

    # gg "I love it!"
    gg "¡Me encanta!"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:32
translate spanish adrianarcadestartdate_1b8393bf:

    # pc "Is this like the business you want to start?"
    pc "¿Es esto como el negocio que quieres montar?"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:33
translate spanish adrianarcadestartdate_cb319d99:

    # gg "Hm, not really. I'm looking to appeal to a younger crowd, with newer games and private playing areas."
    gg "Mmm, la verdad es que no. Quiero atraer a un público más joven, con juegos más nuevos y zonas de juego privadas."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:34
translate spanish adrianarcadestartdate_1dc6627f:

    # gg "These are all old machines, pretty beat up too. I love them, but I doubt their business is booming here."
    gg "Todas estas máquinas son viejas, y además están bastante estropeadas. Me encantan, pero dudo que el negocio vaya viento en popa aquí."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:35
translate spanish adrianarcadestartdate_b342ddbc:

    # gg "Anyway..."
    gg "En fin..."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:36
translate spanish adrianarcadestartdate_ce26e6ca:

    # gg "Let's go play some games!"
    gg "¡Vamos a jugar un rato!"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:37
translate spanish adrianarcadestartdate_5d89bf80:

    # "We head over to the machines."
    "Nos dirigimos a las máquinas."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:44
translate spanish adrianarcadestartdate_fcc66601:

    # "We chat while we play games together."
    "Charlamos mientras jugamos juntos."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:51
translate spanish adrianarcadestartdate_aa98635a:

    # "It's fun just to hang out with her. She obviously loves this stuff."
    "Es divertido simplemente pasar el rato con ella. Es obvio que le encantan estas cosas."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:60
translate spanish adrianarcadestartdate_b0953d82:

    # gg "That was fun. You're pretty good at these old games."
    gg "Ha sido divertido. Se te dan bastante bien estos juegos antiguos."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:61
translate spanish adrianarcadestartdate_98d42c74:

    # pc "Thanks! I used to play these types of games with my dad as a kid all the time."
    pc "¡Gracias! De pequeña solía jugar a este tipo de juegos con mi padre todo el tiempo."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:62
translate spanish adrianarcadestartdate_fb8d8dab:

    # "After we get our fill, playing most of the games in the place several times, we're both ready to leave."
    "Después de hartarnos, jugando varias veces a la mayoría de los juegos del local, las dos estamos listas para irnos."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:66
translate spanish adrianarcadestartdate_96accbe9:

    # gg "That was fun!"
    gg "¡Ha sido divertido!"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:68
translate spanish adrianarcadestartdate_1e0d4722:

    # pc "Did you get the research you need?"
    pc "¿Has conseguido la información que necesitabas?"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:69
translate spanish adrianarcadestartdate_d081eccb:

    # gg "Yeah, I think so."
    gg "Sí, creo que sí."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:72
translate spanish adrianarcadestartdate_57656827:

    # gg "Want to take me home and research me now?"
    gg "¿Quieres llevarme a casa y buscar información sobre mí ahora?"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:73
translate spanish adrianarcadestartdate_82ba066c:

    # pc "That sounds fantastic."
    pc "Suena fantástico."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:79
translate spanish adrianarcadestartdate_05218083:

    # "We leave the arcade, then I drive her home and walk her up to her front door."
    "Salimos de la sala de juegos, luego la llevo a casa y la acompaño hasta la puerta de su casa."

