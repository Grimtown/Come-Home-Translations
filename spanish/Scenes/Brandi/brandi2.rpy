# game/Scenes/Brandi/brandi2.rpy:15
translate spanish brandi2_801610c4:

    # "It's Brandi. I press accept and answer the phone."
    "Es Brandi. Pulso aceptar y contesto la llamada."

# game/Scenes/Brandi/brandi2.rpy:17
translate spanish brandi2_bea5e8cb:

    # pc "Hello?"
    pc "¿Hola?"

# game/Scenes/Brandi/brandi2.rpy:20
translate spanish brandi2_d41d8cd9:

    # voice 'voices/brandi_hey2.mp3'
    voice 'voices/brandi_hey2.mp3'

# game/Scenes/Brandi/brandi2.rpy:21
translate spanish brandi2_5281a818:

    # fd "Hey, [pcname]."
    fd "Hola, [pcname]."

# game/Scenes/Brandi/brandi2.rpy:22
translate spanish brandi2_48df05b4:

    # fd "I was wondering if you wanted to go out for dinner with me tonight? My treat of course."
    fd "Me preguntaba si te apetecería salir a cenar conmigo esta noche. Yo invito, por supuesto."

# game/Scenes/Brandi/brandi2.rpy:23
translate spanish brandi2_95de9f02:

    # pc "You mean like a date?"
    pc "¿Te refieres a una cita?"

# game/Scenes/Brandi/brandi2.rpy:24
translate spanish brandi2_bc08406c:

    # fd "Well, yeah. Exactly like a date."
    fd "Bueno, sí. Exactamente como una cita."

# game/Scenes/Brandi/brandi2.rpy:25
translate spanish brandi2_c14c8905:

    # fd "Except my laptop will be there too and I'll be livestreaming and a few hundred people will be watching us."
    fd "Excepto que mi portátil también estará allí y lo retransmitiré en directo, y unos cientos de personas nos estarán viendo."

# game/Scenes/Brandi/brandi2.rpy:29
translate spanish brandi2_60b83ec3:

    # fd "Great!"
    fd "¡Genial!"

# game/Scenes/Brandi/brandi2.rpy:30
translate spanish brandi2_fcc3b2b6:

    # fd "You know Luigi's? The new Italian place? Could you meet me there?"
    fd "¿Conoces Luigi's? ¿El nuevo restaurante italiano? ¿Podrías quedar conmigo allí?"

# game/Scenes/Brandi/brandi2.rpy:31
translate spanish brandi2_06cea6b3:

    # pc "I'm on my way."
    pc "Voy de camino."

# game/Scenes/Brandi/brandi2.rpy:33
translate spanish brandi2_d41d8cd9_1:

    # voice 'voices/brandi_awesome2.mp3'
    voice 'voices/brandi_awesome2.mp3'

# game/Scenes/Brandi/brandi2.rpy:34
translate spanish brandi2_baf45d7c:

    # fd "Awesome. See you there!"
    fd "Genial. ¡Nos vemos allí!"

# game/Scenes/Brandi/brandi2.rpy:37
translate spanish brandi2_72628cc8:

    # fd "Aw dang."
    fd "Vaya, qué pena."

# game/Scenes/Brandi/brandi2.rpy:38
translate spanish brandi2_23254083:

    # fd "Oh well, give me a call if you change your mind. I usually eat out most every night."
    fd "Bueno, llámame si cambias de opinión. Suelo salir a cenar casi todas las noches."

# game/Scenes/Brandi/brandi2.rpy:39
translate spanish brandi2_5d94ae2f:

    # fd "It's kind of my job."
    fd "Es como mi trabajo."

# game/Scenes/Brandi/brandi2.rpy:40
translate spanish brandi2_63023601:

    # pc "Okay."
    pc "Vale."

# game/Scenes/Brandi/brandi2.rpy:41
translate spanish brandi2_21f428c4:

    # fd "See ya, [pcname]."
    fd "Nos vemos, [pcname]."

# game/Scenes/Brandi/brandi2.rpy:42
translate spanish brandi2_fc0e4cb5:

    # "With that, she hangs up."
    "Y con eso, cuelga."

# game/Scenes/Brandi/brandi2.rpy:43
translate spanish brandi2_b0060369:

    # "She seems nice, but I'm not all that interested in dating her with the internet always watching."
    "Parece simpática, pero no me interesa mucho salir con ella con todo el mundo mirando por Internet."

# game/Scenes/Brandi/brandi2.rpy:44
translate spanish brandi2_61234404:

    # "There are just other people I'd rather spend my time with."
    "Hay otras personas con las que prefiero pasar el rato."

# game/Scenes/Brandi/brandi2.rpy:54
translate spanish brandi2_7a261ee1:

    # "I pull up into the Luigi's parking lot and my phone buzzes again."
    "Aparco en el aparcamiento de Luigi's y mi teléfono vuelve a vibrar."

# game/Scenes/Brandi/brandi2.rpy:61
translate spanish brandi2_763b14c3:

    # "Looks like she's already here. I head inside."
    "Parece que ya está aquí. Entro."

# game/Scenes/Brandi/brandi2.rpy:64
translate spanish brandi2_4bde4e1d:

    # "She must have been watching for me, because as soon as I walk in, she jumps up from her table and rushes over towards me."
    "Debe de haberme estado esperando, porque en cuanto entro, se levanta de un salto de su mesa y corre hacia mí."

# game/Scenes/Brandi/brandi2.rpy:67
translate spanish brandi2_d67052d1:

    # "Then she wraps her arms around me and pulls me into a hug."
    "Luego me rodea con los brazos y me atrae hacia ella para darme un abrazo."

# game/Scenes/Brandi/brandi2.rpy:69
translate spanish brandi2_d41d8cd9_2:

    # voice 'voices/brandi_hey2.mp3'
    voice 'voices/brandi_hey2.mp3'

# game/Scenes/Brandi/brandi2.rpy:70
translate spanish brandi2_e3c46240:

    # fd "Hey, [pcname]. I'm so glad you came."
    fd "Hola, [pcname]. Me alegro mucho de que hayas venido."

# game/Scenes/Brandi/brandi2.rpy:73
translate spanish brandi2_7623cc69:

    # fd "The chat is already excited to see our first date."
    fd "El chat ya está emocionado por ver nuestra primera cita."

# game/Scenes/Brandi/brandi2.rpy:74
translate spanish brandi2_36036053:

    # fd "I know that this is a little weird having all those people watching us, but just pretend like they're not there okay?"
    fd "Sé que es un poco raro que toda esa gente nos esté mirando, pero haz como si no estuvieran ahí, ¿vale?"

# game/Scenes/Brandi/brandi2.rpy:75
translate spanish brandi2_63023601_1:

    # pc "Okay."
    pc "Vale."

# game/Scenes/Brandi/brandi2.rpy:76
translate spanish brandi2_50d36c3a:

    # fd "Cool, follow me."
    fd "Genial, sígueme."

# game/Scenes/Brandi/brandi2.rpy:78
translate spanish brandi2_5342c32e:

    # fd "Hey everybody, BurgerBuddy is here. Or [pcname], which we should probably call him from now on."
    fd "Hola a todos, BurgerBuddy está aquí. O [pcname], que probablemente deberíamos llamarle así a partir de ahora."

# game/Scenes/Brandi/brandi2.rpy:79
translate spanish brandi2_21079f98:

    # pc "Yes, I'd prefer that."
    pc "Sí, lo prefiero así."

# game/Scenes/Brandi/brandi2.rpy:80
translate spanish brandi2_66c11aab:

    # fd "Okay, let's order some food. I'm getting spaghetti and meatballs today. What do you like?"
    fd "Vale, pidamos algo de comer. Hoy voy a pedir espaguetis con albóndigas. ¿Qué te apetece?"

# game/Scenes/Brandi/brandi2.rpy:81
translate spanish brandi2_155c8f5e:

    # pc "Uh, I guess I'll have that too."
    pc "Eh, supongo que yo también pediré eso."

# game/Scenes/Brandi/brandi2.rpy:82
translate spanish brandi2_98b146f0:

    # fd "Good choice."
    fd "Buena elección."

# game/Scenes/Brandi/brandi2.rpy:83
translate spanish brandi2_beb3f8ca:

    # "The waiter comes and takes our order, then Brandi turns towards me sort of dramatically. She is putting on a show for sure."
    "El camarero viene a tomar nota y, entonces, Brandi se gira hacia mí de forma un poco dramática. Sin duda, está montando un espectáculo."

# game/Scenes/Brandi/brandi2.rpy:86
translate spanish brandi2_74f01f3b:

    # fd "So, first date. We should get to know each other a little better."
    fd "Bueno, primera cita. Deberíamos conocernos un poco mejor."

# game/Scenes/Brandi/brandi2.rpy:87
translate spanish brandi2_6f946235:

    # fd "It's always a little awkward at first. We've only talked a few times before, I don't really know you very well."
    fd "Siempre es un poco incómodo al principio. Solo hemos hablado unas cuantas veces antes, no te conozco muy bien."

# game/Scenes/Brandi/brandi2.rpy:88
translate spanish brandi2_76f35fc6:

    # fd "And you're a cute guy and I'm sitting so close to you."
    fd "Y eres un chico guapo y estoy sentada muy cerca de ti."

# game/Scenes/Brandi/brandi2.rpy:89
translate spanish brandi2_e86c12d0:

    # fd "So what should I talk about? What are good conversation topics for the first date?"
    fd "¿De qué debería hablar? ¿Qué temas de conversación son buenos para una primera cita?"

# game/Scenes/Brandi/brandi2.rpy:90
translate spanish brandi2_65ba2cc2:

    # fd "What do you think, chat? What should we talk about?"
    fd "¿Qué te parece, charlamos? ¿De qué hablamos?"

# game/Scenes/Brandi/brandi2.rpy:93
translate spanish brandi2_c16cea75:

    # "She leans in and looks closer at the screen."
    "Se inclina y mira más de cerca la pantalla."

# game/Scenes/Brandi/brandi2.rpy:94
translate spanish brandi2_14197c78:

    # fd "No, not that. Too heavy for a first date. Wow, no I'm not asking him that! Geez, guys!"
    fd "No, eso no. Demasiado serio para una primera cita. ¡Vaya, no, no le voy a preguntar eso! ¡Por Dios, chicos!"

# game/Scenes/Brandi/brandi2.rpy:95
translate spanish brandi2_7c433d80:

    # fd "Ah, there's a good one."
    fd "Ah, ahí hay uno bueno."

# game/Scenes/Brandi/brandi2.rpy:98
translate spanish brandi2_78389a04:

    # fd "BurgerChic suggests I ask if you have any brothers or sisters?"
    fd "BurgerChic sugiere que te pregunte si tienes hermanos o hermanas."

# game/Scenes/Brandi/brandi2.rpy:99
translate spanish brandi2_37eda2d6:

    # pc "No blood-related siblings, but there is Suzy, I guess. She's my [sister]."
    pc "No tengo hermanos de sangre, pero está Suzy, supongo. Es mi [sister]."

# game/Scenes/Brandi/brandi2.rpy:100
translate spanish brandi2_8266c6d6:

    # pc "What about you?"
    pc "¿Y tú?"

# game/Scenes/Brandi/brandi2.rpy:101
translate spanish brandi2_35c433bd:

    # fd "Oh yeah, I have two brothers and two sisters. "
    fd "Ah, sí, tengo dos hermanos y dos hermanas. "

# game/Scenes/Brandi/brandi2.rpy:102
translate spanish brandi2_2b1f61d6:

    # fd "They don't live here though. They all moved away after college, but I like Skyhill so I stuck around."
    fd "Aunque no viven aquí. Todos se mudaron después de la universidad, pero a mí me gusta Skyhill, así que me quedé."

# game/Scenes/Brandi/brandi2.rpy:105
translate spanish brandi2_0a955753:

    # fd "Do you have a job?"
    fd "¿Tienes trabajo?"

# game/Scenes/Brandi/brandi2.rpy:106
translate spanish brandi2_fce9f9b7:

    # pc "I do. I'm an assistant for an attorney."
    pc "Sí. Soy asistente de un abogado."

# game/Scenes/Brandi/brandi2.rpy:107
translate spanish brandi2_8844ef8a:

    # fd "Oh, so you're going to be a lawyer?"
    fd "Ah, ¿entonces vas a ser abogado?"

# game/Scenes/Brandi/brandi2.rpy:108
translate spanish brandi2_afbdac62:

    # pc "Well, no. I'm in school for quantum physics actually."
    pc "Bueno, no. En realidad estoy estudiando física cuántica."

# game/Scenes/Brandi/brandi2.rpy:109
translate spanish brandi2_04c1148e:

    # fd "Wow, that's impressive."
    fd "Vaya, eso es impresionante."

# game/Scenes/Brandi/brandi2.rpy:110
translate spanish brandi2_1de87a6b:

    # fd "I dropped out of high school and now I eat food in front of an audience for money."
    fd "Yo dejé el instituto y ahora me gano la vida comiendo delante de un público."

# game/Scenes/Brandi/brandi2.rpy:111
translate spanish brandi2_037690dc:

    # pc "Hey, whatever pays the bills."
    pc "Oye, lo que sea para pagar las facturas."

# game/Scenes/Brandi/brandi2.rpy:112
translate spanish brandi2_75eca7b6:

    # fd "Right! Somebody tell my mom that."
    fd "¡Exacto! Que se lo diga alguien a mi madre."

# game/Scenes/Brandi/brandi2.rpy:115
translate spanish brandi2_3adc15d4:

    # "The waiter brings out our food and we start digging in."
    "El camarero nos trae la comida y empezamos a comer."

# game/Scenes/Brandi/brandi2.rpy:116
translate spanish brandi2_bc981603:

    # fd "Since you're the guest, you get first taste."
    fd "Como eres el invitado, tú pruebas primero."

# game/Scenes/Brandi/brandi2.rpy:117
translate spanish brandi2_350435c4:

    # pc "Okay, sounds good to me."
    pc "Vale, por mí perfecto."

# game/Scenes/Brandi/brandi2.rpy:118
translate spanish brandi2_96c0c900:

    # fd "What do you think, [pcname]? Do you like it?"
    fd "¿Qué te parece, [pcname]? ¿Te gusta?"

# game/Scenes/Brandi/brandi2.rpy:119
translate spanish brandi2_efb02d33:

    # pc "Yeah it's pretty damn good."
    pc "Sí, está buenísimo."

# game/Scenes/Brandi/brandi2.rpy:120
translate spanish brandi2_f2d6f866:

    # fd "See? I love this place."
    fd "¿Ves? Me encanta este sitio."

# game/Scenes/Brandi/brandi2.rpy:123
translate spanish brandi2_add75b21:

    # fd "Now it's my turn."
    fd "Ahora me toca a mí."

# game/Scenes/Brandi/brandi2.rpy:124
translate spanish brandi2_d1a17c3f:

    # fd "I like to start with the balls."
    fd "Me gusta empezar por las bolas."

# game/Scenes/Brandi/brandi2.rpy:125
translate spanish brandi2_dcb21a7c:

    # fd "Just pop the whole thing in there and..."
    fd "Te lo metes todo en la boca y..."

# game/Scenes/Brandi/brandi2.rpy:128
translate spanish brandi2_b3f6951f:

    # fd "Delicious!"
    fd "¡Delicioso!"

# game/Scenes/Brandi/brandi2.rpy:129
translate spanish brandi2_36d64bd9:

    # "Time passes quickly while we eat and before long, we have spent nearly an hour chatting and we are both so full."
    "El tiempo pasa rápido mientras comemos y, en un abrir y cerrar de ojos, llevamos casi una hora charlando y los dos estamos llenos."

# game/Scenes/Brandi/brandi2.rpy:132
translate spanish brandi2_248b5030:

    # fd "Okay, one last question from chat, then we're going to head out."
    fd "Vale, una última pregunta del chat y luego nos vamos."

# game/Scenes/Brandi/brandi2.rpy:133
translate spanish brandi2_cc48f82b:

    # fd "No, I'm not asking him that."
    fd "No, no le voy a preguntar eso."

# game/Scenes/Brandi/brandi2.rpy:134
translate spanish brandi2_5360ee4b:

    # fd "Okay, that's a good one."
    fd "Vale, esa es buena."

# game/Scenes/Brandi/brandi2.rpy:135
translate spanish brandi2_85beb4d2:

    # fd "Where would you like this relationship to go?"
    fd "¿Hacia dónde te gustaría que fuera esta relación?"

# game/Scenes/Brandi/brandi2.rpy:140
translate spanish brandi2_c8eaa0d3:

    # fd "Haha! Straight to the point."
    fd "¡Jaja! Directo al grano."

# game/Scenes/Brandi/brandi2.rpy:141
translate spanish brandi2_e9e17cc6:

    # fd "Well, we will see. I like to let things build up a little before we get to that point."
    fd "Bueno, ya veremos. Me gusta dejar que las cosas maduren un poco antes de llegar a ese punto."

# game/Scenes/Brandi/brandi2.rpy:142
translate spanish brandi2_6930b345:

    # fd "But we are definitely heading in that direction."
    fd "Pero sin duda vamos en esa dirección."

# game/Scenes/Brandi/brandi2.rpy:146
translate spanish brandi2_6e80582d:

    # fd "I like that answer. The build-up is part of the fun."
    fd "Me gusta esa respuesta. El proceso es parte de la diversión."

# game/Scenes/Brandi/brandi2.rpy:147
translate spanish brandi2_01aec78f:

    # fd "We'll take it slow and see where it takes us."
    fd "Nos lo tomaremos con calma y veremos adónde nos lleva."

# game/Scenes/Brandi/brandi2.rpy:150
translate spanish brandi2_173c3c75:

    # fd "Okay guys, that's it for today. Remember to click Like and Subscribe if you're not already following me."
    fd "Vale, chicos, eso es todo por hoy. Recordad darle a «Me gusta» y suscribiros si aún no me seguís."

# game/Scenes/Brandi/brandi2.rpy:151
translate spanish brandi2_97f9ef0f:

    # fd "This was fun. I hope we'll be able to do it again sometime soon."
    fd "Ha sido divertido. Espero que podamos volver a hacerlo pronto."

# game/Scenes/Brandi/brandi2.rpy:152
translate spanish brandi2_7bb0c1c0:

    # fd "Love you guys! Bye!"
    fd "¡Os quiero, chicos! ¡Adiós!"

# game/Scenes/Brandi/brandi2.rpy:157
translate spanish brandi2_4e9c7ec4:

    # "She closes the laptop and then looks at me."
    "Cierra el portátil y luego me mira."

# game/Scenes/Brandi/brandi2.rpy:158
translate spanish brandi2_7a30d65f:

    # fd "I really did have a good time. I hope you did too."
    fd "De verdad lo he pasado muy bien. Espero que tú también."

# game/Scenes/Brandi/brandi2.rpy:161
translate spanish brandi2_d9c44974:

    # fd "Great! I'm glad."
    fd "¡Genial! Me alegro."

# game/Scenes/Brandi/brandi2.rpy:165
translate spanish brandi2_2545de2f:

    # fd "I get it. Really, I do."
    fd "Lo entiendo. De verdad, lo entiendo."

# game/Scenes/Brandi/brandi2.rpy:166
translate spanish brandi2_b23717c5:

    # fd "But this is part of who I am. I hope that you'll be okay with that."
    fd "Pero esto es parte de quien soy. Espero que te parezca bien."

# game/Scenes/Brandi/brandi2.rpy:167
translate spanish brandi2_ecd95542:

    # fd "If you're not, then we just won't be able to date, I'm sorry."
    fd "Si no es así, entonces no podremos salir juntos, lo siento."

# game/Scenes/Brandi/brandi2.rpy:172
translate spanish brandi2_c90abea0:

    # fd "Good, because I think that really went over well with the audience."
    fd "Bien, porque creo que eso ha tenido muy buena acogida entre el público."

# game/Scenes/Brandi/brandi2.rpy:173
translate spanish brandi2_6f7cc3ca:

    # fd "I got a bunch of new subscribers and the tips were coming in hard."
    fd "He conseguido un montón de nuevos suscriptores y las propinas no paraban de llegar."

# game/Scenes/Brandi/brandi2.rpy:174
translate spanish brandi2_67293cc6:

    # fd "People are curious to see where this relationship goes."
    fd "La gente tiene curiosidad por ver cómo evoluciona esta relación."

# game/Scenes/Brandi/brandi2.rpy:175
translate spanish brandi2_23d6be6d:

    # fd "So am I actually."
    fd "La verdad es que yo también."

# game/Scenes/Brandi/brandi2.rpy:177
translate spanish brandi2_625d8282:

    # fd "Okay then. Thanks for hanging out with me today."
    fd "De acuerdo, entonces. Gracias por pasar el rato conmigo hoy."

# game/Scenes/Brandi/brandi2.rpy:178
translate spanish brandi2_d3615a77:

    # fd "I'll go get the check. You can leave now."
    fd "Voy a pedir la cuenta. Ya te puedes ir."

# game/Scenes/Brandi/brandi2.rpy:181
translate spanish brandi2_6f831ce8:

    # "I get up and walk out. She doesn't say anything else to me."
    "Me levanto y salgo. Ella no me dice nada más."

# game/Scenes/Brandi/brandi2.rpy:182
translate spanish brandi2_1e44de24:

    # "Oh well. She is okay, but I don't like having an audience watching our whole relationship."
    "Bueno, qué le vamos a hacer. Ella está bien, pero no me gusta que haya gente observando toda nuestra relación."

# game/Scenes/Brandi/brandi2.rpy:183
translate spanish brandi2_2fa87c07:

    # "There are other people out there I'm more interested in."
    "Hay otras personas que me interesan más."

# game/Scenes/Brandi/brandi2.rpy:185
translate spanish brandi2_fbe3fcb3:

    # "I go out to the car and drive away."
    "Salgo al coche y me voy."

# game/Scenes/Brandi/brandi2.rpy:189
translate spanish brandi2_0da34d09:

    # fd "Okay, I'll go take care of the check real quick and we can head out."
    fd "Vale, voy a pagar la cuenta rapidito y nos podemos ir."

# game/Scenes/Brandi/brandi2.rpy:192
translate spanish brandi2_76db71da:

    # fd "I appreciate you being chivalrous. I actually find that extremely attractive in a guy."
    fd "Te agradezco que seas tan caballeroso. De hecho, eso me parece muy atractivo en un chico."

# game/Scenes/Brandi/brandi2.rpy:193
translate spanish brandi2_79a749bb:

    # fd "But it's a business expense for me, so I get a big discount and a tax break."
    fd "Pero para mí es un gasto de empresa, así que me hacen un gran descuento y me deduzco los impuestos."

# game/Scenes/Brandi/brandi2.rpy:194
translate spanish brandi2_91244ab3:

    # fd "So don't worry about it at all."
    fd "Así que no te preocupes por nada."

# game/Scenes/Brandi/brandi2.rpy:195
translate spanish brandi2_e4ebd2ba:

    # pc "Okay, if you say so."
    pc "Vale, si tú lo dices."

# game/Scenes/Brandi/brandi2.rpy:198
translate spanish brandi2_edaf03df:

    # "She goes over to the counter to pay the bill, then comes back to the table."
    "Se dirige a la caja para pagar la cuenta y luego vuelve a la mesa."

# game/Scenes/Brandi/brandi2.rpy:202
translate spanish brandi2_06e3ffe9:

    # fd "Seriously, [pcname]. I had a great time."
    fd "En serio, [pcname]. Me lo he pasado muy bien."

# game/Scenes/Brandi/brandi2.rpy:203
translate spanish brandi2_bf746f0d:

    # fd "I'm really looking forward to our next date."
    fd "Tengo muchas ganas de que llegue nuestra próxima cita."

# game/Scenes/Brandi/brandi2.rpy:206
translate spanish brandi2_fbd35383:

    # fd "Sorry if I'm a bit of a tease. I just want to take things slow."
    fd "Perdona si soy un poco provocadora. Es que quiero ir poco a poco."

# game/Scenes/Brandi/brandi2.rpy:207
translate spanish brandi2_8958b08a:

    # fd "But if we keep going on dates, I promise that we'll get more intimate in the future, okay?"
    fd "Pero si seguimos saliendo, te prometo que nos volveremos más íntimos en el futuro, ¿vale?"

# game/Scenes/Brandi/brandi2.rpy:208
translate spanish brandi2_19e5a49d:

    # pc "That's fine Brandi. No rush. I'm enjoying just spending time with you."
