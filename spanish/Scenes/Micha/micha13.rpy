# game/Scenes/Micha/micha13.rpy:10
translate spanish micha13_66a911ed:

    # "When I get to the counselor's office, I'm surprised to see Gertrude behind the counter instead of Mi-Cha."
    "Cuando llego a la oficina de la consejera, me sorprende ver a Gertrude detrás del mostrador en lugar de a Mi-Cha."

# game/Scenes/Micha/micha13.rpy:11
translate spanish micha13_51f359cb:

    # sc "Good morning, [pcname]. If you're here for a counseling session, I'm sorry. I have to work reception today."
    sc "Buenos días, [pcname]. Si has venido para una sesión de asesoramiento, lo siento. Hoy tengo que trabajar en recepción."

# game/Scenes/Micha/micha13.rpy:12
translate spanish micha13_320f7ecc:

    # pc "Where's Mi-Cha?"
    pc "¿Dónde está Mi-Cha?"

# game/Scenes/Micha/micha13.rpy:13
translate spanish micha13_f822911c:

    # sc "She called this morning saying she couldn't come in for some reason. She sounded upset."
    sc "Llamó esta mañana diciendo que no podía venir por alguna razón. Parecía molesta."

# game/Scenes/Micha/micha13.rpy:14
translate spanish micha13_d6ed663d:

    # sc "If you have time, maybe you could go check on her? I know you two have become friends."
    sc "Si tienes tiempo, ¿podrías ir a ver cómo está? Sé que os habéis hecho amigos."

# game/Scenes/Micha/micha13.rpy:15
translate spanish micha13_477e82cd:

    # pc "Yeah, I think I have a little time before class. I'll go do that."
    pc "Sí, creo que tengo un poco de tiempo antes de clase. Iré a hacerlo."

# game/Scenes/Micha/micha13.rpy:18
translate spanish micha13_cfda0a84:

    # "I leave the counselor's office, walk over to the dorms, and make my way up to Mi-Cha's door."
    "Salgo de la oficina del orientador, camino hacia las residencias y me dirijo a la puerta de Mi-Cha."

# game/Scenes/Micha/micha13.rpy:22
translate spanish micha13_90464c94:

    # "She answers after a couple of knocks."
    "Me abre tras unos cuantos golpes."

# game/Scenes/Micha/micha13.rpy:23
translate spanish micha13_94a711d9:

    # mc "Oh, [pcname]! Why are you here?"
    mc "¡Oh, [pcname]! ¿Qué haces aquí?"

# game/Scenes/Micha/micha13.rpy:24
translate spanish micha13_36eedc65:

    # pc "Gertrude asked me to come check on you. She said you called in. Are you sick?"
    pc "Gertrude me ha pedido que viniera a ver cómo estabas. Me ha dicho que habías llamado. ¿Estás enferma?"

# game/Scenes/Micha/micha13.rpy:25
translate spanish micha13_2e46b23a:

    # mc "No, I'm not sick."
    mc "No, no estoy enferma."

# game/Scenes/Micha/micha13.rpy:26
translate spanish micha13_cb45e08c:

    # pc "Well, what's going on?"
    pc "Bueno, ¿qué pasa entonces?"

# game/Scenes/Micha/micha13.rpy:29
translate spanish micha13_98c909b0:

    # "I follow her inside and we sit on her bed."
    "La sigo al interior y nos sentamos en su cama."

# game/Scenes/Micha/micha13.rpy:30
translate spanish micha13_2f43efba:

    # mc "I argued with my parents last night. They told me to quit dance class. They say that it interferes with my studies."
    mc "Anoche discutí con mis padres. Me han dicho que deje las clases de baile. Dicen que interfiere con mis estudios."

# game/Scenes/Micha/micha13.rpy:31
translate spanish micha13_6282a1b7:

    # pc "But you like dancing."
    pc "Pero te gusta bailar."

# game/Scenes/Micha/micha13.rpy:34
translate spanish micha13_44899e27:

    # mc "I love dancing. And I have a performance soon that I was very much looking forward to."
    mc "Me encanta bailar. Y pronto tengo una actuación que esperaba con muchas ganas."

# game/Scenes/Micha/micha13.rpy:35
translate spanish micha13_4624f9be:

    # mc "But they say that I have to stop."
    mc "Pero dicen que tengo que dejarlo."

# game/Scenes/Micha/micha13.rpy:36
translate spanish micha13_ff3c6bab:

    # pc "So what?"
    pc "¿Y qué?"

# game/Scenes/Micha/micha13.rpy:37
translate spanish micha13_f0ac6ad2:

    # mc "I can't just not do what they say."
    mc "No puedo simplemente no hacer lo que dicen."

# game/Scenes/Micha/micha13.rpy:40
translate spanish micha13_23d549c1:

    # pc "But I want you to dance."
    pc "Pero yo quiero que bailes."

# game/Scenes/Micha/micha13.rpy:41
translate spanish micha13_81709362:

    # mc "You do?"
    mc "¿De verdad?"

# game/Scenes/Micha/micha13.rpy:42
translate spanish micha13_6dba6230:

    # pc "Yes."
    pc "Sí."

# game/Scenes/Micha/micha13.rpy:43
translate spanish micha13_27a4c741:

    # mc "Are you telling me to?"
    mc "¿Me estás diciendo que lo haga?"

# game/Scenes/Micha/micha13.rpy:44
translate spanish micha13_f43da382:

    # pc "Yes, Mi-Cha. I'm telling you to dance."
    pc "Sí, Mi-Cha. Te estoy diciendo que bailes."

# game/Scenes/Micha/micha13.rpy:49
translate spanish micha13_d41d8cd9:

    # voice 'voices/micha_yessir.mp3'
    voice 'voices/micha_yessir.mp3'

# game/Scenes/Micha/micha13.rpy:50
translate spanish micha13_620baac7:

    # mc "Yes, [mcsir]."
    mc "Sí, [mcsir]."

# game/Scenes/Micha/micha13.rpy:51
translate spanish micha13_929f424d:

    # pc "So you will?"
    pc "¿Entonces lo harás?"

# game/Scenes/Micha/micha13.rpy:54
translate spanish micha13_d41d8cd9_1:

    # voice 'voices/micha_yessir.mp3'
    voice 'voices/micha_yessir.mp3'

# game/Scenes/Micha/micha13.rpy:55
translate spanish micha13_620baac7_1:

    # mc "Yes, [mcsir]."
    mc "Sí, [mcsir]."

# game/Scenes/Micha/micha13.rpy:56
translate spanish micha13_536da0ad:

    # mc "I will keep dancing. For you."
    mc "Seguiré bailando. Por ti."

# game/Scenes/Micha/micha13.rpy:57
translate spanish micha13_f07574ec:

    # pc "Good."
    pc "Bien."

# game/Scenes/Micha/micha13.rpy:61
translate spanish micha13_d41d8cd9_2:

    # voice 'voices/micha_thankyou1.mp3'
    voice 'voices/micha_thankyou1.mp3'

# game/Scenes/Micha/micha13.rpy:62
translate spanish micha13_5b61e929:

    # mc "Thank you, [pcname]."
    mc "Gracias, [pcname]."

# game/Scenes/Micha/micha13.rpy:63
translate spanish micha13_e3b6df4e:

    # pc "Do you feel better now?"
    pc "¿Te sientes mejor ahora?"

# game/Scenes/Micha/micha13.rpy:64
translate spanish micha13_c324b928:

    # mc "Yes. I feel much better now."
    mc "Sí. Ahora me siento mucho mejor."

# game/Scenes/Micha/micha13.rpy:65
translate spanish micha13_63023601:

    # pc "Okay."
    pc "Vale."

# game/Scenes/Micha/micha13.rpy:66
translate spanish micha13_c98760d6:

    # mc "I'll get dressed and go to the office."
    mc "Me voy a vestir y me voy a la oficina."

# game/Scenes/Micha/micha13.rpy:70
translate spanish micha13_d41d8cd9_3:

    # voice 'voices/micha_imsorry2.mp3'
    voice 'voices/micha_imsorry2.mp3'

# game/Scenes/Micha/micha13.rpy:71
translate spanish micha13_5fbcf7dd:

    # mc "I'm sorry you had to see me like this. In my pajamas with no makeup."
    mc "Siento que hayas tenido que verme así. En pijama y sin maquillaje."

# game/Scenes/Micha/micha13.rpy:72
translate spanish micha13_57c13e1f:

    # pc "Don't be silly. You're gorgeous."
    pc "No seas tonto. Estás preciosa."

# game/Scenes/Micha/micha13.rpy:75
translate spanish micha13_d41d8cd9_4:

    # voice 'voices/micha_thankyousir2.mp3'
    voice 'voices/micha_thankyousir2.mp3'

# game/Scenes/Micha/micha13.rpy:76
translate spanish micha13_b00529b9:

    # mc "Thank you, [mcsir]."
    mc "Gracias, [mcsir]."

# game/Scenes/Micha/micha13.rpy:79
translate spanish micha13_80adb898:

    # "I kiss her goodbye."
    "Le doy un beso de despedida."

# game/Scenes/Micha/micha13.rpy:80
translate spanish micha13_bed52260:

    # "If I had time, I'd do more."
    "Si tuviera tiempo, haría más."

# game/Scenes/Micha/micha13.rpy:83
translate spanish micha13_1a383b4b:

    # "But I have to get to class, so we pull apart and I tell her goodbye."
    "Pero tengo que ir a clase, así que nos separamos y me despido de ella."

