# game/Scenes/Mari/mari0.rpy:13
translate spanish mari0_268d9953:

    # "After about five minutes, a young woman with beautiful curly hair and an even prettier smile walks up with my order."
    "Al cabo de unos cinco minutos, una joven con un precioso pelo rizado y una sonrisa aún más bonita se acerca con mi pedido."

# game/Scenes/Mari/mari0.rpy:14
translate spanish mari0_61ae3800:

    # fr "Hey there. This must be yours."
    fr "Hola. Esto debe de ser para ti."

# game/Scenes/Mari/mari0.rpy:16
translate spanish mari0_d41d8cd9:

    # voice 'voices/mari_immariwaitress.mp3'
    voice 'voices/mari_immariwaitress.mp3'

# game/Scenes/Mari/mari0.rpy:17
translate spanish mari0_83cd92ec:

    # fr "I'm Mari. I'll be your waitress today."
    fr "Soy Mari. Hoy seré tu camarera."

# game/Scenes/Mari/mari0.rpy:18
translate spanish mari0_0a82c299:

    # fr "You just let me know if you need anything else."
    fr "Si necesitas algo más, solo tienes que decírmelo."

# game/Scenes/Mari/mari0.rpy:19
translate spanish mari0_f711eed2:

    # "She gives me a smile and puts the food down on the table."
    "Me sonríe y deja la comida sobre la mesa."

# game/Scenes/Mari/mari0.rpy:23
translate spanish mari0_84e54e6e:

    # "She blushes a bit and playfully slaps my shoulder."
    "Se sonroja un poco y me da una palmada juguetona en el hombro."

# game/Scenes/Mari/mari0.rpy:24
translate spanish mari0_967f0281:

    # fr "You're just a charmer, aren't you?"
    fr "Eres todo un encanto, ¿verdad?"

# game/Scenes/Mari/mari0.rpy:27
translate spanish mari0_d41d8cd9_1:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari0.rpy:28
translate spanish mari0_9af4e82f:

    # fr "Sure thing!"
    fr "¡Claro que sí!"

# game/Scenes/Mari/mari0.rpy:31
translate spanish mari0_d41d8cd9_2:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari0.rpy:32
translate spanish mari0_22159de4:

    # fr "Sure thing! I'll bring it right out."
    fr "¡Claro que sí! Te lo traigo enseguida."

# game/Scenes/Mari/mari0.rpy:33
translate spanish mari0_55ee1584:

    # "She runs to the back and gets the ketchup, then quickly returns with it."
    "Corre hacia la trastienda y coge el ketchup, y luego vuelve rápidamente con él."

# game/Scenes/Mari/mari0.rpy:34
translate spanish mari0_fe5173b6:

    # fr "Just give me a holler if I can do anything else for you."
    fr "Avísame si puedo hacer algo más por ti."

# game/Scenes/Mari/mari0.rpy:37
translate spanish mari0_d0ec727b:

    # "She walks over to a nearby table, pulls out a rag, and starts wiping it down, bending over just enough to give me a good view of her ass."
    "Se acerca a una mesa cercana, saca un trapo y empieza a limpiarla, inclinándose lo justo para que pueda ver bien su culo."

# game/Scenes/Mari/mari0.rpy:40
translate spanish mari0_8458142b:

    # "And damn, that's a nice ass."
    "Y joder, qué buen culo."

# game/Scenes/Mari/mari0.rpy:43
translate spanish mari0_a58a4782:

    # "I eat my food and Mari returns a couple more times to give me a refill on my drink."
    "Me como la comida y Mari vuelve un par de veces más para rellenarme la bebida."

# game/Scenes/Mari/mari0.rpy:46
translate spanish mari0_cc46d500:

    # "Then when I'm finished, I stand up and give her a smile and a wave."
    "Luego, cuando termino, me levanto y le dedico una sonrisa y un saludo con la mano."

# game/Scenes/Mari/mari0.rpy:49
translate spanish mari0_d41d8cd9_3:

    # voice 'voices/mari_thanksgoodnight.mp3'
    voice 'voices/mari_thanksgoodnight.mp3'

# game/Scenes/Mari/mari0.rpy:50
translate spanish mari0_8fafd7cf:

    # fr "Thanks for coming in. You have a good night."
    fr "Gracias por venir. Que pases buena noche."

# game/Scenes/Mari/mari0.rpy:53
translate spanish marifirsttip_1c31faa0:

    # "I place $5 on the table before I leave."
    "Dejo 5 dólares sobre la mesa antes de irme."

# game/Scenes/Mari/mari0.rpy:55
translate spanish marifirsttip_01e672c5:

    # "I head back out to the car."
    "Vuelvo al coche."

