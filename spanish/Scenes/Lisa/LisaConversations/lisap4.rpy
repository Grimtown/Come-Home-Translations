# game/Scenes/Lisa/LisaConversations/lisap4.rpy:10
translate spanish lisap4_c5b343c2:

    # sp "I think both of us were a little hesitant."
    sp "Creo que los dos estábamos un poco indecisos."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:12
translate spanish lisap4_8bbe7e94:

    # sp "I wasn't sure I wanted to get married again, after Suzy's dad."
    sp "No estaba segura de querer volver a casarme, después del padre de Suzy."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:13
translate spanish lisap4_f402bb2b:

    # sp "I learned a lot from that marriage. When I got married to him, I gave up a lot of myself."
    sp "Aprendí mucho de ese matrimonio. Cuando me casé con él, renuncié a gran parte de mí misma."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:14
translate spanish lisap4_963f214f:

    # sp "I wouldn't do that again, unless it was somebody I trusted implicitly."
    sp "No volvería a hacerlo, a menos que fuera con alguien en quien confiara ciegamente."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:15
translate spanish lisap4_d73c4458:

    # sp "I never really got to that level of trust with your father."
    sp "Nunca llegué a alcanzar ese nivel de confianza con tu padre."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:17
translate spanish lisap4_e31a4356:

    # sp "I think we both know why now."
    sp "Creo que ahora las dos sabemos por qué."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:18
translate spanish lisap4_e46000fe:

    # sp "He always had this thing holding him back from dedicating himself 100 percent to our relationship."
    sp "Siempre había algo que le impedía dedicarse al cien por cien a nuestra relación."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:20
translate spanish lisap4_b9625231:

    # sp "I felt that from him. I always have."
    sp "Lo notaba en él. Siempre lo he notado."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:21
translate spanish lisap4_0cac6017:

    # pc "I didn't realize things were that bad."
    pc "No me di cuenta de que las cosas estaban tan mal."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:23
translate spanish lisap4_0b14ac36:

    # sp "Oh, they weren't bad. I was happy. Our relationship worked."
    sp "Oh, no estaban mal. Yo era feliz. Nuestra relación funcionaba."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:25
translate spanish lisap4_c350f751:

    # sp "At least, I thought it did. It did for me."
    sp "Al menos, eso creía yo. Para mí, sí funcionaba."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:27
translate spanish lisap4_3fb6fc56:

    # sp "But I guess I couldn't compete with your mother."
    sp "Pero supongo que no podía competir con tu madre."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:28
translate spanish lisap4_26839154:

    # pc "You shouldn't have to."
    pc "No deberías tener que hacerlo."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:30
translate spanish lisap4_caaf8bf7:

    # sp "You're right. I shouldn't."
    sp "Tienes razón. No debería."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:31
translate spanish lisap4_993d1f35:

    # sp "Thanks, [pcname]."
    sp "Gracias, [pcname]."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:32
translate spanish lisap4_9cc5fed8:

    # pc "Would you ever get married again though?"
    pc "¿Te volverías a casar alguna vez?"

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:34
translate spanish lisap4_49159893:

    # sp "If I ever found somebody I trusted completely... sure."
    sp "Si alguna vez encontrara a alguien en quien confiara plenamente... claro."

# game/Scenes/Lisa/LisaConversations/lisap4.rpy:36
translate spanish lisap4_0d37b2f1:

    # sp "I'm not sure a man like that exists though."
    sp "Aunque no estoy segura de que exista un hombre así."

