# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:25
translate chinese izzymoviedatestart_cce13d6e:

    # gl "Hey Twig. Ready to go see this movie?"
    gl "嘿，Twig。准备去看电影了吗？"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:26
translate chinese izzymoviedatestart_49d1b26a:

    # pc "Sure. Should be fun."
    pc "当然。应该挺好玩的。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:27
translate chinese izzymoviedatestart_481be106:

    # gl "Yeah. I need to get out of the damn house for a while, that's for sure."
    gl "是啊。我确实得从这该死的家里出去透透气。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:28
translate chinese izzymoviedatestart_5b0e3d1a:

    # pc "Well, you look nice."
    pc "嗯，你看起来挺好看的。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:29
translate chinese izzymoviedatestart_ddae2ca0:

    # gl "Thanks Twig. I put on a shirt, just for you."
    gl "谢谢，Twig。我特意为你穿了件衬衫。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:30
translate chinese izzymoviedatestart_0ee370cd:

    # pc "Aw, you shouldn't have."
    pc "哎呀，你真不用这么大费周章。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:33
translate chinese izzymoviedatestart_d41d8cd9:

    # voice 'voices/izzy_whatsup.mp3'
    voice 'voices/izzy_whatsup.mp3'

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:34
translate chinese izzymoviedatestart_01687529:

    # gl "What's up, Twig. Let's go see this movie."
    gl "怎么了，Twig。咱们去看看这部电影吧。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:38
translate chinese izzymoviedatestart_00bfd309:

    # gl "This is kinda fun actually. Been a while since I've gone to the movies."
    gl "其实挺有意思的。好久没去电影院了。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:39
translate chinese izzymoviedatestart_3746eb4d:

    # gl "Except taking my brothers to see Shrek and shit."
    gl "除了带我兄弟们去看《怪物史莱克》之类的。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:40
translate chinese izzymoviedatestart_fefe72bc:

    # gl "Not on a date or anything, anyways."
    gl "反正不是约会什么的。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:41
translate chinese izzymoviedatestart_a14fd1a7:

    # pc "So it is a date?"
    pc "所以这是约会吗？"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:43
translate chinese izzymoviedatestart_92636968:

    # gl "You want to date me? Like, seriously?"
    gl "你想跟我约会？是认真的吗？"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:46
translate chinese izzymoviedatestart_4e0b05f2:

    # gl "You know I'm not into the whole monogamy thing though, right?"
    gl "你知道我不太接受一夫一妻制吧？"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:47
translate chinese izzymoviedatestart_e9418800:

    # pc "I'm not really either."
    pc "我其实也不太接受。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:48
translate chinese izzymoviedatestart_4dabe89e:

    # gl "So you keep fucking who you want and I keep fucking who I want, but we also go on dates and fuck each other?"
    gl "所以你继续和你想上的人上床，我也继续和我想上的人上床，但我们也会约会并上床？"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:49
translate chinese izzymoviedatestart_0aa625bf:

    # pc "I mean, that sounds cool to me."
    pc "我觉得这听起来挺酷的。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:51
translate chinese izzymoviedatestart_0933ffde:

    # gl "Me too. Let's just keep it simple. As long as you're not trying to chain me down, I'm happy with the situation."
    gl "我也是。咱们就简单点吧。只要你不试图束缚我，我对这种状况很满意。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:52
translate chinese izzymoviedatestart_2843a332:

    # gl "The moment you tell me I can't do what I want to do, we'll have problems."
    gl "一旦你告诉我不能做我想做的事，我们就会有问题。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:53
translate chinese izzymoviedatestart_0d652c29:

    # pc "I wouldn't do that."
    pc "我不会那样做的。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:55
translate chinese izzymoviedatestart_2e09af75:

    # gl "Cool. We can date then. We're dating."
    gl "好。那我们可以约会了。我们正在约会。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:56
translate chinese izzymoviedatestart_9900eca8:

    # pc "Cool."
    pc "好。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:60
translate chinese izzymoviedatestart_208b86a1:

    # gl "Cool, that's all I want. You fuck who you want, and I fuck who I want."
    gl "好，这就是我想要的。你和谁上床都行，我也和谁上床都行。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:61
translate chinese izzymoviedatestart_92ed55df:

    # gl "And if we want to go see a movie, or grab dinner together, we don't have to call it dating."
    gl "如果我们想去看电影，或者一起吃个晚饭，也不必非得叫它约会。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:62
translate chinese izzymoviedatestart_df196688:

    # gl "We're just watching a movie."
    gl "我们只是看场电影。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:63
translate chinese izzymoviedatestart_7acad64a:

    # pc "Right."
    pc "对。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:64
translate chinese izzymoviedatestart_3dff977c:

    # gl "Cool."
    gl "好。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:68
translate chinese izzymoviedatestart_62737a7b:

    # "We find a seat in the back and chat a bit until the movie starts."
    "我们在后排找了座位，聊了一会儿直到电影开始。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:73
translate chinese izzymoviedatestart_56f38f5f:

    # "The movie starts and we go quiet."
    "电影开始后，我们便安静下来。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:75
translate chinese izzymoviedatestart_4c04d5aa:

    # "It's a fun movie and Izzy laughs a lot."
    "这是一部很有趣的电影，伊兹笑个不停。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:77
translate chinese izzymoviedatestart_0edfdae0:

    # "When it ends, she turns to me."
    "电影结束时，她转过头看着我。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:78
translate chinese izzymoviedatestart_4746d3c6:

    # gl "That was pretty damn good, huh?"
    gl "这片子真他妈的棒，对吧？"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:79
translate chinese izzymoviedatestart_5867f7ce:

    # "We hang out and chat some while the credits roll."
    "片尾字幕滚动时，我们还待在一起聊了一会儿。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:83
translate chinese izzymoviedatestart_28be3ae8:

    # "When the credits end, I drive Izzy back to her house."
    "字幕结束后，我开车送伊兹回她家。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:84
translate chinese izzymoviedatestart_2a5b6b89:

    # "I pull into her driveway and she turns to look at me."
    "我把车开进她家车道，她转过头看着我。"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:86
translate chinese izzymoviedatestart_6dd86d8c:

    # gl "So, do you want to come inside and fuck a little?"
    gl "“所以，你想进来干一发吗？”"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:92
translate chinese izzymoviedatestart_dcbc938c:

    # gl "Cool, let's go."
    gl "“行啊，走吧。”"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:95
translate chinese izzymoviedatestart_dcbc938c_1:

    # gl "Cool, let's go."
    gl "“行啊，走吧。”"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:98
translate chinese izzymoviedatestart_9a2ffc1c:

    # gl "Damn, fingers it is then. Thanks for the movie anyway, Twig. See ya later."
    gl "“见鬼，那只能用手指了。不过还是谢谢你请我看电影，Twig。回头见。”"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:99
translate chinese izzymoviedatestart_63fc4244:

    # pc "Bye, Izzy."
    pc "“再见，伊兹。”"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:102
translate chinese izzymoviedatestart_8b93ebfd:

    # "I wait until she gets out and walks into her house before I drive away."
    "我等到她下车走进屋里，才开车离开。"

