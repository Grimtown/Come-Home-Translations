# game/Scenes/Update20/u20a.rpy:11
translate spanish u20a_96c9481d:

    # "Then the lights kick on and the door opens."
    "Entonces se encienden las luces y se abre la puerta."

# game/Scenes/Update20/u20a.rpy:14
translate spanish u20a_45da60e7:

    # wt "Finally, you're back. Took you long enough."
    wt "Por fin has vuelto. Has tardado bastante."

# game/Scenes/Update20/u20a.rpy:15
translate spanish u20a_fd9e8f88:

    # wt "I really thought I might be going to jail!"
    wt "¡De verdad pensé que me iban a meter en la cárcel!"

# game/Scenes/Update20/u20a.rpy:18
translate spanish u20a_a33db221:

    # pc "How long have I been gone?"
    pc "¿Cuánto tiempo he estado fuera?"

# game/Scenes/Update20/u20a.rpy:19
translate spanish u20a_e000eef8:

    # wt "Thirty days."
    wt "Treinta días."

# game/Scenes/Update20/u20a.rpy:22
translate spanish u20a_8d8b1bd7:

    # pc "THIRTY!?"
    pc "¡¿TREINTA?!"

# game/Scenes/Update20/u20a.rpy:23
translate spanish u20a_d92a0cb0:

    # wt "Yes. It's been a difficult time for me as well."
    wt "Sí. También ha sido un tiempo difícil para mí."

# game/Scenes/Update20/u20a.rpy:27
translate spanish u20a_c77aa2a4:

    # wt "Lisa has been very persistent and is nearing her breaking point. I suspect she may involve the police soon."
    wt "Lisa ha sido muy insistente y está a punto de llegar a su límite. Sospecho que pronto podría involucrar a la policía."

# game/Scenes/Update20/u20a.rpy:28
translate spanish u20a_c1e86e55:

    # wt "She thinks I killed both you and your dad."
    wt "Cree que maté tanto a ti como a tu padre."

# game/Scenes/Update20/u20a.rpy:32
translate spanish u20a_9a9b3000:

    # wt "Suzy and Tammy have been after me every day. I don't think I could hold them off from calling the police for much longer."
    wt "Suzy y Tammy me han estado acosando todos los días. No creo que pueda evitar que llamen a la policía por mucho más tiempo."

# game/Scenes/Update20/u20a.rpy:33
translate spanish u20a_24d0649b:

    # wt "They brought in Suzy's mom too, Lisa."
    wt "También han metido en esto a la madre de Suzy, Lisa."

# game/Scenes/Update20/u20a.rpy:34
translate spanish u20a_c0b726db:

    # wt "They are not happy with me. Tammy has threatened me with physical violence. I'd prefer to avoid that."
    wt "No están contentas conmigo. Tammy me ha amenazado con violencia física. Preferiría evitar eso."

# game/Scenes/Update20/u20a.rpy:38
