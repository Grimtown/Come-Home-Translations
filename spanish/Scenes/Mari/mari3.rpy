    # voice 'voices/mari_heythere.mp3'
    voice 'voices/mari_heythere.mp3'

# game/Scenes/Mari/mari3.rpy:13
translate spanish mari3_5fec8fcf:

    # fr "Hey there, [pcname]. How are you today?"
    fr "Hola, [pcname]. ¿Cómo estás hoy?"

# game/Scenes/Mari/mari3.rpy:14
translate spanish mari3_b835b9eb:

    # pc "I'm doing great, how's my favorite waitress?"
    pc "Estoy genial, ¿y mi camarera favorita?"

# game/Scenes/Mari/mari3.rpy:15
translate spanish mari3_334e62bd:

    # fr "Much better now that her favorite customer is here."
    fr "Mucho mejor ahora que su cliente favorito está aquí."

# game/Scenes/Mari/mari3.rpy:20
translate spanish mari3_747e36cd:

    # pc "Mari, there was something I wanted to ask you."
    pc "Mari, hay algo que quería preguntarte."

# game/Scenes/Mari/mari3.rpy:21
translate spanish mari3_96d48818:

    # fr "Ask away."
    fr "Adelante."

# game/Scenes/Mari/mari3.rpy:22
translate spanish mari3_05be9386:

    # pc "Would you want to go out on a date with me sometime?"
    pc "¿Te gustaría salir conmigo alguna vez?"

# game/Scenes/Mari/mari3.rpy:25
translate spanish mari3_d41d8cd9_1:

    # voice 'voices/mari_idloveto.mp3'
    voice 'voices/mari_idloveto.mp3'

# game/Scenes/Mari/mari3.rpy:26
translate spanish mari3_ad1c3ebd:

    # fr "Really? I'd love to."
    fr "¿En serio? Me encantaría."

# game/Scenes/Mari/mari3.rpy:27
translate spanish mari3_1da24e01:

    # pc "Awesome."
    pc "Genial."

# game/Scenes/Mari/mari3.rpy:29
translate spanish mari3_008e9d39:

    # fr "I don't get to go out on dates very often, and I do really like you."
    fr "No suelo salir mucho, y me gustas de verdad."

# game/Scenes/Mari/mari3.rpy:30
translate spanish mari3_098a6e78:

    # fr "I'm busy a lot, but I'll give you my phone number and maybe we could go out in the evening on a weekend sometime?"
    fr "Estoy muy ocupada, pero te daré mi número de teléfono y quizá podamos salir alguna tarde de fin de semana."

# game/Scenes/Mari/mari3.rpy:31
translate spanish mari3_d2954fc0:

    # pc "That sounds great."
    pc "Suena genial."

# game/Scenes/Mari/mari3.rpy:32
translate spanish mari3_52d8f6ae:

    # fr "Oh I'm so excited."
    fr "Oh, qué emoción."

# game/Scenes/Mari/mari3.rpy:34
translate spanish mari3_e7685f1d:

    # fr "Here's my phone number."
    fr "Aquí tienes mi número de teléfono."

# game/Scenes/Mari/mari3.rpy:36
translate spanish mari3_639d3c6f:

    # fr "You can call me any time, but I won't be able to talk while I'm working, and I work a lot!"
    fr "Puedes llamarme cuando quieras, pero no podré hablar mientras esté trabajando, ¡y trabajo mucho!"

# game/Scenes/Mari/mari3.rpy:37
translate spanish mari3_73bf0030:

    # pc "I'll definitely give you a call sometime."
    pc "Te llamaré sin falta algún día."

# game/Scenes/Mari/mari3.rpy:38
translate spanish mari3_c2bff929:

    # fr "Good, I can't wait!"
    fr "¡Genial, estoy deseándolo!"

# game/Scenes/Mari/mari3.rpy:39
translate spanish mari3_910292d4:

    # fr "I better go get your food."
    fr "Mejor voy a por tu comida."

# game/Scenes/Mari/mari3.rpy:40
translate spanish mari3_63023601:

    # pc "Okay."
    pc "Vale."

# game/Scenes/Mari/mari3.rpy:42
translate spanish mari3_0aa5dfbc:

    # "She starts to walk away, then looks back at me."
    "Empieza a alejarse, pero luego se vuelve a mirar hacia mí."

# game/Scenes/Mari/mari3.rpy:43
translate spanish mari3_8f6f1358:

    # fr "Thanks for asking me out. I'm really looking forward to our date."
    fr "Gracias por invitarme a salir. Tengo muchas ganas de que llegue nuestra cita."

# game/Scenes/Mari/mari3.rpy:44
translate spanish mari3_03eaad50:

    # pc "Me too."
    pc "Yo también."

# game/Scenes/Mari/mari3.rpy:45
translate spanish mari3_7553af6a:

    # "With that, she smiles and leaves to get my food."
    "Dicho esto, sonríe y se marcha a buscar mi comida."

# game/Scenes/Mari/mari3.rpy:47
translate spanish mari3_43045d37:

    # "We don't talk much more while I eat and she has to help other customers, but every time she looks at me, she's smiling."
    "No hablamos mucho más mientras como y ella tiene que atender a otros clientes, pero cada vez que me mira, está sonriendo."

# game/Scenes/Mari/mari3.rpy:48
translate spanish mari3_2d44a908:

    # "The smile is different than usual. More sincere almost."
    "La sonrisa es diferente a la de siempre. Casi más sincera."

# game/Scenes/Mari/mari3.rpy:51
translate spanish maritip3_474b8780:

    # "I leave 10 dollars on the table."
    "Dejo 10 dólares sobre la mesa."

# game/Scenes/Mari/mari3.rpy:53
translate spanish maritip3_bbc6048f:

    # "No need to leave money, I'll give her something better later."
    "No hace falta que dejes dinero, ya le daré algo mejor más tarde."

# game/Scenes/Mari/mari3.rpy:55
translate spanish maritip3_c56febff:

    # "Then I start to walk out towards my car."
    "Entonces empiezo a salir hacia mi coche."

# game/Scenes/Mari/mari3.rpy:58
translate spanish maritip3_e3c07fca:

    # "Mari stops me though, wrapping her arms around me and pulling me into a hug."
    "Pero Mari me detiene, me rodea con sus brazos y me atrae hacia ella para darme un abrazo."

# game/Scenes/Mari/mari3.rpy:59
translate spanish maritip3_7db5e01d:

    # fr "I can't wait to see you again."
    fr "Estoy deseando volver a verte."

# game/Scenes/Mari/mari3.rpy:60
translate spanish maritip3_98e7787f:

    # fr "Be sure you call me."
    fr "Asegúrate de llamarme."

# game/Scenes/Mari/mari3.rpy:61
translate spanish maritip3_5bc44b07:

    # pc "I will."
    pc "Lo haré."

# game/Scenes/Mari/mari3.rpy:62
translate spanish maritip3_2e512b95:

    # fr "Okay, take care."
    fr "Vale, cuídate."

# game/Scenes/Mari/mari3.rpy:65
translate spanish maritip3_5794a059:

    # "She releases me and I go outside. She's really excited about our date it seems."
    "Me suelta y salgo. Parece que está muy emocionada con nuestra cita."

# game/Scenes/Mari/mari3.rpy:66
translate spanish maritip3_f0d4672c:

    # "I'm excited too. It should be fun."
    "Yo también estoy emocionado. Debería ser divertido."

