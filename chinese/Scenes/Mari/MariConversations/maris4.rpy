translate chinese maris4_4a957ed1:

    # fr "I used to like the rodeo, but now I think it's kind of cruel."
    fr "我以前喜欢牛仔竞技，但现在觉得有点残忍。"

# game/Scenes/Mari/MariConversations/maris4.rpy:19
translate chinese maris4_2df4d2c2:

    # fr "I love the animals, but I don't really like how they're treated."
    fr "我爱动物，但不太喜欢它们受到的待遇。"

# game/Scenes/Mari/MariConversations/maris4.rpy:20
translate chinese maris4_311961b2:

    # fr "I think I'd rather just watch cartoons, you know?"
    fr "我觉得我还是看卡通片吧，你知道吗？"

# game/Scenes/Mari/MariConversations/maris4.rpy:22
translate chinese maris4_4b210c47:

    # fr "What about you? Do you like sports?"
    fr "那你呢？喜欢运动吗？"

# game/Scenes/Mari/MariConversations/maris4.rpy:27
translate chinese maris4_d41d8cd9:

    # voice 'voices/mari_ohcool1.mp3'
