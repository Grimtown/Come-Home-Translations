translate spanish suzytammylakedate_2a690dca:

    # "When the girls are ready, we drive out to the lake together."
    "Cuando las chicas están listas, nos vamos juntas en coche al lago."

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:19
translate spanish suzytammylakedate_80ba5381:

    # ss "Wow. We have the whole place to ourselves?"
    ss "Vaya. ¿Tenemos todo el sitio para nosotras solas?"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:20
translate spanish suzytammylakedate_126ea9d5:

    # pc "Yeah, people don't come out here too often."
    pc "Sí, la gente no suele venir aquí muy a menudo."

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:21
translate spanish suzytammylakedate_2949eaf8:

    # tm "So we can skinny dip?"
