# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:85
translate spanish suzytammymovietheaterstartdate_65007bab:

    # tm "I don't know about you two, but I'm ready to head back home."
    tm "No sé vosotros dos, pero yo estoy lista para volver a casa."

# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:86
translate spanish suzytammymovietheaterstartdate_f89287b0:

    # ss "That sounds good to me. You ready to take this date back to the house, [bro]?"
    ss "Me parece bien. ¿Estás lista para llevarte a esta cita a casa, [bro]?"

# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:87
translate spanish suzytammymovietheaterstartdate_a400a310:

    # pc "Sure, let's go home."
    pc "Claro, vamos a casa."

# game/Scenes/Suzy/SuzyDates/suzytammymoviedate.rpy:92
