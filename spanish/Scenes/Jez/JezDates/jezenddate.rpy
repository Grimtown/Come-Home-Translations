# game/Scenes/Jez/JezDates/jezenddate.rpy:8
translate spanish jezenddate_687d0176:

    # det "So, do you want to come back to my place for a while?"
    det "Bueno, ¿quieres venir a mi casa un rato?"

# game/Scenes/Jez/JezDates/jezenddate.rpy:9
translate spanish jezenddate_30d6b817:

    # det "Mamá's got Javi for a bit. We could spend some time together."
    det "Mamá se queda con Javi un rato. Podríamos pasar un rato juntos."

# game/Scenes/Jez/JezDates/jezenddate.rpy:12
translate spanish jezenddate_3ba845d3:

    # det "Good, let's go."
    det "Bien, vamos."

# game/Scenes/Jez/JezDates/jezenddate.rpy:15
translate spanish jezenddate_588b9a6e:

    # "We get in our cars and I follow her back to her house, where we quickly make our way inside to her bedroom."
    "Nos subimos a nuestros coches y la sigo hasta su casa, donde entramos rápidamente y nos dirigimos a su dormitorio."

# game/Scenes/Jez/JezDates/jezenddate.rpy:19
translate spanish jezenddate_77b42da9:

    # det "Oh, alright then. Well I had a nice date anyway. I'll see you later, [pcname]."
    det "Oh, vale, entonces. Bueno, al menos he tenido una cita agradable. Nos vemos luego, [pcname]."

# game/Scenes/Jez/JezDates/jezenddate.rpy:21
translate spanish jezenddate_b4d69820:

    # "I lean in and we kiss, my arms wrapped around her."
    "Me inclino y nos besamos, con mis brazos rodeándola."

# game/Scenes/Jez/JezDates/jezenddate.rpy:22
translate spanish jezenddate_3091dff1:

    # pc "Bye, Jez. See you again soon."
    pc "Adiós, Jez. Nos vemos pronto."

# game/Scenes/Jez/JezDates/jezenddate.rpy:25
translate spanish jezenddate_f48c2630:

    # "She leaves, and I go back out to my car and drive away."
    "Ella se marcha, y yo vuelvo a mi coche y me alejo."

# game/Scenes/Jez/JezDates/jezenddate.rpy:29
translate spanish jezenddate_716db417:

    # det "I had a really good time. I'm looking forward to doing this again soon."
    det "Me lo he pasado muy bien. Espero que podamos volver a hacerlo pronto."

# game/Scenes/Jez/JezDates/jezenddate.rpy:30
translate spanish jezenddate_03eaad50:

    # pc "Me too."
    pc "Yo también."

# game/Scenes/Jez/JezDates/jezenddate.rpy:33
translate spanish jezenddate_398aacb4:

    # det "I'd invite you over to my place, but I'm not quite ready for my son to meet you yet."
    det "Te invitaría a mi casa, pero aún no estoy preparada para que mi hijo te conozca."

# game/Scenes/Jez/JezDates/jezenddate.rpy:34
translate spanish jezenddate_70367ea3:

    # det "I don't want him to get confused by male figures being in his life for only a short time."
    det "No quiero que se sienta confundido por la presencia de figuras masculinas en su vida durante un periodo tan breve."

# game/Scenes/Jez/JezDates/jezenddate.rpy:35
translate spanish jezenddate_6cf8b822:

    # det "I want to make sure that this thing between me and you is real before we do that. I hope you understand."
    det "Quiero asegurarme de que esto entre tú y yo es real antes de dar ese paso. Espero que lo entiendas."

# game/Scenes/Jez/JezDates/jezenddate.rpy:36
translate spanish jezenddate_cca20d9e:

    # pc "I do understand."
    pc "Lo entiendo."

# game/Scenes/Jez/JezDates/jezenddate.rpy:38
translate spanish jezenddate_3239d4cf:

    # det "Thanks."
    det "Gracias."

# game/Scenes/Jez/JezDates/jezenddate.rpy:41
translate spanish jezenddate_b4d69820_1:

    # "I lean in and we kiss, my arms wrapped around her."
