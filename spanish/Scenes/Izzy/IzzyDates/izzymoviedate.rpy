    gl "Genial, vamos."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:95
translate spanish izzymoviedatestart_dcbc938c_1:

    # gl "Cool, let's go."
    gl "Genial, vamos."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:98
translate spanish izzymoviedatestart_9a2ffc1c:

    # gl "Damn, fingers it is then. Thanks for the movie anyway, Twig. See ya later."
    gl "Joder, pues con los dedos será. Gracias por la peli de todas formas, Twig. Nos vemos luego."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:99
translate spanish izzymoviedatestart_63fc4244:

    # pc "Bye, Izzy."
    pc "Adiós, Izzy."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:102
translate spanish izzymoviedatestart_8b93ebfd:

    # "I wait until she gets out and walks into her house before I drive away."
    "Espero a que salga y entre en su casa antes de marcharme."

