# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:29
translate spanish tammycafestartdate_cfe5cfd9:

    # tm "Java Lava is all business people. People getting their coffee on the way to work or something."
    tm "En Java Lava solo hay gente de negocios. Gente que se toma un café de camino al trabajo o algo así."

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:35
translate spanish tammycafestartdate_d91a9226:

    # "We sit and chat and drink our coffee."
    "Nos sentamos, charlamos y nos tomamos el café."

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:37
translate spanish tammycafestartdate_c45a6676:

    # tm "This was nice."
