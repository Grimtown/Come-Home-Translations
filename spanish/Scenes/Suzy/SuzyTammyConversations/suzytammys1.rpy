# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:46
translate spanish suzytammys1_073efbf9:

    # ss "That's what he makes me think of."
    ss "Eso es lo que me hace pensar él."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:48
translate spanish suzytammys1_a4339d9b:

