    # det "Can you stay? I don't want to be alone tonight."
    det "¿Te puedes quedar? No quiero estar sola esta noche."

# game/Scenes/Jez/jez13.rpy:139
translate spanish jez13_1fd61d7b:

    # pc "Yeah, I can stay."
    pc "Sí, me puedo quedar."

# game/Scenes/Jez/jez13.rpy:142
