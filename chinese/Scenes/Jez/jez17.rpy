translate chinese jez17_403e60ed:

    # jav "No, Mamá. He's a good teacher."
    jav "没有，妈妈。他是个好老师。"

# game/Scenes/Jez/jez17.rpy:114
translate chinese jez17_69c5f526:

    # pc "I just explained things to him like my dad explained them to me."
    pc "“我只是像我爸爸教我那样给他讲解了。”"

# game/Scenes/Jez/jez17.rpy:115
translate chinese jez17_c6bb9386:

    # pc "He was a good teacher too. He taught me a lot when I was Javi's age."
    pc "“他也是个好老师。我跟哈维一样大的时候，他教了我很多。”"

# game/Scenes/Jez/jez17.rpy:116
translate chinese jez17_0ce6133c:

    # jav "[pcname] is better than my teacher. I don't like her."
    jav "“[pcname]比我的老师好。我不喜欢她。”"

# game/Scenes/Jez/jez17.rpy:119
translate chinese jez17_96cd260f:

    # det "Okay, mijo. Let's eat."
    det "“好的，孩子。我们开动吧。”"

# game/Scenes/Jez/jez17.rpy:122
translate chinese jez17_b7ccc42b:

    # "We eat and talk."
    "我们一边吃一边聊。"

# game/Scenes/Jez/jez17.rpy:123
translate chinese jez17_bbd791ab:

    # "It feels nice. Not awkward at all like that first breakfast had been. I'm part of the family now."
    "感觉很不错。完全不像那第一顿早餐时那么尴尬。我现在已经是这个家庭的一员了。"

# game/Scenes/Jez/jez17.rpy:126
translate chinese jez17_deb44750:

    # "After dinner, I take my plate to the kitchen where Ivelisse has already started cleaning up."
    "饭后，我端着盘子走进厨房，伊维莉丝已经开始收拾了。"

