# game/Scenes/Bai/BaiDates/baiparkdate.rpy:33
translate spanish baiparkstartdate_4053ffc0:

    # "Bai and I walk around the trails, chit-chatting for a while."
    "Bai y yo damos un paseo por los senderos, charlando un rato."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:44
translate spanish baiparkstartdate_236ab045:

    # "Eventually, we reach the bench halfway along the trail."
    "Al final, llegamos al banco que hay a mitad del camino."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:52
translate spanish baiparkstartdate_1b78059e:

    # "We sit next to each other for a bit, chatting."
    "Nos sentamos uno al lado del otro un rato, charlando."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:54
translate spanish baiparkstartdate_8ab96ed5:

    # "I'm still a little uncomfortable with this, and I'm pretty sure he is too."
    "Todavía me siento un poco incómodo con esto, y estoy bastante seguro de que él también."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:55
translate spanish baiparkstartdate_96695859:

    # "Things are a little awkward."
    "El ambiente es un poco incómodo."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:58
translate spanish baiparkstartdate_fbccb841:

    # "I put my arm around him and we sit in a comfortable silence together, just enjoying being close."
    "Le rodeo con el brazo y nos sentamos juntos en un silencio cómodo, simplemente disfrutando de estar cerca."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:59
translate spanish baiparkstartdate_cf2869ab:

    # "Then, after a while, it's time to head back."
    "Luego, al cabo de un rato, es hora de volver."

