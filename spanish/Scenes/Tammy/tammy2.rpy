# game/Scenes/Tammy/tammy2.rpy:12
translate spanish tammy2_58882cf4:

    # "I spend some time working out with Tammy."
    "Paso un rato entrenando con Tammy."

# game/Scenes/Tammy/tammy2.rpy:13
translate spanish tammy2_f8739613:

    # "First I spot her."
    "Primero la ayudo a ella."

# game/Scenes/Tammy/tammy2.rpy:16
translate spanish tammy2_b03ba21e:

    # "Then she spots me."
    "Luego ella me ayuda a mí."

# game/Scenes/Tammy/tammy2.rpy:20
translate spanish tammy2_f59c8527:

    # "Then we start chatting a bit between reps."
    "Después empezamos a charlar un poco entre series."

# game/Scenes/Tammy/tammy2.rpy:21
translate spanish tammy2_e027ab69:

    # tm "You ever think about trying MMA?"
    tm "¿Alguna vez has pensado en probar las MMA?"

# game/Scenes/Tammy/tammy2.rpy:22
translate spanish tammy2_08f599b9:

    # pc "MMA? Like fighting?"
    pc "¿MMA? ¿Como pelear?"

# game/Scenes/Tammy/tammy2.rpy:23
translate spanish tammy2_7ed92c4d:

    # tm "Yeah, like fighting. I train every weekend in the morning."
    tm "Sí, como pelear. Entreno todos los fines de semana por la mañana."

# game/Scenes/Tammy/tammy2.rpy:24
translate spanish tammy2_690f9781:

    # tm "You could come join me sometime."
    tm "Podrías venir a acompañarme alguna vez."

# game/Scenes/Tammy/tammy2.rpy:25
translate spanish tammy2_50211aa2:

    # pc "You're just looking for an excuse to beat me up."
    pc "Solo estás buscando una excusa para darme una paliza."

# game/Scenes/Tammy/tammy2.rpy:27
translate spanish tammy2_d669bb2f:

    # "She punches me hard in the arm."
    "Me da un fuerte puñetazo en el brazo."

# game/Scenes/Tammy/tammy2.rpy:28
translate spanish tammy2_68bd08bc:

    # tm "Ha! I don't need an excuse for that."
    tm "¡Ja! No necesito una excusa para eso."

# game/Scenes/Tammy/tammy2.rpy:29
translate spanish tammy2_dedf8f6f:

    # pc "Ow! Damn."
    pc "¡Ay! Joder."

# game/Scenes/Tammy/tammy2.rpy:31
translate spanish tammy2_eb4630f0:

    # tm "See that's why you need to come train in MMA. You got a nice body, but you're too soft."
    tm "Ves, por eso tienes que venir a entrenar MMA. Tienes un buen cuerpo, pero eres demasiado blando."

# game/Scenes/Tammy/tammy2.rpy:32
translate spanish tammy2_eb998a13:

    # pc "You think I have a nice body?"
    pc "¿Crees que tengo un buen cuerpo?"

# game/Scenes/Tammy/tammy2.rpy:33
translate spanish tammy2_9ac6fb46:

    # tm "Well, yeah."
    tm "Bueno, sí."

# game/Scenes/Tammy/tammy2.rpy:34
translate spanish tammy2_cce51848:

    # pc "Alright, I'll come wrestle with you some time."
    pc "Vale, vendré a luchar contigo algún día."

# game/Scenes/Tammy/tammy2.rpy:35
translate spanish tammy2_bdefbf8e:

    # tm "Good. I'm looking forward to it. Mornings and Afternoons on the weekends, I'll be here."
    tm "Bien. Estoy deseándolo. Las mañanas y las tardes de los fines de semana estaré aquí."

# game/Scenes/Tammy/tammy2.rpy:39
translate spanish tammy2_7cd89556:

    # "We finish our workout and say goodbye to each other."
    "Terminamos nuestro entrenamiento y nos despedimos."

# game/Scenes/Tammy/tammy2.rpy:41
translate spanish tammy2_d33670c7:

    # "I have to admit, rolling around on the mat with her has a certain appeal."
    "Tengo que admitir que revolcarme por la lona con ella tiene cierto atractivo."

# game/Scenes/Tammy/tammy2.rpy:42
translate spanish tammy2_bf0d0df4:

    # "For now though, I leave the gym and go out to my car."
    "Por ahora, sin embargo, salgo del gimnasio y me dirijo a mi coche."

translate spanish strings:

    # game/Scenes/Tammy/tammy2.rpy:2
    old "Workout with Tammy on the weekend again."
    new "Entrenar con Tammy el fin de semana otra vez."

    # game/Scenes/Tammy/tammy2.rpy:3
    old "Then she will ask if you want to train MMA with her."
    new "Entonces ella te preguntará si quieres entrenar MMA con ella."

