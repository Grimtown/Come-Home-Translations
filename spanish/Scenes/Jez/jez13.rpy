    # det "Bad people doing bad things, you know?"
    det "Gente mala haciendo cosas malas, ¿sabes?"

# game/Scenes/Jez/jez13.rpy:98
translate spanish jez13_d41d8cd9_3:

    # voice 'voices/jez_13_4.mp3'
    voice 'voices/jez_13_4.mp3'

