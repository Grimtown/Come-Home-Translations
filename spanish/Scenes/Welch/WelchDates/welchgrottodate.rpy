# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:11
translate spanish welchgrottosetup_6881458b:

    # pc "Have you ever been to The Grotto?"
    pc "¿Has estado alguna vez en The Grotto?"

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:12
translate spanish welchgrottosetup_20f84972:

    # sst "That's the fancy restaurant out by the lake, right?"
    sst "Es ese restaurante elegante que hay junto al lago, ¿verdad?"

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:13
translate spanish welchgrottosetup_dcb78a71:

    # pc "Yeah that's it. Want to go?"
    pc "Sí, ese mismo. ¿Quieres ir?"

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:15
translate spanish welchgrottosetup_cc9ccb65:

    # sst "You want to take me out to a fancy restaurant? That's so cute."
    sst "¿Quieres llevarme a un restaurante elegante? Qué detalle."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:16
translate spanish welchgrottosetup_7476dfe0:

    # sst "Sure. That place is usually pretty dark. Hopefully nobody will notice us."
    sst "Claro. Ese sitio suele estar bastante a oscuras. Con suerte, nadie se fijará en nosotros."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:17
translate spanish welchgrottosetup_c02d4e40:

    # sst "Putting on a slinky dress and going out with you is too hard to resist either way."
    sst "Ponerme un vestido ceñido y salir contigo es demasiado tentador como para resistirse, de cualquier modo."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:18
translate spanish welchgrottosetup_224ce4c0:

    # pc "I'll come pick you up in half an hour or so then."
    pc "Entonces iré a recogerte dentro de media hora más o menos."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:20
translate spanish welchgrottosetup_820f35a4:

    # sst "See you then!"
    sst "¡Nos vemos entonces!"

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:23
translate spanish welchgrottosetup_1e8d0bcd:

    # sst "That sounds great. Come pick me up."
    sst "Suena genial. Ven a recogerme."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:24
translate spanish welchgrottosetup_8caa4a9c:

    # pc "On my way."
    pc "Voy de camino."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:38
translate spanish welchgrotto_1c038d34:

    # "I drive over to Nora's house and pick her up."
    "Conduzco hasta la casa de Nora y la recojo."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:39
translate spanish welchgrotto_193f5eb6:

    # "Then we drive together out to The Grotto."
    "Luego vamos juntos en coche a The Grotto."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:44
translate spanish welchgrotto_cad8af70:

    # sst "I'm so glad this place opened up. It's so pretty out here."
    sst "Me alegro mucho de que hayan abierto este sitio. Es muy bonito aquí."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:45
translate spanish welchgrotto_29523955:

    # sst "And the food is amazing."
    sst "Y la comida es increíble."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:46
translate spanish welchgrotto_612eb9c9:

    # pc "You been here a lot?"
    pc "¿Has venido aquí muchas veces?"

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:47
translate spanish welchgrotto_75b36cd4:

    # sst "Just a few times with my girlfriends. Gives us an excuse to dress up."
    sst "Solo unas cuantas con mis amigas. Nos da una excusa para arreglarnos."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:51
translate spanish welchgrotto_ecd9ab22:

    # "The server takes our orders and we chat for a while."
    "El camarero nos toma nota y charlamos un rato."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:54
translate spanish welchgrotto_ac38448c:

    # "Then we eat and chat some more."
    "Luego comemos y seguimos charlando."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:60
translate spanish welchgrotto_94d3f64e:

    # "Then we get up and dance a bit to the soft music."
    "Después nos levantamos y bailamos un poco al son de la música suave."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:62
translate spanish welchgrotto_834fdc5e:

    # sst "Hopefully nobody sees us here. I didn't recognize anybody. And it's kind of dark."
    sst "Ojalá nadie nos vea aquí. No he reconocido a nadie. Y está un poco oscuro."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:63
translate spanish welchgrotto_812291bf:

    # pc "I don't even care. I just like being here with you."
    pc "Ni siquiera me importa. Simplemente me gusta estar aquí contigo."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:64
translate spanish welchgrotto_dc9c454d:

    # sst "Yeah, I just don't want to get fired."
    sst "Sí, es que no quiero que me despidan."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:65
translate spanish welchgrotto_5936967d:

    # pc "Well... yeah, that's true, I guess."
    pc "Bueno... sí, eso es cierto, supongo."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:69
translate spanish welchgrotto_9d3da435:

    # sst "You're a pretty good dancer."
    sst "Bailas bastante bien."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:70
translate spanish welchgrotto_ee7cc753:

    # sst "This is turning me on, like, a lot."
    sst "Esto me está poniendo a mil."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:71
translate spanish welchgrotto_245905a7:

    # sst "I think you better take me home and pound me into the mattress."
    sst "Creo que será mejor que me lleves a casa y me folles contra el colchón."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:72
translate spanish welchgrotto_08551511:

    # pc "You got it."
    pc "De acuerdo."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:75
translate spanish welchgrotto_7c346eae:

    # "Ten minutes later..."
    "Diez minutos más tarde..."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:82
translate spanish welchgrotto_0dca6c5b:

    # sst "I think I'm ready for you to take me home now, handsome."
    sst "Creo que ya estoy lista para que me lleves a casa, guapo."

# game/Scenes/Welch/WelchDates/welchgrottodate.rpy:83
translate spanish welchgrotto_3b622a38:

    # "We drive back to her house and quickly make our way up to her bedroom."
    "Volvemos a su casa y subimos rápidamente a su dormitorio."

translate spanish strings:

    # game/Scenes/Welch/WelchDates/welchgrottodate.rpy:6
    old "After you start dating Ms. Welch, you can call her to take her out on a date in the evening."
    new "Una vez que empieces a salir con la Srta. Welch, puedes llamarla para invitarla a salir por la noche."

    # game/Scenes/Welch/WelchDates/welchgrottodate.rpy:7
    old "If you have unlocked The Grotto on Whitney's path, you'll be able to take Nora there."
    new "Si has desbloqueado «The Grotto» en la ruta de Whitney, podrás llevar a Nora allí."

