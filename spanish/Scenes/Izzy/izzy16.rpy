    "No tardamos mucho en quedarnos dormidos los dos."

# game/Scenes/Izzy/izzy16.rpy:352
translate spanish izzy16_1cee6238:

    # "I wake up to the sound of my phone alarm in the morning."
    "Me despierto con el sonido de la alarma de mi teléfono por la mañana."

# game/Scenes/Izzy/izzy16.rpy:355
translate spanish izzy16_bc4ff6d9:

    # pc "Hey, Izzy. I have to go."
    pc "Hola, Izzy. Tengo que irme."

# game/Scenes/Izzy/izzy16.rpy:356
translate spanish izzy16_4511aa4e:

    # gl "Oh okay, baby."
    gl "Ah, vale, cariño."

# game/Scenes/Izzy/izzy16.rpy:357
translate spanish izzy16_475c67d1:

    # gl "Hope you have a good day. Thanks for staying over."
    gl "Espero que tengas un buen día. Gracias por quedarte a dormir."

# game/Scenes/Izzy/izzy16.rpy:360
translate spanish izzy16_f4a8219d:

    # pc "I'll talk to you later."
    pc "Hablamos luego."

# game/Scenes/Izzy/izzy16.rpy:361
translate spanish izzy16_923d4965:

    # gl "Okay."
    gl "Vale."

# game/Scenes/Izzy/izzy16.rpy:364
translate spanish izzy16_7db1b4d7:

    # "As I'm walking away, I hear her say, almost too low to make out the words..."
    "Mientras me alejo, la oigo decir, casi en un susurro que apenas se distingue..."

# game/Scenes/Izzy/izzy16.rpy:365
translate spanish izzy16_968ee224:

    # gl "Love you, Twig."
    gl "Te quiero, Twig."

# game/Scenes/Izzy/izzy16.rpy:366
translate spanish izzy16_5236ef26:

    # "I leave Izzy's house, then head home to change and shower before starting my day."
    "Salgo de casa de Izzy y me dirijo a mi casa para cambiarme y ducharme antes de empezar el día."

