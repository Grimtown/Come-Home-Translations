# game/Scenes/Adrian/adrian15.rpy:15
translate chinese adrian15_156a2700:

    # "My phone starts buzzing in my pocket. I pull it out and see that Adrian is calling."
    "我的手机在口袋里开始震动。我掏出来一看，是艾德里安打来的。"

# game/Scenes/Adrian/adrian15.rpy:20
translate chinese adrian15_bea5e8cb:

    # pc "Hello?"
    pc "喂？"

# game/Scenes/Adrian/adrian15.rpy:21
translate chinese adrian15_f9cf1bde:

    # gg "Hey, [pcname]. You busy?"
    gg "嘿，[pcname]。你忙吗？"

# game/Scenes/Adrian/adrian15.rpy:22
translate chinese adrian15_e74e5c12:

    # pc "Not really. What's up?"
    pc "不忙。有什么事吗？"

# game/Scenes/Adrian/adrian15.rpy:24
translate chinese adrian15_aa2be04d:

    # gg "Want to come over and play some games or something? Hang out for a bit?"
    gg "想过来玩会儿游戏什么的吗？一起待会儿？"

# game/Scenes/Adrian/adrian15.rpy:26
translate chinese adrian15_e5c1fea0:

    # gg "My mom's not home."
    gg "我妈不在家。"

# game/Scenes/Adrian/adrian15.rpy:32
translate chinese adrian15_75da4880:

    # gg "Aw, alright."
    gg "哎，那算了。"

# game/Scenes/Adrian/adrian15.rpy:34
translate chinese adrian15_29cb8792:

    # gg "Maybe next weekend then."
    gg "那下周末吧。"

# game/Scenes/Adrian/adrian15.rpy:35
translate chinese adrian15_ba01fe47:

    # pc "Okay, see you later, Adrian."
    pc "好的，待会儿见，艾德里安。"

# game/Scenes/Adrian/adrian15.rpy:36
translate chinese adrian15_225cc39e:

    # gg "See ya."
    gg "见。"

# game/Scenes/Adrian/adrian15.rpy:42
translate chinese adrian15_997826d2:

    # pc "I'll be right over."
    pc "我马上就到。"

# game/Scenes/Adrian/adrian15.rpy:44
translate chinese adrian15_1f3fc4dd:

    # gg "Awesome! See you then."
    gg "太棒了！到时候见。"

# game/Scenes/Adrian/adrian15.rpy:48
translate chinese adrian15_3415b62c:

    # "I get ready real quick and drive over to Adrian's house to hang out with her."
    "我迅速收拾好，开车去艾德里安家找她玩。"

# game/Scenes/Adrian/adrian15.rpy:52
translate chinese adrian15_0be6e60c:

    # "She greets me in the kitchen with a deep kiss."
    "她在厨房里用一个深吻迎接了我。"

# game/Scenes/Adrian/adrian15.rpy:53
translate chinese adrian15_19e9b3da:

    # gg "We {i}could{/i} just skip straight to the sex today, but I do really want to play some games."
    gg "我们{i}本{/i}可以直接跳过前戏直接做爱，但我真的很想玩会儿游戏。"

# game/Scenes/Adrian/adrian15.rpy:54
translate chinese adrian15_216dab98:

    # gg "Is that okay?"
    gg "这样可以吗？"

# game/Scenes/Adrian/adrian15.rpy:55
translate chinese adrian15_e1f76998:

    # pc "Of course. I was looking forward to playing games with you too."
    pc "当然可以。我也一直很期待和你一起玩游戏。"

# game/Scenes/Adrian/adrian15.rpy:59
translate chinese adrian15_abe6c25e:

    # "We go upstairs and start playing."
    "我们上楼开始玩。"

# game/Scenes/Adrian/adrian15.rpy:61
translate chinese adrian15_c8f89ecf:

    # "As soon as I get there, we go upstairs and start playing."
    "一到那里，我们就上楼开始玩。"

# game/Scenes/Adrian/adrian15.rpy:62
translate chinese adrian15_d2b3fa04:

    # "As usual, she's just a little bit better than me at just about everything we play."
    "一如既往，无论玩什么，她都比我稍微强一点。"

# game/Scenes/Adrian/adrian15.rpy:64
translate chinese adrian15_1c125346:

    # gg "Ooh, you're getting frustrated. I want you to take that out on me later."
    gg "哦，你好像有点不爽了。等会儿我要你把这股火发在我身上。"

# game/Scenes/Adrian/adrian15.rpy:65
translate chinese adrian15_49db3af1:

    # pc "Oh I will. I'm going to fucking pound you."
    pc "哦，我会的。我要狠狠地干你。"

# game/Scenes/Adrian/adrian15.rpy:66
translate chinese adrian15_05fc893c:

    # gg "Not as hard as I'm pounding you right now."
    gg "可没我现在干你这么猛。"

# game/Scenes/Adrian/adrian15.rpy:68
translate chinese adrian15_23cf97cd:

    # gg "You're getting frustrated. Want me to take it easy on you?"
    gg "你好像有点不爽了。要我对你温柔点吗？"

# game/Scenes/Adrian/adrian15.rpy:69
translate chinese adrian15_07b12e2a:

    # pc "Absolutely not."
    pc "绝对不要。"

# game/Scenes/Adrian/adrian15.rpy:70
translate chinese adrian15_61c39868:

    # gg "Okay then."
    gg "那好吧。"

# game/Scenes/Adrian/adrian15.rpy:73
translate chinese adrian15_e6bf8cf8:

    # gg "Get wrecked!"
    gg "被我干趴下！"

# game/Scenes/Adrian/adrian15.rpy:74
translate chinese adrian15_458a16fb:

    # pc "Damn it!"
    pc "该死！"

# game/Scenes/Adrian/adrian15.rpy:75
translate chinese adrian15_e2f2f564:

    # "Just then, Adrian's phone starts to ring."
    "就在这时，阿德里安的手机响了起来。"

# game/Scenes/Adrian/adrian15.rpy:78
translate chinese adrian15_1ff26783:

    # gg "Oh hold on, my cousin is calling. I gotta answer this."
    gg "哦，等一下，我表弟打来了。我得接个电话。"

# game/Scenes/Adrian/adrian15.rpy:79
translate chinese adrian15_9b761d73:

    # pc "Okay, no problem."
    pc "好的，没问题。"

# game/Scenes/Adrian/adrian15.rpy:82
translate chinese adrian15_993631a3:

    # gg "Hey, cuz. What's up?"
    gg "嘿，表弟。怎么了？"

# game/Scenes/Adrian/adrian15.rpy:83
translate chinese adrian15_55836b8e:

    # gg "Not really, just hanging out with a friend."
    gg "没什么，就是和朋友在一起。"

# game/Scenes/Adrian/adrian15.rpy:84
translate chinese adrian15_1717d990:

    # gg "You're almost here already?"
    gg "你都快到了？"

# game/Scenes/Adrian/adrian15.rpy:85
translate chinese adrian15_82261785:

    # gg "Okay then, see you in a few minutes."
    gg "那好吧，几分钟后见。"

# game/Scenes/Adrian/adrian15.rpy:88
translate chinese adrian15_d0342fde:

    # gg "She's coming over to see me."
    gg "她要过来见我。"

# game/Scenes/Adrian/adrian15.rpy:89
translate chinese adrian15_241b8044:

    # gg "Sorry, this is completely unexpected."
    gg "抱歉，这完全出乎意料。"

# game/Scenes/Adrian/adrian15.rpy:90
translate chinese adrian15_58426ace:

    # gg "But I'm excited that you're going to get to meet her!"
    gg "但我很高兴你能见到她！"

# game/Scenes/Adrian/adrian15.rpy:91
translate chinese adrian15_6f1ff7f5:

    # pc "You two get along, I guess?"
    pc "你们俩相处得不错吧？"

# game/Scenes/Adrian/adrian15.rpy:92
translate chinese adrian15_56ba3372:

    # gg "Yeah, she's amazing. I love her so much."
    gg "是啊，她太棒了。我超爱她。"

# game/Scenes/Adrian/adrian15.rpy:93
translate chinese adrian15_f36cae87:

    # gg "Come on, let's go down and greet her."
    gg "走吧，我们下去迎接她。"

# game/Scenes/Adrian/adrian15.rpy:96
translate chinese adrian15_e520b635:

    # "We go downstairs and wait outside for a few minutes before a woman pulls up on a motorcycle and parks in Adrian's driveway."
    "我们下楼在外面等了几分钟，随后一位女子骑着摩托车驶来，停在了阿德里安的车道上。"

# game/Scenes/Adrian/adrian15.rpy:97
translate chinese adrian15_327f8422:

    # gg "There she is!"
    gg "就是她！"

# game/Scenes/Adrian/adrian15.rpy:98
translate chinese adrian15_80f73ec8:

    # gg "Thena!"
    gg "塞娜！"

# game/Scenes/Adrian/adrian15.rpy:101
translate chinese adrian15_41689eaf:

    # gg "What's going on, cuz?"
    gg "怎么了，表妹？"

# game/Scenes/Adrian/adrian15.rpy:103
translate chinese adrian15_bdbb7e4a:

    # ath "Ugh, I have so much to tell you."
    ath "哎呀，我有很多事要告诉你。"

# game/Scenes/Adrian/adrian15.rpy:106
translate chinese adrian15_f34f39f9:

    # "Adrian rushes towards her and they hug."
    "阿德里安冲过去拥抱了她。"

# game/Scenes/Adrian/adrian15.rpy:107
translate chinese adrian15_8a2ad9ef:

    # ath "Can we go inside and talk for a bit?"
    ath "我们能进去聊会儿吗？"

# game/Scenes/Adrian/adrian15.rpy:108
translate chinese adrian15_6cec5501:

    # gg "Sure."
    gg "当然。"

# game/Scenes/Adrian/adrian15.rpy:111
translate chinese adrian15_40382c6b:

    # ath "Oh, who's this?"
    ath "哦，这位是谁？"

# game/Scenes/Adrian/adrian15.rpy:113
translate chinese adrian15_f248dcf0:

    # gg "This is my boyfriend, [pcname]. [pcname], this is my cousin, Athena."
    gg "这是我的男朋友，[pcname]。[pcname]，这是我的表妹，雅典娜。"

# game/Scenes/Adrian/adrian15.rpy:115
translate chinese adrian15_2fec0547:

    # gg "This is my friend, [pcname]. [pcname], this is my cousin, Athena."
    gg "这是我的朋友，[pcname]。[pcname]，这是我的表妹，雅典娜。"

# game/Scenes/Adrian/adrian15.rpy:116
translate chinese adrian15_bc87a0d4:

    # pc "Nice to meet you."
    pc "很高兴见到你。"

# game/Scenes/Adrian/adrian15.rpy:117
translate chinese adrian15_15faa5ea:

    # ath "Yeah, you too."
    ath "嗯，我也是。"

# game/Scenes/Adrian/adrian15.rpy:122
translate chinese adrian15_7ac147ee:

    # "We go in and go upstairs and sit in the bedroom and the tone immediately changes to something more somber and uncomfortable."
    "我们走进屋里，上楼坐在卧室里，气氛立刻变得沉重而尴尬。"

# game/Scenes/Adrian/adrian15.rpy:123
translate chinese adrian15_da185fde:

    # pc "Should I go? Do you two need to talk?"
    pc "我该走了吗？你们俩需要单独谈谈吗？"

# game/Scenes/Adrian/adrian15.rpy:124
translate chinese adrian15_6b5e2f35:

    # gg "No, you don't have to go."
    gg "不用，你不用走。"

# game/Scenes/Adrian/adrian15.rpy:125
translate chinese adrian15_ff42571e:

    # gg "Right, Athena? What's going on? Did something happen?"
    gg "对吧，雅典娜？怎么回事？发生什么事了吗？"

# game/Scenes/Adrian/adrian15.rpy:128
translate chinese adrian15_cd5138a1:

    # ath "Yeah, but I'm not allowed to tell you everything."
    ath "是啊，但我不能告诉你全部。"

# game/Scenes/Adrian/adrian15.rpy:129
translate chinese adrian15_0937f8ec:

    # ath "I'm going to be leaving for a while. For my own protection."
    ath "我得离开一阵子。为了保护自己。"

# game/Scenes/Adrian/adrian15.rpy:132
translate chinese adrian15_ea61cda2:

    # gg "What do you mean? Are you in trouble?"
    gg "什么意思？你遇到麻烦了吗？"

# game/Scenes/Adrian/adrian15.rpy:134
translate chinese adrian15_d6235708:

    # ath "I got mixed up in something. I can't tell you any more about it right now."
    ath "我卷进了一件事里。现在不能再多说了。"

# game/Scenes/Adrian/adrian15.rpy:135
translate chinese adrian15_a6ace00b:

    # ath "Hopefully some day. Whenever it all blows over."
    ath "希望有一天能告诉你。等这一切都过去之后。"

# game/Scenes/Adrian/adrian15.rpy:137
translate chinese adrian15_8643f80d:

    # gg "What do you mean you have to leave?"
    gg "你说“必须离开”是什么意思？"

# game/Scenes/Adrian/adrian15.rpy:139
translate chinese adrian15_666954cc:

    # ath "I have to cut contact with everybody. Witness protection."
    ath "我必须和所有人断绝联系。证人保护计划。"

# game/Scenes/Adrian/adrian15.rpy:141
translate chinese adrian15_479d733b:

    # gg "Cut contact? So we're not going to be able to talk? At all?"
    gg "断绝联系？那我们以后就不能联系了吗？完全不能？"

# game/Scenes/Adrian/adrian15.rpy:144
translate chinese adrian15_dc747734:

    # ath "Not for a while."
    ath "暂时不能。"

# game/Scenes/Adrian/adrian15.rpy:145
translate chinese adrian15_49c637e0:

    # gg "How long?"
    gg "要多久？"

# game/Scenes/Adrian/adrian15.rpy:146
translate chinese adrian15_7b465be2:

    # ath "I don't know."
    ath "我不知道。"

# game/Scenes/Adrian/adrian15.rpy:147
translate chinese adrian15_024a8128:

    # gg "Are you in danger?"
    gg "你有危险吗？"

# game/Scenes/Adrian/adrian15.rpy:148
translate chinese adrian15_619b8851:

    # gg "Because you know I would burn the whole world down for you."
    gg "因为你知道，为了你，我哪怕烧毁整个世界也在所不惜。"

# game/Scenes/Adrian/adrian15.rpy:151
translate chinese adrian15_10475b4e:

    # ath "I know. I'd do the same for you too."
    ath "我知道。我也会为你做同样的事。"

# game/Scenes/Adrian/adrian15.rpy:152
translate chinese adrian15_db6c9ba9:

    # gg "Do we need to? Go on a Thelma and Louise style cross-country escape?"
    gg "我们有必要吗？像《末路狂花》那样横跨全国逃亡？"

# game/Scenes/Adrian/adrian15.rpy:153
translate chinese adrian15_938aadfc:

    # ath "No, it's okay, Adrian."
    ath "不用，没事的，阿德里安。"

# game/Scenes/Adrian/adrian15.rpy:156
translate chinese adrian15_9d14717d:

    # ath "I'll be safe. And I'll be with people I love."
    ath "我会很安全的。而且我会和爱的人在一起。"

# game/Scenes/Adrian/adrian15.rpy:157
translate chinese adrian15_ad669f44:

    # ath "I'll just be... hidden for a while."
    ath "我只是……暂时躲起来一阵子。"

# game/Scenes/Adrian/adrian15.rpy:160
translate chinese adrian15_ab7ecd37:

    # ath "But you don't have to worry about me, I promise."
    ath "但你不用担心我，我保证。"

# game/Scenes/Adrian/adrian15.rpy:161
translate chinese adrian15_6fc1467e:

    # ath "And as soon as I'm able to, I'll contact you."
    ath "只要一有机会，我就会联系你。"

# game/Scenes/Adrian/adrian15.rpy:162
translate chinese adrian15_f33637a0:

    # ath "This isn't a goodbye. Just a see you later. Okay?"
    ath "这不是告别。只是暂别。好吗？"

# game/Scenes/Adrian/adrian15.rpy:165
translate chinese adrian15_97b198b3:

    # gg "It feels like a goodbye."
    gg "感觉就像是告别。"

# game/Scenes/Adrian/adrian15.rpy:166
translate chinese adrian15_1ba8b0dd:

    # ath "Oh don't cry, cuz, please. You'll make me cry too."
    ath "哦，别哭，表妹，求你了。 你会让我也哭的。"

# game/Scenes/Adrian/adrian15.rpy:169
translate chinese adrian15_0e2cfb70:

    # gg "I just don't know what I'm going to do without being able to talk to you and play games with you every night."
    gg "我真的不知道，如果不能每天晚上和你聊天、一起玩游戏，我该怎么办。"

# game/Scenes/Adrian/adrian15.rpy:170
translate chinese adrian15_0b0416f8:

    # gg "I'm going to miss you so much."
    gg "我会非常想你的。"

# game/Scenes/Adrian/adrian15.rpy:171
translate chinese adrian15_4851e337:

    # ath "I'll miss you too, Adrian."
    ath "我也会想你的，阿德里安。"

# game/Scenes/Adrian/adrian15.rpy:172
translate chinese adrian15_decbe2a6:

    # ath "You'll be okay though. You have friends. You are loved."
    ath "不过你会没事的。你有朋友。你被爱着。"

# game/Scenes/Adrian/adrian15.rpy:173
translate chinese adrian15_b994f8f3:

    # ath "And one day I'll call you and we'll hang out and I'll tell you everything."
    ath "总有一天我会给你打电话，我们一起出去玩，我会把一切都告诉你。"

# game/Scenes/Adrian/adrian15.rpy:176
translate chinese adrian15_baad95b7:

    # gg "You better."
    gg "你最好做到。"

# game/Scenes/Adrian/adrian15.rpy:177
translate chinese adrian15_e694fdb2:

    # gg "Or I might come looking for you, and I'll take out anybody in my way."
    gg "不然我可能会来找你，挡我路的人我一个不留。"

# game/Scenes/Adrian/adrian15.rpy:178
translate chinese adrian15_0cebbbe1:

    # gg "I have a very particular set of skills."
    gg "我有一套非常特别的技能。"

# game/Scenes/Adrian/adrian15.rpy:179
translate chinese adrian15_46263ea2:

    # ath "I'm not sure how mob management with ice magic or looking amazing in a tank top is going to help you there."
    ath "我不确定用冰系魔法处理人群，或者穿背心穿得超帅，能帮你什么忙。"

# game/Scenes/Adrian/adrian15.rpy:180
translate chinese adrian15_5b9f42ef:

    # gg "Fine. I might need to obtain more skills."
    gg "好吧。我可能需要再练点新技能。"

# game/Scenes/Adrian/adrian15.rpy:183
translate chinese adrian15_297bbe15:

    # ath "So, my ride is going to be here to pick me up soon. I don't have a lot of time."
    ath "所以，接我的人马上就到了。我没多少时间了。"

# game/Scenes/Adrian/adrian15.rpy:184
translate chinese adrian15_083bd235:

    # ath "But I do have some good news for you too."
    ath "不过我也有个好消息要告诉你。"

# game/Scenes/Adrian/adrian15.rpy:185
translate chinese adrian15_5f5f9537:

    # gg "Oh really?"
    gg "哦，真的吗？"

# game/Scenes/Adrian/adrian15.rpy:188
translate chinese adrian15_c24bc319:

    # ath "I'm not going to need my bike anymore. So it's all yours."
    ath "我以后用不着我的自行车了。所以它全归你了。"

# game/Scenes/Adrian/adrian15.rpy:189
translate chinese adrian15_9e813a25:

    # gg "What!? You're just giving it to me!?"
    gg "什么！？你就这样送给我！？"

# game/Scenes/Adrian/adrian15.rpy:190
translate chinese adrian15_ca7279be:

    # ath "Sure. You had a blast riding it when you visited me last and I can't take it with me."
    ath "当然。你上次来找我时骑得可开心了，而且我带不走它。"

# game/Scenes/Adrian/adrian15.rpy:191
translate chinese adrian15_f0112aa2:

    # ath "So I wanted you to have it."
    ath "所以我希望你能拥有它。"

# game/Scenes/Adrian/adrian15.rpy:194
translate chinese adrian15_6fb0514f:

    # gg "You're amazing, Thena. I love you."
    gg "你太棒了，塞娜。我爱你。"

# game/Scenes/Adrian/adrian15.rpy:195
translate chinese adrian15_a77a6e8c:

    # ath "I love you too, cuz."
    ath "我也爱你，表妹。"

# game/Scenes/Adrian/adrian15.rpy:196
translate chinese adrian15_04259593:

    # ath "Take care of it, okay? And be careful."
    ath "好好珍惜它，好吗？还有，骑车要小心。"

# game/Scenes/Adrian/adrian15.rpy:197
translate chinese adrian15_62a41927:

    # gg "I will, I promise."
    gg "我会的，我保证。"

# game/Scenes/Adrian/adrian15.rpy:198
translate chinese adrian15_1339b17c:

    # ath "We should probably go downstairs. My ride will be here any minute."
    ath "我们最好下去吧。接我的人马上就到了。"

# game/Scenes/Adrian/adrian15.rpy:201
translate chinese adrian15_1192b455:

    # ath "Be sure to tell your mom what's going on, okay? I was hoping she'd be here so I could say goodbye to her too."
    ath "记得把事情的经过告诉妈妈，好吗？我本来希望她也在，这样我也能跟她道别。"

# game/Scenes/Adrian/adrian15.rpy:202
translate chinese adrian15_e8147df6:

    # gg "I will. She's going to be as confused as I am about it, I'm sure."
    gg "我会告诉她的。我敢肯定，她会和我一样摸不着头脑。"

# game/Scenes/Adrian/adrian15.rpy:203
translate chinese adrian15_43503f58:

    # ath "Yeah, I'm really sorry that I can't tell you more. It's better to know as little as possible for everybody's safety."
    ath "是啊，真的很抱歉不能告诉你更多。为了大家的安全，知道得越少越好。"

# game/Scenes/Adrian/adrian15.rpy:206
translate chinese adrian15_b0be2693:

    # ath "And I'm sorry that we couldn't meet under better circumstances."
    ath "还有，很遗憾我们没能在更好的情况下见面。"

# game/Scenes/Adrian/adrian15.rpy:207
translate chinese adrian15_488c149e:

    # gg "Yeah, usually when Athena and I are together, it's all laughs and playing games and stuff."
    gg "是啊，通常我和雅典娜在一起的时候，总是笑声不断，玩游戏之类的。"

# game/Scenes/Adrian/adrian15.rpy:208
translate chinese adrian15_3dedfad6:

    # gg "It would have been fun to hang out for a while with all three of us and play some Smash or something."
    gg "要是我们三个人能一起待会儿，玩玩《任天堂明星大乱斗》之类的，肯定会很有趣。"

# game/Scenes/Adrian/adrian15.rpy:211
translate chinese adrian15_a29880ae:

    # ath "Do you still main Kirby? I'd love to kick that little pink ball's ass sometime."
    ath "你还在玩《星之卡比》吗？我真想找个机会把那个粉红小球揍一顿。"

# game/Scenes/Adrian/adrian15.rpy:212
translate chinese adrian15_c75ca3d4:

    # gg "You wish."
    gg "你想得美。"

# game/Scenes/Adrian/adrian15.rpy:213
translate chinese adrian15_9882e4ae:

    # ath "We might have time to fit in a quick game, if we hurry. It won't take me long to wipe the floor with you."
    ath "如果我们快点的话，说不定还有时间来一局。把你打得落花流水用不了多久。"

# game/Scenes/Adrian/adrian15.rpy:214
translate chinese adrian15_36bb3cc8:

    # gg "Let's go then, bitch!"
    gg "那走吧，贱人！"

# game/Scenes/Adrian/adrian15.rpy:217
translate chinese adrian15_b7c027eb:

    # "Just then, a police car parks in front of the house and a man in a suit steps out, looking grim and official."
    "就在这时，一辆警车停在了房子前，一个西装革履的男人走了出来，神情严肃而威严。"

# game/Scenes/Adrian/adrian15.rpy:218
translate chinese adrian15_b3e6504f:

    # ath "Rain check, I guess. Time to go."
    ath "看来只能改天了。该走了。"

# game/Scenes/Adrian/adrian15.rpy:221
translate chinese adrian15_d5f4dd84:

    # ath "I love you, cuz. I'll see you again soon."
    ath "我爱你，表妹。很快就能再见。"

# game/Scenes/Adrian/adrian15.rpy:222
translate chinese adrian15_b13e0d25:

    # gg "I love you too."
    gg "我也爱你。"

# game/Scenes/Adrian/adrian15.rpy:223
translate chinese adrian15_96dc14b2:

    # gg "I hate this so much. I don't want to let you go."
    gg "我真讨厌这样。我不想让你走。"

# game/Scenes/Adrian/adrian15.rpy:224
translate chinese adrian15_1edb5510:

    # ath "I know. We'll be okay though."
    ath "我知道。不过我们会没事的。"

# game/Scenes/Adrian/adrian15.rpy:225
translate chinese adrian15_e2fe510e:

    # ath "And when I see you again, we'll hang out for days, okay?"
    ath "等我再见到你，咱们要一起玩好几天，行吗？"

# game/Scenes/Adrian/adrian15.rpy:226
translate chinese adrian15_c5cc5eaf:

    # gg "Okay, but if there's anything I can do to help, please call me."
    gg "行，但如果有任何我能帮忙的地方，请给我打电话。"

# game/Scenes/Adrian/adrian15.rpy:227
translate chinese adrian15_20fcca99:

    # ath "I will."
    ath "我会打的。"

# game/Scenes/Adrian/adrian15.rpy:230
translate chinese adrian15_170b7c68:

    # ath "And [pcname], it was nice to meet you."
    ath "还有[pcname]，很高兴认识你。"

# game/Scenes/Adrian/adrian15.rpy:231
translate chinese adrian15_61906ded:

    # pc "Nice to meet you too, Athena."
    pc "我也一样，雅典娜。"

# game/Scenes/Adrian/adrian15.rpy:235
translate chinese adrian15_84825cda:

    # "Suddenly, she pulls my hand, yanking me closer, then whispers in my ear."
    "突然，她拉住我的手，把我拽近，然后在我耳边低语。"

# game/Scenes/Adrian/adrian15.rpy:236
translate chinese adrian15_46517656:

    # ath "Be good to her. If you hurt my cousin, I will find you."
    ath "好好对待她。如果你伤害了我的表妹，我会找到你的。"

# game/Scenes/Adrian/adrian15.rpy:237
translate chinese adrian15_17a1cb32:

    # pc "Uh, I will."
    pc "呃，我会的。"

# game/Scenes/Adrian/adrian15.rpy:240
translate chinese adrian15_05763882:

    # ath "Bye, Adrian! Love you!"
    ath "再见，阿德里安！爱你！"

# game/Scenes/Adrian/adrian15.rpy:241
translate chinese adrian15_11b6245f:

    # gg "Bye! Love you too!"
    gg "再见！我也爱你！"

# game/Scenes/Adrian/adrian15.rpy:242
translate chinese adrian15_fd99ecee:

    # ath "Tell your mom I love her too!"
    ath "告诉你妈妈我也爱她！"

# game/Scenes/Adrian/adrian15.rpy:243
translate chinese adrian15_b909935e:

    # gg "I will!"
    gg "我会的！"

# game/Scenes/Adrian/adrian15.rpy:244
translate chinese adrian15_124dcc1b:

    # ath "I'll kick your pink Kirby ass real soon!"
    ath "我很快就会踢你那粉红色的柯比屁股！"

# game/Scenes/Adrian/adrian15.rpy:248
translate chinese adrian15_4829e0da:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns towards me, tears in her eyes."
    "雅典娜一上车，车子开始驶离，艾德里安便转向我，眼中含着泪。"

# game/Scenes/Adrian/adrian15.rpy:249
translate chinese adrian15_5928d159:

    # gg "Ugh, this fucking sucks."
    gg "唉，这他妈的真糟糕。"

# game/Scenes/Adrian/adrian15.rpy:250
translate chinese adrian15_72615de3:

    # gg "I'm sorry, [pcname]. I don't much feel like playing games anymore."
    gg "对不起，[pcname]。我实在没心情再玩这些把戏了。"

# game/Scenes/Adrian/adrian15.rpy:251
translate chinese adrian15_fd83325a:

    # gg "I'll see you later, okay?"
    gg "回头见，好吗？"

# game/Scenes/Adrian/adrian15.rpy:252
translate chinese adrian15_e576c8b5:

    # pc "Are you going to be all right."
    pc "你会没事的吧。"

# game/Scenes/Adrian/adrian15.rpy:253
translate chinese adrian15_0da71ea1:

    # gg "Yeah. I'll have to be."
    gg "嗯。我得撑过去。"

# game/Scenes/Adrian/adrian15.rpy:254
translate chinese adrian15_4004410a:

    # gg "But I need some time alone now."
    gg "但我现在需要独处一会儿。"

# game/Scenes/Adrian/adrian15.rpy:255
translate chinese adrian15_b21f0baf:

    # pc "No problem. Let me know if I can help. See you later, Adrian."
    pc "没问题。如果需要帮忙就告诉我。回头见，艾德里安。"

# game/Scenes/Adrian/adrian15.rpy:256
translate chinese adrian15_9d092ee2:

    # gg "Thanks, [pcname]. See ya."
    gg "谢谢，[pcname]。再见。"

# game/Scenes/Adrian/adrian15.rpy:259
translate chinese adrian15_25d8780e:

    # "I leave Adrian's house, hoping that she'll be okay."
    "我离开艾德里安的家，希望她能好起来。"

# game/Scenes/Adrian/adrian15.rpy:267
translate chinese adrian15_d9f27044:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns and collapses into my arms, crying against my shoulder."
    "雅典娜一上车，车子刚一开动，艾德里安就转过身扑进我怀里，把脸埋在我肩头哭了起来。"

# game/Scenes/Adrian/adrian15.rpy:268
translate chinese adrian15_0e12d7d2:

    # gg "This fucking sucks!!!"
    gg "这他妈的太糟了！！！"

# game/Scenes/Adrian/adrian15.rpy:269
translate chinese adrian15_182f9ad8:

    # "I rub her back and hold her and let her cry it out."
    "我轻拍她的背，紧紧抱着她，任由她痛哭一场。"

# game/Scenes/Adrian/adrian15.rpy:272
translate chinese adrian15_8bf9515c:

    # "A few minutes later, she sniffs up her tears and looks at me."
    "几分钟后，她抽了抽鼻子，抬头看着我。"

# game/Scenes/Adrian/adrian15.rpy:273
translate chinese adrian15_3d955406:

    # gg "Okay, feeling slightly better."
    gg "好了，感觉好一点了。"

# game/Scenes/Adrian/adrian15.rpy:274
translate chinese adrian15_58a70a56:

    # gg "I want to go for a ride. Do you want to come with me?"
    gg "我想去兜兜风。你要一起去吗？"

# game/Scenes/Adrian/adrian15.rpy:275
translate chinese adrian15_2b3b24ff:

    # "I think I probably should stay with her, with how upset she is."
    "她这么难过，我觉得我应该陪着她。"

# game/Scenes/Adrian/adrian15.rpy:276
translate chinese adrian15_2d17893f:

    # pc "Sure, let's do it, if you're okay to drive?"
    pc "当然，那就去吧，如果你能开车的话？"

# game/Scenes/Adrian/adrian15.rpy:277
translate chinese adrian15_28404c62:

    # gg "Yeah, I'm okay."
    gg "嗯，我能行。"

# game/Scenes/Adrian/adrian15.rpy:280
translate chinese adrian15_58afc396:

    # gg "Here, I found her old helmet in the storage under the seat. You should probably wear it."
    gg "看，我在座下储物箱里找到了她那顶旧头盔。你最好戴上。"

# game/Scenes/Adrian/adrian15.rpy:281
translate chinese adrian15_4fb22de7:

    # pc "Dear lord, this thing is huge."
    pc "天啊，这玩意儿好大。"

# game/Scenes/Adrian/adrian15.rpy:282
translate chinese adrian15_2409eb5c:

    # gg "That's what she... nevermind, let's just go."
    gg "这就是她……算了，咱们走吧。"

# game/Scenes/Adrian/adrian15.rpy:283
translate chinese adrian15_9b4e9f4c:

    # pc "You know how to ride this thing?"
    pc "你会骑这东西吗？"

# game/Scenes/Adrian/adrian15.rpy:284
translate chinese adrian15_12315e04:

    # gg "Yeah, Athena taught me when I visited her last time. We rode all over the place on it."
    gg "会啊，上次去她那儿的时候雅典娜教过我。我们骑着它到处转。"

# game/Scenes/Adrian/adrian15.rpy:285
translate chinese adrian15_c4bccc9f:

    # gg "I'm the only person she'd ever let drive it."
    gg "我是她唯一允许开这车的人。"

# game/Scenes/Adrian/adrian15.rpy:289
translate chinese adrian15_65c8468c:

    # "I wrap my arms around her and hold on as she pulls out into the street."
    "她驶入街道时，我双臂环住她，紧紧抱住。"

# game/Scenes/Adrian/adrian15.rpy:290
translate chinese adrian15_a4cc4d56:

    # pc "Where are we going?"
    pc "我们要去哪儿？"

# game/Scenes/Adrian/adrian15.rpy:291
translate chinese adrian15_33da7917:

    # gg "I just feel like riding for a while. Clear my head, you know."
    gg "我就是想骑一会儿。理理思绪，你知道的。"

# game/Scenes/Adrian/adrian15.rpy:292
translate chinese adrian15_61f77a4c:

    # pc "Sure."
    pc "行。"

# game/Scenes/Adrian/adrian15.rpy:294
translate chinese adrian15_df03bfba:

    # "It feels like we're riding forever. We leave town and take a rarely used highway out towards the lake."
    "感觉我们骑了很久。我们驶出镇子，沿着一条鲜少有人走的高速公路朝湖边开去。"

# game/Scenes/Adrian/adrian15.rpy:295
translate chinese adrian15_ba48df36:

    # "After a while, I'm not even sure where we are anymore. Hopefully Adrian knows. I guess I have GPS on the phone if we get lost."
    "过了一会儿，我甚至都不确定我们在哪里了。希望阿德里安知道。我想如果迷路了，手机里还有GPS。"

# game/Scenes/Adrian/adrian15.rpy:296
translate chinese adrian15_0bac7b03:

    # "But I don't say anything. I just hold on and let Adrian clear her mind of everything."
    "但我什么也没说。我只是紧紧抱住她，任由艾德里安将脑海中的一切都抛诸脑后。"

# game/Scenes/Adrian/adrian15.rpy:297
translate chinese adrian15_76cd1d73:

    # "She seems calm now, like this is exactly what she needed to get through this."
    "她现在看起来很平静，仿佛这正是她走出阴霾所需要的。"

# game/Scenes/Adrian/adrian15.rpy:298
translate chinese adrian15_f0b56a2e:

    # "Then, after what must have been at least an hour, she pulls off the highway and drives a little ways up towards the cliffside near the lake."
    "随后，大概过了至少一个小时，她驶离高速公路，沿着湖边的悬崖峭壁往上开了一小段路。"

# game/Scenes/Adrian/adrian15.rpy:301
translate chinese adrian15_135327af:

    # "We sit and I hold her close, trying to provide whatever comfort I can."
    "我们坐下来，我将她搂在怀里，尽力给予她能给予的安慰。"

# game/Scenes/Adrian/adrian15.rpy:302
translate chinese adrian15_fa24fdf7:

    # gg "I'm sorry I'm being such a bummer. This was supposed to be a fun day."
    gg "“抱歉我这么扫兴。今天本该是愉快的一天。”"

# game/Scenes/Adrian/adrian15.rpy:303
translate chinese adrian15_cfd80ee8:

    # pc "It's okay, Adrian. I'm here for you. Whatever you need."
    pc "“没关系，艾德里安。我在这里陪着你。无论你需要什么。”"

# game/Scenes/Adrian/adrian15.rpy:304
translate chinese adrian15_64ee3ae6:

    # gg "Thanks, [pcname]. I just need a friend really."
    gg "“谢谢，[pcname]。其实我只是需要一个朋友。”"

# game/Scenes/Adrian/adrian15.rpy:306
translate chinese adrian15_d41d8cd9:

    # voice 'voices/adrian_whenitransitioned.mp3'
    voice 'voices/adrian_whenitransitioned.mp3'

# game/Scenes/Adrian/adrian15.rpy:307
translate chinese adrian15_ec81d936:

    # gg "When I transitioned, besides my mom, Athena was the only person who was there for me."
    gg "“在我转变身份的时候，除了我妈妈，雅典娜是唯一一个支持我的人。”"

# game/Scenes/Adrian/adrian15.rpy:309
translate chinese adrian15_d41d8cd9_1:

    # voice 'voices/adrian_nohesitation.mp3'
    voice 'voices/adrian_nohesitation.mp3'

# game/Scenes/Adrian/adrian15.rpy:310
translate chinese adrian15_b76e91f4:

    # gg "No hesitation, no questions, just a ton of support and love."
    gg "没有犹豫，没有质疑，只有满满的支持与爱。"

# game/Scenes/Adrian/adrian15.rpy:312
translate chinese adrian15_d41d8cd9_2:

    # voice 'voices/adrian_shewastheonly.mp3'
    voice 'voices/adrian_shewastheonly.mp3'

# game/Scenes/Adrian/adrian15.rpy:313
translate chinese adrian15_5be20e3b:

    # gg "She was the only friend I had for a long time."
    gg "很长一段时间里，她是我唯一的朋友。"

# game/Scenes/Adrian/adrian15.rpy:317
translate chinese adrian15_d41d8cd9_3:

    # voice 'voices/adrian_untilyou.mp3'
    voice 'voices/adrian_untilyou.mp3'

# game/Scenes/Adrian/adrian15.rpy:318
translate chinese adrian15_b79560a9:

    # gg "Until you."
    gg "直到遇见你。"

# game/Scenes/Adrian/adrian15.rpy:320
translate chinese adrian15_d41d8cd9_4:

    # voice 'voices/adrian_missherlikecrazy.mp3'
    voice 'voices/adrian_missherlikecrazy.mp3'

# game/Scenes/Adrian/adrian15.rpy:321
translate chinese adrian15_65372d0d:

    # gg "So, I'm going to miss her like crazy, and I'm going to worry about her until I hear from her again."
    gg "所以，我会疯狂地想念她，直到再次收到她的消息，我都会为她担心。"

# game/Scenes/Adrian/adrian15.rpy:323
translate chinese adrian15_d41d8cd9_5:

    # voice 'voices/adrian_butimsoglad.mp3'
    voice 'voices/adrian_butimsoglad.mp3'

# game/Scenes/Adrian/adrian15.rpy:324
translate chinese adrian15_4de0338c:

    # gg "But I'm so glad that you're here."
    gg "但我真的很高兴你在这里。"

# game/Scenes/Adrian/adrian15.rpy:326
translate chinese adrian15_d41d8cd9_6:

    # voice 'voices/adrian_iloveyou1.mp3'
    voice 'voices/adrian_iloveyou1.mp3'

# game/Scenes/Adrian/adrian15.rpy:327
translate chinese adrian15_9c8fbba1:

    # gg "I love you, [pcname]."
    gg "我爱你，[pcname]。"

# game/Scenes/Adrian/adrian15.rpy:330
translate chinese adrian15_456cffdf:

    # pc "I love you too, Adrian."
    pc "我也爱你，阿德里安。"

# game/Scenes/Adrian/adrian15.rpy:333
translate chinese adrian15_e9e54f9a:

    # "We sit and watch the sun set, holding each other, enjoying the quiet evening."
    "我们相拥着坐着看日落，享受这宁静的夜晚。"

# game/Scenes/Adrian/adrian15.rpy:334
translate chinese adrian15_5a0d166e:

    # "I just want to be whatever she needs now."
    "我只想成为她此刻需要的任何人。"

# game/Scenes/Adrian/adrian15.rpy:335
translate chinese adrian15_46b97a11:

    # "I realize how hard I've fallen for her. I'd do anything to make her happy."
    "我意识到自己有多么深爱着她。为了让她开心，我愿意做任何事。"

# game/Scenes/Adrian/adrian15.rpy:338
translate chinese adrian15_7f8ffd28:

    # "After the sun sets, we drive back to her house."
    "日落之后，我们开车回她家。"

# game/Scenes/Adrian/adrian15.rpy:341
translate chinese adrian15_78e6be93:

    # gg "It looks like my mom is home now. I'm going to have to explain everything to her."
    gg "看来我妈妈现在在家。我得把一切都跟她解释清楚。"

# game/Scenes/Adrian/adrian15.rpy:342
translate chinese adrian15_f3610339:

    # gg "This is not going to be fun."
    gg "这可不会好受。"

# game/Scenes/Adrian/adrian15.rpy:343
translate chinese adrian15_20cd9dd9:

    # pc "Want some backup?"
    pc "需要我陪你去吗？"

# game/Scenes/Adrian/adrian15.rpy:344
translate chinese adrian15_0c91a1a8:

    # gg "No, I think I better do this on my own."
    gg "不用，我觉得还是我自己去比较好。"

# game/Scenes/Adrian/adrian15.rpy:345
translate chinese adrian15_cf913627:

    # gg "Thanks for everything though, [pcname]. You've been amazing."
    gg "不过还是谢谢你，[pcname]。你真的很棒。"

# game/Scenes/Adrian/adrian15.rpy:346
translate chinese adrian15_c46a0b54:

    # pc "Any time."
    pc "随时欢迎。"

# game/Scenes/Adrian/adrian15.rpy:347
translate chinese adrian15_ee13ba27:

    # gg "I'll call you soon, okay?"
    gg "我很快会给你打电话，好吗？"

# game/Scenes/Adrian/adrian15.rpy:350
translate chinese adrian15_1f2a71e7:

    # pc "Okay. Good night, Adrian."
    pc "好的。晚安，艾德里安。"

# game/Scenes/Adrian/adrian15.rpy:351
translate chinese adrian15_f27d9018:

    # gg "Good night, [pcname]."
    gg "晚安，[pcname]。"

# game/Scenes/Adrian/adrian15.rpy:352
translate chinese adrian15_80adb898:

    # "I kiss her goodbye."
    "我吻别了她。"

# game/Scenes/Adrian/adrian15.rpy:355
translate chinese adrian15_0cbac92b:

    # "Then I get in my car and drive away, hoping that everything will be okay."
    "然后我坐进车里开走了，希望一切都会好起来。"

# game/Scenes/Adrian/adrian15.rpy:356
translate chinese adrian15_339d053a:

    # "And if she needs me, I'll do anything I can to help her."
    "如果她需要我，我会尽我所能去帮助她。"

translate chinese strings:

    # game/Scenes/Adrian/adrian15.rpy:6
    old "After you have checked out a local arcade with Adrian,"
    new "在你和艾德里安去当地的街机厅逛过之后，"

    # game/Scenes/Adrian/adrian15.rpy:7
    old "she will call and invite you to hang out in the afternoon on the weekend."
    new "她会打电话邀请你在周末的下午一起出去玩。"

    # game/Scenes/Adrian/adrian15.rpy:28
    old "Oh heck yeah"
    new "哦，太棒了"

