# game/Scenes/Jamie/jamie7.rpy:193
translate chinese jamie7_4996d024:

    # gnd "Here's a little something for you to think about when you go to sleep tonight."
    gnd "这里有个小建议，今晚睡觉前你可以想想。"

# game/Scenes/Jamie/jamie7.rpy:194
translate chinese jamie7_47e9d405:

    # pc "Damn, you're killing me here."
    pc "天啊，你真是要命。"

# game/Scenes/Jamie/jamie7.rpy:197
translate chinese jamie7_d41d8cd9_38:

    # voice 'voices/jamie_7_35.mp3'
    voice 'voices/jamie_7_35.mp3'

# game/Scenes/Jamie/jamie7.rpy:198
translate chinese jamie7_549d319e:

    # gnd "I'd love to be with you tonight. We'll have to make some time soon."
    gnd "今晚真想和你在一起。我们得尽快找个时间见见。"

# game/Scenes/Jamie/jamie7.rpy:200
translate chinese jamie7_d41d8cd9_39:

    # voice 'voices/jamie_7_36.mp3'
    voice 'voices/jamie_7_36.mp3'

# game/Scenes/Jamie/jamie7.rpy:201
translate chinese jamie7_f47ae404:

    # gnd "I need to go to sleep now though. Have to be ready for that speech. It's pretty important."
    gnd "不过我现在得去睡了。 得为那场演讲做好准备。这很重要。"

# game/Scenes/Jamie/jamie7.rpy:202
translate chinese jamie7_df8be67f:

    # pc "Okay. Well good luck."
    pc "好的。那祝你好运。"

# game/Scenes/Jamie/jamie7.rpy:205
translate chinese jamie7_d41d8cd9_40:

    # voice 'voices/jamie_7_37.mp3'
    voice 'voices/jamie_7_37.mp3'

# game/Scenes/Jamie/jamie7.rpy:206
translate chinese jamie7_32592d9e:

    # gnd "Thanks, [pcname]. Good night."
    gnd "谢谢，[pcname]。晚安。"

# game/Scenes/Jamie/jamie7.rpy:207
translate chinese jamie7_e32c95cf:

    # pc "Good night, Jamie."
    pc "晚安，杰米。"

# game/Scenes/Jamie/jamie7.rpy:209
translate chinese jamie7_00e0c49a:

    # "We hang up, but I watch her just a little longer as she walks over to the lamp beside her bed."
    "我们挂断了电话，但我还多看了她一会儿，直到她走到床边的台灯旁。"

# game/Scenes/Jamie/jamie7.rpy:211
translate chinese jamie7_62544acf:

    # "Then she turns it off and the show is over."
    "然后她关掉了灯，这场“演出”也结束了。"

# game/Scenes/Jamie/jamie7.rpy:213
translate chinese jamie7_55c194a5:

    # "I guess I should get some sleep too."
    "我想我也该睡了。"

# game/Scenes/Jamie/jamie7.rpy:214
translate chinese jamie7_5ef2b12b:

    # "I lie down and fall asleep, thinking about Jamie."
    "我躺下睡着了，脑海里想着杰米。"

