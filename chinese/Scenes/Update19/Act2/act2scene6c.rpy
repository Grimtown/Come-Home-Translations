    # sst "There's something else out here in these woods."
    sst "这片树林里还有别的什么东西。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:58
translate chinese u19a2s6c_c67257e9:

    # rb "What the heck was that? Who's there?"
    rb "那到底是什么？谁在那儿？"

# game/Scenes/Update19/Act2/act2scene6c.rpy:60
translate chinese u19a2s6c_c078095b:

    # cw "I don't think we're alone out here."
    cw "我觉得我们不是独自一人在这里。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:62
translate chinese u19a2s6c_34ffacad:

    # "I am not alone out here."
    "我不是独自一人在这里。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:63
translate chinese u19a2s6c_92bc8f2c:

    # "I unsheathe my sword and hold it ready, just in case."
    "我拔出剑来，随时准备迎战，以防万一。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:64
translate chinese u19a2s6c_1bb756e1:

    # pc "Jez?"
    pc "杰兹？"

# game/Scenes/Update19/Act2/act2scene6c.rpy:69
translate chinese u19a2s6c_ab435d1a:

    # "Then it's chaos, as we are suddenly surrounded by enemies."
    "接着便是一片混乱，我们突然被敌人包围了。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:71
translate chinese u19a2s6c_a6c05bcb:

    # "Then it's chaos, as I am suddenly surrounded by enemies."
    "接着便是一片混乱，我突然被敌人包围了。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:72
translate chinese u19a2s6c_77908e8b:

    # "They step out from the trees in front of and behind us."
    "他们从我们前后树丛中涌了出来。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:90
translate chinese u19a2s6c_0235d083:

    # gg "There's a lot of them. We might be able to take them, but this is going to get rough."
    gg "敌人数量众多。我们或许能应付，但这场战斗会很艰难。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:92
translate chinese u19a2s6c_067a076a:

    # sg "I don't know about this. There's too many of them."
    sg "我不确定。敌人实在太多了。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:94
translate chinese u19a2s6c_f596ce83:

    # bn "The odds are not in our favor here. We are surrounded."
    bn "形势对我们不利。我们已被包围。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:96
translate chinese u19a2s6c_065f6b79:

    # sst "I can probably take a few of them out, but this is going to be a tough fight."
    sst "我大概能解决几个，但这将是一场硬仗。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:98
translate chinese u19a2s6c_ce47fe3f:

    # rb "I'm not sure if I can clobber all of these guys. This is bad."
    rb "我不确定能否打倒所有这些家伙。情况不妙。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:100
translate chinese u19a2s6c_440b233e:

    # cw "There's too many of them. This is going to be difficult."
    cw "人太多了。这下可难办了。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:102
translate chinese u19a2s6c_d557ab7d:

    # "I don't see any way of standing up against this many enemies. Not alone."
    "面对这么多敌人，我看不出有什么办法能抗衡。单枪匹马更是没戏。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:105
translate chinese u19a2s6c_4f562773:

    # "Bandit" "Well aren't you pretty..."
    "Bandit" "哟，你长得还挺……"

# game/Scenes/Update19/Act2/act2scene6c.rpy:106
translate chinese u19a2s6c_d607ebbd:

    # "Bandit" "Drop your weapon and hand over all of your stuff."
    "Bandit" "放下武器，交出所有东西。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:107
translate chinese u19a2s6c_2db1bc6b:

    # "Bandit" "Then maybe we won't fuck your face before we kill you."
    "Bandit" "那样的话，说不定我们在杀你之前不会先把你脸给打烂。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:110
translate chinese u19a2s6c_d3f8f83f:

    # "Before I can even respond, there is a sickening crack and the man's face explodes."
    "我还没来得及反应，就听到一声令人作呕的爆裂声，那人的脸瞬间炸裂。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:114
translate chinese u19a2s6c_01e9cd43:

    # "The bandits barely realize what has happened before Jez drops in from the trees above, blasting with two glowing pistols."
    "强盗们还没弄清发生了什么，杰兹就从头顶的树丛中扑下来，挥舞着两把发光的左轮手枪疯狂扫射。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:132
translate chinese u19a2s6c_fe432f48:

    # "The pistols crack over and over again and the bandits all fall dead around me."
    "枪声此起彼伏，强盗们纷纷倒在我周围。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:134
translate chinese u19a2s6c_cb1d533e:

    # "The pistols crack over and over again and the bandits all fall dead around us."
    "枪声此起彼伏，强盗们纷纷倒在我们周围。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:137
translate chinese u19a2s6c_fcbb048d:

    # "Then, the noise finally stops and Jez walks towards me."
    "随后，枪声终于停歇，杰兹朝我走来。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:138
translate chinese u19a2s6c_c941ba51:

    # det "Did I hear you say my name before all of that bullshit started?"
    det "刚才那场闹剧开始前，我是不是听见你叫了我的名字？"

# game/Scenes/Update19/Act2/act2scene6c.rpy:155
translate chinese u19a2s6c_b72bb31a:

    # pc "Uh, yeah... Wow, that was violent."
    pc "呃，是啊……哇，太暴力了。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:156
translate chinese u19a2s6c_46a44815:

    # det "Sometimes you have to stop violence with violence."
    det "有时候，只能以暴制暴。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:157
translate chinese u19a2s6c_6f0162f9:

    # det "How do you know my name?"
    det "你怎么知道我的名字？"

# game/Scenes/Update19/Act2/act2scene6c.rpy:158
translate chinese u19a2s6c_24374ea4:

    # "I explain everything to her about the other world, the bracelet, and the Ice Queen."
    "我向她详细解释了另一个世界、手镯以及冰雪女王的事。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:159
translate chinese u19a2s6c_25131235:

    # det "The Ice Queen... she has caused so many problems."
    det "冰雪女王……她惹出了这么多麻烦。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:162
translate chinese u19a2s6c_d49da151:

    # det "You'll probably need backup. I'll go with you."
    det "你大概需要支援。我跟你一起去。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:163
translate chinese u19a2s6c_bc87b3ed:

    # pc "Thanks, Jez."
    pc "谢谢，杰兹。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:164
translate chinese u19a2s6c_2886f31b:

    # det "It feels like something I should do. Something inside me tells me that I should protect you."
    det "这感觉就像是我该做的事。我内心有个声音告诉我，我应该保护你。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:165
translate chinese u19a2s6c_ce9e78e3:

    # pc "I'll take all the help I can get."
    pc "能得到任何帮助我都感激不尽。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:186
translate chinese u19a2s6c_ecc8297e:

    # "With that, Jez gathers her supplies and we continue down the path to the north."
    "说完，杰兹收拾好装备，我们继续沿着小路向北走去。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:188
translate chinese u19a2s6c_853e9742:

    # sst "Hi Jez. I'm Nora."
    sst "嗨，杰兹。我是诺拉。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:189
translate chinese u19a2s6c_787e33e0:

    # sst "Always happy to have another badass woman in the group."
    sst "队伍里能多一位狠角色总是令人高兴的。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:190
translate chinese u19a2s6c_20824ddf:

    # det "Thanks for having me. I'm looking forward to seeing what you can do."
    det "谢谢你的邀请。我很期待看看你的本事。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:192
translate chinese u19a2s6c_66e8ad88:

    # rb "Hi Jez. My name's Reba."
    rb "嗨，杰兹。我叫瑞芭。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:193
translate chinese u19a2s6c_4c352005:

    # rb "I've never seen anything like your weapons there. I just swing my hammer."
    rb "我从没见过像你那样的武器。我只知道挥动我的锤子。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:194
translate chinese u19a2s6c_5c9e4657:

    # det "I bet you can do some damage with that hammer too."
    det "我敢打赌，那把锤子也能造成不小的伤害。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:195
translate chinese u19a2s6c_83664a9b:

    # rb "Sometimes. When it's necessary."
    rb "有时候。在必要的时候。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:196
