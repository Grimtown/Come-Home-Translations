# game/Scenes/Bai/bai15.rpy:13
translate chinese bai15_b4b2dfce:

    # "My phone starts buzzing in my pocket. Looks like Bai is calling."
    "口袋里的手机开始震动。看来是白打来的。"

# game/Scenes/Bai/bai15.rpy:18
translate chinese bai15_55db51fd:

    # pc "Hey, Bai. What's up?"
    pc "嘿，白。怎么了？"

# game/Scenes/Bai/bai15.rpy:20
translate chinese bai15_4c5b4d27:

    # bai "Hey, [pcname]. I know this is kind of sudden, but are you busy this evening? I could really use some help."
    bai "嘿，[pcname]。我知道这有点突然，但你今晚有空吗？我真的很需要帮忙。"

# game/Scenes/Bai/bai15.rpy:21
translate chinese bai15_7a93e2b0:

    # pc "Okay, what do you need?"
    pc "好的，你需要什么？"

# game/Scenes/Bai/bai15.rpy:23
translate chinese bai15_c3d8151a:

    # bai "My parents are coming into town to visit."
    bai "我父母要来城里看我。"

# game/Scenes/Bai/bai15.rpy:24
translate chinese bai15_1769b53f:

    # bai "I think I'm going to tell them about me... about us."
    bai "我想跟他们说说我的事……说说我们。"

# game/Scenes/Bai/bai15.rpy:25
translate chinese bai15_8392a4ca:

    # bai "Would you be there with me?"
    bai "你能陪我一起去吗？"

# game/Scenes/Bai/bai15.rpy:26
translate chinese bai15_2cd33def:

    # pc "Absolutely."
    pc "当然。"

# game/Scenes/Bai/bai15.rpy:28
translate chinese bai15_ce64cc54:

    # bai "Oh, good! I know this is kind of a whole thing. Coming out to my parents. Meeting my parents."
    bai "哦，太好了！我知道这事挺大。向我父母出柜。见我父母。"

# game/Scenes/Bai/bai15.rpy:29
translate chinese bai15_2ecdb735:

    # bai "I know it's a little awkward."
    bai "我知道会有点尴尬。"

# game/Scenes/Bai/bai15.rpy:30
translate chinese bai15_62b2a1d1:

    # pc "It's no problem really. I'd love to meet them. And I want to be there with you."
    pc "真的没问题。我很想见见他们。而且我想陪在你身边。"

# game/Scenes/Bai/bai15.rpy:31
translate chinese bai15_9c6957e3:

    # pc "You have all of my support."
    pc "我会全力支持你。"

# game/Scenes/Bai/bai15.rpy:33
translate chinese bai15_8dbd62cc:

    # bai "Thanks, [pcname]. Really. It means a lot."
    bai "谢谢，[pcname]。真的。这对我意义重大。"

# game/Scenes/Bai/bai15.rpy:34
translate chinese bai15_e9fe102b:

    # bai "Hopefully, with you there, I'll have the courage to go through with this."
    bai "希望有你在，我会有勇气把这件事做下去。"

# game/Scenes/Bai/bai15.rpy:35
translate chinese bai15_1f6808e2:

    # pc "I know it's tough. We can do it though."
    pc "我知道这很难。不过我们一定能行。"

# game/Scenes/Bai/bai15.rpy:37
translate chinese bai15_94319605:

    # bai "We're going to go to Luigi's at 6pm. Do you know where that is?"
    bai "我们晚上6点去路易吉餐厅。你知道那儿在哪儿吗？"

# game/Scenes/Bai/bai15.rpy:38
translate chinese bai15_8e508689:

    # pc "Sure. I can meet you there."
    pc "当然。我可以在那儿和你碰头。"

# game/Scenes/Bai/bai15.rpy:39
translate chinese bai15_41b7a831:

    # bai "Yeah, that'd be perfect."
    bai "嗯，那太好了。"

# game/Scenes/Bai/bai15.rpy:41
translate chinese bai15_f4fe4a57:

    # bai "Thanks again, [pcname]."
    bai "再次谢谢你，[pcname]。"

# game/Scenes/Bai/bai15.rpy:42
translate chinese bai15_df401732:

    # pc "No problem. I'll see you then."
    pc "没问题。到时候见。"

# game/Scenes/Bai/bai15.rpy:43
translate chinese bai15_5ea5aa90:

    # bai "See ya!"
    bai "再见！"

# game/Scenes/Bai/bai15.rpy:46
translate chinese bai15_3c387be2:

    # "Meeting Bai's parents. This should be interesting!"
    "见白家的父母。这应该会很有意思！"

# game/Scenes/Bai/bai15.rpy:47
translate chinese bai15_98881080:

    # "I go home and take a shower, then get ready to go out."
    "我回家冲了个澡，然后准备出门。"

# game/Scenes/Bai/bai15.rpy:51
translate chinese bai15_dbb1cc31:

    # "Later, at Luigi's, I walk in and find Bai and his family already sitting at a booth, waiting for me."
    "后来，在路易吉餐厅，我一进门就看到白和他家人已经坐在卡座里等我了。"

# game/Scenes/Bai/bai15.rpy:52
translate chinese bai15_e768f363:

    # bai "Hey, [pcname]! Over here."
    bai "嘿，[pcname]！这边。"

# game/Scenes/Bai/bai15.rpy:53
translate chinese bai15_bc35e5a2:

    # pc "I'm sorry, am I late?"
    pc "抱歉，我迟到了吗？"

# game/Scenes/Bai/bai15.rpy:54
translate chinese bai15_d881598d:

    # bai "No, we just got here a little early."
    bai "没有，我们只是来得稍微早了一点。"

# game/Scenes/Bai/bai15.rpy:57
translate chinese bai15_4bd90501:

    # bai "Mom, Dad, this is my friend, [pcname]."
    bai "爸妈，这是我的朋友，[pcname]。"

# game/Scenes/Bai/bai15.rpy:58
translate chinese bai15_0d66f124:

    # bai "[pcname], these are my parents, Mr. and Mrs. Wáng."
    bai "[pcname]，这是我的父母，王先生和王太太。"

# game/Scenes/Bai/bai15.rpy:59
translate chinese bai15_6561806e:

    # pc "It's really nice to meet you."
    pc "很高兴见到你们。"

# game/Scenes/Bai/bai15.rpy:62
translate chinese bai15_72bd522f:

    # "I'm not sure if I should bow or what, but Mr. Wáng saves me the awkwardness by putting out his hand."
    "我正犹豫该不该鞠躬，王先生却伸出手来，帮我解了围。"

# game/Scenes/Bai/bai15.rpy:63
translate chinese bai15_1010f7f8:

    # "Mr. Wáng" "It's nice to meet you, [pcname]."
    "Mr. Wáng" "很高兴见到你，[pcname]。"

# game/Scenes/Bai/bai15.rpy:64
translate chinese bai15_9f61af91:

    # pc "Very nice to meet you too. And you, Mrs. Wáng."
    pc "我也非常高兴见到你。王太太，您也是。"

# game/Scenes/Bai/bai15.rpy:65
translate chinese bai15_5017a9ed:

    # "Mr. Wáng" "Sit, sit, Bai was just telling us about his school work."
    "Mr. Wáng" "请坐，请坐，白刚跟我们聊起他的学业。"

# game/Scenes/Bai/bai15.rpy:68
translate chinese bai15_85af3f14:

    # "Mr. Wáng" "He's going to be a doctor, right son?"
    "Mr. Wáng" "他将来要当医生，对吧，儿子？"

# game/Scenes/Bai/bai15.rpy:69
translate chinese bai15_fb3ec878:

    # bai "Well, a physical therapist."
    bai "嗯，是物理治疗师。"

# game/Scenes/Bai/bai15.rpy:70
translate chinese bai15_fc08db4e:

    # "Mrs. Wáng" "Same thing."
    "Mrs. Wáng" "差不多就是医生。"

# game/Scenes/Bai/bai15.rpy:71
translate chinese bai15_90b16dec:

    # "Mr. Wáng" "Yes, it is basically a doctor."
    "Mr. Wáng" "是的，基本上就是医生。"

# game/Scenes/Bai/bai15.rpy:72
translate chinese bai15_354f7ad1:

    # "Mr. Wáng" "You help injured people. That is what doctors do, right [pcname]?"
    "Mr. Wáng" "你帮助受伤的人。这就是医生做的事，对吧[pcname]？"

# game/Scenes/Bai/bai15.rpy:73
translate chinese bai15_97f396d1:

    # pc "Sounds right to me."
    pc "听起来没错。"

# game/Scenes/Bai/bai15.rpy:74
translate chinese bai15_2cf478a4:

    # "Mrs. Wáng" "Ming Bai has always been smart. He can do anything he wants."
    "Mrs. Wáng" "明白一直都很聪明。他想做什么都能做到。"

# game/Scenes/Bai/bai15.rpy:77
translate chinese bai15_3a71c4c0:

    # pc "Ming Bai?"
    pc "明白？"

# game/Scenes/Bai/bai15.rpy:78
translate chinese bai15_831647d4:

    # bai "That's my full name. Wáng Ming Bai."
    bai "那是我的全名。王明白。"

# game/Scenes/Bai/bai15.rpy:81
translate chinese bai15_f174e123:

    # "Mrs. Wáng" "Bai means white and pure. He's my pure boy."
    "Mrs. Wáng" "“白”代表纯洁。他就是我那纯洁的孩子。"

# game/Scenes/Bai/bai15.rpy:82
translate chinese bai15_e488fece:

    # "Mr. Wáng" "But it is girl's name."
    "Mr. Wáng" "但这名字通常是女生的。"

# game/Scenes/Bai/bai15.rpy:83
translate chinese bai15_3020f103:

    # "Mrs. Wáng" "It can go both ways."
    "Mrs. Wáng" "男女通用。"

# game/Scenes/Bai/bai15.rpy:84
translate chinese bai15_bec55e4d:

    # "Mr. Wáng" "It is mostly a girl's name. So I named him Ming. A strong boy's name. It means bright."
    "Mr. Wáng" "不过多半是女生的名字。所以我给他取名“明”。这是个充满力量的男名，意为“明亮”。"

# game/Scenes/Bai/bai15.rpy:85
translate chinese bai15_cc0f7e52:

    # "Mrs. Wáng" "Yes, so he is bright and pure. The light in my life."
    "Mrs. Wáng" "是的，所以他既明亮又纯洁。是我生命中的光。"

# game/Scenes/Bai/bai15.rpy:88
translate chinese bai15_5eab4fbe:

    # bai "Aw Mom, stop."
    bai "哎呀妈妈，别说了。"

# game/Scenes/Bai/bai15.rpy:89
translate chinese bai15_73788646:

    # "We keep talking for a while and I wait for Bai to bring up the topic. The elephant in the room."
    "我们又聊了一会儿，我等着白主动提起那个话题——那个大家心照不宣的尴尬话题。"

# game/Scenes/Bai/bai15.rpy:90
translate chinese bai15_d56ba29f:

    # "Surely they realize that he didn't just invite me here as a friend."
    "他们肯定明白，他邀请我来这里绝不仅仅是因为我是朋友。"

# game/Scenes/Bai/bai15.rpy:93
translate chinese bai15_67ec92e0:

    # "Eventually... he coughs and chokes out the words."
    "终于……他清了清嗓子，艰难地吐出了那句话。"

# game/Scenes/Bai/bai15.rpy:94
translate chinese bai15_f8709a15:

    # bai "Mom... Dad... There's something I need to talk to you about."
    bai "妈……爸……有件事我想跟你们说。"

# game/Scenes/Bai/bai15.rpy:97
translate chinese bai15_c8442c8e:

    # "I give his hand a reassuring squeeze under the table."
    "我隔着桌子轻轻捏了捏他的手，给他一些安慰。"

# game/Scenes/Bai/bai15.rpy:98
translate chinese bai15_be278660:

    # "Mr. Wáng" "What is it, son?"
    "Mr. Wáng" "怎么了，儿子？"

# game/Scenes/Bai/bai15.rpy:101
translate chinese bai15_954bc39c:

    # bai "I'm... uh... I'm bi."
    bai "我……呃……我是双性恋。"

# game/Scenes/Bai/bai15.rpy:102
translate chinese bai15_fe0ef88f:

    # "Mr. Wáng" "I know you're Bai. Who you think named you that?"
    "Mr. Wáng" "我知道你是白。你以为是谁给你取的这名字？"

# game/Scenes/Bai/bai15.rpy:103
translate chinese bai15_90b22383:

    # bai "No, Dad. I'm bisexual."
    bai "不，爸爸。我是双性恋。"

# game/Scenes/Bai/bai15.rpy:104
translate chinese bai15_94ad15b4:

    # bai "I like girls... but I also like boys."
    bai "我喜欢女生……但也喜欢男生。"

# game/Scenes/Bai/bai15.rpy:105
translate chinese bai15_358a4695:

    # bai "[pcname] is not just my friend. He's my boyfriend."
    bai "[pcname]不只是我的朋友。他是我的男朋友。"

# game/Scenes/Bai/bai15.rpy:108
translate chinese bai15_33884c3f:

    # "A few moments pass and nobody talks."
    "片刻沉默，无人开口。"

# game/Scenes/Bai/bai15.rpy:109
translate chinese bai15_fbd8d2a0:

    # "Even the other people in the restaurant seem to get quieter."
    "就连餐厅里的其他客人似乎也变得安静了。"

# game/Scenes/Bai/bai15.rpy:112
translate chinese bai15_d2c120b1:

    # "Mrs. Wáng" "We know that. You think we're stupid?"
    "Mrs. Wáng" "我们早就知道了。你以为我们傻吗？"

# game/Scenes/Bai/bai15.rpy:113
translate chinese bai15_b2d3df9a:

    # "Mrs. Wáng" "We love you no matter what."
    "Mrs. Wáng" "无论发生什么，我们都爱你。"

# game/Scenes/Bai/bai15.rpy:114
translate chinese bai15_83b82ca9:

    # "Mrs. Wáng" "If you like boys, and you find a boy that likes you back, that's great."
    "Mrs. Wáng" "如果你喜欢男生，而且找到了一个也喜欢你的男生，那太棒了。"

# game/Scenes/Bai/bai15.rpy:115
translate chinese bai15_272024f0:

    # bai "Really, Mom?"
    bai "真的，妈妈？"

# game/Scenes/Bai/bai15.rpy:116
translate chinese bai15_158f0fe3:

    # "Mrs. Wáng" "Yes, really."
    "Mrs. Wáng" "是的，真的。"

# game/Scenes/Bai/bai15.rpy:119
translate chinese bai15_fd86eb81:

    # "Mr. Wáng" "I hope you weren't nervous about telling us this. I hope you know that nothing would make us stop loving you."
    "Mr. Wáng" "希望你告诉我们这件事时没感到紧张。希望你知道，没有什么能让我们停止爱你。"

# game/Scenes/Bai/bai15.rpy:120
translate chinese bai15_ca9fc704:

    # "Mr. Wáng" "You are an absolute joy to have as a son. I am so proud of you."
    "Mr. Wáng" "能有你这样的儿子，真是我们的福气。我为你感到无比自豪。"

# game/Scenes/Bai/bai15.rpy:123
translate chinese bai15_51678d55:

    # bai "Thank you so much."
    bai "太感谢你们了。"

# game/Scenes/Bai/bai15.rpy:124
translate chinese bai15_0d02d68c:

    # bai "You are the best parents ever, holy crap."
    bai "你们真是世上最棒的父母，天啊。"

# game/Scenes/Bai/bai15.rpy:126
translate chinese bai15_2500edfb:

    # "Mr. Wáng" "You remember that when we get old and you have to take care of us."
    "Mr. Wáng" "等我们老了需要你们照顾的时候，记得这一点哦。"

# game/Scenes/Bai/bai15.rpy:128
translate chinese bai15_f44e14a7:

    # "Mrs. Wáng" "Yes, stop crying, Ming Bai. I want to see your smile."
    "Mrs. Wáng" "对，别哭了，明白。我想看你笑。"

# game/Scenes/Bai/bai15.rpy:131
translate chinese bai15_073b52bf:

    # bai "I'm so happy."
    bai "我太开心了。"

# game/Scenes/Bai/bai15.rpy:132
translate chinese bai15_50bd8c22:

    # bai "This went way better than I thought it would."
    bai "这比我想象中顺利多了。"

# game/Scenes/Bai/bai15.rpy:133
translate chinese bai15_5bfadc88:

    # "Mrs. Wáng" "You think that we are monsters? That we would be upset that you love a man?"
    "Mrs. Wáng" "你以为我们是怪物吗？以为我们会因为你爱一个男人而生气？"

# game/Scenes/Bai/bai15.rpy:134
translate chinese bai15_dffb885d:

    # bai "I didn't know."
    bai "我不知道。"

# game/Scenes/Bai/bai15.rpy:135
translate chinese bai15_0519aada:

    # "Mr. Wáng" "If you told us you are switching to a liberal arts major, then we would have issue."
    "Mr. Wáng" "要是你跟我们说要转读文科专业，那我们才真有意见呢。"

# game/Scenes/Bai/bai15.rpy:138
translate chinese bai15_8e5fa26f:

    # "After nearly two hours of eating and chatting, where they pepper me with questions about myself, they announce that they have to leave."
    "吃了聊了将近两个小时，他们不停地问我各种关于我自己的问题，最后宣布他们得走了。"

# game/Scenes/Bai/bai15.rpy:139
translate chinese bai15_cb7cfe75:

    # "Mr. Wáng" "It was nice meeting you, [pcname]."
    "Mr. Wáng" "很高兴认识你，[pcname]。"

# game/Scenes/Bai/bai15.rpy:140
translate chinese bai15_48048864:

    # pc "Nice to meet you too, Mr. Wáng."
    pc "我也高兴认识你，王先生。"

# game/Scenes/Bai/bai15.rpy:143
translate chinese bai15_1005ee8b:

    # "Mrs. Wáng" "You treat my son well, okay? He is everything to us."
    "Mrs. Wáng" "你要好好对待我儿子，行吗？他就是我们的全部。"

# game/Scenes/Bai/bai15.rpy:144
translate chinese bai15_db1ed0fe:

    # pc "I will, Mrs. Wáng."
    pc "我会照顾好的，王太太。"

# game/Scenes/Bai/bai15.rpy:145
translate chinese bai15_bfe014f5:

    # "Mrs. Wáng" "And maybe we get wedding soon, huh?"
    "Mrs. Wáng" "说不定我们很快就能结婚了，对吧？"

# game/Scenes/Bai/bai15.rpy:146
translate chinese bai15_e2ee86ba:

    # pc "Uhh..."
    pc "呃……"

# game/Scenes/Bai/bai15.rpy:147
translate chinese bai15_f6b18e48:

    # "Mrs. Wáng" "I'm joking. No rush."
    "Mrs. Wáng" "我开玩笑的。不急。"

# game/Scenes/Bai/bai15.rpy:150
translate chinese bai15_6b860891:

    # "Mrs. Wáng" "Goodbye Ming Bai. {font=fonts/yrdzst semibold.ttf}我会一直陪着你 {/font}"
    "Mrs. Wáng" "再见，明白。{font=fonts/yrdzst semibold.ttf}我会一直陪着你 {/font}"

# game/Scenes/Bai/bai15.rpy:152
translate chinese bai15_e5290e82:

    # bai "{font=fonts/yrdzst semibold.ttf}妈, 我爱你{/font}"
    bai "{font=fonts/yrdzst semibold.ttf}妈，我爱你{/font}"

# game/Scenes/Bai/bai15.rpy:155
translate chinese bai15_af1459aa:

    # "When his parents leave, Bai turns to me."
    "等他父母离开后，白转过身来对我说。"

# game/Scenes/Bai/bai15.rpy:156
translate chinese bai15_57a4ab8c:

    # bai "Thanks for being here with me for this."
    bai "谢谢你陪我一起经历这一切。"

# game/Scenes/Bai/bai15.rpy:157
translate chinese bai15_08ab74ef:

    # bai "I don't know why I was so afraid to tell them."
    bai "我也不知道为什么之前那么害怕告诉他们。"

# game/Scenes/Bai/bai15.rpy:158
translate chinese bai15_f15c7675:

    # pc "Yeah, your parents are great."
    pc "是啊，你父母真好。"

# game/Scenes/Bai/bai15.rpy:159
translate chinese bai15_5134b355:

    # bai "They're amazing."
    bai "他们太棒了。"

# game/Scenes/Bai/bai15.rpy:162
translate chinese bai15_31f3ad75:

    # bai "You're amazing too."
    bai "你也很棒。"

# game/Scenes/Bai/bai15.rpy:163
translate chinese bai15_8dc5e485:

    # bai "What we have is the best thing that's happened to me in a long time."
    bai "我们之间的感情是我很久以来遇到的最美好的事。"

# game/Scenes/Bai/bai15.rpy:164
translate chinese bai15_1693dbf5:

    # bai "Thank you."
    bai "谢谢你。"

# game/Scenes/Bai/bai15.rpy:167
translate chinese bai15_44635a47:

    # "We say our goodbyes and I drive away."
    "我们道别后，我开车离开了。"

# game/Scenes/Bai/bai15.rpy:168
translate chinese bai15_e4e4e222:

    # "Things are getting pretty serious with Bai. Meeting his parents and everything."
    "我和白的关系变得相当认真了。见了他的父母，还有其他种种。"

# game/Scenes/Bai/bai15.rpy:169
translate chinese bai15_ae781b3c:

    # "I guess I'm going to have to decide soon how serious I am about this relationship."
    "我想我得尽快决定，我对这段感情到底有多认真。"

translate chinese strings:

    # game/Scenes/Bai/bai15.rpy:6
