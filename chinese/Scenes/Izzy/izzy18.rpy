# TODO: Translation updated at 2026-04-15 14:26

# game/Scenes/Izzy/izzy18.rpy:13
translate chinese izzy18_48f73cbb:

    # "My phone buzzes in my pocket. I pull it out and see Izzy is calling."
    "口袋里的手机震动起来。我掏出来，看到是伊兹打来的。"

# game/Scenes/Izzy/izzy18.rpy:17
translate chinese izzy18_0b193747:

    # pc "Hey, Izzy!"
    pc "嘿，伊兹！"

# game/Scenes/Izzy/izzy18.rpy:18
translate chinese izzy18_67747f91:

    # gl "Hey, [pcname]. Do you think you could come over?"
    gl "嘿，[pcname]。你能过来一趟吗？"

# game/Scenes/Izzy/izzy18.rpy:19
translate chinese izzy18_079eca90:

    # pc "Sure. Is everything okay?"
    pc "当然。一切都还好吗？"

# game/Scenes/Izzy/izzy18.rpy:21
translate chinese izzy18_994c37aa:

    # gl "Yeah, it's okay. Great actually."
    gl "嗯，还好。其实挺好的。"

# game/Scenes/Izzy/izzy18.rpy:22
translate chinese izzy18_7bc637d7:

    # gl "I was approved to get custody of my brothers. They're coming home today."
    gl "我获准获得弟弟们的监护权了。他们今天要回家了。"

# game/Scenes/Izzy/izzy18.rpy:23
translate chinese izzy18_bcb1c8ac:

    # pc "Wow! That's awesome!"
    pc "哇！太棒了！"

# game/Scenes/Izzy/izzy18.rpy:25
translate chinese izzy18_f7e9774e:

    # gl "Yeah... I'm just really nervous."
    gl "是啊……但我真的很紧张。"

# game/Scenes/Izzy/izzy18.rpy:26
translate chinese izzy18_1abab176:

    # gl "So, could you come over? For support?"
    gl "所以，你能过来吗？给我点支持？"

# game/Scenes/Izzy/izzy18.rpy:27
translate chinese izzy18_7b21993a:

    # pc "Of course. I'll be there in ten."
    pc "当然。十分钟到。"

# game/Scenes/Izzy/izzy18.rpy:29
translate chinese izzy18_ac4baa1d:

    # gl "Thanks, [pcname]. See you when you get here."
    gl "谢谢，[pcname]。等你到了见。"

# game/Scenes/Izzy/izzy18.rpy:33
translate chinese izzy18_42aac3f3:

    # "We hang up, and a few minutes later I arrive at her house."
    "我们挂了电话，几分钟后我到了她家。"

# game/Scenes/Izzy/izzy18.rpy:34
translate chinese izzy18_44049f47:

    # "She stands nervously in the kitchen."
    "她紧张地站在厨房里。"

# game/Scenes/Izzy/izzy18.rpy:35
translate chinese izzy18_ae9ec1ae:

    # gl "I'm sorry, I just feel so anxious about this."
    gl "对不起，我就是对这件事感到特别焦虑。"

# game/Scenes/Izzy/izzy18.rpy:36
translate chinese izzy18_e9fa4b62:

    # pc "What are you worried about?"
    pc "你在担心什么？"

# game/Scenes/Izzy/izzy18.rpy:39
translate chinese izzy18_24491b47:

    # gl "I'm scared they're going to hate me, [pcname]."
    gl "我怕他们会讨厌我，[pcname]。"

# game/Scenes/Izzy/izzy18.rpy:40
translate chinese izzy18_d8ca02d0:

    # gl "What if they don't want to come back here?"
    gl "万一他们不想回来呢？"

# game/Scenes/Izzy/izzy18.rpy:41
translate chinese izzy18_77345d17:

    # gl "I'm so broke. I can't afford to fix the house. We have to buy cheap food and thrift-store clothes."
    gl "我手头很紧。没钱修缮房子。我们只能买便宜的食物和旧货店的衣服。"

# game/Scenes/Izzy/izzy18.rpy:42
translate chinese izzy18_976944f0:

    # gl "Why would they want to come back here?"
    gl "他们为什么要回来？"

# game/Scenes/Izzy/izzy18.rpy:45
translate chinese izzy18_1c46df37:

    # pc "Because you're here, Izzy."
    pc "因为你在，伊兹。"

# game/Scenes/Izzy/izzy18.rpy:46
translate chinese izzy18_b64f93b8:

    # pc "Because you love them. They know that."
    pc "因为你爱他们。他们知道的。"

# game/Scenes/Izzy/izzy18.rpy:47
translate chinese izzy18_a520fca4:

    # pc "They will want to be with you. You're their sister. They love you."
    pc "他们会想和你在一起的。你是他们的姐姐。他们爱你。"

# game/Scenes/Izzy/izzy18.rpy:48
translate chinese izzy18_268fd7eb:

    # gl "I hope you're right, [pcname]. I really do."
    gl "希望你说得对，[pcname]。我真的希望如此。"

# game/Scenes/Izzy/izzy18.rpy:52
translate chinese izzy18_5722cdcb:

    # gl "I guess we're about to find out."
    gl "我想我们马上就能知道了。"

# game/Scenes/Izzy/izzy18.rpy:53
translate chinese izzy18_0fb2d05f:

    # "She takes a deep breath."
    "她深吸了一口气。"

# game/Scenes/Izzy/izzy18.rpy:54
translate chinese izzy18_fcfdafdf:

    # pc "You got this."
    pc "你一定能行的。"

# game/Scenes/Izzy/izzy18.rpy:55
translate chinese izzy18_027e66f0:

    # gl "Okay... here we go."
    gl "好吧……开始吧。"

# game/Scenes/Izzy/izzy18.rpy:58
translate chinese izzy18_e277f99d:

    # "As soon as Izzy opens the door, her brothers charge through, hugging her, almost tackling her to the ground."
    "伊兹一打开门，她的两个弟弟就冲了进来，紧紧抱住她，差点把她扑倒在地。"

# game/Scenes/Izzy/izzy18.rpy:59
translate chinese izzy18_d5005b33:

    # "Stanley" "Sissy!"
    "Stanley" "姐姐！"

# game/Scenes/Izzy/izzy18.rpy:62
translate chinese izzy18_29392a48:

    # gl "I missed you two so much."
    gl "我太想你们两个了。"

# game/Scenes/Izzy/izzy18.rpy:63
translate chinese izzy18_b3c27f06:

    # "Paul" "We missed you too, Sis."
    "Paul" "我们也想你，姐姐。"

# game/Scenes/Izzy/izzy18.rpy:64
translate chinese izzy18_5e663f52:

    # "Stanley" "Don't ever let them take us again."
    "Stanley" "千万别再让他们把我们带走了。"

# game/Scenes/Izzy/izzy18.rpy:65
translate chinese izzy18_4b2a23f0:

    # gl "I won't. You're home now."
    gl "我不会的。你们现在回家了。"

# game/Scenes/Izzy/izzy18.rpy:68
translate chinese izzy18_079c6442:

    # "The social worker steps in after them."
    "社工跟在他们身后走了进来。"

# game/Scenes/Izzy/izzy18.rpy:69
translate chinese izzy18_54f57576:

    # "Social Worker" "We just have some paperwork to take care of and I have to do the routine search through the house."
    "Social Worker" "我们只需要处理一些文书工作，而且我得按例搜查一下房子。"

# game/Scenes/Izzy/izzy18.rpy:70
translate chinese izzy18_1e34149c:

    # gl "Yes, ma'am."
    gl "是的，女士。"

# game/Scenes/Izzy/izzy18.rpy:71
translate chinese izzy18_e2ef09a8:

    # gl "Why don't you two go watch some TV in the living room, okay?"
    gl "你们两个去客厅看会儿电视吧，好吗？"

# game/Scenes/Izzy/izzy18.rpy:72
translate chinese izzy18_6330802a:

    # "Paul" "Okay, Sis."
    "Paul" "好的，姐姐。"

# game/Scenes/Izzy/izzy18.rpy:75
translate chinese izzy18_b3f92cd5:

    # "The boys go to the living room and we sit in the kitchen, Izzy holding my hand under the table."
    "男孩们去了客厅，我们坐在厨房里，伊兹在桌子底下握着我的手。"

# game/Scenes/Izzy/izzy18.rpy:76
translate chinese izzy18_3083cd34:

    # "Social Worker" "You're looking good, Isabel. The house looks good too."
    "Social Worker" "你看起来不错，伊莎贝尔。房子也打理得挺好。"

# game/Scenes/Izzy/izzy18.rpy:77
translate chinese izzy18_9df6bcf7:

    # gl "Thank you."
    gl "谢谢。"

# game/Scenes/Izzy/izzy18.rpy:78
translate chinese izzy18_e9ec6fe9:

    # "Social Worker" "And this is?"
    "Social Worker" "这位是？"

# game/Scenes/Izzy/izzy18.rpy:81
translate chinese izzy18_d425bfc9:

    # gl "Oh, this is my boyfriend, [pcname]. He's just here to give me some support."
    gl "哦，这是我的男朋友，[pcname]。他只是过来支持我的。"

# game/Scenes/Izzy/izzy18.rpy:82
translate chinese izzy18_1162fb74:

    # "Social Worker" "Is he living here?"
    "Social Worker" "他住在这里吗？"

# game/Scenes/Izzy/izzy18.rpy:83
translate chinese izzy18_03e12495:

    # gl "No, he just comes over occasionally."
    gl "不，他只是偶尔过来。"

# game/Scenes/Izzy/izzy18.rpy:84
translate chinese izzy18_7ab89bd3:

    # "Social Worker" "I'm going to need his information as well."
    "Social Worker" "我还需要他的信息。"

# game/Scenes/Izzy/izzy18.rpy:87
translate chinese izzy18_c72b1f7c:

    # gl "Is that okay?"
    gl "这样可以吗？"

# game/Scenes/Izzy/izzy18.rpy:88
translate chinese izzy18_977f18ad:

    # pc "Sure, I don't have a criminal history or anything."
    pc "当然，我又没有犯罪记录之类的。"

# game/Scenes/Izzy/izzy18.rpy:89
translate chinese izzy18_37c22e5c:

    # gl "All right, stop bragging."
    gl "好了，别再吹牛了。"

# game/Scenes/Izzy/izzy18.rpy:92
translate chinese izzy18_4a5d20ed:

    # "We go through some very boring paperwork, filling out a dozen forms."
    "我们处理了一些非常枯燥的文书工作，填了十几份表格。"

# game/Scenes/Izzy/izzy18.rpy:95
translate chinese izzy18_407d8bc5:

    # "Then the social worker asks Izzy a lot of questions."
    "然后社工问伊兹很多问题。"

# game/Scenes/Izzy/izzy18.rpy:96
translate chinese izzy18_f60332fb:

    # "I can tell Izzy is nervous. Like if she answers one thing wrong, she's going to lose her brothers again."
    "看得出伊兹很紧张。好像只要回答错一个问题，她就会再次失去她的兄弟们。"

# game/Scenes/Izzy/izzy18.rpy:99
translate chinese izzy18_ff06b03c:

    # "But I give her hand a reassuring squeeze and she makes it through."
    "但我轻轻捏了捏她的手以示安慰，她总算挺过来了。"

# game/Scenes/Izzy/izzy18.rpy:102
translate chinese izzy18_9eab5eb8:

    # "Then I sit in the living room with Paul and Stanley and we watch some cartoons while the social worker does her search through the house."
    "随后我坐在客厅里，和保罗、斯坦利一起看卡通片，社工则在屋里进行检查。"

# game/Scenes/Izzy/izzy18.rpy:105
translate chinese izzy18_2d767d13:

    # "Social Worker" "Everything looks good."
    "Social Worker" "一切看起来都很不错。"

# game/Scenes/Izzy/izzy18.rpy:106
translate chinese izzy18_a15cf495:

    # "Social Worker" "You're doing great, Isabel. I'm really happy to see how much you've improved things around here."
    "Social Worker" "你做得很好，伊莎贝尔。看到你把这里打理得这么好，我真的很高兴。"

# game/Scenes/Izzy/izzy18.rpy:107
translate chinese izzy18_9df6bcf7_1:

    # gl "Thank you."
    gl "谢谢。"

# game/Scenes/Izzy/izzy18.rpy:108
translate chinese izzy18_49402ae6:

    # "Social Worker" "Take care and I'll see you again in two weeks."
    "Social Worker" "保重，两周后见。"

# game/Scenes/Izzy/izzy18.rpy:109
translate chinese izzy18_09005e13:

    # gl "Yes, ma'am. Thank you."
    gl "是的，女士。谢谢您。"

# game/Scenes/Izzy/izzy18.rpy:112
translate chinese izzy18_b3abd917:

    # "Then the social worker leaves and Izzy gasps, like she's been holding her breath the whole time."
    "社工离开后，伊兹猛地呼出一口气，仿佛刚才一直憋着气似的。"

# game/Scenes/Izzy/izzy18.rpy:113
translate chinese izzy18_fa75bbc3:

    # pc "Are you okay?"
    pc "你还好吗？"

# game/Scenes/Izzy/izzy18.rpy:116
translate chinese izzy18_0d5fc033:

    # gl "I did it! Oh my fucking God, I did it!"
    gl "我做到了！天啊，我真的做到了！"

# game/Scenes/Izzy/izzy18.rpy:117
translate chinese izzy18_a279b5e1:

    # gl "Thank you!"
    gl "谢谢您！"

# game/Scenes/Izzy/izzy18.rpy:118
translate chinese izzy18_781ab01e:

    # pc "You did amazing, Izzy."
    pc "你表现得太棒了，伊兹。"

# game/Scenes/Izzy/izzy18.rpy:119
translate chinese izzy18_119e2fab:

    # pc "Want to take them out somewhere to celebrate?"
    pc "要带他们去哪里庆祝一下吗？"

# game/Scenes/Izzy/izzy18.rpy:120
translate chinese izzy18_1ac539d0:

    # gl "I would love that."
    gl "那太好了。"

# game/Scenes/Izzy/izzy18.rpy:123
translate chinese izzy18_c6477fda:

    # "We decide to all go to the arcade together."
    "我们决定一起去游戏厅。"

# game/Scenes/Izzy/izzy18.rpy:124
translate chinese izzy18_273332a9:

    # "Stanley and Paul had never been before and they have a blast playing all the different games there."
    "斯坦利和保罗以前从没去过那里，玩得特别开心，试遍了各种游戏。"

# game/Scenes/Izzy/izzy18.rpy:127
translate chinese izzy18_f36e0cea:

    # "There's a lot of laughing and joking."
    "大家笑声不断，开玩笑不断。"

# game/Scenes/Izzy/izzy18.rpy:128
translate chinese izzy18_c6bbc8d4:

    # "I don't think I've ever seen Izzy smile this much."
    "我觉得我从来没见过伊兹笑得这么开心。"

# game/Scenes/Izzy/izzy18.rpy:131
translate chinese izzy18_b84de43e:

    # "Then we have a dance-off and Paul wipes the floor with all of us."
    "后来我们来场舞蹈对决，保罗把我们全都碾压了。"

# game/Scenes/Izzy/izzy18.rpy:132
translate chinese izzy18_e649e772:

    # gl "Man, this ain't the kind of dancing I know how to do."
    gl "天啊，这可不是我会跳的那种舞。"

# game/Scenes/Izzy/izzy18.rpy:133
translate chinese izzy18_c726dcf4:

    # "Stanley" "What kind of dancing do you know, Sis?"
    "Stanley" "那你会跳什么舞啊，姐？"

# game/Scenes/Izzy/izzy18.rpy:136
translate chinese izzy18_b8613348:

    # pc "Let's go get burgers!"
    pc "咱们去吃汉堡吧！"

# game/Scenes/Izzy/izzy18.rpy:139
translate chinese izzy18_cbc41878:

    # "When we're done at the arcade, we go to Jackson Burger together."
    "玩完游戏厅后，我们一起去杰克逊汉堡店。"

# game/Scenes/Izzy/izzy18.rpy:140
translate chinese izzy18_52fef02b:

    # "Stanley" "Dang, these are good."
    "Stanley" "天啊，这汉堡真好吃。"

# game/Scenes/Izzy/izzy18.rpy:141
translate chinese izzy18_1058b1e6:

    # "Paul" "You work here now, Sis?"
    "Paul" "姐，你现在在这儿工作吗？"

# game/Scenes/Izzy/izzy18.rpy:142
translate chinese izzy18_ffeeb947:

    # gl "Yeah, I do. Here comes my boss right now."
    gl "是啊。我老板这就过来了。"

# game/Scenes/Izzy/izzy18.rpy:145
translate chinese izzy18_c1593b1c:

    # jk "How are you doing, Izzy? These are your brothers?"
    jk "伊兹，你最近怎么样？这些是你兄弟们吗？"

# game/Scenes/Izzy/izzy18.rpy:146
translate chinese izzy18_3dc4d4e6:

    # gl "Yeah, this is them. I got custody back today."
    gl "对，就是他们。我今天刚拿回监护权。"

# game/Scenes/Izzy/izzy18.rpy:147
translate chinese izzy18_ce588c4b:

    # "Paul" "Since she works here, we get free burgers now, right?"
    "Paul" "既然她在这儿工作，那咱们现在能吃免费汉堡了吧？"

# game/Scenes/Izzy/izzy18.rpy:148
translate chinese izzy18_32d684f0:

    # jk "Haha, well sometimes, sure."
    jk "哈哈，嗯，有时候可以。"

# game/Scenes/Izzy/izzy18.rpy:151
translate chinese izzy18_a6caef49:

    # jk "I'm proud of you, kid. You're doing great."
    jk "我为你骄傲，小家伙。你做得真棒。"

# game/Scenes/Izzy/izzy18.rpy:152
translate chinese izzy18_d815f7ea:

    # gl "Thanks, boss."
    gl "谢谢，老板。"

# game/Scenes/Izzy/izzy18.rpy:153
translate chinese izzy18_3e93b6aa:

    # jk "Y'all have fun now."
    jk "你们玩得开心点。"

# game/Scenes/Izzy/izzy18.rpy:156
translate chinese izzy18_762c6ed4:

    # "Full of burgers now, we get back to Izzy's house."
    "吃饱汉堡后，我们回到了伊兹家。"

# game/Scenes/Izzy/izzy18.rpy:157
translate chinese izzy18_04954375:

    # gl "Time to get ready for bed, boys."
    gl "该准备睡觉了，孩子们。"

# game/Scenes/Izzy/izzy18.rpy:158
translate chinese izzy18_f0cc05be:

    # "Paul" "Yeah, okay."
    "Paul" "嗯，好的。"

# game/Scenes/Izzy/izzy18.rpy:159
translate chinese izzy18_890945a8:

    # "Stanley" "I'm sleepy."
    "Stanley" "我困了。"

# game/Scenes/Izzy/izzy18.rpy:162
translate chinese izzy18_8e435665:

    # gl "Tell [pcname] thank you, first."
    gl "先跟[pcname]道声谢谢。"

# game/Scenes/Izzy/izzy18.rpy:163
translate chinese izzy18_7c71e313:

    # "Paul" "Thanks for taking us out, [pcname]. See you later."
    "Paul" "谢谢你带我们出来玩，[pcname]。 回头见。"

# game/Scenes/Izzy/izzy18.rpy:164
translate chinese izzy18_f0c7cd78:

    # "Stanley" "Bye, [pcname]! Thank you!"
    "Stanley" "拜拜，[pcname]！谢谢！"

# game/Scenes/Izzy/izzy18.rpy:167
translate chinese izzy18_edb80472:

    # "Her brothers run off to their room and Izzy turns to look at me."
    "她的兄弟们跑回房间，伊兹转过身看着我。"

# game/Scenes/Izzy/izzy18.rpy:169
translate chinese izzy18_d41d8cd9:

    # voice 'voices/izzy_18_1.mp3'
    voice 'voices/izzy_18_1.mp3'

# game/Scenes/Izzy/izzy18.rpy:170
translate chinese izzy18_5fa69c8d:

    # gl "Thank you. Seriously. For everything."
    gl "谢谢你。真的。谢谢你做的一切。"

# game/Scenes/Izzy/izzy18.rpy:171
translate chinese izzy18_c46a0b54:

    # pc "Any time."
    pc "随时欢迎。"

# game/Scenes/Izzy/izzy18.rpy:175
translate chinese izzy18_d41d8cd9_1:

    # voice 'voices/izzy_18_2.mp3'
    voice 'voices/izzy_18_2.mp3'

# game/Scenes/Izzy/izzy18.rpy:176
translate chinese izzy18_709c5077:

    # gl "I love you."
    gl "我爱你。"

# game/Scenes/Izzy/izzy18.rpy:177
translate chinese izzy18_94fa29a3:

    # pc "I love you too, Izzy."
    pc "我也爱你，伊兹。"

# game/Scenes/Izzy/izzy18.rpy:180
translate chinese izzy18_6d9bb252:

    # gl "You should probably go, though."
    gl "不过你最好还是走吧。"

# game/Scenes/Izzy/izzy18.rpy:181
translate chinese izzy18_ec0cf9f3:

    # gl "I'd love to have you stay the night, but things are probably going to be a little different with my brothers here now."
    gl "我很想让你留宿，但现在我兄弟们都在这儿，情况可能会有点不一样。"

# game/Scenes/Izzy/izzy18.rpy:182
translate chinese izzy18_fc7890c0:

    # gl "We can't just be fucking like crazy with them in the other room, you know?"
    gl "你知道的，他们就在隔壁房间，我们总不能像疯了一样做爱吧？"

# game/Scenes/Izzy/izzy18.rpy:183
translate chinese izzy18_34b44705:

    # pc "I understand."
    pc "我懂。"

# game/Scenes/Izzy/izzy18.rpy:186
translate chinese izzy18_fc89ad79:

    # gl "But I'm still going to find time to get some of that dick."
    gl "但我还是会找时间来尝尝那根肉棒的。"

# game/Scenes/Izzy/izzy18.rpy:187
translate chinese izzy18_07324fcb:

    # gl "Trust."
    gl "放心。"

# game/Scenes/Izzy/izzy18.rpy:190
translate chinese izzy18_7791a395:

    # "We say our goodbyes, then I leave to go on with my night."
    "我们道别后，我便离开去继续我的夜晚。"

