# game/Scenes/Izzy/izzy1.rpy:30
translate spanish izzy1_51076f5a:

    # pc "I just thought I'd come over and say hi. I'm new in town."
    pc "Solo pensé en acercarme a saludar. Soy nuevo en la ciudad."

