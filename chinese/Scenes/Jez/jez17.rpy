translate chinese jez17_d41d8cd9_4:

    # voice 'voices/jez_17_4.mp3'
    voice 'voices/jez_17_4.mp3'

# game/Scenes/Jez/jez17.rpy:69
translate chinese jez17_7d01b471:

    # det "Ai! Go do your homework."
    det "哎哟！去写作业吧。"

# game/Scenes/Jez/jez17.rpy:70
translate chinese jez17_d985b91b:

    # jav "Yes, Mamá."
    jav "好的，妈妈。"

# game/Scenes/Jez/jez17.rpy:73
translate chinese jez17_76e13829:

    # det "Hey, [pcname]. You look great."
    det "嘿，[pcname]。你看起来真棒。"

# game/Scenes/Jez/jez17.rpy:74
translate chinese jez17_e99cb122:

    # pc "So do you."
    pc "你也是。"

# game/Scenes/Jez/jez17.rpy:75
translate chinese jez17_cee6953d:

    # det "Please. I'm all sweaty and gross."
    det "别这么说。我满身是汗，很邋遢。"

# game/Scenes/Jez/jez17.rpy:76
translate chinese jez17_19132156:

    # pc "I like it when you're all sweaty."
    pc "我喜欢你满身大汗的样子。"

# game/Scenes/Jez/jez17.rpy:77
translate chinese jez17_103a9f7f:

    # det "I'm in the kitchen, helping Mamá with dinner. Just make yourself comfortable in here."
    det "我在厨房帮妈妈做晚饭。你就在这儿随便坐吧。"

# game/Scenes/Jez/jez17.rpy:80
translate chinese jez17_11b9483f:

    # "Jez returns to the kitchen and I sit across from Javi at the table."
    "杰兹回到厨房，我坐在餐桌对面和哈维一起。"

# game/Scenes/Jez/jez17.rpy:81
translate chinese jez17_77fcec40:

    # pc "So... homework?"
    pc "所以……作业？"

# game/Scenes/Jez/jez17.rpy:82
translate chinese jez17_6a2e7971:

    # jav "Yeah. It sucks."
    jav "是啊。真烦人。"

# game/Scenes/Jez/jez17.rpy:83
translate chinese jez17_ad40d24a:

    # jav "I want to play Minecraft, but Mamá won't let me until I finish my homework."
    jav "我想玩《我的世界》，但妈妈说不做完作业就不让我玩。"

# game/Scenes/Jez/jez17.rpy:86
translate chinese jez17_989d7f8d:

    # mama "Hola, [pcname]!"
    mama "嗨，[pcname]！"

# game/Scenes/Jez/jez17.rpy:87
