# game/Scenes/Mari/mari3.rpy:12
translate chinese mari3_d41d8cd9:

    # voice 'voices/mari_heythere.mp3'
    voice 'voices/mari_heythere.mp3'

# game/Scenes/Mari/mari3.rpy:13
translate chinese mari3_5fec8fcf:

    # fr "Hey there, [pcname]. How are you today?"
    fr "嗨，[pcname]。今天过得怎么样？"

# game/Scenes/Mari/mari3.rpy:14
translate chinese mari3_b835b9eb:

    # pc "I'm doing great, how's my favorite waitress?"
    pc "我很好，我最喜欢的女服务员呢？"

# game/Scenes/Mari/mari3.rpy:15
translate chinese mari3_334e62bd:

    # fr "Much better now that her favorite customer is here."
    fr "既然我最喜欢的顾客来了，现在感觉好多了。"

# game/Scenes/Mari/mari3.rpy:20
translate chinese mari3_747e36cd:

    # pc "Mari, there was something I wanted to ask you."
    pc "玛丽，有件事我想问你。"

# game/Scenes/Mari/mari3.rpy:21
translate chinese mari3_96d48818:

    # fr "Ask away."
    fr "尽管问。"

# game/Scenes/Mari/mari3.rpy:22
translate chinese mari3_05be9386:

    # pc "Would you want to go out on a date with me sometime?"
    pc "你愿意什么时候和我约个会吗？"

# game/Scenes/Mari/mari3.rpy:25
translate chinese mari3_d41d8cd9_1:

    # voice 'voices/mari_idloveto.mp3'
    voice 'voices/mari_idloveto.mp3'

# game/Scenes/Mari/mari3.rpy:26
translate chinese mari3_ad1c3ebd:

    # fr "Really? I'd love to."
    fr "真的吗？我非常愿意。"

# game/Scenes/Mari/mari3.rpy:27
translate chinese mari3_1da24e01:

    # pc "Awesome."
    pc "太棒了。"

# game/Scenes/Mari/mari3.rpy:29
translate chinese mari3_008e9d39:

    # fr "I don't get to go out on dates very often, and I do really like you."
    fr "我平时很少有机会约会，而且我真的很喜欢你。"

# game/Scenes/Mari/mari3.rpy:30
translate chinese mari3_098a6e78:

    # fr "I'm busy a lot, but I'll give you my phone number and maybe we could go out in the evening on a weekend sometime?"
    fr "我虽然很忙，但我可以给你我的电话号码，也许我们可以在某个周末的晚上出去约会？"

# game/Scenes/Mari/mari3.rpy:31
translate chinese mari3_d2954fc0:

    # pc "That sounds great."
    pc "听起来很棒。"

# game/Scenes/Mari/mari3.rpy:32
translate chinese mari3_52d8f6ae:

    # fr "Oh I'm so excited."
    fr "哦，我太兴奋了。"

# game/Scenes/Mari/mari3.rpy:34
translate chinese mari3_e7685f1d:

    # fr "Here's my phone number."
    fr "这是我的电话号码。"

# game/Scenes/Mari/mari3.rpy:36
translate chinese mari3_639d3c6f:

    # fr "You can call me any time, but I won't be able to talk while I'm working, and I work a lot!"
    fr "你可以随时给我打电话，但我工作的时候没法接，而且我工作很忙！"

# game/Scenes/Mari/mari3.rpy:37
translate chinese mari3_73bf0030:

    # pc "I'll definitely give you a call sometime."
    pc "我肯定会找个时间给你打个电话的。"

# game/Scenes/Mari/mari3.rpy:38
translate chinese mari3_c2bff929:

    # fr "Good, I can't wait!"
    fr "太好了，我等不及了！"

# game/Scenes/Mari/mari3.rpy:39
translate chinese mari3_910292d4:

    # fr "I better go get your food."
    fr "我得去给你拿餐了。"

# game/Scenes/Mari/mari3.rpy:40
translate chinese mari3_63023601:

    # pc "Okay."
    pc "好的。"

# game/Scenes/Mari/mari3.rpy:42
translate chinese mari3_0aa5dfbc:

    # "She starts to walk away, then looks back at me."
    "她转身要走，又回头看了我一眼。"

# game/Scenes/Mari/mari3.rpy:43
translate chinese mari3_8f6f1358:

    # fr "Thanks for asking me out. I'm really looking forward to our date."
    fr "谢谢你约我出去。我真的很期待我们的约会。"

# game/Scenes/Mari/mari3.rpy:44
translate chinese mari3_03eaad50:

    # pc "Me too."
    pc "我也是。"

# game/Scenes/Mari/mari3.rpy:45
translate chinese mari3_7553af6a:

    # "With that, she smiles and leaves to get my food."
    "说完，她笑着去给我拿食物了。"

# game/Scenes/Mari/mari3.rpy:47
translate chinese mari3_43045d37:

    # "We don't talk much more while I eat and she has to help other customers, but every time she looks at me, she's smiling."
    "我吃饭时她得去招呼其他客人，我们没怎么说话，但每次她看我的时候，都在微笑。"

# game/Scenes/Mari/mari3.rpy:48
translate chinese mari3_2d44a908:

    # "The smile is different than usual. More sincere almost."
    "那笑容和平时不太一样。感觉更真诚了些。"

# game/Scenes/Mari/mari3.rpy:51
translate chinese maritip3_474b8780:

    # "I leave 10 dollars on the table."
    "我在桌上留了10美元。"

# game/Scenes/Mari/mari3.rpy:53
translate chinese maritip3_bbc6048f:

    # "No need to leave money, I'll give her something better later."
    "不用留钱，等会儿我会给她更好的。"

# game/Scenes/Mari/mari3.rpy:55
translate chinese maritip3_c56febff:

    # "Then I start to walk out towards my car."
    "随后我走向停车场。"

# game/Scenes/Mari/mari3.rpy:58
translate chinese maritip3_e3c07fca:

    # "Mari stops me though, wrapping her arms around me and pulling me into a hug."
    "不过玛丽拦住了我，双臂环住我，把我拽进怀里。"

# game/Scenes/Mari/mari3.rpy:59
translate chinese maritip3_7db5e01d:

    # fr "I can't wait to see you again."
    fr "我等不及要再见到你了。"

# game/Scenes/Mari/mari3.rpy:60
translate chinese maritip3_98e7787f:

    # fr "Be sure you call me."
    fr "记得给我打电话。"

# game/Scenes/Mari/mari3.rpy:61
translate chinese maritip3_5bc44b07:

    # pc "I will."
    pc "我会打的。"

# game/Scenes/Mari/mari3.rpy:62
translate chinese maritip3_2e512b95:

    # fr "Okay, take care."
    fr "好的，保重。"

# game/Scenes/Mari/mari3.rpy:65
translate chinese maritip3_5794a059:

    # "She releases me and I go outside. She's really excited about our date it seems."
    "她松开我，我走出了餐厅。看来她对这次约会真的很期待。"

# game/Scenes/Mari/mari3.rpy:66
translate chinese maritip3_f0d4672c:

    # "I'm excited too. It should be fun."
    "我也挺期待的。应该会很有趣。"

