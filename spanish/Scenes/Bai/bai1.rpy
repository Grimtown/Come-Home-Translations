translate spanish bai1d_d0ca3261:

    # bai "Hope we can hang out like this again soon."
    bai "Espero que podamos volver a quedar así pronto."

# game/Scenes/Bai/bai1.rpy:258
translate spanish bai1d_03eaad50_1:

    # pc "Me too."
    pc "Yo también."

# game/Scenes/Bai/bai1.rpy:260
translate spanish bai1d_30423311:

    # bai "Hey before we leave, let me give you my phone number."
    bai "Oye, antes de irnos, déjame darte mi número de teléfono."

# game/Scenes/Bai/bai1.rpy:261
translate spanish bai1d_0b8345e6:

    # bai "I don't have a lot of friends around here, so I'd love to just chat with you whenever you feel up to it."
    bai "No tengo muchos amigos por aquí, así que me encantaría charlar contigo cuando te apetezca."

# game/Scenes/Bai/bai1.rpy:262
translate spanish bai1d_465c988e:

    # bai "And maybe we can go out again sometime soon."
    bai "Y quizá podamos volver a salir pronto."

# game/Scenes/Bai/bai1.rpy:263
translate spanish bai1d_50eb93b7:

    # pc "Okay, sounds good."
    pc "Vale, me parece bien."

# game/Scenes/Bai/bai1.rpy:270
translate spanish bai1d_0e8a2008:

    # "We finish up our food, he leaves some money on the table, then we head outside."
    "Terminamos de comer, él deja algo de dinero sobre la mesa y luego salimos."

# game/Scenes/Bai/bai1.rpy:271
translate spanish bai1d_630eae85:

    # bai "Well that was the most fun I've had in a while."
    bai "Bueno, me lo he pasado mejor que en mucho tiempo."

# game/Scenes/Bai/bai1.rpy:272
translate spanish bai1d_a96bfd7d:

    # bai "Thanks again for hanging out with me tonight."
    bai "Gracias de nuevo por salir conmigo esta noche."

# game/Scenes/Bai/bai1.rpy:273
translate spanish bai1d_fe5246ec:

    # pc "No problem. I had fun too."
    pc "No hay problema. Yo también me lo he pasado bien."

# game/Scenes/Bai/bai1.rpy:274
translate spanish bai1d_b6980062:

    # bai "Alright, well I better head home."
    bai "Vale, bueno, mejor me voy a casa."

# game/Scenes/Bai/bai1.rpy:276
translate spanish bai1d_5d4a4d14:

    # bai "I'll see you later."
    bai "Nos vemos luego."

# game/Scenes/Bai/bai1.rpy:277
translate spanish bai1d_1aff6c8c:

    # pc "See ya, Bai."
    pc "Nos vemos, Bai."

# game/Scenes/Bai/bai1.rpy:278
translate spanish bai1d_ba9439b8:

    # "He goes to his car and drives off and I walk to mine."
    "Se dirige a su coche y se marcha, y yo camino hacia el mío."

