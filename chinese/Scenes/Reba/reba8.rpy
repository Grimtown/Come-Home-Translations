# game/Scenes/Reba/reba8.rpy:20
translate chinese reba8_d1862604:

    # "My phone starts buzzing. Reba's calling."
    "手机开始震动。是瑞芭打来的。"

# game/Scenes/Reba/reba8.rpy:23
translate chinese reba8_bea5e8cb:

    # pc "Hello?"
    pc "喂？"

# game/Scenes/Reba/reba8.rpy:24
translate chinese reba8_6f14a2e1:

    # rb "Good morning, sunshine! Oh, did I wake you up? I'm sorry!"
    rb "早上好，小太阳！哦，是我吵醒你了吗？真抱歉！"

# game/Scenes/Reba/reba8.rpy:25
translate chinese reba8_f259614b:

    # rb "I was just wondering if you wanted to hang out this afternoon."
    rb "我只是想问问你今天下午想不想一起出去玩。"

# game/Scenes/Reba/reba8.rpy:27
translate chinese reba8_985f82ca:

    # rb "Was thinking about taking the truck out mudding. You wanna come?"
    rb "我正打算开卡车去玩泥地越野。你要不要一起去？"

# game/Scenes/Reba/reba8.rpy:30
translate chinese reba8mudding_6cec19f1:

    # pc "What's mudding?"
    pc "什么是泥地越野？"

# game/Scenes/Reba/reba8.rpy:32
translate chinese reba8mudding_e7087767:

    # rb "You never heard of mudding?"
    rb "你没听说过泥地越野？"

# game/Scenes/Reba/reba8.rpy:34
translate chinese reba8mudding_b6ed8158:

    # rb "You really are a city boy!"
    rb "你真是个城里小子！"

# game/Scenes/Reba/reba8.rpy:35
translate chinese reba8mudding_e360ee19:

    # rb "Mudding is when you take your truck, or 4-wheeler, or whatever out into a muddy place and drive through mud."
    rb "“泥地驾驶”就是开着皮卡、四轮车或者别的什么车去泥泞的地方，在泥里开来开去。"

# game/Scenes/Reba/reba8.rpy:36
translate chinese reba8mudding_a8bf8c06:

    # rb "You sling that stuff all over the place, make a big mess."
    rb "你会把泥巴甩得到处都是，弄得一团糟。"

# game/Scenes/Reba/reba8.rpy:37
translate chinese reba8mudding_9408222a:

    # rb "It's fun!"
    rb "很有趣！"

# game/Scenes/Reba/reba8.rpy:39
translate chinese reba8mudding_d01eb8f7:

    # rb "So you want to come mudding with me?"
    rb "所以你想跟我一起去泥地驾驶吗？"

# game/Scenes/Reba/reba8.rpy:46
translate chinese reba8mudding_90947dda:

    # rb "Oh okay. Well maybe next week then."
    rb "哦，好吧。那可能下周吧。"

# game/Scenes/Reba/reba8.rpy:50
translate chinese reba8mudding_e88ebc4a:

    # rb "Okay, I'll call you then. Hope you have a great day, [pcname]."
    rb "好的，到时候我给你打电话。祝你今天过得愉快，[pcname]。"

# game/Scenes/Reba/reba8.rpy:51
translate chinese reba8mudding_19e6f6ea:

    # pc "You too Reba. Bye."
    pc "你也一样，瑞芭。再见。"

# game/Scenes/Reba/reba8.rpy:56
translate chinese reba8mudding_d3af0ef5:

    # rb "You're just not interested at all?"
    rb "你完全没兴趣吗？"

# game/Scenes/Reba/reba8.rpy:57
translate chinese reba8mudding_fdf33919:

    # pc "No, I'm not. Sorry."
    pc "没有，我没兴趣。抱歉。"

# game/Scenes/Reba/reba8.rpy:59
translate chinese reba8mudding_24e974ff:

    # rb "Okay then. Take care, [pcname]."
    rb "那好吧。保重，[pcname]。"

# game/Scenes/Reba/reba8.rpy:60
translate chinese reba8mudding_dbe309fc:

    # rb "Bye."
    rb "再见。"

# game/Scenes/Reba/reba8.rpy:63
translate chinese reba8mudding_273bc4d3:

    # "She hangs up. I guess that's it for me and Reba. Oh well - plenty of others out there I'm more interested in."
    "她挂了电话。看来我和瑞芭的事到此为止了。算了——外面还有很多我更感兴趣的女孩。"

# game/Scenes/Reba/reba8.rpy:68
translate chinese reba8mudding_5cc21e87:

    # rb "Yay! Come on out here then! I'll start getting ready."
    rb "太棒了！那快过来吧！我这就开始准备。"

# game/Scenes/Reba/reba8.rpy:69
translate chinese reba8mudding_2c0a751f:

    # pc "Okay, see you in a bit."
    pc "好的，一会儿见。"

# game/Scenes/Reba/reba8.rpy:70
translate chinese reba8mudding_9cdb897f:

    # rb "I can't wait! This is gonna be so dang fun!"
    rb "我等不及了！这肯定会超级好玩！"

# game/Scenes/Reba/reba8.rpy:73
translate chinese reba8mudding_f8872536:

    # "She hangs up and I go get dressed and head out towards her trailer."
    "她挂了电话，我换好衣服，朝她的拖车走去。"

# game/Scenes/Reba/reba8.rpy:78
translate chinese reba8mudding_1e97ea52:

    # "When I get to her trailer, she's already outside waiting for me."
    "到了她的拖车那里，她已经在外面等我了。"

# game/Scenes/Reba/reba8.rpy:79
translate chinese reba8mudding_611dcce8:

    # rb "Hey, [pcname]."
    rb "嘿，[pcname]。"

# game/Scenes/Reba/reba8.rpy:80
translate chinese reba8mudding_ee516682:

    # pc "Hey, Reba. You're looking cute."
    pc "嘿，瑞芭。你看起来真可爱。"

# game/Scenes/Reba/reba8.rpy:82
translate chinese reba8mudding_20522f33:

    # rb "Thanks! Just some old overalls that I don't care about getting muddy."
    rb "谢谢！就只是一条旧工装裤，弄脏了也没关系。"

# game/Scenes/Reba/reba8.rpy:83
translate chinese reba8mudding_1a0f92f5:

    # pc "Well you look great."
    pc "嗯，你看起来很棒。"

# game/Scenes/Reba/reba8.rpy:84
translate chinese reba8mudding_6bf9d827:

    # pc "Your brother isn't going to be coming with us, is he?"
    pc "你哥哥不会跟我们一起去吧？"

# game/Scenes/Reba/reba8.rpy:86
translate chinese reba8mudding_cd9c66f2:

    # rb "Nah, he's out with his friends right now and won't be back for a while."
    rb "不会，他现在和朋友出去玩了，过会儿才回来。"

# game/Scenes/Reba/reba8.rpy:87
translate chinese reba8mudding_3bbcece5:

    # rb "So, let's go. I'm looking forward to this."
    rb "那，走吧。我期待这次活动。"

# game/Scenes/Reba/reba8.rpy:90
translate chinese reba8mudding_bac3c1f7:

    # "I follow her over to a truck that is not the one I expected to see."
    "我跟着她走到一辆卡车前，这辆车和我预想的不一样。"

# game/Scenes/Reba/reba8.rpy:91
translate chinese reba8mudding_701cd65b:

    # pc "This is your truck? What happened to the old red classic one?"
    pc "这是你的车？那辆经典的红色老车呢？"

# game/Scenes/Reba/reba8.rpy:92
translate chinese reba8mudding_ed741e5e:

    # rb "Oh I left it at the garage today. Not going to take that one out mudding, of course. That's just for weekend drives."
    rb "哦，今天我把它留在车库了。当然不会开那辆去玩泥巴，那只是周末兜风用的。"

# game/Scenes/Reba/reba8.rpy:93
translate chinese reba8mudding_b0f293e1:

    # rb "This one I'm not afraid to beat up a little."
    rb "这辆我可不怕弄脏。"

# game/Scenes/Reba/reba8.rpy:96
translate chinese reba8mudding_9138b610:

    # rb "You ready to do this?"
    rb "准备好了吗？"

# game/Scenes/Reba/reba8.rpy:97
translate chinese reba8mudding_69f1deb2:

    # pc "Sure, let's go."
    pc "当然，走吧。"

# game/Scenes/Reba/reba8.rpy:98
translate chinese reba8mudding_8e844e87:

    # rb "I know this one spot where there's ALWAYS mud. I'll take you there."
    rb "我知道有个地方总是有泥巴，我带你去。"

# game/Scenes/Reba/reba8.rpy:101
translate chinese reba8mudding_c74fb292:

    # "She drives us out into the middle of nowhere, taking curving backroads until I'm completely lost."
    "她开车带我们驶向荒郊野外，沿着蜿蜒的乡间小路前行，直到我彻底迷失方向。"

# game/Scenes/Reba/reba8.rpy:102
translate chinese reba8mudding_d33cf134:

    # "She seems to know exactly where she's going, but there's no way I would be able to find my way back through this maze of paths that could barely be called roads."
    "她似乎对路线了如指掌，但这迷宫般的路径简直难称道路，我绝对找不到回程的路。"

# game/Scenes/Reba/reba8.rpy:103
translate chinese reba8mudding_16815133:

    # "Then she parks in front of a muddy path through the forest in front of us. "
    "随后，她将车停在我们面前一条穿过森林的泥泞小径前。"

# game/Scenes/Reba/reba8.rpy:106
translate chinese reba8mudding_0f04ea1b:

    # "She looks over at me, a somewhat unsettling smile on her face."
    "她朝我望来，脸上挂着一种令人不安的微笑。"

# game/Scenes/Reba/reba8.rpy:107
translate chinese reba8mudding_8e751324:

    # rb "Are you ready?"
    rb "准备好了吗？"

# game/Scenes/Reba/reba8.rpy:108
translate chinese reba8mudding_5a8379d3:

    # pc "Uh... sure."
    pc "呃……当然。"

# game/Scenes/Reba/reba8.rpy:109
translate chinese reba8mudding_0d43968d:

    # rb "Okay, get your phone out and keep time for me. I've done this track in one minute and five seconds, hitting all the mud pits before. I wanna to see if I can beat that time."
    rb "好，拿出手机帮我计时。我之前跑过这条路线，用时一分零五秒，而且每个泥坑都踩到了。我想看看能不能打破这个纪录。"

# game/Scenes/Reba/reba8.rpy:110
translate chinese reba8mudding_63023601:

    # pc "Okay."
    pc "好的。"

# game/Scenes/Reba/reba8.rpy:111
translate chinese reba8mudding_5d0cf67b:

    # "I fumble my phone out, get my finger over the start button of the stopwatch app, and then start to count down."
    "我笨拙地掏出手机，手指按在计时器应用的开始键上，然后开始倒计时。"

# game/Scenes/Reba/reba8.rpy:112
translate chinese reba8mudding_f184bd09:

    # rb "Go!"
    rb "走！"

# game/Scenes/Reba/reba8.rpy:115
translate chinese reba8mudding_98515560:

    # "She pushes the pedal all the way down, causing the tires to spin for just a moment before they gain traction and launch us forward."
    "她将油门踩到底，轮胎空转了一瞬间，随即抓地，猛地将我们向前甩去。"

# game/Scenes/Reba/reba8.rpy:116
translate chinese reba8mudding_ac5744a1:

    # "I'm barely able to hold onto my phone as I'm slammed backwards in the seat."
    "我被狠狠地甩回座位，几乎抓不住手机。"

# game/Scenes/Reba/reba8.rpy:117
translate chinese reba8mudding_8dc485bd:

    # "Maybe I should have worn a seat belt? I'm not even sure this truck has seat belts!"
    "也许我该系上安全带？我甚至不确定这辆卡车有没有安全带！"

# game/Scenes/Reba/reba8.rpy:120
translate chinese reba8mudding_5562507a:

    # "The truck barrels ahead and hits a large mud pit, sending mud flying into the air and bouncing me about in the cabin."
    "卡车如脱缰野马般冲向前方，撞进一个巨大的泥坑，泥浆四溅，我在车厢里被抛来抛去。"

# game/Scenes/Reba/reba8.rpy:121
translate chinese reba8mudding_a90c1d29:

    # rb "Wooohoooo!"
    rb "哇哦——！"

# game/Scenes/Reba/reba8.rpy:122
translate chinese reba8mudding_89afb209:

    # "She cheers and doesn't slow down at all as she spins through the next turn and on to the next mud pit."
    "她欢呼着，丝毫没有减速，径直冲过下一个弯道，驶向下一个泥坑。"

# game/Scenes/Reba/reba8.rpy:125
translate chinese reba8mudding_c2cf0ebc:

    # "The truck slides, and me along with it, every time we turn a corner."
    "每次转弯，卡车都会打滑，我也随之晃动。"

# game/Scenes/Reba/reba8.rpy:128
translate chinese reba8mudding_8ce22517:

    # "Every time she hits a mud pit, we spray more mud all over the truck."
    "每次撞进泥坑，卡车身上都会溅满更多的泥浆。"

# game/Scenes/Reba/reba8.rpy:129
translate chinese reba8mudding_95dfd36d:

    # "I hold my hand against the ceiling to try to keep myself in my seat."
    "我用手撑住车顶，努力让自己别从座位上滑出去。"

# game/Scenes/Reba/reba8.rpy:130
translate chinese reba8mudding_b6be7db2:

    # rb "Hold on to your butt! This last one is a real hoosawhatsit."
    rb "抓紧你的屁股！最后这个泥坑可真是个大麻烦。"

# game/Scenes/Reba/reba8.rpy:133
translate chinese reba8mudding_9e1718b9:

    # "We keep going faster, the windshield is covered with mud to the point that I'm not sure how she can even see anymore."
    "我们越开越快，挡风玻璃上已经沾满了泥，我都不知道她还能不能看清路。"

# game/Scenes/Reba/reba8.rpy:134
translate chinese reba8mudding_37c878ad:

    # rb "We're coming up on the finish, get your stopwatch ready!"
    rb "快到终点了，准备好你的秒表！"

# game/Scenes/Reba/reba8.rpy:135
translate chinese reba8mudding_f514d106:

    # pc "Oh thank God."
    pc "哦，谢天谢地。"

# game/Scenes/Reba/reba8.rpy:136
translate chinese reba8mudding_799b862b:

    # rb "Okay... now!"
    rb "好了……现在！"

# game/Scenes/Reba/reba8.rpy:139
translate chinese reba8mudding_b7684910:

    # "Finally Reba presses on the brakes and the truck lurches to a stop. I let out a breath I didn't realize I'd been holding."
    "终于，瑞芭踩下刹车，卡车猛地停了下来。我松了一口气，甚至没意识到自己一直憋着气。"

# game/Scenes/Reba/reba8.rpy:140
translate chinese reba8mudding_1dbb6329:

    # rb "So? How did I do?"
    rb "怎么样？我表现得如何？"

# game/Scenes/Reba/reba8.rpy:141
translate chinese reba8mudding_f6466edf:

    # "I look at the time on the stopwatch."
    "我看了看秒表上的时间。"

# game/Scenes/Reba/reba8.rpy:142
translate chinese reba8mudding_7270a13f:

    # pc "One minute, three seconds."
    pc "一分钟零三秒。"

# game/Scenes/Reba/reba8.rpy:143
translate chinese reba8mudding_b149628e:

    # rb "New record! Yes!"
    rb "新纪录！太棒了！"

# game/Scenes/Reba/reba8.rpy:144
translate chinese reba8mudding_8658f887:

    # rb "That was fun, right?"
    rb "这很有趣，对吧？"

# game/Scenes/Reba/reba8.rpy:145
translate chinese reba8mudding_89a6c21b:

    # pc "Yeah. Fun."
    pc "是啊。挺好玩的。"

# game/Scenes/Reba/reba8.rpy:146
translate chinese reba8mudding_7d646560:

    # rb "Good, because I think we can do better. Let's do it again!"
    rb "太好了，因为我觉得我们还能做得更好。再来一次吧！"

# game/Scenes/Reba/reba8.rpy:149
translate chinese reba8mudding_bd620e81:

    # "We spend the next hour or so driving around the mud track until the truck is completely covered, and I have completely lost feeling in my ass."
    "接下来的一个多小时里，我们在这条泥泞的赛道上兜圈子，直到卡车浑身沾满泥巴，我的屁股也完全麻木了。"

# game/Scenes/Reba/reba8.rpy:150
translate chinese reba8mudding_343cd1cb:

    # "Reba has a blast, and though I'm terrified that we'll get stuck or crash into a tree or something, after a bit, I start to have a fun just watching her have fun."
    "丽贝卡玩得特别尽兴，虽然我一直害怕我们会陷在泥里，或者撞上树什么的，但过了一会儿，光是看着她玩得开心，我也开始觉得有趣了。"

# game/Scenes/Reba/reba8.rpy:153
translate chinese reba8mudding_973634d2:

    # "Then she finally has her fill and we head back to her trailer."
    "后来她终于玩够了，我们便返回她的拖车房。"

# game/Scenes/Reba/reba8.rpy:156
translate chinese reba8mudding_05492d38:

    # "She pulls in and parks in the field near her trailer and turns towards me."
    "她把车开进拖车旁的空地停好，转过身来面对我。"

# game/Scenes/Reba/reba8.rpy:159
translate chinese reba8mudding_75a03e1e:

    # rb "So did you have fun?"
    rb "“玩得开心吗？”"

# game/Scenes/Reba/reba8.rpy:160
translate chinese reba8mudding_a96bbb2c:

    # pc "I did. I wasn't sure if I would, and I was a little worried at first, but yeah, it was really fun."
    pc "“开心。起初我没把握，也有些担心，但确实玩得很尽兴。”"

# game/Scenes/Reba/reba8.rpy:161
translate chinese reba8mudding_aeccbbbf:

    # pc "I don't envy you having to wash this truck though. Getting all that dirt off is not going to be easy."
    pc "“不过我可不羡慕你得洗这辆卡车。把那些泥土洗干净可不容易。”"

# game/Scenes/Reba/reba8.rpy:162
translate chinese reba8mudding_513ca920:

    # rb "I don't mind though. It's okay to get a little dirty every once in a while."
    rb "“我倒是不介意。” 偶尔弄脏一点也没关系。"

# game/Scenes/Reba/reba8.rpy:165
translate chinese reba8mudding_2c34965d:

    # "Without warning, she slides over and straddles me, sitting on my lap and kissing me hungrily."
    "毫无预兆地，她滑过来跨坐在我身上，坐在我的腿上，饥渴地吻着我。"

# game/Scenes/Reba/reba8.rpy:166
translate chinese reba8mudding_1afe0aad:

    # "Her hands are all over me, caressing, pulling me closer as she grinds her hips on my lap."
    "她的双手在我身上游走，爱抚着我，一边将我拉近，一边用臀部在我腿上磨蹭。"

# game/Scenes/Reba/reba8.rpy:167
translate chinese reba8mudding_b05dede8:

    # rb "You feel so good."
    rb "你摸起来真舒服。"

# game/Scenes/Reba/reba8.rpy:168
translate chinese reba8mudding_1ddd540f:

    # pc "Should we be doing this here?"
    pc "我们在这里做这个合适吗？"

# game/Scenes/Reba/reba8.rpy:169
translate chinese reba8mudding_f3c90719:

    # rb "I just want to kiss you a little. I'm not planning on having sex with you."
    rb "我只是想亲亲你。我没打算跟你做爱。"

# game/Scenes/Reba/reba8.rpy:170
translate chinese reba8mudding_78efb177:

    # rb "At least not right here, right now."
    rb "至少不是就在这里，不是现在。"

# game/Scenes/Reba/reba8.rpy:171
translate chinese reba8mudding_db7d54af:

    # rb "But geez, I want to. Really bad."
    rb "但天啊，我好想。真的好想。"

# game/Scenes/Reba/reba8.rpy:174
translate chinese reba8mudding_01b84f46:

    # "Suddenly, the moment is broken by a loud banging on the window."
    "突然，窗外传来一阵猛烈的敲击声，打破了这片宁静。"

# game/Scenes/Reba/reba8.rpy:175
translate chinese reba8mudding_b1399e56:

    # mk "You get the fuck off my sister!"
    mk "你给我滚开，别碰我妹妹！"

# game/Scenes/Reba/reba8.rpy:176
translate chinese reba8mudding_f430f39f:

    # mk "Get out of there right now!"
    mk "立刻给我滚出去！"

# game/Scenes/Reba/reba8.rpy:177
translate chinese reba8mudding_d3c077e8:

    # rb "Oh no."
    rb "哦，不。"

# game/Scenes/Reba/reba8.rpy:178
translate chinese reba8mudding_da60c5f6:

    # mk "Come on out now!"
    mk "快出来！"

# game/Scenes/Reba/reba8.rpy:181
translate chinese reba8mudding_ac03042f:

    # "We both get out of the car and Reba slams the door behind her."
    "我们俩都下了车，瑞芭砰地关上了车门。"

# game/Scenes/Reba/reba8.rpy:182
translate chinese reba8mudding_f3332dc9:

    # rb "Mickey, we talked about this!"
    rb "米奇，我们说好了的！"

# game/Scenes/Reba/reba8.rpy:183
translate chinese reba8mudding_65738771:

    # mk "If you think I'm gonna let this asshole fuck my sister right outside of my house, you're outta your goddamn mind."
    mk "“如果你以为我会让这混蛋在我家门口干我妹妹，那你他妈的脑子有问题。”"

# game/Scenes/Reba/reba8.rpy:184
translate chinese reba8mudding_94d699fc:

    # rb "We wasn't, Mickey! We wasn't doing anything!"
    rb "“我们没……米奇！我们什么都没做！”"

# game/Scenes/Reba/reba8.rpy:185
translate chinese reba8mudding_25793dab:

    # mk "And you ain't gonna, cause I'm gonna teach this boy a lesson!"
    mk "“而且你们也做不了，因为我要给这小子点教训！”"

# game/Scenes/Reba/reba8.rpy:188
translate chinese reba8mudding_ccda4aeb:

    # "It's obvious that Reba isn't going to be able to talk any sense into him this time."
    "很明显，这次丽贝卡是说服不了他的了。"

# game/Scenes/Reba/reba8.rpy:189
translate chinese reba8mudding_c5f2f949:

    # "He comes at me, fist raised."
    "他朝我冲过来，拳头高高举起。"

# game/Scenes/Reba/reba8.rpy:192
translate chinese reba8mudding_0552f3ff:

    # "All that training with Tammy comes in handy. This guy is nothing compared to the punches that she has thrown at me."
    "和塔米一起练过的功夫派上了用场。这家伙跟她打在我身上的那些拳头比起来根本不算什么。"

# game/Scenes/Reba/reba8.rpy:203
translate chinese reba8mudding_781f13e4:

    # "I step into the punch, knocking his hand to the side and countering with a right hook to the side of his jaw. It lands with a satisfying crack."
    "我迎着他的拳头迈步，将他的手打偏，随即用一记右勾拳击中他的下颌侧面。拳头击中时发出令人满意的脆响。"

# game/Scenes/Reba/reba8.rpy:206
translate chinese reba8mudding_510db655:

    # "I go in for another punch, but Reba jumps between us."
    "我正要再出拳，但丽贝卡跳到我们中间。"

# game/Scenes/Reba/reba8.rpy:207
translate chinese reba8mudding_53c501af:

    # rb "No! Stop fighting!"
    rb "不！别打了！"

# game/Scenes/Reba/reba8.rpy:208
translate chinese reba8mudding_ceeca70d:

    # mk "I'm gonna fucking kill him, get out of my way!"
    mk "我他妈的要杀了他，给我让开！"

# game/Scenes/Reba/reba8.rpy:209
translate chinese reba8mudding_b769b5ca:

    # rb "No you're not!"
    rb "“不，你别想！”"

# game/Scenes/Reba/reba8.rpy:210
translate chinese reba8mudding_d9fe3e76:

    # pc "She's right, if you come at me again I'm going to lay you out."
    pc "“她说得对，你要是再敢动我，我就把你打趴下。”"

# game/Scenes/Reba/reba8.rpy:211
translate chinese reba8mudding_0caaea36:

    # mk "That was a lucky punch you son of a bitch!"
    mk "“那只是运气好打中的，你这混蛋！”"

# game/Scenes/Reba/reba8.rpy:212
translate chinese reba8mudding_a2a7eb65:

    # rb "STOP!"
    rb "“住手！”"

# game/Scenes/Reba/reba8.rpy:213
translate chinese reba8mudding_54567e75:

    # rb "Just go, [pcname]. I'll talk to you later."
    rb "“你先走吧，[pcname]。等会儿再跟你谈。”"

# game/Scenes/Reba/reba8.rpy:214
translate chinese reba8mudding_61f77a4c:

    # pc "Sure."
    pc "“行。”"

# game/Scenes/Reba/reba8.rpy:218
translate chinese reba8mudding_bdfd4cce:

    # "That training with Tammy comes in handy. This guy is nothing compared to the punches that she had thrown at me."
    "和塔米一起练的那些招派上了用场。这家伙跟她以前打在我身上的那些拳头比起来，根本不算什么。"

# game/Scenes/Reba/reba8.rpy:219
translate chinese reba8mudding_6c41ac4b:

    # "I easily step outside of his punch and prepare to dodge whatever he has to follow it up with."
    "我轻松闪开他的拳头，准备躲开他接下来的任何招式。"

# game/Scenes/Reba/reba8.rpy:222
translate chinese reba8mudding_d02d2a53:

    # "Before he can throw another one though, Reba jumps between us."
    "不过在他能再出拳之前，瑞芭跳到了我们中间。"

# game/Scenes/Reba/reba8.rpy:223
translate chinese reba8mudding_53c501af_1:

    # rb "No! Stop fighting!"
    rb "不！别打了！"

# game/Scenes/Reba/reba8.rpy:224
translate chinese reba8mudding_ace0e755:

    # mk "This asshole needs to be taught a lesson!"
    mk "这混蛋得教训一下！"

# game/Scenes/Reba/reba8.rpy:225
translate chinese reba8mudding_64d142d4:

    # pc "I didn't do anything."
    pc "我什么都没做。"

# game/Scenes/Reba/reba8.rpy:226
translate chinese reba8mudding_c9511b36:

    # mk "You're trying to fuck my sister!"
    mk "你想搞我妹妹！"

# game/Scenes/Reba/reba8.rpy:227
translate chinese reba8mudding_a40a4d44:

    # rb "We didn't do nothing, Mickey! Stop!"
    rb "我们什么都没做，米奇！住手！"

# game/Scenes/Reba/reba8.rpy:228
translate chinese reba8mudding_54567e75_1:

    # rb "Just go, [pcname]. I'll talk to you later."
    rb "你先走吧，[pcname]。等会儿再跟你聊。"

# game/Scenes/Reba/reba8.rpy:229
translate chinese reba8mudding_61f77a4c_1:

    # pc "Sure."
    pc "行。"

# game/Scenes/Reba/reba8.rpy:234
translate chinese reba8mudding_a3c096b9:

    # "I try to get my hands up, but I have no experience with fighting and I don't know what I'm doing."
    "我试图举起双手，但我毫无格斗经验，根本不知道该怎么做。"

# game/Scenes/Reba/reba8.rpy:235
translate chinese reba8mudding_29541e19:

    # "I nearly fall to the ground when Mickey's fist lands cleanly with my jaw, making my head rock back."
    "米奇的拳头正中我的下巴，我的头猛地向后甩去，差点摔倒在地。"

# game/Scenes/Reba/reba8.rpy:238
translate chinese reba8mudding_7167e5de:

    # "I manage to stay on my feet and turn expecting another punch to come up at me, but Reba steps between us."
    "我勉强站稳，转身准备迎接下一拳，但瑞芭又挡在了我们中间。"

# game/Scenes/Reba/reba8.rpy:239
translate chinese reba8mudding_53c501af_2:

    # rb "No! Stop fighting!"
    rb "“不！别打了！”"

# game/Scenes/Reba/reba8.rpy:240
translate chinese reba8mudding_1cc87b7a:

    # mk "Get out of my way Reba! I'm going to kick his ass!"
    mk "“让开，丽贝卡！我要揍扁他！”"

# game/Scenes/Reba/reba8.rpy:241
translate chinese reba8mudding_b0ef0d77:

    # rb "No! Mickey don't, he didn't do anything!"
    rb "“不！米奇别这样，他什么都没做！”"

# game/Scenes/Reba/reba8.rpy:242
translate chinese reba8mudding_c7a337dd:

    # mk "He's out here trying to fuck you."
    mk "“他明明是来勾引你的。”"

# game/Scenes/Reba/reba8.rpy:243
translate chinese reba8mudding_cf33bf08:

    # pc "No, I--"
    pc "“不，我——”"

# game/Scenes/Reba/reba8.rpy:244
translate chinese reba8mudding_f8c3269f:

    # rb "We didn't do nothing, Mickey!"
    rb "“我们什么都没做，米奇！”"

# game/Scenes/Reba/reba8.rpy:245
translate chinese reba8mudding_54567e75_2:

    # rb "Just go, [pcname]. I'll talk to you later."
    rb "“你先走吧，[pcname]。等会儿再跟你谈。”"

# game/Scenes/Reba/reba8.rpy:246
translate chinese reba8mudding_61f77a4c_2:

    # pc "Sure."
    pc "“行。”"

# game/Scenes/Reba/reba8.rpy:250
translate chinese reba8mudding_e5760220:

    # "I walk back towards my car, annoyed at the whole situation."
    "我走向自己的车，对整件事感到恼火。"

# game/Scenes/Reba/reba8.rpy:251
translate chinese reba8mudding_47832cf5:

    # mk "Yeah you better leave city boy. You come out here and mess with my sister again and I'll fucking kill you."
    mk "是啊，你最好滚蛋，城里小子。你要是再敢来这儿招惹我妹妹，我他妈的杀了你。"

# game/Scenes/Reba/reba8.rpy:252
translate chinese reba8mudding_de895dda:

    # rb "Shut up, Mickey!"
    rb "闭嘴，米奇！"

# game/Scenes/Reba/reba8.rpy:253
translate chinese reba8mudding_268e6bf6:

    # "I think about going back and finishing this right here, but Reba is already upset, and I'm upset, and I don't think us having a brawl will make the situation any better."
    "我本想回去把这事解决干净，但丽贝卡已经很生气了，我也火大，我觉得打起来对局面没什么好处。"

# game/Scenes/Reba/reba8.rpy:255
translate chinese reba8mudding_1ae8c9bc:

    # "Plus, I'm not even sure I could take him. He might actually kill me."
    "而且，我甚至不确定自己能打赢他。他说不定真会杀了我。"

# game/Scenes/Reba/reba8.rpy:258
translate chinese reba8mudding_953ca1e1:

    # "I get into my car and drive away. Hopefully I can spend some more time with Reba later, but this shit with her brother is getting old."
    "我钻进车里开走了。希望稍后还能再和丽芭待会儿，但她哥哥这事真让人烦透了。"

# game/Scenes/Reba/reba8.rpy:261
translate chinese reba8mudding_9669528e:

    # "Later..."
    "稍后……"

# game/Scenes/Reba/reba8.rpy:268
translate chinese reba8b_9c8ee4a8:

    # "I start to get ready for bed and my phone rings. Reba's calling."
    "我正准备睡觉，手机响了。是丽芭打来的。"

# game/Scenes/Reba/reba8.rpy:273
translate chinese reba8b_ec87f6ba:

    # pc "Hello."
    pc "喂。"

# game/Scenes/Reba/reba8.rpy:274
translate chinese reba8b_611dcce8:

    # rb "Hey, [pcname]."
    rb "嘿，[pcname]。"

# game/Scenes/Reba/reba8.rpy:276
translate chinese reba8b_2cf6fac4:

    # rb "I just wanted to apologize for Mickey."
    rb "我只是想为米奇的事道歉。"

# game/Scenes/Reba/reba8.rpy:277
translate chinese reba8b_3f19332b:

    # rb "He's such a pain in the butt sometimes, you know?"
    rb "他有时候真是个烦人的家伙，你知道的？"

# game/Scenes/Reba/reba8.rpy:278
translate chinese reba8b_66ecc76b:

    # rb "With Daddy gone, he thinks that it's his job to protect me. But I'm 19. I'm an adult. I can do whatever I want."
    rb "爸爸不在了，他觉得保护我是他的责任。但我已经19岁了，是个成年人，想做什么就做什么。"

# game/Scenes/Reba/reba8.rpy:279
translate chinese reba8b_c1b58d40:

    # rb "Still, I can't convince him to leave it alone."
    rb "可我就是说服不了他别管这事。"

# game/Scenes/Reba/reba8.rpy:281
translate chinese reba8b_f0842945:

    # rb "So, I'd like to see you again, but it's probably a good idea if you don't come out to the trailer anymore."
    rb "所以，我很想再见你，但你最好别再来拖车房了。"

# game/Scenes/Reba/reba8.rpy:286
translate chinese reba8b_7bb269b5:

    # rb "Yeah, I guess that's the other option."
    rb "嗯，我想这也是个办法。"

# game/Scenes/Reba/reba8.rpy:287
translate chinese reba8b_3090c8da:

    # rb "Okay. I had a good time today, [pcname]. Sorry it didn't go like we planned though."
    rb "好的。今天我很开心，[pcname]。不过很抱歉事情没按计划进行。"

# game/Scenes/Reba/reba8.rpy:288
translate chinese reba8b_9e254bb2:

    # rb "Take care. Bye."
    rb "保重。再见。"

# game/Scenes/Reba/reba8.rpy:291
translate chinese reba8b_596474d1:

    # "She hangs up and I put my phone back in my pocket."
    "她挂了电话，我把手机放回口袋。"

# game/Scenes/Reba/reba8.rpy:292
translate chinese reba8b_c8a4994e:

    # "With her family, it just isn't going to work out between us and I don't want to get any more involved."
    "有她家人在，我们之间根本不可能有结果，我也不想再深陷其中。"

# game/Scenes/Reba/reba8.rpy:294
translate chinese reba8b_cde6c8b5:

    # "I put my phone away and go to sleep."
    "我收起手机，准备睡觉。"

# game/Scenes/Reba/reba8.rpy:298
translate chinese reba8b_4e07e53d:

    # rb "Oh I'm so glad you said that. I'd love to."
    rb "哦，太好了，你这么说。我当然愿意。"

# game/Scenes/Reba/reba8.rpy:299
translate chinese reba8b_410939a3:

    # rb "I was a little afraid you wouldn't want to see me anymore. I know it's difficult to deal with my family."
    rb "我有点担心你不想再见我了。我知道应付我的家人很难。"

# game/Scenes/Reba/reba8.rpy:300
translate chinese reba8b_f09c8cc4:

    # pc "It is. But I like you, Reba. That's what really matters."
    pc "确实很难。但我喜欢你，瑞芭。这才是最重要的。"

# game/Scenes/Reba/reba8.rpy:301
translate chinese reba8b_5661fd5c:

    # rb "I like you too."
    rb "我也喜欢你。"

# game/Scenes/Reba/reba8.rpy:302
translate chinese reba8b_04916afe:

    # pc "So do you want to go on a date sometime?"
    pc "那你愿意什么时候约我出去吗？"

# game/Scenes/Reba/reba8.rpy:304
translate chinese reba8b_c8d6195d:

    # rb "Yes! I really do."
    rb "好啊！我真的很想。"

# game/Scenes/Reba/reba8.rpy:305
translate chinese reba8b_af09a7ac:

    # rb "I'll give you a call soon and let you know when I'm available okay?"
    rb "我很快会给你打电话，告诉你什么时候有空，好吗？"

# game/Scenes/Reba/reba8.rpy:306
translate chinese reba8b_050f909c:

    # pc "Sounds good."
    pc "听起来不错。"

# game/Scenes/Reba/reba8.rpy:307
translate chinese reba8b_91ddb576:

    # rb "Okay. See you later, [pcname]. Good night."
    rb "好的。回头见，[pcname]。晚安。"

# game/Scenes/Reba/reba8.rpy:310
translate chinese reba8b_2eac7384:

    # "She hangs up and I put my phone back onto my night stand."
    "她挂断电话，我把手机放回床头柜上。"

# game/Scenes/Reba/reba8.rpy:311
translate chinese reba8b_7703588f:

    # "A real date with Reba sounds fun. Something to look forward to."
    "和丽贝卡来场真正的约会听起来真有趣。真让人期待。"

# game/Scenes/Reba/reba8.rpy:314
translate chinese reba8b_75603258:

    # "I fall asleep, thinking of where I might want to take her."
    "我一边想着该带她去哪里，一边睡着了。"

translate chinese strings:

    # game/Scenes/Reba/reba8.rpy:7
    old "A few days after you go camping with Reba and have called and had a conversation with her on the phone,"
    new "在你和瑞芭去露营并和她通了电话聊过之后几天，"

    # game/Scenes/Reba/reba8.rpy:8
    old "she will call and invite you out again in the morning on the weekend."
    new "她会在周末的早上打电话来再次邀请你出去。"

    # game/Scenes/Reba/reba8.rpy:29
    old "Mudding?"
    new "去泥地玩？"

    # game/Scenes/Reba/reba8.rpy:42
    old "Sounds fun"
    new "听起来挺好玩的"

    # game/Scenes/Reba/reba8.rpy:191
    old "Block and counterpunch"
    new "格挡并反击"

    # game/Scenes/Reba/reba8.rpy:216
    old "Dodge the punch"
    new "闪避这一拳"

    # game/Scenes/Reba/reba8.rpy:231
    old "Try to block"
    new "试着格挡"

    # game/Scenes/Reba/reba8.rpy:283
    old "That's okay, we can meet in town"
    new "没关系，我们可以在镇上见面"

    # game/Scenes/Reba/reba8.rpy:285
    old "I think we should just end this"
    new "我觉得我们还是结束吧"

