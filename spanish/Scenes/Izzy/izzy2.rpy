# game/Scenes/Izzy/izzy2.rpy:13
translate spanish izzy2_b51311fa:

    # "I'm not going to run though. I'm confident in myself."
    "Pero no voy a huir. Tengo confianza en mí mismo."

# game/Scenes/Izzy/izzy2.rpy:14
translate spanish izzy2_a9a2f7bf:

    # "Maybe he'll kick my ass, but I'm not running."
    "Quizá me dé una paliza, pero no voy a huir."

# game/Scenes/Izzy/izzy2.rpy:17
translate spanish izzy2_da02f2e6:

    # "When Moose is about to slam into me, I quickly step aside and instead he trips forward, tumbling through the air."
    "Cuando Moose está a punto de abalanzarse sobre mí, me aparto rápidamente y, en su lugar, él tropieza hacia delante, dando vueltas en el aire."

# game/Scenes/Izzy/izzy2.rpy:20
translate spanish izzy2_4a1e9586:

    # "He slams hard into the ground and lies there moaning."
    "Se estrella con fuerza contra el suelo y se queda allí gimiendo."

# game/Scenes/Izzy/izzy2.rpy:21
translate spanish izzy2_7575cb2e:

    # "Izzy and the others burst into laughter, pointing at him."
    "Izzy y los demás se echan a reír, señalándolo."

# game/Scenes/Izzy/izzy2.rpy:22
translate spanish izzy2_58f4b0c6:

    # moose "S'not funny, man."
    moose "No tiene gracia, tío."

# game/Scenes/Izzy/izzy2.rpy:23
translate spanish izzy2_fa71cc47:

    # mal "I don't know about that."
    mal "No estoy tan seguro."

# game/Scenes/Izzy/izzy2.rpy:24
translate spanish izzy2_0a29e854:

    # gl "Pretty damn funny to me."
    gl "A mí me parece muy gracioso."

# game/Scenes/Izzy/izzy2.rpy:28
