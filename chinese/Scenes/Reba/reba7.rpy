    rb "谢谢，[pcname]。和你在一起真的很开心。希望以后还能再这样，不用有人在旁边看着。"

# game/Scenes/Reba/reba7.rpy:459
translate chinese reba7_097223de:

    # pc "That would be nice."
    pc "那可太好了。"

# game/Scenes/Reba/reba7.rpy:463
