# game/Scenes/Bai/bai2.rpy:10
translate chinese bai2_98ca1a51:

    # "My phone buzzes in my pocket."
    "口袋里的手机震动起来。"

# game/Scenes/Bai/bai2.rpy:14
translate chinese bai2_a13b13a8:

    # "It's Bai. I guess I have time to chat a bit."
    "是白。我想我还有时间聊一会儿。"

# game/Scenes/Bai/bai2.rpy:17
translate chinese bai2_c0d6b27a:

    # pc "Hey Bai, what's up?"
    pc "嘿，白，干嘛呢？"

# game/Scenes/Bai/bai2.rpy:18
translate chinese bai2_ca2e0cd6:

    # bai "Hey, [pcname]. I was just lying here bored and wondered what you were up to?"
    bai "嘿，[pcname]。我正躺在这儿无聊，想问问你在忙什么？"

# game/Scenes/Bai/bai2.rpy:19
translate chinese bai2_f020dde3:

    # pc "Just getting ready for bed, but I can talk for a while."
    pc "正准备睡觉，不过可以聊一会儿。"

# game/Scenes/Bai/bai2.rpy:20
translate chinese bai2_b9768b08:

    # bai "That's cool. I've just been thinking a lot."
    bai "那挺好。我最近一直在想很多事。"

# game/Scenes/Bai/bai2.rpy:21
translate chinese bai2_e61255db:

    # pc "About what?"
    pc "想什么？"

# game/Scenes/Bai/bai2.rpy:23
translate chinese bai2_67224ed1:

    # bai "Just stuff mostly."
    bai "就是一些琐事吧。"

# game/Scenes/Bai/bai2.rpy:24
translate chinese bai2_19828c08:

    # pc "You're going to have to be a little more specific than that or this conversation isn't going to go anywhere."
    pc "你得具体点，不然这对话没法进行下去。"

# game/Scenes/Bai/bai2.rpy:25
translate chinese bai2_64de84cd:

    # bai "Okay, well."
    bai "好吧，那……"

# game/Scenes/Bai/bai2.rpy:26
translate chinese bai2_d7d9d996:

    # bai "I uh... I've only dated girls in the past."
    bai "我啊……我以前只跟女生约会过。"

# game/Scenes/Bai/bai2.rpy:27
translate chinese bai2_36470b3e:

    # bai "I've had sex and stuff. With girls."
    bai "我也发生过关系之类的。对象都是女生。"

# game/Scenes/Bai/bai2.rpy:28
translate chinese bai2_41c2c9e2:

    # bai "But uh... I think I might be into guys too."
    bai "但……我觉得我可能也对男生有感觉。"

# game/Scenes/Bai/bai2.rpy:30
translate chinese bai2_8833a2ab:

    # pc "So, you're bisexual?"
    pc "所以，你是双性恋？"

# game/Scenes/Bai/bai2.rpy:31
translate chinese bai2_61b09772:

    # bai "Maybe?"
    bai "也许吧？"

# game/Scenes/Bai/bai2.rpy:32
translate chinese bai2_0e63d7c1:

    # bai "What about you? Are you into guys at all?"
    bai "那你呢？你对男生有感觉吗？"

# game/Scenes/Bai/bai2.rpy:36
translate chinese bai2_bde64ebd:

    # bai "Oh okay. I thought maybe we had a thing. It's okay though."
    bai "哦，这样啊。我还以为我们之间可能有点什么。不过没关系。"

# game/Scenes/Bai/bai2.rpy:37
translate chinese bai2_0fe323b5:

    # pc "Sorry, man. Chicks only for me."
    pc "抱歉，兄弟。我只喜欢女生。"

# game/Scenes/Bai/bai2.rpy:38
translate chinese bai2_83d8b883:

    # bai "It's cool. I understand."
    bai "没关系。我理解。"

# game/Scenes/Bai/bai2.rpy:40
translate chinese bai2_ecf05d77:

    # bai "Still friends though?"
    bai "我们还能做朋友吗？"

# game/Scenes/Bai/bai2.rpy:41
translate chinese bai2_71d4cebe:

    # pc "Sure, we're still friends."
    pc "当然，我们还是朋友。"

# game/Scenes/Bai/bai2.rpy:44
translate chinese bai2_e26b3f90:

    # bai "Cool."
    bai "太好了。"

# game/Scenes/Bai/bai2.rpy:47
translate chinese bai2_b66cc0ac:

    # bai "Really? I thought maybe we had a thing, but I wasn't sure."
    bai "真的吗？我以为我们之间可能有点什么，但我也不确定。"

# game/Scenes/Bai/bai2.rpy:49
translate chinese bai2_f39ae0a2:

    # bai "Are you into me?"
    bai "你喜欢我吗？"

# game/Scenes/Bai/bai2.rpy:53
translate chinese bai2_99a03550:

    # bai "That makes me so happy."
    bai "这让我好开心。"

# game/Scenes/Bai/bai2.rpy:55
translate chinese bai2_99b1838b:

    # bai "So do you maybe want to actually go on a date sometime?"
    bai "那你有没有兴趣什么时候真正约个会？"

# game/Scenes/Bai/bai2.rpy:56
translate chinese bai2_39757b54:

    # pc "Yeah, let's do it."
    pc "好啊，那就约吧。"

# game/Scenes/Bai/bai2.rpy:57
translate chinese bai2_8c98f2da:

    # bai "Okay, just give me a call in the evening sometime then. I'm available almost every day."
    bai "好的，那你晚上找个时间给我打电话吧。我几乎每天都有空。"

# game/Scenes/Bai/bai2.rpy:58
translate chinese bai2_58a87bc2:

    # pc "Sounds good. I'm looking forward to it."
    pc "听起来不错。我很期待。"

# game/Scenes/Bai/bai2.rpy:59
translate chinese bai2_10a70856:

    # bai "Me too. Really."
    bai "我也是。真的。"

# game/Scenes/Bai/bai2.rpy:60
translate chinese bai2_4d74a398:

    # bai "This is new territory for me, but I'm really looking forward to exploring it with you."
    bai "这对我来说是片新天地，但我真的很期待和你一起探索。"

# game/Scenes/Bai/bai2.rpy:63
translate chinese bai2_c0a43543:

    # bai "Oh, so you're into guys, but you're not into me."
    bai "哦，所以你喜欢男生，但不喜欢我。"

# game/Scenes/Bai/bai2.rpy:64
translate chinese bai2_27247fe1:

    # bai "Gotta say, that hurts man."
    bai "得说，这真让人伤心啊，兄弟。"

# game/Scenes/Bai/bai2.rpy:65
translate chinese bai2_c31c7975:

    # pc "Sorry, just being honest."
    pc "抱歉，我只是实话实说。"

# game/Scenes/Bai/bai2.rpy:66
translate chinese bai2_40a3eff2:

    # bai "Yeah okay. Well that sucks."
    bai "嗯，好吧。真倒霉。"

# game/Scenes/Bai/bai2.rpy:67
translate chinese bai2_0cce2b18:

    # pc "We can still be friends though."
    pc "不过我们还是可以做朋友的。"

# game/Scenes/Bai/bai2.rpy:68
translate chinese bai2_46106a33:

    # bai "Yeah, okay. I'm going to bed."
    bai "嗯，好吧。我要睡觉了。"

# game/Scenes/Bai/bai2.rpy:70
translate chinese bai2_14a17911:

    # "He hangs up. I guess that didn't go so well."
    "他挂了电话。看来这次聊得不太顺利。"

# game/Scenes/Bai/bai2.rpy:71
translate chinese bai2_a0d6f0f3:

    # "Oh well. He'll get over it. Or not, whatever."
    "算了。他会走出来的。或者不会，随他去吧。"

# game/Scenes/Bai/bai2.rpy:72
translate chinese bai2_ef88129a:

    # "I put the phone away and get ready for bed."
    "我收起手机，准备睡觉。"

# game/Scenes/Bai/bai2.rpy:75
translate chinese bai2_17d3424c:

    # "We chat a little longer about our days, until we are both tired."
    "我们又聊了一会儿各自的近况，直到都累了。"

# game/Scenes/Bai/bai2.rpy:77
translate chinese bai2_3898d259:

    # bai "I better get some sleep man."
    bai "我得睡了，兄弟。"

# game/Scenes/Bai/bai2.rpy:78
translate chinese bai2_89c07fc5:

    # bai "I'll talk to you later."
    bai "回头再聊。"

# game/Scenes/Bai/bai2.rpy:79
translate chinese bai2_d2381b62:

    # pc "Okay. See ya, Bai."
    pc "行。再见，Bai。"

# game/Scenes/Bai/bai2.rpy:82
translate chinese bai2_52d6e3cf:

    # "We hang up and I get ready for bed."
    "我们挂了电话，我准备睡觉。"

