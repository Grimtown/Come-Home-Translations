# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:14
translate spanish whitneys1_5b89c8f2:

    # wt "I just believed in what he was doing."
    wt "Simplemente creía en lo que él hacía."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:15
translate spanish whitneys1_255c9138:

    # wt "He had a way of explaining things that made me want to go along with anything he said."
    wt "Tenía una forma de explicar las cosas que me hacía querer estar de acuerdo con todo lo que decía."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:16
translate spanish whitneys1_a0974c4f:

    # wt "I really liked his theories, and I could tell that he was a genius."
    wt "Me gustaban mucho sus teorías, y me daba cuenta de que era un genio."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:17
translate spanish whitneys1_3a0437f9:

    # pc "My dad? A genius?"
    pc "¿Mi padre? ¿Un genio?"

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:19
translate spanish whitneys1_4117d5f5:

    # wt "Oh yeah."
    wt "Oh, sí."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:20
translate spanish whitneys1_11fcf59f:

    # pc "I know he's smart, but a genius?"
    pc "Sé que es inteligente, pero ¿un genio?"

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:21
translate spanish whitneys1_9967cac8:

    # wt "Absolutely. The things he came up with were extraordinary."
    wt "Por supuesto. Las cosas que se le ocurrían eran extraordinarias."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:23
translate spanish whitneys1_d453b5e4:

    # wt "You think that anyone but a genius could have made a device to allow them to travel to another universe?"
    wt "¿Crees que alguien que no fuera un genio podría haber fabricado un dispositivo que permitiera viajar a otro universo?"

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:24
translate spanish whitneys1_3186ca77:

    # pc "If that's even what happened."
    pc "Si es que eso es lo que pasó."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:26
translate spanish whitneys1_38f36d99:

    # wt "I'm pretty sure it is."
    wt "Estoy bastante segura de que sí."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:27
translate spanish whitneys1_e4aa8ba6:

    # wt "There was also this sadness to him. He never spoke of it, but I could tell that he was kind of broken."
    wt "También había algo de tristeza en él. Nunca hablaba de ello, pero me daba cuenta de que estaba un poco destrozado."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:28
translate spanish whitneys1_1a0b2401:

    # wt "I like fixing things. I guess I couldn't say no to that."
    wt "Me gusta arreglar cosas. Supongo que no podía decir que no a eso."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:30
translate spanish whitneys1_a91ab7fa:

    # wt "Do you know why he was so sad?"
    wt "¿Sabes por qué estaba tan triste?"

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:31
translate spanish whitneys1_de24c7fa:

    # pc "Yeah, I think so. My mom died. Cancer."
    pc "Sí, creo que sí. Mi madre murió. De cáncer."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:33
translate spanish whitneys1_5d0b8356:

    # wt "Yeah, that would do it."
    wt "Sí, eso lo explicaría."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:34
translate spanish whitneys1_c9d7b2e0:

    # wt "Sorry, by the way. That's rough."
    wt "Lo siento, por cierto. Es duro."

# game/Scenes/Whitney/WhitneyConversations/whitneys1.rpy:35
translate spanish whitneys1_6efc15e2:

    # pc "Yeah. Thanks."
    pc "Sí. Gracias."

