# game/Scenes/Gertrude/gertrude1.rpy:12
translate spanish gertrude1_b8ab60df:

    # sc "I had a kind of personal question for you today."
    sc "Hoy tenía una pregunta un poco personal para ti."

# game/Scenes/Gertrude/gertrude1.rpy:13
translate spanish gertrude1_46f5a669:

    # pc "Okay, go ahead."
    pc "Vale, adelante."

# game/Scenes/Gertrude/gertrude1.rpy:14
translate spanish gertrude1_f61c5e45:

    # sc "If you don't want to answer it, you don't have to."
    sc "Si no quieres responder, no tienes por qué hacerlo."

# game/Scenes/Gertrude/gertrude1.rpy:15
translate spanish gertrude1_e2305d2c:

    # pc "Just ask."
    pc "Pregunta."

# game/Scenes/Gertrude/gertrude1.rpy:16
translate spanish gertrude1_0cd2dbde:

    # sc "Are you sexually active?"
    sc "¿Eres sexualmente activo?"

# game/Scenes/Gertrude/gertrude1.rpy:20
translate spanish gertrude1_7b5b8bbb:

    # sc "I think that most people would say that."
    sc "Creo que la mayoría de la gente diría que sí."

# game/Scenes/Gertrude/gertrude1.rpy:23
translate spanish gertrude1_ebf7eccb:

    # sc "Good, I'm glad."
    sc "Bien, me alegro."

# game/Scenes/Gertrude/gertrude1.rpy:26
translate spanish gertrude1_13162311:

    # sc "I'm sorry, I'm not trying to get involved in your personal life."
    sc "Lo siento, no pretendo entrometerme en tu vida personal."

# game/Scenes/Gertrude/gertrude1.rpy:27
translate spanish gertrude1_dda22b21:

    # sc "But I do think that it is healthy to be sexually active at your age."
    sc "Pero creo que es saludable ser sexualmente activo a tu edad."

# game/Scenes/Gertrude/gertrude1.rpy:29
translate spanish gertrude1_5a649775:

    # sc "College is the perfect opportunity to experiment."
    sc "La universidad es la oportunidad perfecta para experimentar."

# game/Scenes/Gertrude/gertrude1.rpy:30
translate spanish gertrude1_b8b829eb:

    # sc "To figure out what you like and don't like."
    sc "Para descubrir lo que te gusta y lo que no te gusta."

# game/Scenes/Gertrude/gertrude1.rpy:32
translate spanish gertrude1_8594ced1:

    # sc "You don't want to look back later in life and wonder about the things you missed out on."
    sc "No querrás mirar atrás más adelante en la vida y preguntarte por las cosas que te perdiste."

# game/Scenes/Gertrude/gertrude1.rpy:36
translate spanish gertrude1_639c8f25:

    # sc "Good."
    sc "Bien."

# game/Scenes/Gertrude/gertrude1.rpy:39
translate spanish gertrude1_070c7224:

    # sc "As long as you're safe about it, yes."
    sc "Siempre y cuando lo hagas de forma segura, sí."

# game/Scenes/Gertrude/gertrude1.rpy:40
translate spanish gertrude1_9fc07896:

    # sc "I think that you should have lots of sex with a variety of people."
    sc "Creo que deberías tener mucho sexo con gente diferente."

# game/Scenes/Gertrude/gertrude1.rpy:41
translate spanish gertrude1_6bec941c:

    # sc "I believe that it gives you a healthier mindset when you're older, like me."
    sc "Creo que te da una mentalidad más sana cuando eres mayor, como yo."

# game/Scenes/Gertrude/gertrude1.rpy:43
translate spanish gertrude1_a0193afd:

    # sc "Anyway, that is enough of this talk."
    sc "En fin, ya basta de esta charla."

# game/Scenes/Gertrude/gertrude1.rpy:44
translate spanish gertrude1_e11ba8d0:

    # sc "You should get to class, right?"
    sc "Deberías ir a clase, ¿no?"

# game/Scenes/Gertrude/gertrude1.rpy:46
translate spanish gertrude1_9f00d552:

    # pc "Yeah, I guess so."
    pc "Sí, supongo que sí."

# game/Scenes/Gertrude/gertrude1.rpy:47
translate spanish gertrude1_8f9b25a7:

    # sc "Okay, well I'll see you next time, [pcname]."
    sc "Vale, pues nos vemos la próxima vez, [pcname]."

# game/Scenes/Gertrude/gertrude1.rpy:48
translate spanish gertrude1_850ead77:

    # pc "Okay. Bye, Gertrude."
    pc "Vale. Adiós, Gertrude."

