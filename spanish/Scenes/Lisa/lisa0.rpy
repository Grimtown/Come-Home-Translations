    new "Ve a ver cómo está cuando esté en el salón por las tardes entre semana"

    # game/Scenes/Lisa/lisa0.rpy:20
    old "Check on her"
    new "Ve a ver cómo está"

    # game/Scenes/Lisa/lisa0.rpy:42
    old "I don't think so."
    new "No lo creo."

    # game/Scenes/Lisa/lisa0.rpy:44
    old "A little maybe?"
    new "¿Quizás un poco?"

    # game/Scenes/Lisa/lisa0.rpy:60
    old "Go comfort her"
    new "Ve a consolarla"

    # game/Scenes/Lisa/lisa0.rpy:72
