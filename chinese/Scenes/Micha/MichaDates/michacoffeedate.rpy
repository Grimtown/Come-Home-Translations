# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:17
translate chinese michacoffeedate_617439f0:

    # "I head over to the café for my coffee date with Mi-Cha."
    "我前往咖啡馆，准备和米查的咖啡约会。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:31
translate chinese michacafestartdate_046f6d25:

    # "When I walk into the café, I spot Mi-Cha sitting alone at one of the tables. She sees me immediately, as if she has been staring at the door waiting for me to enter."
    "当我走进咖啡馆时，看到米查正独自坐在一张桌子旁。 她立刻就看到了我，仿佛一直在盯着门口等着我进来似的。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:34
translate chinese michacafestartdate_01bd2ac6:

    # "She stands and walks up towards me."
    "她站起身，朝我走来。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:35
translate chinese michacafestartdate_0b7caa3b:

    # mc "Hello, [pcname]. It is very nice to see you."
    mc "你好，[pcname]。见到你真好。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:36
translate chinese michacafestartdate_4ff32b15:

    # pc "It's nice to see you too Mi-Cha."
    pc "见到你也很高兴，米查。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:42
translate chinese michacafestartdate_41391618:

    # "We order coffee and return to the table where Mi-Cha had been sitting."
    "我们点了咖啡，回到米查刚才坐的那张桌子旁。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:49
translate chinese michacafestartdate_ac673695:

    # "She finishes her coffee and grows quiet again."
    "她喝完咖啡后，又沉默了下来。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:50
translate chinese michacafestartdate_d2998c07:

    # mc "I think I need to leave now."
    mc "我想我该走了。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:52
translate chinese michacafestartdate_d6f5dbcf:

    # pc "Okay. Is everything okay?"
    pc "好的。你没事吧？"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:54
translate chinese michacafestartdate_bb0a4fc6:

    # mc "Yes, I am good. This was fun, thank you."
    mc "嗯，我没事。今天很开心，谢谢。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:55
translate chinese michacafestartdate_8d3a0887:

    # mc "I want to go out with you again soon."
    mc "我希望很快能再和你约会。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:56
translate chinese michacafestartdate_56445a21:

    # pc "Good. So do I."
    pc "好。我也是。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:58
translate chinese michacafestartdate_e04395ed:

    # mc "I'm glad to hear that."
    mc "听到你这么说真高兴。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:59
translate chinese michacafestartdate_a1f6c0b4:

    # mc "I'll talk to you again soon."
    mc "我们很快再联系。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:64
translate chinese michacafestartdate_0c36f48d:

    # "With that, she stands up and walks towards the exit."
    "说完，她站起身走向出口。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:69
translate chinese michacafestartdate_54f90ca5:

    # "That seemed to have gone well though. She's starting to open up a little more."
    "不过这次似乎进行得很顺利。她开始稍微敞开心扉了。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:70
translate chinese michacafestartdate_c570b5db:

    # "I finish my coffee and then leave."
    "我喝完咖啡后也离开了。"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:76
translate chinese michacafestartdate_d41d8cd9:

    # voice 'voices/micha_walkmeback.mp3'
    voice 'voices/micha_walkmeback.mp3'

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:77
translate chinese michacafestartdate_79fa8246:

    # mc "Would you walk me back to my dorm?"
    mc "能送我回宿舍吗？"

# game/Scenes/Micha/MichaDates/michacoffeedate.rpy:78
translate chinese michacafestartdate_7e389ec4:

    # pc "Sure, I can do that."
    pc "当然可以。"

