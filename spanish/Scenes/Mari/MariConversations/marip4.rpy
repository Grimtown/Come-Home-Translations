translate spanish marip4_396c4a27:

    # fr "Not really."
    fr "En realidad, no."

# game/Scenes/Mari/MariConversations/marip4.rpy:14
translate spanish marip4_a3a6e94e:

    # fr "I talk to some people online and we meet occasionally."
    fr "Hablo con algunas personas por Internet y nos vemos de vez en cuando."

# game/Scenes/Mari/MariConversations/marip4.rpy:15
translate spanish marip4_bb06b846:

    # fr "Then there is Jackson and Connie at work, a couple of people that I chat with at the vet clinic."
    fr "Luego están Jackson y Connie en el trabajo, un par de personas con las que charlo en la clínica veterinaria."

# game/Scenes/Mari/MariConversations/marip4.rpy:17
translate spanish marip4_f4e0d40e:

    # fr "And you, of course."
    fr "Y tú, por supuesto."

# game/Scenes/Mari/MariConversations/marip4.rpy:18
translate spanish marip4_aefff0dc:

    # fr "I wouldn't say any of those relationships are close."
    fr "No diría que ninguna de esas relaciones sea cercana."

# game/Scenes/Mari/MariConversations/marip4.rpy:19
translate spanish marip4_3c863e30:

    # fr "At least not yet."
    fr "Al menos, todavía no."

# game/Scenes/Mari/MariConversations/marip4.rpy:24
translate spanish marip4_36d8c862:

    # fr "Not as close as I would like to be."
    fr "No tan cercana como me gustaría que fuera."

# game/Scenes/Mari/MariConversations/marip4.rpy:26
translate spanish marip4_a14f7e23:

    # fr "Still though, thank you for saying so."
    fr "Aun así, gracias por decirlo."

# game/Scenes/Mari/MariConversations/marip4.rpy:30
translate spanish marip4_4b65bcb5:

    # fr "It definitely is!"
    fr "¡Sin duda lo es!"

# game/Scenes/Mari/MariConversations/marip4.rpy:31
translate spanish marip4_93b501c6:

    # fr "Everybody is always so busy with their own things, it's hard to keep up with everything going on in other people's lives."
    fr "Todo el mundo está siempre tan ocupado con sus propias cosas que es difícil estar al tanto de todo lo que pasa en la vida de los demás."

# game/Scenes/Mari/MariConversations/marip4.rpy:32
translate spanish marip4_0dd5ba27:

    # pc "Very true."
    pc "Muy cierto."

# game/Scenes/Mari/MariConversations/marip4.rpy:34
translate spanish marip4_5292c0c6:

    # fr "But I do wish that I had a couple of close friends that I could confide in."
    fr "Pero sí que me gustaría tener un par de amigos íntimos en los que poder confiar."

# game/Scenes/Mari/MariConversations/marip4.rpy:36
translate spanish marip4_7199f799:

    # fr "Maybe some day."
    fr "Quizá algún día."

# game/Scenes/Mari/MariConversations/marip4.rpy:39
translate spanish marip4_7567a5a5:

    # fr "Yeah, I guess so."
    fr "Sí, supongo que sí."

# game/Scenes/Mari/MariConversations/marip4.rpy:40
translate spanish marip4_fe109b44:

    # fr "What a loser huh?"
    fr "Menudo perdedor, ¿eh?"

# game/Scenes/Mari/MariConversations/marip4.rpy:42
translate spanish marip4_ea2dcc2a:

    # fr "I will eventually. It's just hard to find nice people who share your interests."
    fr "Al final lo conseguiré. Es que es difícil encontrar gente agradable que comparta tus intereses."

# game/Scenes/Mari/MariConversations/marip4.rpy:44
translate spanish marip4_0b4501cf:

    # fr "Anyways. Let's talk about something else."
    fr "En fin. Hablemos de otra cosa."

