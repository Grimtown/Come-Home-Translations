translate chinese dana13rescue_887022bf:

    # cw "[pcname], this is my best friend, Liz. Liz, this is the guy I told you about."
    cw "[pcname]，这是我最好的朋友，莉兹。莉兹，这就是我跟你说过的那个男生。"

# game/Scenes/Dana/dana13.rpy:402
translate chinese dana13rescue_d41d8cd9_16:

    # voice "voices/dana 12_22.wav"
    voice "voices/dana 12_22.wav"

