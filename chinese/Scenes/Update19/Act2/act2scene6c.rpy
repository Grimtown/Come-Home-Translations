    # det "Yeah... it seems to be more and more necessary lately."
    det "是啊……最近似乎越来越必要了。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:197
translate chinese u19a2s6c_408cc224:

    # rb "You're telling me."
    rb "你说的对。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:199
translate chinese u19a2s6c_8edf6aab:

    # cw "Hi Jez. I'm Dana, by the way."
    cw "嗨，杰兹。顺便说一下，我是达娜。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:200
translate chinese u19a2s6c_5790dd63:

    # cw "That was brutal back there. Wow."
    cw "刚才那场面太残暴了。哇。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:201
translate chinese u19a2s6c_c85d1325:

    # det "Yeah. I'm not a fan of the violence, but some people only speak one language."
    det "是啊。我虽然不喜欢暴力，但有些人只懂一种语言。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:202
translate chinese u19a2s6c_94830ef7:

    # cw "I suppose so."
    cw "大概是吧。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:204
translate chinese u19a2s6c_4111fb67:

    # gg "I'm Adrian. Nice to meet you, Jez."
    gg "我是阿德里安。很高兴认识你，杰兹。"

# game/Scenes/Update19/Act2/act2scene6c.rpy:205
translate chinese u19a2s6c_65966cd5:

    # det "Nice to meet you as well."
    det "我也一样。"

