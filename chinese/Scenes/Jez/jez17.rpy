translate chinese jez17_adefd58e:

    # jav "Fifteen."
    jav "十五。"

# game/Scenes/Jez/jez17.rpy:94
translate chinese jez17_e475d53f:

    # pc "Oh okay, thanks."
    pc "哦，好的，谢谢。"

# game/Scenes/Jez/jez17.rpy:95
translate chinese jez17_49e399f0:

    # pc "Do you need any help? What kind of homework is it?"
    pc "需要帮忙吗？是什么作业？"

