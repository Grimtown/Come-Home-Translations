# game/Scenes/Bai/BaiConversations/baip1.rpy:13
translate spanish baip1_4fa21f8f:

    # bai "Oof, probably telling my last girlfriend that I might be interested in guys."
    bai "Uf, probablemente decirle a mi última novia que podría estar interesado en los chicos."

# game/Scenes/Bai/BaiConversations/baip1.rpy:15
translate spanish baip1_ffbd6fca:

    # bai "I knew that the reaction was not going to be good, but I didn't expect her to completely turn against me and take all my friends with her."
    bai "Sabía que la reacción no iba a ser buena, pero no esperaba que se volviera completamente en mi contra y se llevara a todos mis amigos con ella."

# game/Scenes/Bai/BaiConversations/baip1.rpy:16
translate spanish baip1_d3859f56:

    # bai "I wish I would have just broken up with her and kept it a secret until I left for college."
    bai "Ojalá me hubiera separado de ella y lo hubiera mantenido en secreto hasta que me fuera a la universidad."

# game/Scenes/Bai/BaiConversations/baip1.rpy:18
translate spanish baip1_8b41827b:

    # bai "I don't know. I guess it helped me find who my real friends were… which was none of them."
    bai "No lo sé. Supongo que me ayudó a descubrir quiénes eran mis verdaderos amigos… que resultaron ser ninguno de ellos."

# game/Scenes/Bai/BaiConversations/baip1.rpy:20
translate spanish baip1_ddc15c60:

    # bai "I don't regret coming out, or at least partially coming out, but I regret doing it at that time."
    bai "No me arrepiento de haber salido del armario, o al menos de haberlo hecho parcialmente, pero sí me arrepiento de haberlo hecho en ese momento."

# game/Scenes/Bai/BaiConversations/baip1.rpy:21
translate spanish baip1_e386481e:

    # bai "Should have waited until I was in a better place."
    bai "Debería haber esperado hasta estar en una situación mejor."

# game/Scenes/Bai/BaiConversations/baip1.rpy:23
translate spanish baip1_0d4610a1:

    # bai "Though I expect there would be drama no matter when I chose to do it."
    bai "Aunque supongo que habría habido líos independientemente de cuándo hubiera decidido hacerlo."

# game/Scenes/Bai/BaiConversations/baip1.rpy:24
translate spanish baip1_9c2f65a6:

    # bai "It would have always been hard."
    bai "Siempre habría sido difícil."

# game/Scenes/Bai/BaiConversations/baip1.rpy:25
translate spanish baip1_8ac655b7:

    # pc "Well I'm here for you man, if you need support."
    pc "Bueno, estoy aquí para lo que necesites, tío, si necesitas apoyo."

# game/Scenes/Bai/BaiConversations/baip1.rpy:27
translate spanish baip1_ae9dc969:

    # bai "Thanks, man. I appreciate it."
    bai "Gracias, tío. Te lo agradezco."

