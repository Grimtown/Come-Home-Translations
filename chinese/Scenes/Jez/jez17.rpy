    # det "Si, pero did you know that before you opened the door?"
    det "是啊，但你在开门前知道是他是吗？"

# game/Scenes/Jez/jez17.rpy:59
translate chinese jez17_10365fcf:

    # jav "You said he was coming."
    jav "你不是说他要来吗？"

# game/Scenes/Jez/jez17.rpy:61
