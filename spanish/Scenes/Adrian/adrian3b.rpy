# TODO: Translation updated at 2026-04-15 14:25

# game/Scenes/Adrian/adrian3b.rpy:17
translate spanish adrian3b_bdd6187c:

    # "I sit down at the computer and install the game that Adrian had bought for me."
    "Me siento frente al ordenador e instalo el juego que Adrian me había comprado."

# game/Scenes/Adrian/adrian3b.rpy:18
translate spanish adrian3b_3e2f7daf:

    # "It doesn't take too long, then it is on my desktop."
    "No tarda mucho, y ya lo tengo en el escritorio."

# game/Scenes/Adrian/adrian3b.rpy:19
translate spanish adrian3b_e481cbc4:

    # "I guess I'll give it a try."
    "Supongo que le daré una oportunidad."

# game/Scenes/Adrian/adrian3b.rpy:21
translate spanish adrian3b_8131ccda:

    # "I start up the game and choose the server that Adrian had written down for me so that we could play together."
    "Inicio el juego y elijo el servidor que Adrian me había apuntado para que pudiéramos jugar juntos."

# game/Scenes/Adrian/adrian3b.rpy:22
translate spanish adrian3b_62dfcc6e:

    # "First thing I have to do is create a character."
    "Lo primero que tengo que hacer es crear un personaje."

# game/Scenes/Adrian/adrian3b.rpy:24
translate spanish adrian3b_59517f82:

    # "I spend probably too much time going through all the different options, before deciding on the character I want to play."
    "Probablemente paso demasiado tiempo revisando todas las opciones antes de decidirme por el personaje con el que quiero jugar."

# game/Scenes/Adrian/adrian3b.rpy:25
translate spanish adrian3b_827389d1:

    # "I know that Adrian is playing a magic-user, so I want to go with something more physical and melee-focused."
    "Sé que Adrian juega con un mago, así que quiero algo más físico y centrado en el combate cuerpo a cuerpo."

# game/Scenes/Adrian/adrian3b.rpy:27
translate spanish adrian3b_c19763c8:

    # "I end up going with a half-orc warrior. I like the idea of fighting all these enemies up close and personal."
    "Al final me decido por un guerrero semiorco. Me gusta la idea de luchar contra todos esos enemigos de cerca y en persona."

# game/Scenes/Adrian/adrian3b.rpy:28
translate spanish adrian3b_112c09f7:

    # "He is also the biggest, most badass character that I could make."
    "Además, es el personaje más grande y rudo que podría crear."

# game/Scenes/Adrian/adrian3b.rpy:30
translate spanish adrian3b_8f0fae1d:

    # "I turn up the volume and start the game."
    "Subo el volumen y empiezo el juego."

# game/Scenes/Adrian/adrian3b.rpy:31
translate spanish adrian3b_4d69dd27:

    # "After a little intro movie, it drops me into the world."
    "Tras una pequeña intro, me sumerge en el mundo."

# game/Scenes/Adrian/adrian3b.rpy:32
translate spanish adrian3b_62775756:

    # "I wonder if Adrian is online right now? She said she would be. I type her username into the search window and find her."
    "Me pregunto si Adrian estará conectada ahora mismo. Dijo que lo estaría. Escribo su nombre de usuario en la ventana de búsqueda y la encuentro."

# game/Scenes/Adrian/adrian3b.rpy:33
translate spanish adrian3b_03467b31:

    # "So I send her a voicechat request, which she answers almost immediately."
    "Así que le envío una solicitud de chat de voz, a la que responde casi de inmediato."

# game/Scenes/Adrian/adrian3b.rpy:35
translate spanish adrian3b_a3f59b75:

    # gg "[pcname]! You're here!"
    gg "[pcname]¡Estás aquí!"

# game/Scenes/Adrian/adrian3b.rpy:36
translate spanish adrian3b_589ce956:

    # pc "I'm here. Hey, Adrian."
    pc "Estoy aquí. Hola, Adrian."

# game/Scenes/Adrian/adrian3b.rpy:37
translate spanish adrian3b_0ec64e72:

    # gg "Where are you right now?"
    gg "¿Dónde estás ahora mismo?"

# game/Scenes/Adrian/adrian3b.rpy:38
translate spanish adrian3b_2730945b:

    # pc "I'm not sure. Wherever you start as with a half-orc."
    pc "No estoy segura. Donde sea que empieces con un semiorco."

# game/Scenes/Adrian/adrian3b.rpy:39
translate spanish adrian3b_3292efd3:

    # gg "Oh, you're in Arigamir. Okay, I'll teleport there in just a minute."
    gg "Ah, estás en Arigamir. Vale, me teletransportaré allí en un minuto."

# game/Scenes/Adrian/adrian3b.rpy:40
translate spanish adrian3b_b9029897:

    # pc "Okay. I'm just doing some of this tutorial stuff."
    pc "Vale. Estoy haciendo algunas cosas del tutorial."

# game/Scenes/Adrian/adrian3b.rpy:43
translate spanish adrian3b_0520cb55:

    # "After a minute or so, Adrian's character \"Trenoxa\", who I recognize from playing before walks up to me."
    "Al cabo de un minuto más o menos, el personaje de Adrian, «Trenoxa», al que reconozco de haber jugado antes, se acerca a mí."

# game/Scenes/Adrian/adrian3b.rpy:44
translate spanish adrian3b_2116c262:

    # gg "Wow, you're a big guy, huh?"
    gg "Vaya, eres un tipo grande, ¿eh?"

# game/Scenes/Adrian/adrian3b.rpy:45
translate spanish adrian3b_55e9779d:

    # pc "Yeah, I wanted to play a big melee character."
    pc "Sí, quería jugar con un personaje grande de combate cuerpo a cuerpo."

# game/Scenes/Adrian/adrian3b.rpy:46
translate spanish adrian3b_fd3dc2df:

    # gg "Well I'm not complaining."
    gg "Bueno, no me quejo."

# game/Scenes/Adrian/adrian3b.rpy:47
translate spanish adrian3b_33a9a8b1:

    # gg "Want to go kill some stuff?"
    gg "¿Quieres ir a matar a algo?"

# game/Scenes/Adrian/adrian3b.rpy:48
translate spanish adrian3b_39757b54:

    # pc "Yeah, let's do it."
    pc "Sí, hagámoslo."

# game/Scenes/Adrian/adrian3b.rpy:51
translate spanish adrian3b_c06aa83e:

    # "We spend the next hour or so doing various quests, killing monsters, and leveling up."
    "Pasamos la siguiente hora más o menos haciendo varias misiones, matando monstruos y subiendo de nivel."

# game/Scenes/Adrian/adrian3b.rpy:52
translate spanish adrian3b_44e05c13:

    # "She shows me the world a bit, shows me how to advance my character, and gives me a bunch of equipment to start with."
    "Ella me enseña un poco el mundo, me muestra cómo hacer avanzar a mi personaje y me da un montón de equipo para empezar."

# game/Scenes/Adrian/adrian3b.rpy:53
translate spanish adrian3b_606b69f6:

    # "Who needs a tutorial when I have her?"
    "¿Quién necesita un tutorial cuando la tengo a ella?"

# game/Scenes/Adrian/adrian3b.rpy:56
translate spanish adrian3b_40c77f2c:

    # "Then we head back to the Inn, a place called \"The Feedmill\", and sit down for a drink together."
    "Luego volvemos a la posada, un lugar llamado «The Feedmill», y nos sentamos a tomar algo juntos."

# game/Scenes/Adrian/adrian3b.rpy:57
translate spanish adrian3b_4a42f78f:

    # pc "That was really fun."
    pc "Ha sido muy divertido."

# game/Scenes/Adrian/adrian3b.rpy:58
translate spanish adrian3b_e7c80669:

    # gg "I'm glad you enjoyed it. I had a blast."
    gg "Me alegro de que lo hayas disfrutado. Yo me lo he pasado genial."

# game/Scenes/Adrian/adrian3b.rpy:59
translate spanish adrian3b_31f7576c:

    # pc "Me too. I should be careful though. I could see myself really getting addicted to this game."
    pc "Yo también. Aunque debería tener cuidado. Me veo volviéndome adicto a este juego."

# game/Scenes/Adrian/adrian3b.rpy:60
translate spanish adrian3b_0233efaf:

    # gg "You don't have to tell me about that. I play way too much."
    gg "No hace falta que me lo digas. Yo juego demasiado."

# game/Scenes/Adrian/adrian3b.rpy:61
translate spanish adrian3b_2d5d032d:

    # gg "It's good to play in short bursts though. Don't spend all day on here, you know?"
    gg "Aunque está bien jugar en sesiones cortas. No te pases todo el día aquí, ¿sabes?"

# game/Scenes/Adrian/adrian3b.rpy:62
translate spanish adrian3b_7acad64a:

    # pc "Right."
    pc "Claro."

# game/Scenes/Adrian/adrian3b.rpy:63
translate spanish adrian3b_79845768:

    # gg "Well, we should probably get off for today then, but I hope you'll come on here and play again with me soon."
    gg "Bueno, entonces deberíamos desconectarnos por hoy, pero espero que vuelvas pronto a jugar conmigo."

# game/Scenes/Adrian/adrian3b.rpy:64
translate spanish adrian3b_95e44169:

    # pc "I will. Thanks for showing me the ropes."
    pc "Lo haré. Gracias por enseñarme cómo funciona todo."

# game/Scenes/Adrian/adrian3b.rpy:65
translate spanish adrian3b_b6875399:

    # gg "No problem. Keep fighting like that and you'll be max level in no time."
    gg "No hay de qué. Sigue luchando así y alcanzarás el nivel máximo en un santiamén."

# game/Scenes/Adrian/adrian3b.rpy:66
translate spanish adrian3b_d91c0c89:

    # gg "I'll see you later, [pcname]."
    gg "Nos vemos luego, [pcname]."

# game/Scenes/Adrian/adrian3b.rpy:69
translate spanish adrian3b_f4460497:

    # "With that, we log off together."
    "Con eso, nos desconectamos juntos."

translate spanish strings:

    # game/Scenes/Adrian/adrian3b.rpy:2
    old "After Adrian gives you a copy of Souls of War to play with her,"
    new "Después de que Adrian te dé una copia de Souls of War para jugar con ella,"

    # game/Scenes/Adrian/adrian3b.rpy:3
    old "install it on the computer in your bedroom and play with her at night."
    new "instálalo en el ordenador de tu habitación y juega con ella por la noche."

