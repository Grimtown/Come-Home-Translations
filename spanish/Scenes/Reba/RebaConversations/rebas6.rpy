# game/Scenes/Reba/RebaConversations/rebas6.rpy:16
translate spanish rebas6_a96f8fd8:

    # rb "Honestly, no. Not really."
    rb "Sinceramente, no. La verdad es que no."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:18
translate spanish rebas6_8dd8348c:

    # rb "I have to cook almost every night, because Mama can't stand in the kitchen with her bad knees."
    rb "Tengo que cocinar casi todas las noches, porque mamá no puede estar de pie en la cocina con sus rodillas malitas."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:19
translate spanish rebas6_5b8374d8:

    # rb "I'm just tired of it."
    rb "Es que estoy harta de ello."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:21
translate spanish rebas6_5f43b423:

    # rb "A lot of nights, by the time I finish cooking, I'm so hot and exhausted that I don't even feel like eating."
    rb "Muchas noches, para cuando termino de cocinar, tengo tanto calor y estoy tan agotada que ni siquiera me apetece comer."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:23
translate spanish rebas6_ec93f7a6:

    # pc "That sucks. I can understand how that can get tiring."
    pc "Qué rollo. Entiendo que eso pueda resultar agotador."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:24
translate spanish rebas6_c32ce8f1:

    # pc "What is your mom going to do when you move out?"
    pc "¿Qué va a hacer tu madre cuando te mudes?"

# game/Scenes/Reba/RebaConversations/rebas6.rpy:25
translate spanish rebas6_1ebef723:

    # rb "We've talked about it."
    rb "Lo hemos hablado."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:27
translate spanish rebas6_8c648ee8:

    # rb "She's grumpy about it and tries to make me feel guilty for leaving."
    rb "Está de mal humor por eso e intenta hacerme sentir culpable por irme."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:28
translate spanish rebas6_6027de22:

    # rb "I can't cook for her every night if I'm not living there."
    rb "No puedo cocinar para ella todas las noches si no vivo allí."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:30
translate spanish rebas6_8958a6a8:

    # rb "But I'm still planning on going over there once a week and cooking a few meals and putting them in Tupperware so she can warm them up when she wants to eat."
    rb "Pero sigo pensando en ir allí una vez a la semana, cocinar algunas comidas y guardarlas en tupperware para que se las pueda calentar cuando quiera comer."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:31
translate spanish rebas6_450ed4c8:

    # pc "Well that's a little easier on you at least."
    pc "Bueno, al menos eso te lo pone un poco más fácil."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:33
translate spanish rebas6_c89b1de1:

    # rb "Yeah."
    rb "Sí."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:34
translate spanish rebas6_ee963e53:

    # rb "Maybe when she gets knee surgery she'll be able to do more on her own again."
    rb "Quizá cuando se opere de la rodilla pueda volver a valerse más por sí misma."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:36
translate spanish rebas6_3c790017:

    # rb "And maybe once I don't have to cook and clean every night, I'll start to enjoy it again."
    rb "Y quizá, cuando ya no tenga que cocinar y limpiar todas las noches, vuelva a disfrutarlo."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:38
translate spanish rebas6_5ca7ea49:

    # rb "I don't want you to think I'm not good wife material."
    rb "No quiero que pienses que no sirvo para ser esposa."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:39
translate spanish rebas6_c5653eaa:

    # rb "I would cook for you."
    rb "Yo te cocinaría."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:40
translate spanish rebas6_93b41ed7:

    # pc "I'd cook for you too."
    pc "Yo también te cocinaría."

# game/Scenes/Reba/RebaConversations/rebas6.rpy:42
translate spanish rebas6_7538b8de:

    # rb "Oh, I like that even better!"
    rb "¡Oh, eso me gusta aún más!"

