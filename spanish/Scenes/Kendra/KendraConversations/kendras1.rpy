translate spanish kendras1_e461eca9:

    # sg "I don't really watch movies much."
    sg "La verdad es que no veo mucho cine."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:12
translate spanish kendras1_6b88c2c1:

    # sg "I don't know if you've noticed this about me, but I can sort of be all over the place."
    sg "No sé si te has dado cuenta de esto, pero soy un poco disperso."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:14
translate spanish kendras1_0c0d91a3:

    # sg "I have a really hard time sitting still for two hours, just starting at a screen."
    sg "Me cuesta mucho estar quieto dos horas, mirando fijamente una pantalla."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:15
translate spanish kendras1_d19c95ea:

    # sg "It's so boring, I don't see how people binge watch hours and hours of Netflix shows."
    sg "Es tan aburrido que no entiendo cómo la gente puede pasarse horas y horas viendo series en Netflix."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:17
translate spanish kendras1_923cb361:

    # sg "Halfway through one episode and I'm just like \"get to the fucking point!\""
    sg "A mitad de un episodio ya estoy pensando: «¡Ve al puto grano!»"

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:19
translate spanish kendras1_29cd4f51:

    # sg "Anyway, give me a five-minute long YouTube video about cats over The Godfather any day of the week."
    sg "En fin, prefiero un vídeo de YouTube de cinco minutos sobre gatos a El Padrino cualquier día de la semana."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:23
translate spanish kendras1_1762686a:

    # sg "So I'm blasphemous. Suck it."
    sg "Así que soy un blasfemo. Que te den."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:27
translate spanish kendras1_a25a552a:

    # sg "That's cool man. You do you."
    sg "No pasa nada, tío. Haz lo que quieras."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:31
translate spanish kendras1_e0271923:

    # sg "Right?"
    sg "¿Verdad?"

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:33
translate spanish kendras1_64b9724e:

    # sg "I just feel like movies, TV shows, books, video games..."
    sg "Es solo que siento que las películas, las series, los libros, los videojuegos..."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:34
translate spanish kendras1_6d4119aa:

    # sg "They're all just a way to escape and watch somebody else's story."
    sg "Son solo una forma de evadirse y ver la historia de otra persona."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:35
translate spanish kendras1_3019dfaf:

    # sg "I don't want to watch somebody else's story, you know? I want to make my own."
    sg "No quiero ver la historia de otra persona, ¿sabes? Quiero crear la mía propia."

# game/Scenes/Kendra/KendraConversations/kendras1.rpy:36
translate spanish kendras1_2b70283d:

    # pc "That makes sense. I get it."
    pc "Tiene sentido. Lo entiendo."

