translate chinese baienddate_e70e2ced:

    # "We get into our separate cars and drive away."
    "我们各自上车，开车离开了。"

# game/Scenes/Bai/BaiDates/baidate.rpy:64
translate chinese baienddate_4a11d772:

    # bai "Thanks for taking me out, [pcname]."
    bai "谢谢你带我出去玩，[pcname]。"

# game/Scenes/Bai/BaiDates/baidate.rpy:65
translate chinese baienddate_17764b2d:

    # bai "I had a really good time. I'm looking forward to our next date."
    bai "我玩得很开心。期待下次约会。"

# game/Scenes/Bai/BaiDates/baidate.rpy:66
translate chinese baienddate_03eaad50:

    # pc "Me too."
    pc "我也是。"

# game/Scenes/Bai/BaiDates/baidate.rpy:68
translate chinese baienddate_4924fbc9:

    # "He stands close to me, looking in my eyes expectantly. Thinking about something, but seemingly too afraid to do it."
    "他紧挨着我站着，满怀期待地望着我的眼睛。好像在盘算什么，却似乎又不敢付诸行动。"

# game/Scenes/Bai/BaiDates/baidate.rpy:72
translate chinese baienddate_18491609:

    # "He looks a bit surprised as I lean in, but quickly accepts it and kisses back."
    "当我俯身靠近时，他看起来有些惊讶，但很快便接受了，并回吻了我。"

# game/Scenes/Bai/BaiDates/baidate.rpy:74
translate chinese baienddate_ea54ee7b:

    # pc "Can I kiss you?"
    pc "我可以吻你吗？"

# game/Scenes/Bai/BaiDates/baidate.rpy:75
translate chinese baienddate_e48f765e:

    # bai "Yes. I'd like that."
    bai "可以。我很乐意。"

# game/Scenes/Bai/BaiDates/baidate.rpy:77
translate chinese baienddate_ceee6fe3:

    # "I lean in and kiss him."
    "我俯身吻了他。"

# game/Scenes/Bai/BaiDates/baidate.rpy:79
translate chinese baienddate_30410416:

    # "He looks nervous, then that changes a bit to disappointment."
    "他看起来有些紧张，随后神情转为一丝失望。"

# game/Scenes/Bai/BaiDates/baidate.rpy:81
translate chinese baienddate_17fc970f:

    # "The kiss starts off nervously, but then it changes to something more comfortable and eager."
    "起初这个吻有些生涩，但渐渐变得自然而热切。"

# game/Scenes/Bai/BaiDates/baidate.rpy:82
translate chinese baienddate_54e89b78:

    # "And then finally, we pull away."
    "最后，我们分开了。"

# game/Scenes/Bai/BaiDates/baidate.rpy:84
translate chinese baienddate_a5573473:

    # bai "Wow."
    bai "哇。"

# game/Scenes/Bai/BaiDates/baidate.rpy:85
translate chinese baienddate_d908c8e3:

    # bai "My first kiss with a guy."
    bai "这是我第一次和男生接吻。"

# game/Scenes/Bai/BaiDates/baidate.rpy:86
translate chinese baienddate_46fbc1b5:

    # pc "How was it?"
    pc "感觉怎么样？"

# game/Scenes/Bai/BaiDates/baidate.rpy:87
translate chinese baienddate_58dc2fa3:

    # bai "Weird at first. But then it felt good. Incredible even."
    bai "起初有点怪怪的。但后来感觉很好。甚至可以说不可思议。"

# game/Scenes/Bai/BaiDates/baidate.rpy:88
translate chinese baienddate_2b2f5c98:

    # bai "I want more. Hopefully very soon."
    bai "我还想要更多。希望很快就能再体验。"

# game/Scenes/Bai/BaiDates/baidate.rpy:89
translate chinese baienddate_badd9121:

    # bai "Thanks, [pcname]."
    bai "谢谢，[pcname]。"

# game/Scenes/Bai/BaiDates/baidate.rpy:96
translate chinese baienddate_ba7536f7:

    # "We kiss goodbye. I think both of us want a little more, but it seems now is not the time."
    "我们吻别。我觉得我们俩都还想多亲一会儿，但看来现在不是时候。"

# game/Scenes/Bai/BaiDates/baidate.rpy:99
translate chinese baienddate_fa52edbc:

    # bai "Do you want to maybe come back to my place and uh... do stuff?"
    bai "要不要去我那儿……做点什么？"

# game/Scenes/Bai/BaiDates/baidate.rpy:102
translate chinese baienddate_c23a8a8d:

    # bai "Awesome."
    bai "太棒了。"

# game/Scenes/Bai/BaiDates/baidate.rpy:105
translate chinese baienddate_b8b44fef:

    # "We drive back to his apartment, eager to get inside and alone with each other."
    "我们开车回他家，迫不及待想进去独处。"

# game/Scenes/Bai/BaiDates/baidate.rpy:108
translate chinese baienddate_c23a8a8d_1:

