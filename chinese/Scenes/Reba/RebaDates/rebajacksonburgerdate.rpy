    gl "哟，小树枝。你约会的是谁啊？"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:77
translate chinese rebajacksonburgerstartdate_293f257d_1:

    # pc "This is Reba. We met a little while back and have started dating a bit."
    pc "这是丽贝卡。我们前阵子认识的，最近开始约会了。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:80
translate chinese rebajacksonburgerstartdate_96b7d3b1:

    # gl "How's it going, girl? I'm Izzy."
    gl "最近怎么样，姑娘？我是伊兹。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:81
translate chinese rebajacksonburgerstartdate_8cd070cc:

    # rb "Hey there!"
    rb "嗨！"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:82
translate chinese rebajacksonburgerstartdate_9ab5b8d9_1:

    # rb "I guess you're another one of [pcname]'s friends?"
