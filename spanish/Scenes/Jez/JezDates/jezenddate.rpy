# game/Scenes/Jez/JezDates/jezenddate.rpy:43
translate spanish jezenddate_ef81804e:

    # det "Wow, that was nice. Making it really hard for me to say goodbye."
    det "Vaya, eso ha estado muy bien. Me está costando mucho decir adiós."

# game/Scenes/Jez/JezDates/jezenddate.rpy:44
translate spanish jezenddate_c18fe3a7:

    # det "But I have to. Bye, [pcname]."
    det "Pero tengo que hacerlo. Adiós, [pcname]."

