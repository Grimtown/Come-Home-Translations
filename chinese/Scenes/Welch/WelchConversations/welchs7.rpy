# game/Scenes/Welch/WelchConversations/welchs7.rpy:15
translate chinese welchs7_e80c1374:

    # sst "Sure, it matters."
    sst "当然重要。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:16
translate chinese welchs7_80196195:

    # sst "Anybody who says age is just a number is full of shit."
    sst "说年龄只是个数字的人全都在胡扯。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:18
translate chinese welchs7_43137c10:

    # sst "My ex-husband was 15 years older than me."
    sst "我前夫比我大15岁。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:19
translate chinese welchs7_783797d4:

    # sst "He was the typical older man who wanted a woman in her early twenties."
    sst "他就是那种典型的老男人，想要个二十出头的女人。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:20
translate chinese welchs7_a63ce122:

    # sst "Young, naive, and inexperienced, so he could easily control her."
    sst "年轻、天真、没经验，这样他就能轻易控制她。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:21
translate chinese welchs7_522d72a0:

    # sst "I don't trust older men who want young, barely-legal girlfriends."
    sst "我不信任那些想要年轻、刚满法定年龄女友的老男人。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:23
translate chinese welchs7_745134e4:

    # sst "On the other hand, I'm in my thirties now and I'm in my prime, sexually."
    sst "另一方面，我现在三十多岁，正值性欲巅峰。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:24
translate chinese welchs7_423cc11a:

    # sst "I want a younger man who can keep up with me."
    sst "我想要一个能跟上我的年轻男人。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:26
translate chinese welchs7_3c75ea3e:

    # sst "I don't think I'd ever want to be with another man who was older than me."
    sst "我想我再也不会想和比我年长的男人在一起了。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:28
translate chinese welchs7_3799c2d2:

    # sst "I want someone young and strong, who can go for hours."
    sst "我想要一个年轻强壮、能持续数小时的人。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:30
translate chinese welchs7_19718552:

    # sst "But they also need to be mature and intelligent enough to carry on a conversation."
    sst "但他也必须足够成熟和聪明，能进行有深度的对话。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:31
translate chinese welchs7_4c8f51a5:

    # pc "That's a lot to ask."
    pc "这要求确实很高。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:33
translate chinese welchs7_b352d93b:

    # sst "You've seen me."
    sst "你见过我。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:34
translate chinese welchs7_068c4914:

    # sst "I think I'm hot enough that I can be a little picky."
    sst "我觉得自己够性感，所以可以稍微挑剔一点。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:35
translate chinese welchs7_e242e502:

    # pc "You're right about that."
    pc "你说得对。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:37
translate chinese welchs7_aed4708a:

    # sst "I give a lot back when I'm in a relationship, too."
    sst "我在恋爱时也会付出很多。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:39
translate chinese welchs7_f1ce0ee9:

    # sst "When I find the right guy, I make him feel like the king of the world."
    sst "一旦遇到对的人，我会让他感觉自己像世界之王。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:41
translate chinese welchs7_aee81ad7:

    # pc "Yes, you do."
    pc "是的，你确实会。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:43
translate chinese welchs7_224e3c63:

    # pc "That sounds incredible."
    pc "听起来太棒了。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:45
translate chinese welchs7_bbfec07c:

    # sst "Just you wait."
    sst "你等着瞧。"

# game/Scenes/Welch/WelchConversations/welchs7.rpy:46
translate chinese welchs7_a6e2a90a:

    # sst "You haven't seen anything yet."
    sst "你还没见识过呢。"

