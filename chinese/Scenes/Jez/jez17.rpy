translate chinese jez17_95299007:

    # mama "You do now."
    mama "现在有了。"

# game/Scenes/Jez/jez17.rpy:134
translate chinese jez17_b1eb730a:

    # mama "My little Jesabela has been smiling so much more lately. Mamá likes this."
    mama "我小杰萨贝拉最近笑得特别多。妈妈很喜欢这样。"

# game/Scenes/Jez/jez17.rpy:135
translate chinese jez17_12cb5da7:

    # mama "So you just keep making her happy, okay?"
    mama "所以你要一直让她开心，好吗？"

# game/Scenes/Jez/jez17.rpy:136
translate chinese jez17_1a8e690e:

    # pc "Si."
    pc "好的。"

# game/Scenes/Jez/jez17.rpy:139
