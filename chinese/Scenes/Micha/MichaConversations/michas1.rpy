translate chinese michas1_3ed591c2:

    # mc "I am very busy with school, but yes there are things I enjoy doing."
    mc "我上学很忙，不过确实有些我喜欢做的事。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:15
translate chinese michas1_22796789:

    # mc "I like to watch YouTube - especially make-up tutorials and cooking blogs."
    mc "我喜欢看YouTube——尤其是化妆教程和烹饪博主。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:17
translate chinese michas1_2641e76b:

    # mc "I also listen to a lot of music."
    mc "我也经常听音乐。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:18
translate chinese michas1_ca902f38:

    # pc "Korean music? Like K-pop?"
    pc "韩国音乐？像K-pop那种吗？"

# game/Scenes/Micha/MichaConversations/michas1.rpy:19
translate chinese michas1_c54bb033:

    # mc "Mostly American music, but some Korean as well."
    mc "主要是美国音乐，但也听一些韩国的。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:21
translate chinese michas1_14f8a605:

    # mc "I try to watch and listen to as much American content as I can, because I want to better fit in here."
    mc "我尽量多看多听美国的内容，因为我想更好地融入这里。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:22
translate chinese michas1_d64bc11a:

    # pc "That makes sense."
    pc "这很合理。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:24
translate chinese michas1_30e70cb1:

    # mc "I also like yoga. I practice every morning."
    mc "我还喜欢瑜伽。我每天早上都会练。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:25
translate chinese michas1_201d5764:

    # pc "Nice."
    pc "不错。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:26
translate chinese michas1_20a910bd:

    # mc "And dancing. I love to dance."
    mc "还有跳舞。我超爱跳舞。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:27
translate chinese michas1_399bdc0f:

    # pc "Really?"
    pc "真的吗？"

# game/Scenes/Micha/MichaConversations/michas1.rpy:29
translate chinese michas1_24e378f8:

    # mc "Yes. Not with other people, but by myself, at home, I enjoy dancing."
    mc "是的。不是和别人一起，而是在家里自己跳，我很享受跳舞。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:30
translate chinese michas1_b8d053ab:

    # pc "Oh okay. I understand."
    pc "哦，好的。我明白了。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:32
translate chinese michas1_872fff79:

    # mc "I think that is all of my interests."
    mc "我想我的兴趣大概就这些了。"

# game/Scenes/Micha/MichaConversations/michas1.rpy:33
