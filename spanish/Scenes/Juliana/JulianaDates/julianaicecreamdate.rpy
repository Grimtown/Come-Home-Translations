translate spanish julianaicecreamstartdate_6e86a495:

    # bn "I'll have vanilla please."
    bn "Tomaré vainilla, por favor."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:29
translate spanish julianaicecreamstartdate_e28b03b7:

    # pc "Just vanilla? You don't want a flavor?"
    pc "¿Solo vainilla? ¿No quieres ningún sabor?"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:30
translate spanish julianaicecreamstartdate_c049ae90:

    # bn "I like vanilla. It's the finest of the flavors."
    bn "Me gusta la vainilla. Es el mejor de los sabores."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:32
translate spanish julianaicecreamstartdate_bf0f1fe7:

    # pc "\"Gotta see the show, 'cause then you'll know the vertigo is gonna grow 'cause it's so dangerous, you'll have to sign a waiver?\""
    pc "«¿Tienes que ver el espectáculo, porque entonces sabrás que el vértigo va a crecer porque es tan peligroso que tendrás que firmar una exención de responsabilidad?»"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:33
translate spanish julianaicecreamstartdate_3a694dff:

    # bn "Uh... what?"
    bn "Eh... ¿qué?"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:34
translate spanish julianaicecreamstartdate_3efc5a94:

    # pc "Oh, it's from a song. I thought you were making a reference."
    pc "Ah, es de una canción. Pensé que estabas haciendo una referencia."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:35
translate spanish julianaicecreamstartdate_43de1e25:

    # bn "I'm sorry, I don't know the song."
    bn "Lo siento, no conozco la canción."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:36
translate spanish julianaicecreamstartdate_385889cf:

    # pc "Oh... okay. Ignore that then."
    pc "Oh... vale. Entonces ignora eso."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:41
translate spanish julianaicecreamstartdate_a716a63e:

    # "We sit down and enjoy our ice cream and chat for a while."
    "Nos sentamos, disfrutamos de nuestro helado y charlamos un rato."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:49
translate spanish julianaicecreamstartdate_bec02a72:

    # "With the ice cream finished, our conversation slows down."
    "Una vez terminado el helado, nuestra conversación se va apagando."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:50
translate spanish julianaicecreamstartdate_1b4b54ec:

    # bn "I think I'm ready for you to come back to my house now."
    bn "Creo que ya estoy lista para que vengas a mi casa."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:51
translate spanish julianaicecreamstartdate_18e0895f:

    # pc "Okay, let's go."
    pc "Vale, vamos."

