    # game/Scenes/Jez/jez10.rpy:67
    old "Are you sure you want to tell Jez about the meth lab?"
    new "¿Estás seguro de que quieres contarle a Jez lo del laboratorio de metanfetamina?"

    # game/Scenes/Jez/jez10.rpy:71
    old "Are you absolutely sure?"
    new "¿Estás absolutamente seguro?"

    # game/Scenes/Jez/jez10.rpy:73
    old "Yes, I'm not interested in having a romance with Jez"
    new "Sí, no me interesa tener un romance con Jez."

    # game/Scenes/Jez/jez10.rpy:103
    old "Tell her about Izzy"
    new "Cuéntale lo de Izzy."

    # game/Scenes/Jez/jez10.rpy:128
