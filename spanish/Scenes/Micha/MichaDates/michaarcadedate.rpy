translate spanish michaarcadestartdate_cba53581:

    # "We dance for a while longer, until I'm so tired, I can barely move."
    "Bailamos un rato más, hasta que estoy tan cansado que apenas puedo moverme."

# game/Scenes/Micha/MichaDates/michaarcadedate.rpy:135
translate spanish michaarcadestartdate_66adc21b:

