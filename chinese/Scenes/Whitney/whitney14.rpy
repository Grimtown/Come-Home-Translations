    # wt "Let's go."
    wt "走吧。"

# game/Scenes/Whitney/whitney14.rpy:332
translate chinese whitney14leave_4f21c6d8:

    # pc "I need to go."
    pc "我得走了。"

# game/Scenes/Whitney/whitney14.rpy:333
translate chinese whitney14leave_1d1c37b4:

    # wt "Really?"
    wt "真的吗？"

# game/Scenes/Whitney/whitney14.rpy:334
