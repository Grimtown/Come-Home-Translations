# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:12
translate spanish izzyq1_b3f0a2a1:

    # gl "So, uh... what do you do, Twig?"
    gl "Bueno, eh... ¿a qué te dedicas, Twig?"

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:13
translate spanish izzyq1_1cde0fea:

    # pc "You mean like a job?"
    pc "¿Te refieres a un trabajo?"

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:14
translate spanish izzyq1_56c192dd:

    # pc "How long have we been hanging out with each other and we've never talked about this?"
    pc "¿Cuánto tiempo llevamos saliendo juntos y nunca hemos hablado de esto?"

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:16
translate spanish izzyq1_d0eb45b5:

    # gl "I don't think so. If we have, I don't remember."
    gl "No lo creo. Si lo hemos hecho, no lo recuerdo."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:18
translate spanish izzyq1_9dfac34c:

    # gl "Honestly, I wasn't interested in anything above your belt until recently."
    gl "Sinceramente, hasta hace poco no me interesaba nada por encima del cinturón."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:19
translate spanish izzyq1_b5ea135c:

    # pc "That's fair."
    pc "Es justo."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:21
translate spanish izzyq1_e15068c6:

    # pc "Well, I go to college, and I have a job as an assistant at a law firm."
    pc "Bueno, voy a la universidad y trabajo como asistente en un bufete de abogados."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:23
translate spanish izzyq1_93e6458a:

    # gl "You're a fucking lawyer? For real?"
    gl "¿Eres jodidamente abogada? ¿En serio?"

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:25
translate spanish izzyq1_4a320e48:

    # pc "No, no, I'm just an assistant."
    pc "No, no, solo soy asistente."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:26
translate spanish izzyq1_c5a8953c:

    # pc "Like, I clean the office and deal with phones and paperwork and stuff."
    pc "Limpio la oficina y me encargo de los teléfonos, el papeleo y esas cosas."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:28
translate spanish izzyq1_f32b0f5a:

    # gl "Like a secretary plus janitor?"
    gl "¿Como una secretaria que también hace de conserje?"

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:29
translate spanish izzyq1_ef8bda5d:

    # pc "Sort of."
    pc "Más o menos."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:31
translate spanish izzyq1_df5aa9d8:

    # gl "Hell, I could do that! And they pay you good, plus give you a car to drive?"
    gl "¡Joder, yo podría hacer eso! ¿Y te pagan bien, además de darte un coche para conducir?"

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:33
translate spanish izzyq1_9f00d552:

    # pc "Yeah, I guess so."
    pc "Sí, supongo que sí."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:35
translate spanish izzyq1_b429ca1b:

    # gl "I need to get me one of them jobs."
    gl "Tengo que conseguirme uno de esos trabajos."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:36
translate spanish izzyq1_4017ea2a:

    # pc "It ain't bad."
    pc "No está mal."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:38
translate spanish izzyq1_87553e47:

    # pc "Though the boss can be a bit of a pain in the ass sometimes."
    pc "Aunque el jefe a veces puede ser un poco pesado."

