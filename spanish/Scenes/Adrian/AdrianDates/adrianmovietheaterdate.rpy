translate spanish adrianmovietheaterstartdate_13ddb197:

    # "We get to the theater and find seats in the back."
    "Llegamos al cine y encontramos asientos en la parte de atrás."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:26
translate spanish adrianmovietheaterstartdate_6cc4cd44:

    # "There's a little time to chat before the movie starts."
    "Tenemos un rato para charlar antes de que empiece la película."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:34
translate spanish adrianmovietheaterstartdate_c6fd13bc:

    # "Finally lights dim and she leans over against me while we watch the movie."
    "Por fin se apagan las luces y ella se inclina hacia mí mientras vemos la película."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:35
translate spanish adrianmovietheaterstartdate_d2fbe7b2:

    # "It's pretty good and it's nice just being there with her."
    "Está bastante bien y es agradable simplemente estar allí con ella."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:38
translate spanish adrianmovietheaterstartdate_9dc3692e:

    # "Finally the lights dim and the movie starts. It's not bad."
    "Por fin se apagan las luces y empieza la película. No está mal."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:40
translate spanish adrianmovietheaterstartdate_9b19c90f:

    # gg "That was pretty good, huh?"
    gg "Estuvo bastante bien, ¿eh?"

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:41
translate spanish adrianmovietheaterstartdate_a57bb1cd:

    # "We chat a little through the credits."
    "Charlamos un poco durante los créditos."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:46
translate spanish adrianmovietheaterstartdate_cb13127e:

    # "Afterwards, I drive her home and walk her up to her door."
    "Después, la llevo a casa y la acompaño hasta la puerta."

