    # game/Scenes/Juliana/juliana3.rpy:75
    old "You mean like a date?"
    new "你是说像约会那样吗？"

    # game/Scenes/Juliana/juliana3.rpy:81
    old "I'd like to do more than studying"
    new "我希望能做些比学习更亲密的事"

