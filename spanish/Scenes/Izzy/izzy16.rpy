    voice 'voices/izzy_whatsup.mp3'

# game/Scenes/Izzy/izzy16.rpy:24
translate spanish izzy16_2db3da37:

    # gl "What's up, Twig?"
    gl "¿Qué tal, Twig?"

# game/Scenes/Izzy/izzy16.rpy:26
translate spanish izzy16_f269a3da:

    # gl "You wanna come over for a while? Moose and Mal are going to come hang out. I thought we could all hang out together."
    gl "¿Quieres venir un rato? Moose y Mal van a venir a pasar el rato. Pensé que podríamos estar todos juntos."

# game/Scenes/Izzy/izzy16.rpy:27
translate spanish izzy16_5e778dfd:

