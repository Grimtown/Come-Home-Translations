# game/Scenes/CounselorChats/Conversations/cc14.rpy:11
translate chinese cc14_0a8aaad9:

    # sc "Oh, I really don't know."
    sc "哦，我真的不知道。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:13
translate chinese cc14_44f7d77e:

    # sc "I'd try not to get fired."
    sc "我会尽量不被解雇。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:14
translate chinese cc14_ff2b5f43:

    # sc "And even more important than that, I'd try to protect you."
    sc "而且比这更重要的是，我会尽力保护你。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:15
translate chinese cc14_8ce73bbc:

    # sc "I wouldn't want you to lose your diploma over this little fling or anything."
    sc "我可不希望你因为这段小插曲而失去毕业证书。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:17
translate chinese cc14_70b16855:

    # sc "Then, I guess, I would just be embarrassed."
    sc "那样的话，我想我大概会感到尴尬。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:19
translate chinese cc14_fc26938b:

    # sc "Not because of you, of course. Because of things I'd rather keep private being made public."
    sc "当然不是因为你。而是因为那些我宁愿保密的事情被公之于众。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:21
translate chinese cc14_0badc780:

    # sc "Hopefully it will never happen."
    sc "希望这种情况永远不会发生。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:22
translate chinese cc14_8c4a49cd:

    # sc "My husband knows about us now. Not specifically, but he knows that I'm in this relationship outside of our marriage."
    sc "我丈夫现在知道我们的事了。虽然不是具体细节，但他知道我在婚外有这段关系。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:24
translate chinese cc14_0a2a7add:

    # sc "Nobody else ever needs to know. It's not anybody else's business."
    sc "其他人永远不需要知道。这不关别人的事。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:25
translate chinese cc14_f84a0041:

    # pc "I'm with you. I haven't told anybody."
    pc "我站在你这边。我没告诉过任何人。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:27
translate chinese cc14_d3c53958:

    # sc "Good. Let's just keep it that way."
    sc "好。我们就保持这样吧。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:29
translate chinese cc14_5d324c6f:

    # sc "I like this being our little secret."
    sc "我喜欢这成为我们的小秘密。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:30
translate chinese cc14_66c36c23:

    # sc "You better get to class."
    sc "你最好去上课了。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:31
translate chinese cc14_01e30054:

    # pc "Okay. Talk to you later, Gertrude."
    pc "好的。格特鲁德，回头再聊。"

# game/Scenes/CounselorChats/Conversations/cc14.rpy:34
translate chinese cc14_19163858:

    # "I leave her office and go to class."
    "我离开她的办公室去上课。"

translate chinese strings:

    # game/Scenes/CounselorChats/Conversations/cc14.rpy:2
    old "To unlock this conversation, you have to have talked to her about meeting outside of school."
    new "要解锁这段对话，你必须先和她聊过在课外见面这件事。"

