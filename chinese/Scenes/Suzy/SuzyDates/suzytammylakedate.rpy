# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:16
translate chinese suzytammylakedate_2a690dca:

    # "When the girls are ready, we drive out to the lake together."
    "等女孩们准备好后，我们一起开车去了湖边。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:19
translate chinese suzytammylakedate_80ba5381:

    # ss "Wow. We have the whole place to ourselves?"
    ss "哇。这里就我们自己？"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:20
translate chinese suzytammylakedate_126ea9d5:

    # pc "Yeah, people don't come out here too often."
    pc "是啊，很少有人来这儿。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:21
translate chinese suzytammylakedate_2949eaf8:

    # tm "So we can skinny dip?"
    tm "那我们可以裸泳吗？"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:22
translate chinese suzytammylakedate_f06980a5:

    # pc "If you want."
    pc "如果你想的话。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:23
translate chinese suzytammylakedate_8fc077c4:

    # ss "Fuck yeah!"
    ss "太棒了！"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:27
translate chinese suzytammylakedate_5f7a3d7d:

    # "We go out to the pier and they strip out of their clothes."
    "我们走到码头，她们脱掉了衣服。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:28
translate chinese suzytammylakedate_dfc0bda7:

    # "Goddamn they're gorgeous."
    "天啊，她们真美。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:29
translate chinese suzytammylakedate_9757683f:

    # tm "Well, come on, [pcname]. Take your clothes off."
    tm "来吧，[pcname]。你也脱掉衣服。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:30
translate chinese suzytammylakedate_9fdfdc3e:

    # ss "Yeah, [bro]. Let's see those frank and beans."
    ss "对啊，[bro]。让我们看看你的“香肠和豆子”。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:33
translate chinese suzytammylakedate_a648d8e6:

    # tm "Haha, frank and beans? Such a dork."
    tm "哈哈，“香肠和豆子”？真傻。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:34
translate chinese suzytammylakedate_04dcc7c0:

    # ss "Hey! Don't call me a dork!"
    ss "嘿！别叫我傻瓜！"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:35
translate chinese suzytammylakedate_022e3346:

    # tm "What are you going to do about it, skinny?"
    tm "你能拿我怎么办，瘦子？"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:38
translate chinese suzytammylakedate_4508b549:

    # tm "Aah!"
    tm "啊！"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:41
translate chinese suzytammylakedate_5e934eef:

    # "They hit the water with a huge splash, then come up laughing."
    "他们扑通一声跳进水里，溅起巨大水花，然后笑嘻嘻地浮出水面。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:42
translate chinese suzytammylakedate_a94b5451:

    # tm "Frank and beans!"
    tm "肉棒和豆子！"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:43
translate chinese suzytammylakedate_66181e46:

    # ss "Come on, [bro]! Get in here before I drown this bitch."
    ss "快点，[bro]！赶紧进来，不然我要淹死这婊子了。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:46
translate chinese suzytammylakedate_d8760576:

    # "I jump into the water with them and we swim together for a while, chatting as we laugh and relax in the water."
    "我跟着他们跳进水里，我们一起游了一会儿，一边聊天一边在水中开怀大笑，尽情放松。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:54
translate chinese suzytammylakedate_743c8f80:

    # "When the sun starts to set, we sit on the pier to dry off together."
    "当太阳开始西沉时，我们坐在码头上一起晾干身体。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:56
translate chinese suzytammylakedate_f28b8c70:

    # ss "I better not get any splinters in my butt sitting on this thing."
    ss "坐在这玩意儿上，我可别让木刺扎进屁股里。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:57
translate chinese suzytammylakedate_4c128477:

    # tm "Aw, if you do baby, I'll pull them out. With my teeth."
    tm "哎呀，要是扎进去了宝贝，我来帮你拔出来。用牙。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:58
translate chinese suzytammylakedate_7294518d:

    # ss "I'm not sure if that's sexy or not."
    ss "我不确定这算不算性感。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:59
translate chinese suzytammylakedate_07157d28:

    # pc "It is."
    pc "算。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:63
translate chinese suzytammylakedate_4b1e3586:

    # tm "This was really fun."
    tm "今天真的好开心。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:64
translate chinese suzytammylakedate_ad1121f0:

    # ss "Yeah, thanks [bro]."
    ss "是啊，谢谢[bro]。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:65
translate chinese suzytammylakedate_088b071d:

    # ss "Are you ready to take this date back to the house?"
    ss "准备好把这次约会带回屋里了吗？"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:66
translate chinese suzytammylakedate_a400a310:

    # pc "Sure, let's go home."
    pc "当然，咱们回家吧。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:72
translate chinese suzytammylakedate_d41d8cd9:

    # voice 'voices/suzy_enditproperly.mp3'
    voice 'voices/suzy_enditproperly.mp3'

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:73
translate chinese suzytammylakedate_643c2201:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "看来妈妈已经睡着了。所以，你想在这里结束约会，还是上楼去你的房间好好结束？"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:76
translate chinese suzytammylakedate_df8719cf:

    # tm "Fuck yes."
    tm "当然要。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:79
translate chinese suzytammylakedate_60c94072:

    # "We quietly go upstairs together, go into my bedroom, and lock the door."
    "我们悄悄一起上楼，走进我的卧室，锁上了门。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:83
translate chinese suzytammylakedate_acfb634b:

    # ss "Okay, well I had a fun date, [bro]."
    ss "好吧，这次约会很开心，[bro]。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:84
translate chinese suzytammylakedate_be17834a:

    # tm "Yeah, me too."
    tm "嗯，我也是。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:85
translate chinese suzytammylakedate_644a5289:

    # ss "Sleep well. See you tomorrow."
    ss "晚安。明天见。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:86
translate chinese suzytammylakedate_d35669a0:

    # tm "Good night, [pcname]."
    tm "晚安，[pcname]。"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:89
translate chinese suzytammylakedate_d747330a:

    # "They go up to Suzy's bedroom, leaving me to decide what I want to do with my night."
    "他们上了苏茜的卧室，留我独自决定今晚该怎么过。"

translate chinese strings:

    # game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:6
