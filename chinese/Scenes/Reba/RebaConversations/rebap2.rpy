# game/Scenes/Reba/RebaConversations/rebap2.rpy:15
translate chinese rebap2_ec0494f3:

    # pc "But you have to pick a major eventually when you go to college... do you have any idea what it would be?"
    pc "不过上大学后总得选个专业……你有想过要选什么吗？"

# game/Scenes/Reba/RebaConversations/rebap2.rpy:16
translate chinese rebap2_132f7378:

    # rb "I guess engineering, or something like that."
    rb "我想是工程类，或者类似的。"

# game/Scenes/Reba/RebaConversations/rebap2.rpy:17
translate chinese rebap2_5983338d:

    # rb "I like to build stuff. I like to see how things work."
    rb "我喜欢动手制作东西。我喜欢探究事物运作的原理。"

# game/Scenes/Reba/RebaConversations/rebap2.rpy:19
translate chinese rebap2_a653762f:

    # rb "I think I'd be good at that."
    rb "我觉得我在这方面会很在行。"

# game/Scenes/Reba/RebaConversations/rebap2.rpy:20
translate chinese rebap2_2e0b8e20:

    # pc "I know you would."
    pc "我知道你会。"

# game/Scenes/Reba/RebaConversations/rebap2.rpy:21
translate chinese rebap2_60889a8b:

    # pc "I hope I get to see you do it."
    pc "希望有朝一日能看到你大显身手。"

# game/Scenes/Reba/RebaConversations/rebap2.rpy:22
translate chinese rebap2_7cbe57ac:

    # rb "Thanks, [pcname]. Me too."
    rb "谢谢，[pcname]。我也是。"

