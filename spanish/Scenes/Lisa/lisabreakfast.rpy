translate spanish lisabreakfast_b90ab6dc:

    # "Lisa must have gone to work early. She didn't cook any breakfast. I guess she's still upset."
    "Lisa debe de haberse ido a trabajar temprano. No ha preparado el desayuno. Supongo que sigue enfadada."

# game/Scenes/Lisa/lisabreakfast.rpy:12
translate spanish lisabreakfast_5ba2cbf3:

    # "Lisa stands in the kitchen, cooking some eggs in a pan on the stove."
    "Lisa está en la cocina, preparando unos huevos en una sartén sobre la cocina."

# game/Scenes/Lisa/lisabreakfast.rpy:19
translate spanish lisabreakfast_d41d8cd9:

    # voice 'voices/lisa_goodmorning.wav'
    voice 'voices/lisa_goodmorning.wav'

# game/Scenes/Lisa/lisabreakfast.rpy:20
translate spanish lisabreakfast_09b21b2a:

    # sp "Good morning honey. Want some breakfast?"
    sp "Buenos días, cariño. ¿Quieres desayunar?"

# game/Scenes/Lisa/lisabreakfast.rpy:35
translate spanish nottodaymom_d0417e78:

    # sp "Okay honey, let me know if you change your mind."
    sp "Vale, cariño, avísame si cambias de opinión."

# game/Scenes/Lisa/lisabreakfast.rpy:45
translate spanish lisabreakfastconvo_c299cac3:

    # sp "I'll cook you some eggs and bacon."
    sp "Te prepararé unos huevos con beicon."

# game/Scenes/Lisa/lisabreakfast.rpy:46
translate spanish lisabreakfastconvo_e45e3b16:

    # "She returns to the stove and cooks us both breakfast."
    "Vuelve a la cocina y nos prepara el desayuno a los dos."

# game/Scenes/Lisa/lisabreakfast.rpy:49
translate spanish lisabreakfastconvo_2ccb9eb9:

    # "Then we sit down together and have a nice conversation while eating breakfast."
    "Luego nos sentamos juntos y tenemos una agradable conversación mientras desayunamos."

# game/Scenes/Lisa/lisabreakfast.rpy:51
translate spanish lisabreakfastconvo_280140a3:

    # "Afterwards, she cleans up the plates and I head upstairs and get dressed for the day."
    "Después, ella recoge los platos y yo subo a vestirme para el día."

