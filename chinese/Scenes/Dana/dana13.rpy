    # cw "Liz's apartment is on Charles Street, right behind there."
    cw "莉兹的公寓在查尔斯街，就在那后面。"

# game/Scenes/Dana/dana13.rpy:386
translate chinese dana13rescue_238bde54:

    # pc "Got it."
    pc "明白了。"

# game/Scenes/Dana/dana13.rpy:389
translate chinese dana13rescue_dc9048a8:

    # "I drive her over to the apartment and walk with her up to her friend's door. As soon as she opens the door, Liz pulls Dana into a big hug."
    "我开车送她到公寓，陪她走到她朋友家门口。门一开，莉兹就一把把达娜搂进怀里。"

# game/Scenes/Dana/dana13.rpy:390
translate chinese dana13rescue_c66518ae:

    # "Liz" "Oh, girl I'm so proud of you. Did he hit you? I'll kill him."
    "Liz" "哦，姑娘，我为你感到骄傲。他打你了吗？我要杀了他。"

# game/Scenes/Dana/dana13.rpy:392
translate chinese dana13rescue_d41d8cd9_14:

    # voice "voices/dana 12_20.wav"
    voice "voices/dana 12_20.wav"

# game/Scenes/Dana/dana13.rpy:393
translate chinese dana13rescue_8b34869b:

    # cw "It's okay, Liz. I'm okay."
    cw "没事的，莉兹。我没事。"

# game/Scenes/Dana/dana13.rpy:394
translate chinese dana13rescue_63d21bdb:

    # "Liz" "Well, come on inside."
    "Liz" "那，快进来吧。"

# game/Scenes/Dana/dana13.rpy:397
translate chinese dana13rescue_9864b88e:

    # "I follow them into the house and stand awkwardly near the door."
    "我跟着她们进了屋，尴尬地站在门口附近。"

# game/Scenes/Dana/dana13.rpy:399
