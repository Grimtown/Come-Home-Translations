# game/Scenes/Micha/micha18.rpy:15
translate spanish micha18_688d0c7f:

    # "My phone starts buzzing in my pocket. I check and see that Mi-Cha is calling."
    "Mi teléfono empieza a vibrar en el bolsillo. Miro y veo que es Mi-Cha quien llama."

# game/Scenes/Micha/micha18.rpy:20
translate spanish micha18_3f3890ee:

    # pc "Hey, Mi-Cha. How are you doing?"
    pc "Hola, Mi-Cha. ¿Cómo estás?"

# game/Scenes/Micha/micha18.rpy:21
translate spanish micha18_871ef5af:

    # mc "I am feeling very nervous, but also excited."
    mc "Me siento muy nerviosa, pero también emocionada."

# game/Scenes/Micha/micha18.rpy:22
translate spanish micha18_e61255db:

    # pc "About what?"
    pc "¿Por qué?"

# game/Scenes/Micha/micha18.rpy:24
translate spanish micha18_0366f1bc:

    # mc "My dance performance is tonight. Will you come?"
    mc "Esta noche es mi actuación de baile. ¿Vendrás?"

# game/Scenes/Micha/micha18.rpy:25
translate spanish micha18_33cc462a:

    # pc "What? Of course! Why didn't you tell me already? I didn't know it was tonight!"
    pc "¿Qué? ¡Por supuesto! ¿Por qué no me lo habías dicho antes? ¡No sabía que era esta noche!"

# game/Scenes/Micha/micha18.rpy:27
translate spanish micha18_b360fd8d:

    # mc "I'm sorry, [mcsir]."
    mc "Lo siento, [mcsir]."

# game/Scenes/Micha/micha18.rpy:28
translate spanish micha18_c2363c70:

    # mc "I have been shy to talk about it."
    mc "Me daba vergüenza hablar de ello."

# game/Scenes/Micha/micha18.rpy:30
translate spanish micha18_a4fac60b:

    # mc "It is only a small performance. Nothing to get excited about."
    mc "Solo es una pequeña actuación. No hay nada por lo que emocionarse."

# game/Scenes/Micha/micha18.rpy:32
translate spanish micha18_0bb075ff:

    # pc "That's nonsense! You should be excited about it!"
    pc "¡Tonterías! ¡Deberías estar emocionada!"

# game/Scenes/Micha/micha18.rpy:33
translate spanish micha18_16694b2f:

    # pc "I'm really happy for you and I'll be in the audience supporting you."
    pc "Me alegro mucho por ti y estaré entre el público animándote."

# game/Scenes/Micha/micha18.rpy:35
translate spanish micha18_7c591fc4:

    # mc "Okay. I am happy that you will be there."
    mc "Vale. Me alegro de que vayas a estar allí."

# game/Scenes/Micha/micha18.rpy:36
translate spanish micha18_5f7f4323:

    # mc "It is at 7pm on the school's stage."
    mc "Es a las 19:00 en el escenario de la escuela."

# game/Scenes/Micha/micha18.rpy:37
translate spanish micha18_9d74725b:

    # pc "I'll be there. As close as I can get to the front row."
    pc "Allí estaré. Lo más cerca posible de la primera fila."

# game/Scenes/Micha/micha18.rpy:39
translate spanish micha18_02124621:

    # mc "Thank you, [pcname]. I will see you there."
    mc "Gracias, [pcname]. Nos vemos allí."

# game/Scenes/Micha/micha18.rpy:42
translate spanish micha18_25a2f290:

    # "We say our goodbyes, then later that evening, I drive to the school to watch her performance."
    "Nos despedimos y, más tarde esa noche, conduzco hasta la escuela para ver su actuación."

# game/Scenes/Micha/micha18.rpy:45
translate spanish micha18_ebb5885b:

    # "I show up a little early and am able to get a front row seat. There's a few other people in the audience, but it's pretty empty."
    "Llego un poco antes y consigo un asiento en primera fila. Hay algunas personas más entre el público, pero está bastante vacío."

# game/Scenes/Micha/micha18.rpy:48
translate spanish micha18_9b44beaa:

    # "A few minutes later, Gertrude comes in and smiles at me."
    "Unos minutos más tarde, Gertrude entra y me sonríe."

# game/Scenes/Micha/micha18.rpy:49
translate spanish micha18_734ac2ed:

    # sc "Hey, [pcname]. I didn't expect to see you here. I've never seen you at any of the other performances."
    sc "Hola, [pcname]. No esperaba verte aquí. Nunca te he visto en ninguna de las otras actuaciones."

# game/Scenes/Micha/micha18.rpy:50
translate spanish micha18_c2b482c4:

    # pc "Oh, I'm here to support Mi-Cha."
    pc "Oh, estoy aquí para apoyar a Mi-Cha."

# game/Scenes/Micha/micha18.rpy:51
translate spanish micha18_6fc91d73:

    # sc "That's nice of you. I'm looking forward to seeing her perform."
    sc "Qué detalle por tu parte. Tengo muchas ganas de verla actuar."

# game/Scenes/Micha/micha18.rpy:52
translate spanish micha18_0d7c2170:

    # sc "Do you mind if I sit next to you?"
    sc "¿Te importa si me siento a tu lado?"

# game/Scenes/Micha/micha18.rpy:53
translate spanish micha18_6912ead3:

    # pc "Not at all."
    pc "Para nada."

# game/Scenes/Micha/micha18.rpy:57
translate spanish micha18_618925b1:

    # sc "So are you two dating now?"
    sc "¿Así que ahora salís juntos?"

# game/Scenes/Micha/micha18.rpy:58
translate spanish micha18_f78d20fe:

    # pc "Yeah, we've been seeing each other a bit."
    pc "Sí, hemos estado viéndonos un poco."

# game/Scenes/Micha/micha18.rpy:59
translate spanish micha18_5ab35b8c:

    # sc "That's great!"
    sc "¡Qué bien!"

# game/Scenes/Micha/micha18.rpy:60
translate spanish micha18_a0b30b82:

    # sc "How serious is it between you two?"
    sc "¿Hasta qué punto va en serio lo vuestro?"

# game/Scenes/Micha/micha18.rpy:61
translate spanish micha18_b8162d87:

    # pc "Oh I don't know... I think she's great and I like spending time with her."
    pc "Oh, no sé... Creo que es genial y me gusta pasar tiempo con ella."

# game/Scenes/Micha/micha18.rpy:63
translate spanish micha18_8094ff46:

    # sc "We both know she's not the only one you're seeing though..."
    sc "Aunque los dos sabemos que no es la única con la que sales..."

# game/Scenes/Micha/micha18.rpy:64
translate spanish micha18_c417e350:

    # pc "Yeah."
    pc "Sí."

# game/Scenes/Micha/micha18.rpy:65
translate spanish micha18_eda2d229:

    # sc "Just be careful with her. She's a little naive."
    sc "Ten cuidado con ella. Es un poco ingenua."

# game/Scenes/Micha/micha18.rpy:66
translate spanish micha18_11144671:

    # sc "Don't hurt her, okay?"
    sc "No le hagas daño, ¿vale?"

# game/Scenes/Micha/micha18.rpy:67
translate spanish micha18_dd9a629d:

    # pc "I won't."
    pc "No lo haré."

# game/Scenes/Micha/micha18.rpy:70
translate spanish micha18_0a52de10:

    # "As time grows closer to the start of the show, the seats begin to fill up more."
    "A medida que se acerca la hora del espectáculo, las butacas empiezan a llenarse."

# game/Scenes/Micha/micha18.rpy:73
translate spanish micha18_14f8d7ae:

    # "I see Ms. Welch walk in and sit down."
    "Veo a la Sra. Welch entrar y sentarse."

# game/Scenes/Micha/micha18.rpy:77
translate spanish micha18_5868bd91:

    # "She spots me and gives me a wave and a wink."
    "Me ve y me saluda con la mano y me guiña un ojo."

# game/Scenes/Micha/micha18.rpy:80
translate spanish micha18_f6954d22:

    # "Then I look over and see Mrs. McGee sitting as well."
    "Luego miro hacia otro lado y veo a la Sra. McGee sentada también."

# game/Scenes/Micha/micha18.rpy:81
translate spanish micha18_e5a0cf64:

    # "It's more people than I expected to see."
    "Hay más gente de la que esperaba ver."

# game/Scenes/Micha/micha18.rpy:85
translate spanish micha18_f05e2763:

    # "She and Pete both smile and wave at me."
    "Tanto ella como Pete me sonríen y me saludan con la mano."

# game/Scenes/Micha/micha18.rpy:89
translate spanish micha18_29bbeb02:

    # "Then the lights dim, a spotlight shines on the stage, and music begins to play."
    "Entonces las luces se atenúan, un foco ilumina el escenario y empieza a sonar la música."

# game/Scenes/Micha/micha18.rpy:92
translate spanish micha18_16e9fa91:

    # "The curtains open and the ballet starts."
    "Se abre el telón y comienza el ballet."

# game/Scenes/Micha/micha18.rpy:93
translate spanish micha18_5069de6b:

    # "I'm not really sure what is happening, but everybody on stage moves in a well-choreographed dance along with the music."
    "No estoy muy seguro de lo que está pasando, pero todos en el escenario se mueven en una danza bien coreografiada al compás de la música."

# game/Scenes/Micha/micha18.rpy:94
translate spanish micha18_e615adbc:

    # "Everybody else seems to fade into the background as my eyes lock onto Mi-Cha, though."
    "Sin embargo, todos los demás parecen desvanecerse en el fondo mientras mis ojos se fijan en Mi-Cha."

# game/Scenes/Micha/micha18.rpy:95
translate spanish micha18_f7a5d1fe:

    # "She's gorgeous in her costume and her movements are almost hypnotizing in their beauty."
    "Está preciosa con su traje y sus movimientos son casi hipnóticos por su belleza."

# game/Scenes/Micha/micha18.rpy:98
translate spanish micha18_9d2a99c2:

    # "One of the male dancers spins her, then lifts her up like she's flying."
    "Uno de los bailarines la hace girar y luego la levanta como si estuviera volando."

# game/Scenes/Micha/micha18.rpy:101
translate spanish micha18_b95ea171:

    # "Amazingly, she doesn't look nervous at all."
    "Sorprendentemente, no parece nerviosa en absoluto."

# game/Scenes/Micha/micha18.rpy:102
translate spanish micha18_728386fb:

    # "Her usual self-conscious and timid attitude is gone, as if she's in her own world and none of us are even here."
    "Su actitud habitual, tímida y cohibida, ha desaparecido, como si estuviera en su propio mundo y ninguno de nosotros estuviera siquiera aquí."

# game/Scenes/Micha/micha18.rpy:105
translate spanish micha18_ffb4c520:

    # "Part of the way through the performance - I've long lost the story by now - the lights dim once again and only Mi-Cha is illuminated."
    "A mitad de la representación —ya hace tiempo que he perdido el hilo de la historia—, las luces se atenúan de nuevo y solo Mi-Cha queda iluminada."

# game/Scenes/Micha/micha18.rpy:106
translate spanish micha18_ee38e730:

    # "The rest of the cast falls back into the shadows and all eyes are on her."
    "El resto del elenco se retira a las sombras y todas las miradas se centran en ella."

# game/Scenes/Micha/micha18.rpy:110
translate spanish micha18_235a0510:

    # "And she dances."
    "Y ella baila."

# game/Scenes/Micha/micha18.rpy:111
translate spanish micha18_af3cfdb9:

    # "I'm sure her dance is telling the story of her character in the ballet, but I feel like it's telling Mi-Cha's story as well."
    "Estoy seguro de que su baile cuenta la historia de su personaje en el ballet, pero siento que también cuenta la historia de Mi-Cha."

# game/Scenes/Micha/micha18.rpy:112
translate spanish micha18_b3efe8d7:

    # "I feel like I can see right through to her heart. She's wearing clothes, but she is also naked, baring her soul."
    "Siento que puedo ver directamente a través de su corazón. Lleva ropa, pero también está desnuda, mostrando su alma."

# game/Scenes/Micha/micha18.rpy:113
translate spanish micha18_cd9f512f:

    # "There's only been a couple of times where I've felt like Mi-Cha has been completely free and uninhibited - when she's dancing, and when we're fucking."
    "Solo ha habido un par de ocasiones en las que he sentido que Mi-Cha estaba completamente libre y desinhibida: cuando baila y cuando follamos."

# game/Scenes/Micha/micha18.rpy:114
translate spanish micha18_9b3a0aea:

    # "In both cases, she's absolutely beautiful."
    "En ambos casos, es absolutamente preciosa."

# game/Scenes/Micha/micha18.rpy:120
translate spanish micha18_abeb9237:

    # "When the show is over, the whole crowd stands up and applauds."
    "Cuando termina el espectáculo, todo el público se pone en pie y aplaude."

# game/Scenes/Micha/micha18.rpy:121
translate spanish micha18_aca55a3d:

    # "I'm just so happy that everybody can see how amazing Mi-Cha is."
    "Estoy tan feliz de que todo el mundo pueda ver lo increíble que es Mi-Cha."

# game/Scenes/Micha/micha18.rpy:124
translate spanish micha18_f1614496:

    # sc "Wow, that was incredible. She is so talented!"
    sc "Vaya, ha sido increíble. ¡Tiene mucho talento!"

# game/Scenes/Micha/micha18.rpy:125
translate spanish micha18_6c11c780:

    # pc "Yeah. I'm going to go find her."
    pc "Sí. Voy a buscarla."

# game/Scenes/Micha/micha18.rpy:126
translate spanish micha18_9b70b49a:

    # sc "Okay. You two have a good night."
    sc "Vale. Que paséis una buena noche."

# game/Scenes/Micha/micha18.rpy:130
translate spanish micha18_72d6b54c:

    # "I look backstage, but the cast tells me that she's already left."
    "Miro entre bastidores, pero el elenco me dice que ya se ha ido."

# game/Scenes/Micha/micha18.rpy:131
translate spanish micha18_d18e5603:

    # "So I rush out towards her dorm, looking for her."
    "Así que salgo corriendo hacia su residencia, buscándola."

# game/Scenes/Micha/micha18.rpy:134
translate spanish micha18_9cd32c90:

    # "When I find her, she's sitting on the bench outside her dorm, sobbing into her hands."
    "Cuando la encuentro, está sentada en el banco fuera de su residencia, sollozando con las manos en la cara."

# game/Scenes/Micha/micha18.rpy:135
translate spanish micha18_0003d575:

    # pc "Hey, what's wrong? Are you okay?"
    pc "Oye, ¿qué te pasa? ¿Estás bien?"

# game/Scenes/Micha/micha18.rpy:137
translate spanish micha18_d41d8cd9:

    # voice 'voices/micha_18_1.mp3'
    voice 'voices/micha_18_1.mp3'

# game/Scenes/Micha/micha18.rpy:138
translate spanish micha18_918fea83:

    # mc "I'm sorry."
    mc "Lo siento."

# game/Scenes/Micha/micha18.rpy:141
translate spanish micha18_2db90f14:

    # pc "What's wrong? You were amazing. They all loved you."
    pc "¿Qué te pasa? Estuviste increíble. A todos les encantaste."

# game/Scenes/Micha/micha18.rpy:143
translate spanish micha18_d41d8cd9_1:

    # voice 'voices/micha_18_2.mp3'
    voice 'voices/micha_18_2.mp3'

# game/Scenes/Micha/micha18.rpy:144
translate spanish micha18_cd855510:

    # mc "I don't want this to be over."
    mc "No quiero que esto se acabe."

# game/Scenes/Micha/micha18.rpy:146
translate spanish micha18_d41d8cd9_2:

    # voice 'voices/micha_18_3.mp3'
    voice 'voices/micha_18_3.mp3'

# game/Scenes/Micha/micha18.rpy:147
translate spanish micha18_b624d3b4:

    # mc "I have to go back home. No more dancing."
    mc "Tengo que volver a casa. Se acabó el baile."

# game/Scenes/Micha/micha18.rpy:151
translate spanish micha18_d41d8cd9_3:

    # voice 'voices/micha_18_4.mp3'
    voice 'voices/micha_18_4.mp3'

# game/Scenes/Micha/micha18.rpy:152
translate spanish micha18_4a94d1aa:

    # mc "And no more of you."
    mc "Y se acabó estar contigo."

# game/Scenes/Micha/micha18.rpy:154
translate spanish micha18_d41d8cd9_4:

    # voice 'voices/micha_18_5.mp3'
    voice 'voices/micha_18_5.mp3'

# game/Scenes/Micha/micha18.rpy:155
translate spanish micha18_b954ffce:

    # mc "I'm so happy. I don't want to leave."
    mc "Estoy tan feliz. No quiero irme."

# game/Scenes/Micha/micha18.rpy:158
translate spanish micha18_6d39e617:

    # "I hold her for a while. Squeezing her close until she stops crying."
    "La abrazo un rato. La aprieto fuerte contra mí hasta que deja de llorar."

# game/Scenes/Micha/micha18.rpy:159
translate spanish micha18_c40fa025:

    # pc "What if you just stay?"
    pc "¿Y si te quedas?"

# game/Scenes/Micha/micha18.rpy:161
translate spanish micha18_d41d8cd9_5:

    # voice 'voices/micha_18_6.mp3'
    voice 'voices/micha_18_6.mp3'

# game/Scenes/Micha/micha18.rpy:162
translate spanish micha18_fe1e7b75:

    # mc "I can't. I'm only authorized until the end of the semester. If I stay longer, I will be illegal."
    mc "No puedo. Solo tengo permiso hasta el final del semestre. Si me quedo más tiempo, estaré en situación irregular."

# game/Scenes/Micha/micha18.rpy:163
translate spanish micha18_dcbbb7ed:

    # pc "Yeah, I guess that's bad."
    pc "Sí, supongo que eso es malo."

# game/Scenes/Micha/micha18.rpy:166
translate spanish micha18_e22cecb4:

    # pc "Could you get your date extended?"
    pc "¿Podrías conseguir que te amplíen el permiso?"

# game/Scenes/Micha/micha18.rpy:168
translate spanish micha18_d41d8cd9_6:

    # voice 'voices/micha_18_7.mp3'
    voice 'voices/micha_18_7.mp3'

# game/Scenes/Micha/micha18.rpy:169
translate spanish micha18_6be2096b:

    # mc "I don't know. I will talk to Mrs. Spann about it. She knows better than me."
    mc "No lo sé. Hablaré con la señora Spann sobre ello. Ella lo sabe mejor que yo."

# game/Scenes/Micha/micha18.rpy:171
translate spanish micha18_d41d8cd9_7:

    # voice 'voices/micha_18_8.mp3'
    voice 'voices/micha_18_8.mp3'

# game/Scenes/Micha/micha18.rpy:172
translate spanish micha18_708ee42e:

    # mc "I think I have to have a reason to extend though."
    mc "Aunque creo que tengo que tener una razón para ampliarlo."

# game/Scenes/Micha/micha18.rpy:174
translate spanish micha18_d41d8cd9_8:

    # voice 'voices/micha_18_9.mp3'
    voice 'voices/micha_18_9.mp3'

# game/Scenes/Micha/micha18.rpy:175
translate spanish micha18_d4d465f0:

    # mc "Like taking more school. Or marriage."
    mc "Como seguir estudiando. O casarme."

# game/Scenes/Micha/micha18.rpy:179
translate spanish micha18_d41d8cd9_9:

    # voice 'voices/micha_18_10.mp3'
    voice 'voices/micha_18_10.mp3'

# game/Scenes/Micha/micha18.rpy:180
translate spanish micha18_1cf758a9:

    # mc "I'm sorry. I said I wouldn't mention it again, and I did."
    mc "Lo siento. Dije que no volvería a mencionarlo, y lo he hecho."

# game/Scenes/Micha/micha18.rpy:182
translate spanish micha18_d41d8cd9_10:

    # voice 'voices/micha_18_11.mp3'
    voice 'voices/micha_18_11.mp3'

# game/Scenes/Micha/micha18.rpy:183
translate spanish micha18_d88ba6c6:

    # mc "I don't want to pressure you."
    mc "No quiero presionarte."

# game/Scenes/Micha/micha18.rpy:185
translate spanish micha18_d41d8cd9_11:

    # voice 'voices/micha_18_12.mp3'
    voice 'voices/micha_18_12.mp3'

# game/Scenes/Micha/micha18.rpy:186
translate spanish micha18_0a8cc307:

    # mc "I just love you so much."
    mc "Es solo que te quiero muchísimo."

# game/Scenes/Micha/micha18.rpy:189
translate spanish micha18_5735beae:

    # pc "I love you too, Mi-Cha."
    pc "Yo también te quiero, Mi-Cha."

# game/Scenes/Micha/micha18.rpy:190
translate spanish micha18_83eef187:

    # pc "We'll figure this out, one way or another."
    pc "Lo resolveremos, de una forma u otra."

# game/Scenes/Micha/micha18.rpy:191
translate spanish micha18_39f98ad4:

    # pc "Everything will be okay."
    pc "Todo irá bien."

# game/Scenes/Micha/micha18.rpy:192
translate spanish micha18_2c147205:

    # pc "I just want you to keep dancing. I just want you to be happy."
    pc "Solo quiero que sigas bailando. Solo quiero que seas feliz."

# game/Scenes/Micha/micha18.rpy:196
translate spanish micha18_d41d8cd9_12:

    # voice 'voices/micha_18_13.mp3'
    voice 'voices/micha_18_13.mp3'

# game/Scenes/Micha/micha18.rpy:197
translate spanish micha18_06801be0:

    # mc "I am. So happy."
    mc "Lo soy. Muy feliz."

# game/Scenes/Micha/micha18.rpy:201
translate spanish micha18_d41d8cd9_13:

    # voice 'voices/micha_18_14.mp3'
    voice 'voices/micha_18_14.mp3'

# game/Scenes/Micha/micha18.rpy:202
translate spanish micha18_bb0eeaf4:

    # mc "Thank you."
    mc "Gracias."

# game/Scenes/Micha/micha18.rpy:204
translate spanish micha18_d41d8cd9_14:

    # voice 'voices/micha_18_15.mp3'
    voice 'voices/micha_18_15.mp3'

# game/Scenes/Micha/micha18.rpy:205
translate spanish micha18_4d562fad:

    # mc "Even if we are not together forever. You have changed me."
    mc "Aunque no estemos juntos para siempre. Me has cambiado."

# game/Scenes/Micha/micha18.rpy:207
translate spanish micha18_d41d8cd9_15:

    # voice 'voices/micha_18_16.mp3'
    voice 'voices/micha_18_16.mp3'

# game/Scenes/Micha/micha18.rpy:208
translate spanish micha18_4a1f6929:

    # mc "I am better because of you."
    mc "Soy mejor gracias a ti."

# game/Scenes/Micha/micha18.rpy:211
translate spanish micha18_b3c8f504:

    # "We stay there for a while, until it's time for her to get back to her dorm and for me to get back home."
    "Nos quedamos allí un rato, hasta que llega la hora de que ella vuelva a su residencia y yo a casa."

# game/Scenes/Micha/micha18.rpy:212
translate spanish micha18_0f7e558a:

