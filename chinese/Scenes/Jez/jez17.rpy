translate chinese jez17_a86898a3:

    # jav "Hi, [pcname]! You can come inside."
    jav "嗨，[pcname]！进来吧。"

# game/Scenes/Jez/jez17.rpy:48
translate chinese jez17_5a07d1ba:

    # pc "Hey, Javi. How are you doing?"
    pc "嘿，哈维。你最近怎么样？"

