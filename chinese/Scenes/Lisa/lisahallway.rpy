# game/Scenes/Lisa/lisahallway.rpy:9
translate chinese lisahallway_c49eebeb:

    # sp "Oh, hey honey. Did you want to do something together this evening?"
    sp "哦，嗨，亲爱的。今晚想一起做点什么吗？"

# game/Scenes/Lisa/lisahallway.rpy:17
translate chinese cookwithlisa_6524ac29:

    # "We go to the kitchen and cook dinner together."
    "我们走进厨房，一起做晚餐。"

# game/Scenes/Lisa/lisahallway.rpy:20
translate chinese cookwithlisa_2aba8403:

    # "Then we sit together in the dining room and have a nice conversation while eating."
    "随后我们坐在餐厅里，一边吃一边愉快地聊天。"

# game/Scenes/Lisa/lisahallway.rpy:24
translate chinese cookwithlisa_ac9094b5:

    # "Afterwards, we go to the kitchen and I help with the dishes."
    "饭后，我们回到厨房，我帮忙洗碗。"

# game/Scenes/Lisa/lisahallway.rpy:25
translate chinese cookwithlisa_5de5fea4:

    # sp "This was really nice."
    sp "这真是一段美好的时光。"

# game/Scenes/Lisa/lisahallway.rpy:28
translate chinese cookwithlisa_79b9a743:

    # sp "I think I'm going to go take a shower now. Want to join me?"
    sp "我想现在去冲个澡。你要一起去吗？"

# game/Scenes/Lisa/lisahallway.rpy:33
translate chinese cookwithlisa_cf0a5849:

    # sp "Okay. Love you, baby."
    sp "好的。爱你，宝贝。"

# game/Scenes/Lisa/lisahallway.rpy:34
translate chinese cookwithlisa_ce2ae2bf:

    # pc "Love you too."
    pc "我也爱你。"

# game/Scenes/Lisa/lisahallway.rpy:35
translate chinese cookwithlisa_db14aa5a:

    # "We finish up and Lisa goes to her bedroom for the night."
    "我们收拾完毕，丽莎回卧室休息了。"

# game/Scenes/Lisa/lisahallway.rpy:40
translate chinese lisadate_01e3ac80:

    # sp "Oh yeah, I guess since Suzy knows about us now, we could do that."
    sp "哦对了，既然苏茜现在知道我们的事了，我们可以那样做。"

# game/Scenes/Lisa/lisahallway.rpy:41
translate chinese lisadate_88279251:

    # sp "Okay that sounds really nice actually. Where do you want to go?"
    sp "好啊，听起来其实挺不错的。你想去哪里？"

# game/Scenes/Lisa/lisahallway.rpy:44
translate chinese lisadate_8071debf:

    # sp "That sounds great. Where do you want to go?"
    sp "听起来很棒。你想去哪里？"

# game/Scenes/Lisa/lisahallway.rpy:202
translate chinese lisaenddate_637356aa:

    # sp "Thank you so much for taking me out tonight."
    sp "非常感谢你今晚带我出去。"

# game/Scenes/Lisa/lisahallway.rpy:203
translate chinese lisaenddate_6ab2bfff:

    # sp "Do you want to come to my room?"
    sp "你想来我房间吗？"

# game/Scenes/Lisa/lisahallway.rpy:249
translate chinese lisasex_8a718dca:

    # "We go to her room and she strips out of her clothes and lies on the bed, ready for me."
    "我们去了她的房间，她脱掉衣服躺在床上，等着我。"

# game/Scenes/Lisa/lisahallway.rpy:250
translate chinese lisasex_93cfa24d:

    # sp "What do you feel like doing, baby?"
    sp "你想做什么，宝贝？"

# game/Scenes/Lisa/lisahallway.rpy:255
translate chinese lisanottonight_fd2f564d:

    # sp "Okay, honey. Thank you for the amazing date anyway."
    sp "好的，亲爱的。不管怎样，谢谢你给我这么棒的约会。"

# game/Scenes/Lisa/lisahallway.rpy:258
translate chinese lisanottonight_ea3d4ac7:

    # "We say our goodnights and she goes to her bedroom."
    "我们互道晚安，她回了卧室。"

