# game/Scenes/Whitney/whitney16.rpy:13
translate spanish whitney16_50df7566:

    # "My phone buzzes in my pocket. Whitney's calling."
    "Mi teléfono vibra en el bolsillo. Es Whitney llamando."

# game/Scenes/Whitney/whitney16.rpy:17
translate spanish whitney16_0b8efa0c:

    # pc "Hey, Whitney."
    pc "Hola, Whitney."

# game/Scenes/Whitney/whitney16.rpy:19
translate spanish whitney16_c6ee1dad:

    # wt "Could you come over to the lab? I have something to show you."
    wt "¿Podrías venir al laboratorio? Tengo algo que enseñarte."

# game/Scenes/Whitney/whitney16.rpy:20
translate spanish whitney16_61f77a4c:

    # pc "Sure."
    pc "Claro."

# game/Scenes/Whitney/whitney16.rpy:21
translate spanish whitney16_a1cf6718:

    # wt "Good. See you soon."
    wt "Bien. Nos vemos pronto."

# game/Scenes/Whitney/whitney16.rpy:22
translate spanish whitney16_897088bb:

    # "She hangs up before I can say anything else. Guess I better head over to the lab."
    "Cuelga antes de que pueda decir nada más. Supongo que será mejor que me dirija al laboratorio."

# game/Scenes/Whitney/whitney16.rpy:25
translate spanish whitney16_fa8b8cd1:

    # "A few minutes later, I walk into the lab, where she's busy at her computer."
    "Unos minutos más tarde, entro en el laboratorio, donde ella está ocupada con su ordenador."

# game/Scenes/Whitney/whitney16.rpy:26
translate spanish whitney16_4d683f87:

    # wt "Oh, [pcname]. Good. Follow me."
    wt "Oh, [pcname]. Bien. Sígueme."

# game/Scenes/Whitney/whitney16.rpy:29
translate spanish whitney16_1e926628:

    # wt "I have finished the new hoop."
    wt "He terminado el nuevo aro."

# game/Scenes/Whitney/whitney16.rpy:30
translate spanish whitney16_22c83dc1:

    # pc "It's much bigger than the last one."
    pc "Es mucho más grande que el anterior."

# game/Scenes/Whitney/whitney16.rpy:31
translate spanish whitney16_984bce26:

    # wt "Yes, it's true. In this case, size does matter."
    wt "Sí, es cierto. En este caso, el tamaño sí importa."

# game/Scenes/Whitney/whitney16.rpy:32
translate spanish whitney16_650aeb95:

    # wt "I've designed the new hoop so that it will not only transport you to the exact world that your father went to, but it will also bring you back."
    wt "He diseñado el nuevo aro para que no solo te transporte al mundo exacto al que fue tu padre, sino que también te traiga de vuelta."

# game/Scenes/Whitney/whitney16.rpy:33
translate spanish whitney16_d0034e37:

    # wt "It is synced with your DNA profile. When you go through it, you will be tethered to it. I can bring you back from here."
    wt "Está sincronizado con tu perfil de ADN. Cuando lo atravieses, quedarás vinculado a él. Podré traerte de vuelta desde aquí."

# game/Scenes/Whitney/whitney16.rpy:34
translate spanish whitney16_5b38bd59:

    # wt "This is what we should have done with your father, if he had been more patient."
    wt "Esto es lo que deberíamos haber hecho con tu padre, si hubiera tenido más paciencia."

# game/Scenes/Whitney/whitney16.rpy:37
translate spanish whitney16_994924ab:

    # pc "So, it's ready to go?"
    pc "Entonces, ¿ya está listo para funcionar?"

# game/Scenes/Whitney/whitney16.rpy:38
translate spanish whitney16_c60270d5:

    # wt "Not quite. We have to test it first."
    wt "Todavía no. Primero tenemos que probarlo."

# game/Scenes/Whitney/whitney16.rpy:39
translate spanish whitney16_74dfd840:

    # pc "How do we do that?"
    pc "¿Cómo lo hacemos?"

# game/Scenes/Whitney/whitney16.rpy:42
translate spanish whitney16_a54b5eec:

    # wt "This morning, before you got here, I sent a mouse through."
    wt "Esta mañana, antes de que llegaras, envié a un ratón a través de él."

# game/Scenes/Whitney/whitney16.rpy:43
translate spanish whitney16_c4971b1e:

    # pc "Wait, really? You sent a mouse into another universe?"
    pc "Espera, ¿en serio? ¿Enviaste a un ratón a otro universo?"

# game/Scenes/Whitney/whitney16.rpy:44
translate spanish whitney16_6f0e0998:

    # wt "Yes. That's the easy part."
    wt "Sí. Esa es la parte fácil."

# game/Scenes/Whitney/whitney16.rpy:45
translate spanish whitney16_a992c7cf:

    # wt "Now though, I'm going to try to bring it back."
    wt "Ahora, sin embargo, voy a intentar traerlo de vuelta."

# game/Scenes/Whitney/whitney16.rpy:48
translate spanish whitney16_91de8169:

    # "She presses a series of buttons on her watch and the hoop glows to life."
    "Pulsa una serie de botones en su reloj y el aro se ilumina."

# game/Scenes/Whitney/whitney16.rpy:49
translate spanish whitney16_83bcc1d8:

    # "My ears pop as the air pressure in the room changes and there's a slight ringing sound."
    "Se me taponan los oídos al cambiar la presión del aire en la habitación y se oye un ligero zumbido."

# game/Scenes/Whitney/whitney16.rpy:52
translate spanish whitney16_7d1c036c:

    # "Then the sound dissipates and there is something lying on the platform near the hoop."
    "Luego el sonido se disipa y hay algo tirado en la plataforma cerca del aro."

# game/Scenes/Whitney/whitney16.rpy:53
translate spanish whitney16_daaa84a9:

    # pc "What the fuck is that?"
    pc "¿Qué coño es eso?"

# game/Scenes/Whitney/whitney16.rpy:54
translate spanish whitney16_e0330bbf:

    # wt "That... is the mouse."
    wt "Eso... es el ratón."

# game/Scenes/Whitney/whitney16.rpy:57
translate spanish whitney16_2681ebe7:

    # wt "It seems there is some more testing that must be done."
    wt "Parece que hay que hacer algunas pruebas más."

# game/Scenes/Whitney/whitney16.rpy:58
translate spanish whitney16_4492000b:

    # pc "Yeah, I'd say so!"
    pc "¡Sí, yo diría que sí!"

# game/Scenes/Whitney/whitney16.rpy:59
translate spanish whitney16_2551790c:

    # wt "I'll figure it out. We're close."
    wt "Lo resolveré. Estamos cerca."

# game/Scenes/Whitney/whitney16.rpy:62
translate spanish whitney16_004ba629:

    # wt "This is the last little bit to solve, though."
    wt "Aunque esto es lo último que queda por resolver."

# game/Scenes/Whitney/whitney16.rpy:63
translate spanish whitney16_9edb80ec:

    # wt "The hoop is built. It's ready."
    wt "El aro está construido. Está listo."

# game/Scenes/Whitney/whitney16.rpy:64
translate spanish whitney16_b679ea6d:

    # wt "It's just finding out how to do this in a way that we can bring you back in one piece."
    wt "Solo hay que averiguar cómo hacerlo de manera que podamos traerte de vuelta de una pieza."

# game/Scenes/Whitney/whitney16.rpy:65
translate spanish whitney16_19874614:

    # wt "I'll let you know as soon as I figure it out, okay?"
    wt "Te lo diré en cuanto lo averigüe, ¿vale?"

# game/Scenes/Whitney/whitney16.rpy:68
translate spanish whitney16_8c9138ff:

    # pc "Okay. Thanks, Whitney."
    pc "Vale. Gracias, Whitney."

# game/Scenes/Whitney/whitney16.rpy:69
translate spanish whitney16_d39969f2:

    # wt "You're welcome. Sorry for calling you out here for nothing. I really thought that this would be successful."
    wt "De nada. Siento haberte hecho venir aquí para nada. De verdad pensaba que esto iba a salir bien."

# game/Scenes/Whitney/whitney16.rpy:70
translate spanish whitney16_e9a3252a:

    # wt "That is why we are patient though. That is why we test."
    wt "Por eso somos pacientes. Por eso hacemos pruebas."

# game/Scenes/Whitney/whitney16.rpy:71
translate spanish whitney16_4c58fa25:

    # wt "Back to work for me. I'll talk to you later."
    wt "Vuelvo al trabajo. Hablamos luego."

# game/Scenes/Whitney/whitney16.rpy:72
translate spanish whitney16_0854e810:

    # pc "Okay, see ya later."
    pc "Vale, hasta luego."

# game/Scenes/Whitney/whitney16.rpy:75
translate spanish whitney16_0ee8d1bf:

    # "I leave her lab, the image of that mouse in my mind."
    "Salgo de su laboratorio con la imagen de ese ratón en mi mente."

# game/Scenes/Whitney/whitney16.rpy:76
translate spanish whitney16_97666c57:

    # "Fuck, I hope Dad is okay."
    "Joder, espero que papá esté bien."

translate spanish strings:

    # game/Scenes/Whitney/whitney16.rpy:5
    old "A week after the jewelry store robbery, Whitney will call you on an afternoon on the weekend."
    new "Una semana después del robo en la joyería, Whitney te llamará una tarde del fin de semana."

