# game/Scenes/Micha/micha8.rpy:14
translate spanish micha8_5f9760c9:

    # "Before I go to Gertrude's office, Mi-Cha stops me in the lobby."
    "Antes de ir a la oficina de Gertrude, Mi-Cha me para en el vestíbulo."

# game/Scenes/Micha/micha8.rpy:15
translate spanish micha8_ed6bde86:

    # mc "Hello, [pcname]."
    mc "Hola, [pcname]."

# game/Scenes/Micha/micha8.rpy:16
translate spanish micha8_f481dcaa:

    # pc "Hi, Mi-Cha. How are you?"
    pc "Hola, Mi-Cha. ¿Cómo estás?"

# game/Scenes/Micha/micha8.rpy:17
translate spanish micha8_72cb11f5:

    # mc "I am good, thank you."
    mc "Estoy bien, gracias."

# game/Scenes/Micha/micha8.rpy:19
translate spanish micha8_bdbd1fa8:

    # mc "I want to tell you that I enjoyed our coffee date."
    mc "Quiero decirte que disfruté de nuestra cita para tomar café."

# game/Scenes/Micha/micha8.rpy:20
translate spanish micha8_8a7120da:

    # mc "I apologize for rushing off early and would like to again another sometime."
    mc "Te pido disculpas por marcharme tan pronto y me gustaría repetir otra vez algún día."

# game/Scenes/Micha/micha8.rpy:21
translate spanish micha8_3171636b:

    # mc "If you would like to this evening?"
    mc "¿Te apetece esta tarde?"

# game/Scenes/Micha/micha8.rpy:25
translate spanish micha8_2d186b97:

    # mc "Good. I will meet you in the Skyhill Cafe this evening then."
    mc "Bien. Entonces nos vemos esta tarde en el Skyhill Cafe."

# game/Scenes/Micha/micha8.rpy:29
translate spanish micha8_2f88594e:

    # mc "Oh. Okay. Yes, I'm sure you're busy."
    mc "Oh. Vale. Sí, seguro que estás ocupada."

# game/Scenes/Micha/micha8.rpy:31
translate spanish micha8_08d0510d:

    # mc "Enjoy your visit with Mrs. Spann."
    mc "Disfruta de tu visita con la Sra. Spann."

# game/Scenes/Micha/micha8.rpy:32
translate spanish micha8_32a03447:

    # pc "Okay. I'll see you later, Mi-Cha."
    pc "Vale. Nos vemos luego, Mi-Cha."

translate spanish strings:

    # game/Scenes/Micha/micha8.rpy:2
    old "After your first date with Mi-Cha, go talk to her in the counselor's lobby on a weekday morning."
    new "Después de tu primera cita con Mi-Cha, ve a hablar con ella al vestíbulo de la orientadora una mañana entre semana."

    # game/Scenes/Micha/micha8.rpy:3
    old "She will want to go on another date with you."
    new "Ella querrá tener otra cita contigo."

    # game/Scenes/Micha/micha8.rpy:27
    old "Maybe some other night"
    new "Quizá alguna otra noche."

