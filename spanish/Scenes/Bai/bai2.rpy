# game/Scenes/Bai/bai2.rpy:10
translate spanish bai2_98ca1a51:

    # "My phone buzzes in my pocket."
    "Mi teléfono vibra en el bolsillo."

# game/Scenes/Bai/bai2.rpy:14
translate spanish bai2_a13b13a8:

    # "It's Bai. I guess I have time to chat a bit."
    "Es Bai. Supongo que tengo tiempo para charlar un rato."

# game/Scenes/Bai/bai2.rpy:17
translate spanish bai2_c0d6b27a:

    # pc "Hey Bai, what's up?"
    pc "Hola, Bai, ¿qué tal?"

# game/Scenes/Bai/bai2.rpy:18
translate spanish bai2_ca2e0cd6:

    # bai "Hey, [pcname]. I was just lying here bored and wondered what you were up to?"
    bai "Hola, [pcname]. Estaba aquí tumbado, aburrido, y me preguntaba qué tal te iba."

# game/Scenes/Bai/bai2.rpy:19
translate spanish bai2_f020dde3:

    # pc "Just getting ready for bed, but I can talk for a while."
    pc "Me estoy preparando para irme a la cama, pero puedo hablar un rato."

# game/Scenes/Bai/bai2.rpy:20
translate spanish bai2_b9768b08:

    # bai "That's cool. I've just been thinking a lot."
    bai "Genial. Es que he estado pensando mucho."

# game/Scenes/Bai/bai2.rpy:21
translate spanish bai2_e61255db:

    # pc "About what?"
    pc "¿En qué?"

# game/Scenes/Bai/bai2.rpy:23
translate spanish bai2_67224ed1:

    # bai "Just stuff mostly."
    bai "En cosas, sobre todo."

# game/Scenes/Bai/bai2.rpy:24
translate spanish bai2_19828c08:

    # pc "You're going to have to be a little more specific than that or this conversation isn't going to go anywhere."
    pc "Vas a tener que ser un poco más específico o esta conversación no va a llevar a ninguna parte."

# game/Scenes/Bai/bai2.rpy:25
translate spanish bai2_64de84cd:

    # bai "Okay, well."
    bai "Vale, bueno."

# game/Scenes/Bai/bai2.rpy:26
translate spanish bai2_d7d9d996:

    # bai "I uh... I've only dated girls in the past."
    bai "Yo... eh... solo he salido con chicas hasta ahora."

# game/Scenes/Bai/bai2.rpy:27
translate spanish bai2_36470b3e:

    # bai "I've had sex and stuff. With girls."
    bai "He tenido sexo y esas cosas. Con chicas."

# game/Scenes/Bai/bai2.rpy:28
translate spanish bai2_41c2c9e2:

    # bai "But uh... I think I might be into guys too."
    bai "Pero... eh... creo que quizá también me gusten los chicos."

# game/Scenes/Bai/bai2.rpy:30
translate spanish bai2_8833a2ab:

    # pc "So, you're bisexual?"
    pc "Entonces, ¿eres bisexual?"

# game/Scenes/Bai/bai2.rpy:31
translate spanish bai2_61b09772:

    # bai "Maybe?"
    bai "¿Quizá?"

# game/Scenes/Bai/bai2.rpy:32
translate spanish bai2_0e63d7c1:

    # bai "What about you? Are you into guys at all?"
    bai "¿Y tú? ¿Te gustan los chicos?"

# game/Scenes/Bai/bai2.rpy:36
translate spanish bai2_bde64ebd:

    # bai "Oh okay. I thought maybe we had a thing. It's okay though."
    bai "Ah, vale. Pensaba que quizá teníamos algo. Pero no pasa nada."

# game/Scenes/Bai/bai2.rpy:37
translate spanish bai2_0fe323b5:

    # pc "Sorry, man. Chicks only for me."
    pc "Lo siento, tío. Para mí solo chicas."

# game/Scenes/Bai/bai2.rpy:38
translate spanish bai2_83d8b883:

    # bai "It's cool. I understand."
    bai "No pasa nada. Lo entiendo."

# game/Scenes/Bai/bai2.rpy:40
translate spanish bai2_ecf05d77:

    # bai "Still friends though?"
    bai "¿Seguimos siendo amigos?"

# game/Scenes/Bai/bai2.rpy:41
translate spanish bai2_71d4cebe:

    # pc "Sure, we're still friends."
    pc "Claro, seguimos siendo amigos."

# game/Scenes/Bai/bai2.rpy:44
translate spanish bai2_e26b3f90:

    # bai "Cool."
    bai "Genial."

# game/Scenes/Bai/bai2.rpy:47
translate spanish bai2_b66cc0ac:

    # bai "Really? I thought maybe we had a thing, but I wasn't sure."
    bai "¿En serio? Pensaba que quizá teníamos algo, pero no estaba seguro."

# game/Scenes/Bai/bai2.rpy:49
translate spanish bai2_f39ae0a2:

    # bai "Are you into me?"
    bai "¿Te gusto?"

# game/Scenes/Bai/bai2.rpy:53
translate spanish bai2_99a03550:

    # bai "That makes me so happy."
    bai "Eso me hace muy feliz."

# game/Scenes/Bai/bai2.rpy:55
translate spanish bai2_99b1838b:

    # bai "So do you maybe want to actually go on a date sometime?"
    bai "¿Entonces quizá quieras que quedemos alguna vez?"

# game/Scenes/Bai/bai2.rpy:56
translate spanish bai2_39757b54:

    # pc "Yeah, let's do it."
    pc "Sí, hagámoslo."

# game/Scenes/Bai/bai2.rpy:57
translate spanish bai2_8c98f2da:

    # bai "Okay, just give me a call in the evening sometime then. I'm available almost every day."
    bai "Vale, entonces llámame alguna tarde. Estoy libre casi todos los días."

# game/Scenes/Bai/bai2.rpy:58
translate spanish bai2_58a87bc2:

    # pc "Sounds good. I'm looking forward to it."
    pc "Suena bien. Tengo muchas ganas."

# game/Scenes/Bai/bai2.rpy:59
translate spanish bai2_10a70856:

    # bai "Me too. Really."
    bai "Yo también. De verdad."

# game/Scenes/Bai/bai2.rpy:60
translate spanish bai2_4d74a398:

    # bai "This is new territory for me, but I'm really looking forward to exploring it with you."
    bai "Esto es territorio nuevo para mí, pero tengo muchas ganas de explorarlo contigo."

# game/Scenes/Bai/bai2.rpy:63
translate spanish bai2_c0a43543:

    # bai "Oh, so you're into guys, but you're not into me."
    bai "Ah, así que te gustan los chicos, pero yo no te gusto."

# game/Scenes/Bai/bai2.rpy:64
translate spanish bai2_27247fe1:

    # bai "Gotta say, that hurts man."
    bai "Tengo que decir que eso duele, tío."

# game/Scenes/Bai/bai2.rpy:65
translate spanish bai2_c31c7975:

    # pc "Sorry, just being honest."
    pc "Lo siento, solo estoy siendo sincero."

# game/Scenes/Bai/bai2.rpy:66
translate spanish bai2_40a3eff2:

    # bai "Yeah okay. Well that sucks."
    bai "Sí, vale. Bueno, qué pena."

# game/Scenes/Bai/bai2.rpy:67
translate spanish bai2_0cce2b18:

    # pc "We can still be friends though."
    pc "Pero aún así podemos ser amigos."

# game/Scenes/Bai/bai2.rpy:68
translate spanish bai2_46106a33:

    # bai "Yeah, okay. I'm going to bed."
    bai "Sí, vale. Me voy a la cama."

# game/Scenes/Bai/bai2.rpy:70
translate spanish bai2_14a17911:

    # "He hangs up. I guess that didn't go so well."
    "Cuelga. Supongo que eso no ha salido muy bien."

# game/Scenes/Bai/bai2.rpy:71
translate spanish bai2_a0d6f0f3:

    # "Oh well. He'll get over it. Or not, whatever."
    "Bueno, qué le vamos a hacer. Ya se le pasará. O no, da igual."

# game/Scenes/Bai/bai2.rpy:72
translate spanish bai2_ef88129a:

    # "I put the phone away and get ready for bed."
    "Guardo el teléfono y me preparo para irme a la cama."

# game/Scenes/Bai/bai2.rpy:75
translate spanish bai2_17d3424c:

    # "We chat a little longer about our days, until we are both tired."
    "Charlamos un rato más sobre cómo nos ha ido el día, hasta que los dos estamos cansados."

# game/Scenes/Bai/bai2.rpy:77
translate spanish bai2_3898d259:

    # bai "I better get some sleep man."
    bai "Mejor me voy a dormir, tío."

# game/Scenes/Bai/bai2.rpy:78
translate spanish bai2_89c07fc5:

    # bai "I'll talk to you later."
    bai "Hablamos luego."

# game/Scenes/Bai/bai2.rpy:79
translate spanish bai2_d2381b62:

    # pc "Okay. See ya, Bai."
    pc "Vale. Nos vemos, Bai."

# game/Scenes/Bai/bai2.rpy:82
translate spanish bai2_52d6e3cf:

    # "We hang up and I get ready for bed."
    "Colgamos y me preparo para irme a la cama."

