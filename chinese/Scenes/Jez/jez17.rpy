translate chinese jez17_d55e93ff:

    # jav "Aw Mamá, I don't want to. This is fun."
    jav "哎呀妈妈，我不想睡。这很好玩。"

# game/Scenes/Jez/jez17.rpy:173
translate chinese jez17_d41d8cd9_6:

    # voice 'voices/jez_17_6.mp3'
    voice 'voices/jez_17_6.mp3'

