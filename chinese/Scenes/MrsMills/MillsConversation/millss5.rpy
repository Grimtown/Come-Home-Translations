    # game/Scenes/MrsMills/MillsConversation/millss5.rpy:36
    old "Yeah, that's obvious"
    new "是啊，这很明显"

    # game/Scenes/MrsMills/MillsConversation/millss5.rpy:39
    old "I like you"
    new "我喜欢你"

