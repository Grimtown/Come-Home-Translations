translate chinese jez17_ea3619bb:

    # det "Like a couple, you know?"
    det "就像情侣一样，懂吗？"

# game/Scenes/Jez/jez17.rpy:29
translate chinese jez17_8cf916f0:

    # det "And you can stay the night after."
    det "之后你也可以留宿。"

# game/Scenes/Jez/jez17.rpy:30
translate chinese jez17_03d36568:

    # pc "That sounds good to me. I'll get ready."
    pc "听起来不错。我这就准备。"

# game/Scenes/Jez/jez17.rpy:32
translate chinese jez17_4b1b9607:

    # det "Cool. Nothing fancy, okay? This is just a casual thing."
    det "好嘞。别太讲究，行吗？这只是个随意的聚会。"

# game/Scenes/Jez/jez17.rpy:33
translate chinese jez17_e989fe1a:

    # pc "Got it. I'll see you in a bit."
    pc "知道了。一会儿见。"

# game/Scenes/Jez/jez17.rpy:35
translate chinese jez17_1004a446:

    # det "Thanks, [pcname]. I'm really looking forward to this."
    det "谢谢，[pcname]。我真的很期待这次聚会。"

# game/Scenes/Jez/jez17.rpy:36
translate chinese jez17_e8a99189:

    # det "See you when you get here."
    det "等你到了再见。"

# game/Scenes/Jez/jez17.rpy:39
translate chinese jez17_10a754ec:

    # "I put the phone away, get ready, and drive over to Jez's house."
    "我收起手机，准备好后，开车去了杰兹家。"

