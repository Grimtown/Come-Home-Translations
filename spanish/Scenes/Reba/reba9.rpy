# game/Scenes/Reba/reba9.rpy:5
translate spanish reba9_4a2deb47:

    # "My phone starts buzzing. Reba is calling."
    "Mi teléfono empieza a vibrar. Reba está llamando."

# game/Scenes/Reba/reba9.rpy:9
translate spanish reba9_62aee7f1:

    # rb "Hey, [pcname]. You know how we talked about hanging out in town some time?"
    rb "Hola, [pcname]. ¿Te acuerdas de que hablamos de quedar en la ciudad algún día?"

# game/Scenes/Reba/reba9.rpy:10
translate spanish reba9_28c6d658:

    # rb "Are you busy right now? I'm really craving a burger."
    rb "¿Estás ocupado ahora mismo? Me apetece mucho una hamburguesa."

# game/Scenes/Reba/reba9.rpy:14
translate spanish reba9_15d1a1d2:

    # rb "Awesome! I'll meet you at Jackson Burger, alright?"
    rb "¡Genial! Quedamos en Jackson Burger, ¿vale?"

# game/Scenes/Reba/reba9.rpy:15
translate spanish reba9_b0ab0038:

    # pc "Sounds good. See you there."
    pc "Me parece bien. Nos vemos allí."

# game/Scenes/Reba/reba9.rpy:19
translate spanish reba9_e23feda5:

    # rb "Aw alright. Well if you change your mind, just give me a call sometime."
    rb "Vale, de acuerdo. Bueno, si cambias de opinión, llámame cuando quieras."

# game/Scenes/Reba/reba9.rpy:20
translate spanish reba9_24b552e3:

    # rb "I'm available most evenings."
    rb "Estoy libre casi todas las tardes."

# game/Scenes/Reba/reba9.rpy:21
translate spanish reba9_64c8cb1f:

    # pc "Okay, I will."
    pc "Vale, lo haré."

# game/Scenes/Reba/reba9.rpy:22
translate spanish reba9_e0e1ea50:

    # rb "See you later, [pcname]."
    rb "Hasta luego, [pcname]."

# game/Scenes/Reba/reba9.rpy:34
translate spanish reba9b_0e02b106:

    # "My phone buzzes. It looks like I got a text from Reba."
    "Mi teléfono vibra. Parece que he recibido un mensaje de Reba."

# game/Scenes/Reba/reba9.rpy:49
translate spanish reba9b_bce9991d:

    # "Wow."
    "Vaya."

# game/Scenes/Reba/reba9.rpy:53
translate spanish reba9b_ab930a7e:

    # "Just wow."
    "Simplemente, vaya."

# game/Scenes/Reba/reba9.rpy:59
translate spanish reba9b_cb625026:

    # "I put the phone away and go to sleep, thinking about burying my face between those big tits."
    "Guardo el teléfono y me voy a dormir, pensando en hundir la cara entre esas grandes tetas."

translate spanish strings:

    # game/Scenes/Reba/reba9.rpy:26
    old "A few days after you go mudding with Reba, she will call and ask if you want to go out for a burger."
    new "Unos días después de ir a jugar en el barro con Reba, ella te llamará y te preguntará si quieres salir a comer una hamburguesa."

    # game/Scenes/Reba/reba9.rpy:27
    old "Go on the date with her and she will send you a text at night."
    new "Ve a la cita con ella y te enviará un mensaje por la noche."

