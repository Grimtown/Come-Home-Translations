translate chinese lisaq3_31e57519:

    # sp "What are you planning on doing after you graduate?"
    sp "你毕业后打算做什么？"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:13
translate chinese lisaq3_a1c31d32:

    # pc "I haven't really decided yet, but maybe..."
    pc "我还没完全决定，但也许……"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:17
translate chinese lisaq3_26a42da4:

    # sp "That sounds nice."
    sp "听起来不错。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:18
translate chinese lisaq3_41863847:

    # sp "I hope you do. I'd love to see you with a wife and some kids."
    sp "希望你能做到。我很想看到你娶妻生子。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:20
translate chinese lisaq3_e5005521:

    # sp "I think you'd be a great dad."
    sp "我觉得你会是个很棒的爸爸。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:21
translate chinese lisaq3_63440e3b:

    # pc "Thanks. I hope so."
    pc "谢谢。我也希望如此。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:24
translate chinese lisaq3_cae312b2:

    # sp "Just like your dad."
    sp "就像你爸爸一样。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:25
translate chinese lisaq3_1dc5dc35:

    # sp "You're so smart."
    sp "你真聪明。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:27
translate chinese lisaq3_582d94d2:

    # sp "I know you'll do something great. Like cure cancer, or something."
    sp "我知道你会成就一番伟业。比如治愈癌症，或者什么的。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:28
translate chinese lisaq3_2f4d9dc0:

    # pc "Haha, maybe."
    pc "哈哈，也许吧。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:30
translate chinese lisaq3_03ed9f47:

    # sp "Well, I'm sure you'll be great at it."
    sp "嗯，我相信你一定能做得很好。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:31
translate chinese lisaq3_cda2f52e:

    # pc "Thanks, [mom]."
    pc "谢谢，[mom]。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:34
translate chinese lisaq3_a2f8c7cd:

    # sp "Really? You'd have to go back to school for a couple more years."
    sp "真的吗？那你得再回学校读个两三年。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:35
translate chinese lisaq3_5f4c74c4:

    # pc "I don't mind that. I kinda like college."
    pc "我不介意。我挺喜欢上大学的。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:37
translate chinese lisaq3_99520854:

    # sp "That sounds like a good plan then."
    sp "那听起来是个不错的计划。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:38
translate chinese lisaq3_1812991c:

    # sp "I'm sure you'll be great at it."
    sp "我相信你一定能做得很好。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:39
translate chinese lisaq3_d84918f8:

    # sp "You're so smart. You could do anything that you want to do."
    sp "你真聪明。你想做什么都能做到。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:40
translate chinese lisaq3_cda2f52e_1:

    # pc "Thanks, [mom]."
    pc "谢谢，[mom]。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:43
translate chinese lisaq3_c6ae5b92:

    # sp "Oh really? Where to?"
    sp "哦，真的吗？去哪里？"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:44
translate chinese lisaq3_647273c3:

    # pc "All over. Anywhere. I want to see everything."
    pc "到处去。任何地方。我想看看一切。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:46
translate chinese lisaq3_f3122205:

    # sp "That sounds wonderful."
    sp "听起来真棒。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:47
translate chinese lisaq3_f91f8b39:

    # sp "It's a perfect time to do that too. When you're young."
    sp "现在正是做这件事的绝佳时机。趁你还年轻。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:49
translate chinese lisaq3_5625fcc4:

    # sp "Before you have too many things holding you down to one place."
    sp "在你被太多事情束缚在一个地方之前。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:50
translate chinese lisaq3_bd4835a0:

    # pc "You could come with me."
    pc "你可以跟我一起去。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:52
translate chinese lisaq3_fba72f32:

    # sp "That's nice, but no."
    sp "这主意不错，但我不能。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:53
translate chinese lisaq3_13cf1841:

    # sp "I have my job, and the house, and Suzy."
    sp "我有工作，还有房子，还有苏西。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:54
translate chinese lisaq3_3799d882:

    # pc "You could quit your job, sell the house. Suzy could come with us."
    pc "你可以辞职，把房子卖掉。 苏茜也可以跟我们一起去。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:56
translate chinese lisaq3_f3ab4185:

    # sp "She has to finish college too, though."
    sp "不过她还得把大学读完。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:57
translate chinese lisaq3_11fd0b65:

    # pc "College will always be there to finish."
    pc "大学总是在那儿等着你读完的。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:59
translate chinese lisaq3_ffc072b9:

    # sp "Yeah, I guess it will."
    sp "是啊，我想也是。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:61
translate chinese lisaq3_99f03774:

    # sp "It does sound really nice."
    sp "听起来确实很不错。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:62
translate chinese lisaq3_1e4c76ad:

    # sp "Maybe. We'll see."
    sp "也许吧。走着瞧。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:65
translate chinese lisaq3_4320fd10:

    # sp "You're running out of time to make that decision."
    sp "你做这个决定的时间不多了。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:66
translate chinese lisaq3_9f291ed5:

    # sp "You have to do something. Anything. Whatever will make you happy and make your life better."
    sp "你必须做点什么。任何事。只要能让你快乐，让生活变得更好。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:68
translate chinese lisaq3_6caccc38:

    # sp "You're so smart. You could do anything you want to do."
    sp "你这么聪明，想做什么都能做到。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:70
translate chinese lisaq3_ccf69b00:

    # sp "I just want to see you succeed and flourish."
    sp "我只是想看到你成功、茁壮成长。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:71
translate chinese lisaq3_faef80a1:

    # sp "I want you to keep making yourself better."
    sp "我希望你不断让自己变得更好。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:73
translate chinese lisaq3_eb5ed31b:

    # sp "I just love you and want your life to be amazing."
    sp "我只是爱你，希望你的生活精彩纷呈。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:74
translate chinese lisaq3_6f059de9:

    # pc "Thanks, [mom]. My life {i}is{/i} amazing."
    pc "谢谢，[mom]。我的生活{i}本就{/i}精彩纷呈。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:75
translate chinese lisaq3_26be3647:

    # pc "I'll think about it though. I'll figure it out."
    pc "不过我会考虑的。我会想出办法的。"

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:77
translate chinese lisaq3_da695e7c:

    # sp "I know you will."
    sp "我知道你会的。"

