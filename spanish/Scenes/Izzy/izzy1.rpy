translate spanish izzy1_f9a04499:

    # gl "And you think we're the welcoming committee? We look like the type that'd invite you over, make you a casserole?"
    gl "¿Y crees que somos el comité de bienvenida? ¿Te parecemos el tipo de gente que te invitaría a casa y te prepararía un guiso?"

# game/Scenes/Izzy/izzy1.rpy:35
translate spanish izzy1_23081509:

    # moose "Haha! A casserole! You so funny, Izzy."
    moose "¡Ja, ja! ¡Un guiso! Qué graciosa eres, Izzy."

# game/Scenes/Izzy/izzy1.rpy:37
