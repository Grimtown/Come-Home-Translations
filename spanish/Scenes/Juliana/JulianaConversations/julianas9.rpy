# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:13
translate spanish julianas9_f8c18a7e:

    # bn "Talking to people. I wish I was better at that."
    bn "Hablar con la gente. Ojalá se me diera mejor."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:14
translate spanish julianas9_1c56dc8d:

    # bn "I just get nervous and say the wrong thing or start rambling."
    bn "Me pongo nerviosa y digo cosas inapropiadas o empiezo a divagar."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:16
translate spanish julianas9_2aae1fda:

    # bn "I just want to be able to communicate in a way that gets my thoughts across without making people dislike me as much."
    bn "Solo quiero poder comunicarme de una forma que transmita mis pensamientos sin que la gente me rechace tanto."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:17
translate spanish julianas9_bcbffa82:

    # pc "People don't dislike you, Juliana."
    pc "A la gente no le caes mal, Juliana."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:19
translate spanish julianas9_22a5c781:

    # bn "They do though. I can see it in the way they look at me."
    bn "Pero sí que me rechazan. Lo veo en cómo me miran."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:20
translate spanish julianas9_d94209e6:

    # bn "They think I'm weird."
    bn "Piensan que soy rara."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:21
translate spanish julianas9_094b5e6f:

    # bn "They don't like the way I look. They don't like the way I talk. They don't like the things I say."
    bn "No les gusta mi aspecto. No les gusta cómo hablo. No les gustan las cosas que digo."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:23
translate spanish julianas9_0783182f:

    # bn "I wish I could make them like me. I don't like being like this."
    bn "Ojalá pudiera hacer que les gustara. No me gusta ser así."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:24
translate spanish julianas9_16eb8036:

    # pc "I like you, Juliana. You're too hard on yourself."
    pc "A mí me gustas, Juliana. Eres demasiado dura contigo misma."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:25
translate spanish julianas9_e003f5e6:

    # pc "I'm sure people don't think badly about you as much as you think they do."
    pc "Estoy segura de que la gente no piensa tan mal de ti como tú crees."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:27
translate spanish julianas9_26ae011c:

    # bn "Maybe you're right."
    bn "Quizá tengas razón."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:28
translate spanish julianas9_8baf83da:

    # bn "I just haven't met very many people who do like me."
    bn "Es solo que no he conocido a mucha gente a la que le guste."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:30
translate spanish julianas9_00a3827c:

    # bn "You have a skill at talking to people though."
    bn "Aunque tienes un don para hablar con la gente."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:31
translate spanish julianas9_d9154c8e:

    # bn "With making people like you, even though they have no reason to."
    bn "Para hacer que les gustes, aunque no tengan motivos para ello."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:32
translate spanish julianas9_e03c33dc:

    # bn "I wish I had that."
    bn "Ojalá yo tuviera eso."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:33
translate spanish julianas9_ea24f4ec:

    # pc "But I write at a middle school level and don't grasp the subtleties of 1800s' British poetry."
    pc "Pero escribo a un nivel de secundaria y no capto las sutilezas de la poesía británica del siglo XIX."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:35
translate spanish julianas9_b121ebe7:

    # bn "I guess we all have skills in different areas, huh?"
    bn "Supongo que todos tenemos habilidades en diferentes áreas, ¿no?"

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:36
translate spanish julianas9_41d62910:

    # pc "That's what I'm getting at."
    pc "A eso me refiero."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:38
translate spanish julianas9_1e9e800d:

    # bn "I'd give up every poem I've ever read to be able to make a friend a little easier."
    bn "Renunciaría a todos los poemas que he leído para poder hacer amigos con un poco más de facilidad."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:39
translate spanish julianas9_dff3e2a7:

    # pc "I know. Maybe I can introduce you to people."
    pc "Lo sé. Quizás pueda presentarte a gente."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:40
translate spanish julianas9_4b6c1f4d:

    # pc "Once you get to know a person, you open up and talk easier. I mean, you talk to me just fine."
    pc "Una vez que conoces a una persona, te abres y te cuesta menos hablar. Quiero decir, conmigo hablas perfectamente."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:42
translate spanish julianas9_45052827:

    # bn "That sounds like a swell idea."
    bn "Me parece una idea estupenda."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:44
translate spanish julianas9_60f1f81c:

    # bn "I do talk better with you now. I just need to find others that I feel comfortable around."
    bn "Ahora hablo mejor contigo. Solo necesito encontrar a otras personas con las que me sienta cómodo."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:45
translate spanish julianas9_4f8d2b59:

    # pc "Definitely. People will like you, if they get a chance to."
    pc "Sin duda. A la gente le gustarás, si les das la oportunidad."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:47
translate spanish julianas9_0ab48436:

    # bn "Thanks, [pcname]. That makes me feel a little better."
    bn "Gracias, [pcname]. Eso me hace sentir un poco mejor."

# game/Scenes/Juliana/JulianaConversations/julianas9.rpy:48
translate spanish julianas9_f7abc780:

    # bn "You're good at that."
    bn "Se te da bien eso."

