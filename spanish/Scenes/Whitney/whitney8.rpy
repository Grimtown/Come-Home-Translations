# TODO: Translation updated at 2026-04-15 14:25

# game/Scenes/Whitney/whitney8.rpy:11
translate spanish whitney8_9853ab00:

    # "My phone starts buzzing. Whitney's calling."
    "Mi teléfono empieza a vibrar. Es Whitney."

# game/Scenes/Whitney/whitney8.rpy:15
translate spanish whitney8_bea5e8cb:

    # pc "Hello?"
    pc "¿Hola?"

# game/Scenes/Whitney/whitney8.rpy:16
translate spanish whitney8_371e922c:

    # wt "Good morning, [pcname]."
    wt "Buenos días, [pcname]."

# game/Scenes/Whitney/whitney8.rpy:17
translate spanish whitney8_cf39ea68:

    # wt "I'd like you to come out to my lab today and bring the hoop with you."
    wt "Me gustaría que vinieras hoy a mi laboratorio y trajeras el aro contigo."

# game/Scenes/Whitney/whitney8.rpy:18
translate spanish whitney8_8d1327d7:

    # wt "I'm ready to start doing some tests on it, so hopefully we can replicate your father's experiment and get him back."
    wt "Estoy lista para empezar a hacerle algunas pruebas, así que espero que podamos replicar el experimento de tu padre y recuperarlo."

# game/Scenes/Whitney/whitney8.rpy:19
translate spanish whitney8_b764178b:

    # pc "Okay, where is your lab?"
    pc "Vale, ¿dónde está tu laboratorio?"

# game/Scenes/Whitney/whitney8.rpy:22
translate spanish whitney8_c1a287ab:

    # "She gives me detailed instructions how to get to her lab, then I get dressed, grab the hoop from the basement, and drive out there."
    "Me da instrucciones detalladas sobre cómo llegar a su laboratorio, luego me visto, cojo el aro del sótano y conduzco hasta allí."

# game/Scenes/Whitney/whitney8.rpy:25
translate spanish whitney8_f6905d01:

    # "The place is outside of town on a huge plot of land surrounded by trees."
    "El lugar está a las afueras de la ciudad, en una enorme parcela rodeada de árboles."

# game/Scenes/Whitney/whitney8.rpy:26
translate spanish whitney8_ce6d4561:

    # "I park in the circle-driveway at the front and walk up a long path towards her house."
    "Aparco en la rotonda de la entrada principal y subo por un largo camino hacia su casa."

# game/Scenes/Whitney/whitney8.rpy:27
translate spanish whitney8_5f67c947:

    # "Another building that looks like a large warehouse rises up above the house on the right."
    "Otro edificio que parece un gran almacén se eleva sobre la casa a la derecha."

# game/Scenes/Whitney/whitney8.rpy:30
translate spanish whitney8_0081cc36:

    # "I pause for a moment on the path. Should I just go up to the door and knock? Should I send her a text or something?"
    "Me detengo un momento en el camino. ¿Debería simplemente acercarme a la puerta y llamar? ¿Debería enviarle un mensaje o algo así?"

# game/Scenes/Whitney/whitney8.rpy:31
translate spanish whitney8_a385c5c3:

    # wt "Go through the door and to the right."
    wt "Atraviesa la puerta y ve a la derecha."

# game/Scenes/Whitney/whitney8.rpy:32
translate spanish whitney8_e5f3a53a:

    # "Whitney's voice coming over a speaker somewhere startles me and I nearly drop the hoop when I jump."
    "La voz de Whitney, que sale de un altavoz en algún lugar, me sobresalta y casi se me cae el aro al dar un respingo."

# game/Scenes/Whitney/whitney8.rpy:35
translate spanish whitney8_8c6e41ff:

    # pc "Uh, this door?"
    pc "Eh, ¿esta puerta?"

# game/Scenes/Whitney/whitney8.rpy:36
translate spanish whitney8_b8ea1cfd:

    # wt "Yes that door. It is unlocked. Take the hall to the right. The door is labeled."
    wt "Sí, esa puerta. Está abierta. Toma el pasillo a la derecha. La puerta está señalizada."

# game/Scenes/Whitney/whitney8.rpy:37
translate spanish whitney8_63023601:

    # pc "Okay."
    pc "Vale."

# game/Scenes/Whitney/whitney8.rpy:40
translate spanish whitney8_01cacda4:

    # "I follow Whitney's instructions through the house, to the right, and through a door labeled \"Laboratory.\""
    "Sigo las instrucciones de Whitney por la casa, a la derecha y a través de una puerta con el letrero «Laboratorio»."

# game/Scenes/Whitney/whitney8.rpy:41
translate spanish whitney8_e26e6e6a:

    # "The lab is different than what I expected. More like a warehouse or a garage, with open windows above letting in air and light."
    "El laboratorio es diferente de lo que esperaba. Se parece más a un almacén o a un garaje, con ventanas abiertas en la parte superior que dejan entrar aire y luz."

# game/Scenes/Whitney/whitney8.rpy:42
translate spanish whitney8_96655b8e:

    # "The equipment in the place is a mix of old stuff that just looks like junk to me, and newer almost futuristic tools."
    "El equipo del lugar es una mezcla de trastos viejos que a mí me parecen basura y herramientas más nuevas, casi futuristas."

# game/Scenes/Whitney/whitney8.rpy:43
translate spanish whitney8_c8e63656:

    # "Whitney is working at a computer desk in the far corner, but when I enter, she turns and drives over to me."
    "Whitney está trabajando en un escritorio con ordenador en la esquina más alejada, pero cuando entro, se gira y se acerca a mí."

# game/Scenes/Whitney/whitney8.rpy:47
translate spanish whitney8_47d1da62:

    # wt "Hey there, [pcname]. I hope you found the place okay."
    wt "Hola, [pcname]. Espero que hayas encontrado el lugar sin problemas."

# game/Scenes/Whitney/whitney8.rpy:48
translate spanish whitney8_3a839832:

    # pc "Yeah, your instructions were very clear. This is all your house?"
    pc "Sí, tus instrucciones eran muy claras. ¿Todo esto es tu casa?"

# game/Scenes/Whitney/whitney8.rpy:50
translate spanish whitney8_89ef433b:

    # wt "Well, this is the laboratory, but if you mean the whole estate - yes, it is mine."
    wt "Bueno, esto es el laboratorio, pero si te refieres a toda la finca, sí, es mía."

# game/Scenes/Whitney/whitney8.rpy:51
translate spanish whitney8_63dbdd85:

    # wt "Bring the hoop over here and let's take a look at it."
    wt "Trae el aro aquí y echemos un vistazo."

# game/Scenes/Whitney/whitney8.rpy:54
translate spanish whitney8_90255794:

    # "I follow her over to one of her workbenches and put the hoop down on it."
    "La sigo hasta uno de sus bancos de trabajo y dejo el aro sobre él."

# game/Scenes/Whitney/whitney8.rpy:55
translate spanish whitney8_5898a369:

    # wt "Wait, what is this?"
    wt "Espera, ¿qué es esto?"

# game/Scenes/Whitney/whitney8.rpy:56
translate spanish whitney8_80491124:

    # pc "Uh, it's the hoop that I found in the basement?"
    pc "Eh, ¿es el aro que encontré en el sótano?"

# game/Scenes/Whitney/whitney8.rpy:57
translate spanish whitney8_7438caab:

    # wt "This is not the hoop that I made for your father."
    wt "Este no es el aro que le hice a tu padre."

# game/Scenes/Whitney/whitney8.rpy:60
translate spanish whitney8_6b348789:

    # wt "This one is similar, but it's not the same one."
    wt "Este es similar, pero no es el mismo."

# game/Scenes/Whitney/whitney8.rpy:61
translate spanish whitney8_1798e0e8:

    # pc "Then why was this one in my dad's basement?"
    pc "Entonces, ¿por qué estaba este en el sótano de mi padre?"

# game/Scenes/Whitney/whitney8.rpy:62
translate spanish whitney8_9167c132:

    # wt "It seems like he might have made this one himself, based on my designs."
    wt "Parece que él mismo lo hizo, basándose en mis diseños."

# game/Scenes/Whitney/whitney8.rpy:63
translate spanish whitney8_238623a7:

    # wt "But if the one I made for him wasn't there, where is it?"
    wt "Pero si el que le hice no estaba allí, ¿dónde está?"

# game/Scenes/Whitney/whitney8.rpy:64
translate spanish whitney8_0d8ecf6d:

    # wt "It's possible that he took it with him wherever he went."
    wt "Es posible que se lo llevara consigo a dondequiera que fuera."

# game/Scenes/Whitney/whitney8.rpy:65
translate spanish whitney8_d4a9aa35:

    # pc "If he took it with him, does that mean that he planned to use it to come back?"
    pc "Si se lo llevó, ¿significa eso que pensaba usarlo para volver?"

# game/Scenes/Whitney/whitney8.rpy:66
translate spanish whitney8_cc315649:

    # wt "That logic checks out, yes."
    wt "Esa lógica tiene sentido, sí."

# game/Scenes/Whitney/whitney8.rpy:67
translate spanish whitney8_593845d4:

    # pc "There's something that has been bothering me. The instructions seem to show that the user's body has to go through the hoop, but it looks too small to fit through to me."
    pc "Hay algo que me ha estado preocupando. Las instrucciones parecen indicar que el cuerpo del usuario tiene que pasar por el aro, pero a mí me parece demasiado pequeño para caber."

# game/Scenes/Whitney/whitney8.rpy:68
translate spanish whitney8_8fa0e79c:

    # wt "Oh, that's simple."
    wt "Ah, eso es sencillo."

# game/Scenes/Whitney/whitney8.rpy:71
translate spanish whitney8_2f70dff7:

    # wt "It expands when you touch it in the right spot."
    wt "Se expande cuando lo tocas en el punto adecuado."

# game/Scenes/Whitney/whitney8.rpy:72
translate spanish whitney8_d7dea5da:

    # pc "Oh wow, okay."
    pc "Vaya, vale."

# game/Scenes/Whitney/whitney8.rpy:73
translate spanish whitney8_78fb6f94:

    # wt "There's also a small slot here where the diamond goes. There's some carbon traces here, showing that it was burnt out."
    wt "Aquí también hay una pequeña ranura donde va el diamante. Hay algunos restos de carbono aquí, lo que indica que se quemó."

# game/Scenes/Whitney/whitney8.rpy:74
translate spanish whitney8_44a25a7e:

    # wt "Which means your father definitely used this hoop, and it seemed to work."
    wt "Lo que significa que tu padre definitivamente usó este aro, y parece que funcionó."

# game/Scenes/Whitney/whitney8.rpy:75
translate spanish whitney8_4d47a3d4:

    # wt "And there's a memory chip here. This will contain all the data needed to transfer the physical matter, along with the destination."
    wt "Y aquí hay un chip de memoria. Este contendrá todos los datos necesarios para transferir la materia física, junto con el destino."

# game/Scenes/Whitney/whitney8.rpy:76
translate spanish whitney8_c8667879:

    # pc "So we can see where he went?"
    pc "¿Así que podemos ver adónde fue?"

# game/Scenes/Whitney/whitney8.rpy:77
translate spanish whitney8_842d0444:

    # wt "That's the idea. Let's check it out."
    wt "Esa es la idea. Vamos a comprobarlo."

# game/Scenes/Whitney/whitney8.rpy:80
translate spanish whitney8_59c6b5b2:

    # "She removes a small memory chip from a slot on the inside of the hoop and takes it over to her computer, putting it in some sort of reader there."
    "Saca un pequeño chip de memoria de una ranura en el interior del aro y lo lleva a su ordenador, introduciéndolo en una especie de lector que hay allí."

# game/Scenes/Whitney/whitney8.rpy:81
translate spanish whitney8_d37d2d91:

    # wt "The destruction of the diamond must have damaged the chip. A lot of the data here is corrupted."
    wt "La destrucción del diamante debe de haber dañado el chip. Muchos de los datos aquí están corruptos."

# game/Scenes/Whitney/whitney8.rpy:82
translate spanish whitney8_4291afda:

    # pc "So you can't get anything from it?"
    pc "¿Entonces no puedes sacar nada de él?"

# game/Scenes/Whitney/whitney8.rpy:83
translate spanish whitney8_00f46efa:

    # wt "I think I can, but it's going to take me some time to dig through all of this."
    wt "Creo que sí, pero me va a llevar algún tiempo revisar todo esto."

# game/Scenes/Whitney/whitney8.rpy:86
translate spanish whitney8_01905d70:

    # wt "Yeah, I can do this. I'm just going to have to go in and piece everything back together again."
    wt "Sí, puedo hacerlo. Solo tendré que meterme en ello y volver a reconstruirlo todo."

# game/Scenes/Whitney/whitney8.rpy:87
translate spanish whitney8_943d8aea:

    # wt "Give me some time though and I'll be able to tell you where your dad went."
    wt "Pero dame un poco de tiempo y podré decirte adónde fue tu padre."

# game/Scenes/Whitney/whitney8.rpy:88
translate spanish whitney8_7ef52d77:

    # pc "That's great. Thank you so much."
    pc "Genial. Muchísimas gracias."

# game/Scenes/Whitney/whitney8.rpy:89
translate spanish whitney8_68edfea2:

    # wt "There's nothing else for you to do here now. I'll give you a call once I know something more."
    wt "Ya no hay nada más que puedas hacer aquí. Te llamaré en cuanto sepa algo más."

# game/Scenes/Whitney/whitney8.rpy:93
translate spanish whitney8_ca67bf02:

    # wt "I promise I'll call you soon with whatever information I find."
    wt "Te prometo que te llamaré pronto con cualquier información que encuentre."

# game/Scenes/Whitney/whitney8.rpy:94
translate spanish whitney8_ba67f62a:

    # wt "In the meantime, just try to be patient and stay hopeful, okay?"
    wt "Mientras tanto, intenta ser paciente y no pierdas la esperanza, ¿vale?"

# game/Scenes/Whitney/whitney8.rpy:95
translate spanish whitney8_a888ee9a:

    # pc "Okay, I'll try. Thank you again."
    pc "Vale, lo intentaré. Gracias de nuevo."

# game/Scenes/Whitney/whitney8.rpy:96
translate spanish whitney8_4c04d2c6:

    # wt "You're welcome. Talk to you soon."
    wt "De nada. Hablamos pronto."

# game/Scenes/Whitney/whitney8.rpy:99
translate spanish whitney8_e92a15bd:

    # "I leave Whitney's lab and walk back out to my car."
    "Salgo del laboratorio de Whitney y vuelvo a mi coche."

# game/Scenes/Whitney/whitney8.rpy:100
translate spanish whitney8_7f05f195:

    # "I really hope she can find something."
    "Espero de verdad que pueda encontrar algo."

# game/Scenes/Whitney/whitney8.rpy:103
translate spanish whitney8_9669528e:

    # "Later..."
    "Más tarde..."

# game/Scenes/Whitney/whitney8.rpy:113
translate spanish whitney8b_492a1c5d:

    # "I'm about to go to bed when my phone starts ringing."
    "Estoy a punto de irme a la cama cuando mi teléfono empieza a sonar."

# game/Scenes/Whitney/whitney8.rpy:116
translate spanish whitney8b_bea5e8cb:

    # pc "Hello?"
    pc "¿Hola?"

# game/Scenes/Whitney/whitney8.rpy:117
translate spanish whitney8b_f60f17fc:

    # wt "Hello, [pcname]. I wanted to let you know that I've gone through and repaired most of the corrupted data on the chip."
    wt "Hola, [pcname]. Quería decirte que he revisado y reparado la mayor parte de los datos dañados del chip."

# game/Scenes/Whitney/whitney8.rpy:118
translate spanish whitney8b_a26884b5:

    # wt "I believe that I've identified the destination that your father was sent to."
    wt "Creo que he identificado el destino al que enviaron a tu padre."

# game/Scenes/Whitney/whitney8.rpy:119
translate spanish whitney8b_51b4a66e:

    # pc "Really!? Where?"
    pc "¿En serio? ¿Dónde?"

# game/Scenes/Whitney/whitney8.rpy:121
translate spanish whitney8b_55231eaf:

    # wt "46616e74617379204675636b776f726c64"
    wt "46616e74617379204675636b776f726c64"

# game/Scenes/Whitney/whitney8.rpy:122
translate spanish whitney8b_5bb78b12:

    # pc "Wait, what?"
    pc "Espera, ¿qué?"

# game/Scenes/Whitney/whitney8.rpy:123
translate spanish whitney8b_2f36447e:

    # wt "It's not like any of these universes or possible realities are named. It's all just data. It's hard to explain."
    wt "No es que ninguno de estos universos o posibles realidades tenga nombre. Todo son solo datos. Es difícil de explicar."

# game/Scenes/Whitney/whitney8.rpy:124
translate spanish whitney8b_ee97f1fd:

    # wt "The point is that I can target that same location now and transfer something to there."
    wt "La cuestión es que ahora puedo apuntar a esa misma ubicación y transferir algo allí."

# game/Scenes/Whitney/whitney8.rpy:125
translate spanish whitney8b_84389a6c:

    # pc "Great! Let's do it."
    pc "¡Genial! Hagámoslo."

# game/Scenes/Whitney/whitney8.rpy:127
translate spanish whitney8b_06785652:

    # wt "Hold on a moment. I told you I wasn't going to help with this unless we were sure that it was safe."
    wt "Espera un momento. Te dije que no iba a ayudar con esto a menos que estuviéramos seguros de que era seguro."

# game/Scenes/Whitney/whitney8.rpy:128
translate spanish whitney8b_56ef83aa:

    # wt "Right now I am positive that it's not safe."
    wt "Ahora mismo estoy seguro de que no es seguro."

# game/Scenes/Whitney/whitney8.rpy:129
translate spanish whitney8b_eff2f8b9:

    # wt "Also, there's something else. I don't think your father intended to go to this destination."
    wt "Además, hay algo más. No creo que tu padre tuviera la intención de ir a este destino."

# game/Scenes/Whitney/whitney8.rpy:130
translate spanish whitney8b_a2a6fb65:

    # pc "What do you mean?"
    pc "¿Qué quieres decir?"

# game/Scenes/Whitney/whitney8.rpy:131
translate spanish whitney8b_59275be0:

    # wt "I think he made a mistake, or something happened during the transfer. This is not the target that he intended."
    wt "Creo que cometió un error, o que pasó algo durante la transferencia. Este no es el destino al que pretendía ir."

# game/Scenes/Whitney/whitney8.rpy:132
translate spanish whitney8b_93215e54:

    # pc "Does that mean that he's in danger?"
    pc "¿Eso significa que está en peligro?"

# game/Scenes/Whitney/whitney8.rpy:134
translate spanish whitney8b_7ba80d6a:

    # wt "Almost definitely."
    wt "Casi con toda seguridad."

# game/Scenes/Whitney/whitney8.rpy:135
translate spanish whitney8b_6b8a4220:

    # pc "Then we have to help him."
    pc "Entonces tenemos que ayudarle."

# game/Scenes/Whitney/whitney8.rpy:137
translate spanish whitney8b_39eb2bc6:

    # wt "We will."
    wt "Lo haremos."

# game/Scenes/Whitney/whitney8.rpy:138
translate spanish whitney8b_a99ca9b8:

    # wt "Now that I know where he went, I'm going to start working on repairing the hoop, as it was damaged during the transfer."
    wt "Ahora que sé adónde fue, voy a empezar a trabajar en la reparación del aro, ya que se dañó durante el traslado."

# game/Scenes/Whitney/whitney8.rpy:139
translate spanish whitney8b_4e8b893c:

    # wt "Give me a few more days. I'll call you again with an update soon."
    wt "Dame unos días más. Te volveré a llamar pronto para ponerte al día."

# game/Scenes/Whitney/whitney8.rpy:140
translate spanish whitney8b_46e89e6b:

    # pc "Okay, Whitney. Thank you."
    pc "De acuerdo, Whitney. Gracias."

# game/Scenes/Whitney/whitney8.rpy:141
translate spanish whitney8b_6dff3d08:

    # wt "You're welcome. Talk to you again soon."
    wt "De nada. Hablamos pronto."

# game/Scenes/Whitney/whitney8.rpy:144
translate spanish whitney8b_fbbc3740:

    # "I hang up and get ready for bed."
    "Cuelgo y me preparo para irme a la cama."

# game/Scenes/Whitney/whitney8.rpy:147
translate spanish whitney8b_9669528e:

    # "Later..."
    "Más tarde..."

# game/Scenes/Whitney/whitney8.rpy:157
translate spanish whitney8c_9853ab00:

    # "My phone starts buzzing. Whitney's calling."
    "Mi teléfono empieza a vibrar. Es Whitney."

# game/Scenes/Whitney/whitney8.rpy:160
translate spanish whitney8c_bea5e8cb:

    # pc "Hello?"
    pc "¿Hola?"

# game/Scenes/Whitney/whitney8.rpy:161
translate spanish whitney8c_58e0c9ab:

    # wt "Good morning, [pcname]. I've reached a point in my research where I need your assistance."
    wt "Buenos días, [pcname]. He llegado a un punto en mi investigación en el que necesito tu ayuda."

# game/Scenes/Whitney/whitney8.rpy:162
translate spanish whitney8c_801e2e5b:

    # wt "Could you come out to my lab again?"
    wt "¿Podrías venir otra vez a mi laboratorio?"

# game/Scenes/Whitney/whitney8.rpy:163
translate spanish whitney8c_f1d0c30d:

    # pc "Sure. I'll get dressed and head out now."
    pc "Claro. Me voy a vestir y salgo ahora mismo."

# game/Scenes/Whitney/whitney8.rpy:165
translate spanish whitney8c_864d47fe:

    # wt "Thank you. Just go straight to the lab again."
    wt "Gracias. Ve directamente al laboratorio otra vez."

# game/Scenes/Whitney/whitney8.rpy:166
translate spanish whitney8c_2c0a751f:

    # pc "Okay, see you in a bit."
    pc "Vale, nos vemos en un rato."

# game/Scenes/Whitney/whitney8.rpy:170
translate spanish whitney8c_356b5f4c:

    # "I get dressed and drive out to Whitney's lab again, anxious to see what she has found now."
    "Me visto y conduzco hasta el laboratorio de Whitney otra vez, ansioso por ver qué ha descubierto ahora."

# game/Scenes/Whitney/whitney8.rpy:174
translate spanish whitney8c_43ebde66:

    # "When I get there, I head directly through the house and into her lab again."
    "Cuando llego, atravieso la casa y entro directamente en su laboratorio otra vez."

# game/Scenes/Whitney/whitney8.rpy:175
translate spanish whitney8c_7d3d22ee:

    # "She's working on the computer when I walk in, but then turns and greets me."
    "Está trabajando en el ordenador cuando entro, pero se gira y me saluda."

# game/Scenes/Whitney/whitney8.rpy:178
translate spanish whitney8c_8a3a0672:

    # wt "Good morning. Thanks for coming out here."
    wt "Buenos días. Gracias por venir."

# game/Scenes/Whitney/whitney8.rpy:179
translate spanish whitney8c_221b7409:

    # pc "You're welcome. What's going on?"
    pc "De nada. ¿Qué pasa?"

# game/Scenes/Whitney/whitney8.rpy:180
translate spanish whitney8c_06002bcd:

    # wt "I need you to take your clothes off and lie on the table over there please."
    wt "Necesito que te quites la ropa y te tumbes en la camilla de ahí, por favor."

# game/Scenes/Whitney/whitney8.rpy:181
translate spanish whitney8c_5bb78b12:

    # pc "Wait, what?"
    pc "Espera, ¿qué?"

# game/Scenes/Whitney/whitney8.rpy:183
translate spanish whitney8c_0a7d798d:

    # wt "I need to get all of your vitals and measurements and it would make things easier without all your clothes in the way."
    wt "Tengo que tomarte todas las constantes vitales y las medidas, y sería más fácil sin toda la ropa estorbando."

# game/Scenes/Whitney/whitney8.rpy:184
translate spanish whitney8c_21af9c33:

    # wt "You can keep your underwear on. I have no need of anything down there."
    wt "Puedes dejarte la ropa interior puesta. No necesito nada de ahí abajo."

# game/Scenes/Whitney/whitney8.rpy:185
translate spanish whitney8c_45e80a89:

    # wt "There's no need to be embarrassed."
    wt "No hay por qué avergonzarse."

# game/Scenes/Whitney/whitney8.rpy:186
translate spanish whitney8c_0ea55049:

    # pc "I'm not embarrassed. Just a little surprised."
    pc "No me da vergüenza. Solo estoy un poco sorprendida."

# game/Scenes/Whitney/whitney8.rpy:189
translate spanish whitney8c_e78ac241:

    # "I strip down and lie on the examination table, feeling rather awkward. She pulls a machine down over my head and turns it on with a sort of buzzing noise."
    "Me desnudo y me tumbo en la camilla, sintiéndome bastante incómoda. Ella coloca una máquina sobre mi cabeza y la enciende con una especie de zumbido."

# game/Scenes/Whitney/whitney8.rpy:190
translate spanish whitney8c_0389d7fb:

    # pc "What is this thing?"
    pc "¿Qué es esto?"

# game/Scenes/Whitney/whitney8.rpy:191
translate spanish whitney8c_c66baa47:

    # wt "It's sort of like a CAT scan. It's going to measure your brain patterns so that we can store them in the hoop."
    wt "Es algo parecido a una tomografía computarizada. Va a medir tus patrones cerebrales para que podamos almacenarlos en el aro."

# game/Scenes/Whitney/whitney8.rpy:192
translate spanish whitney8c_c2eb693e:

    # pc "It's not going to give me cancer or anything?"
    pc "¿No me va a provocar cáncer ni nada por el estilo?"

# game/Scenes/Whitney/whitney8.rpy:193
translate spanish whitney8c_48b9eb7c:

    # wt "No, I don't think so."
    wt "No, no lo creo."

# game/Scenes/Whitney/whitney8.rpy:194
translate spanish whitney8c_85b1d295:

    # "She spends the next half hour examining me in a very scientific way, obviously not feeling the awkwardness."
    "Se pasa la siguiente media hora examinándome de una manera muy científica, sin sentir, obviamente, la incomodidad."

# game/Scenes/Whitney/whitney8.rpy:195
translate spanish whitney8c_be8b4783:

    # "She takes my blood pressure, a blood sample, swabs my mouth, and asks me for my entire medical history."
    "Me toma la tensión arterial, me extrae una muestra de sangre, me hace un frotis bucal y me pregunta por todo mi historial médico."

# game/Scenes/Whitney/whitney8.rpy:198
translate spanish whitney8c_a8560158:

    # "Eventually, she is done."
    "Al final, termina."

# game/Scenes/Whitney/whitney8.rpy:199
translate spanish whitney8c_e04a7994:

    # wt "Your body is in great condition physically."
    wt "Tu cuerpo está en excelentes condiciones físicas."

# game/Scenes/Whitney/whitney8.rpy:200
translate spanish whitney8c_e8f490d9:

    # wt "I believe you could make the transition."
    wt "Creo que podrías hacer la transición."

# game/Scenes/Whitney/whitney8.rpy:201
translate spanish whitney8c_91eec677:

    # pc "You mean, going through the hoop?"
    pc "¿Te refieres a atravesar el aro?"

# game/Scenes/Whitney/whitney8.rpy:202
translate spanish whitney8c_fcfdd53c:

    # wt "That is what we're trying to do, right?"
    wt "Eso es lo que estamos intentando hacer, ¿no?"

# game/Scenes/Whitney/whitney8.rpy:203
translate spanish whitney8c_1f52f549:

    # wt "Send you through to bring your father back?"
    wt "¿Enviarte al otro lado para traer de vuelta a tu padre?"

# game/Scenes/Whitney/whitney8.rpy:204
translate spanish whitney8c_42085f5f:

    # pc "Yes, I guess so. It just feels so strange. Like a weird fantasy or something. I still can't believe this is real."
    pc "Sí, supongo que sí. Es que me resulta tan extraño. Como una fantasía rara o algo así. Sigo sin poder creer que esto sea real."

# game/Scenes/Whitney/whitney8.rpy:205
translate spanish whitney8c_ecc33c25:

    # wt "We'll take every precaution possible before we do it. I want to make sure you're safe."
    wt "Tomaremos todas las precauciones posibles antes de hacerlo. Quiero asegurarme de que estés a salvo."

# game/Scenes/Whitney/whitney8.rpy:206
translate spanish whitney8c_fdc5f0f0:

    # pc "Yeah, me too."
    pc "Sí, yo también."

# game/Scenes/Whitney/whitney8.rpy:207
translate spanish whitney8c_c53f513a:

    # wt "Okay, you can put your clothes on now."
    wt "Vale, ya puedes vestirte."

# game/Scenes/Whitney/whitney8.rpy:210
translate spanish whitney8c_c637416c:

    # "I do as she says and put my clothes back on."
    "Hago lo que me dice y me vuelvo a poner la ropa."

# game/Scenes/Whitney/whitney8.rpy:211
translate spanish whitney8c_76970b11:

    # "I can't help but feel her staring at me while I do so, this time in a less professional way than she had looked at me before."
    "No puedo evitar sentir su mirada fija en mí mientras lo hago, esta vez de una forma menos profesional que antes."

# game/Scenes/Whitney/whitney8.rpy:215
translate spanish whitney8c_87e35479:

    # wt "Thanks for your help today. I know it was a bit awkward for you, but the data I gathered will help us immensely."
    wt "Gracias por tu ayuda hoy. Sé que ha sido un poco incómodo para ti, pero los datos que he recopilado nos ayudarán enormemente."

# game/Scenes/Whitney/whitney8.rpy:216
translate spanish whitney8c_b3957c4b:

    # wt "I'll use it to configure the hoop to your particular physiology."
    wt "Los usaré para configurar el aro según tu fisiología particular."

# game/Scenes/Whitney/whitney8.rpy:217
translate spanish whitney8c_1a8be2aa:

    # wt "Then my study will shift into finding a way for you to get back home once you have transitioned through the hoop."
    wt "Después, mi estudio se centrará en encontrar una forma de que regreses a casa una vez que hayas atravesado el aro."

# game/Scenes/Whitney/whitney8.rpy:218
translate spanish whitney8c_7b45e859:

    # wt "Meanwhile, you must play the waiting game again. I'll let you know if I discover anything new or need you for anything else."
    wt "Mientras tanto, tendrás que volver a esperar. Te avisaré si descubro algo nuevo o te necesito para cualquier otra cosa."

# game/Scenes/Whitney/whitney8.rpy:219
translate spanish whitney8c_1cb92faa:

    # wt "You may not hear from me for a while, but trust that I'm working on this."
    wt "Puede que no sepas nada de mí durante un tiempo, pero confía en que estoy trabajando en ello."

# game/Scenes/Whitney/whitney8.rpy:220
translate spanish whitney8c_3cf430d2:

    # pc "Okay. Thank you Whitney. I'm glad you're here to help me with this."
    pc "Vale. Gracias, Whitney. Me alegro de que estés aquí para ayudarme con esto."

# game/Scenes/Whitney/whitney8.rpy:222
translate spanish whitney8c_aabc7829:

    # wt "It's no problem. I feel a little responsible for all of it."
    wt "No hay problema. Me siento un poco responsable de todo esto."

# game/Scenes/Whitney/whitney8.rpy:223
translate spanish whitney8c_26af9036:

    # pc "Well, just know that I don't blame you."
    pc "Bueno, solo quiero que sepas que no te culpo."

# game/Scenes/Whitney/whitney8.rpy:225
translate spanish whitney8c_070d2d8b:

    # wt "Thank you. That does mean a lot."
    wt "Gracias. Eso significa mucho para mí."

# game/Scenes/Whitney/whitney8.rpy:227
translate spanish whitney8c_4dfa259f:

    # wt "I'll talk to you later, okay?"
    wt "Hablamos luego, ¿vale?"

# game/Scenes/Whitney/whitney8.rpy:228
translate spanish whitney8c_44ea8ace:

    # pc "Okay. Talk to you later."
    pc "Vale. Hablamos luego."

# game/Scenes/Whitney/whitney8.rpy:231
translate spanish whitney8c_939d2065:

    # "I leave Whitney's lab and go back out to the car, hoping that she'll be able to figure this out and we can bring my dad home."
    "Salgo del laboratorio de Whitney y vuelvo al coche, con la esperanza de que ella pueda resolver esto y podamos llevar a mi padre a casa."

translate spanish strings:

    # game/Scenes/Whitney/whitney8.rpy:4
    old "After you meet Whitney in the park, you can call her and talk to her. Ask her if she lives in Skyhill."
    new "Después de encontrarte con Whitney en el parque, puedes llamarla y hablar con ella. Pregúntale si vive en Skyhill."

    # game/Scenes/Whitney/whitney8.rpy:5
    old "Then, a few days later, she will call you and ask you to come to her lab. She'll call you a couple more times over the next few days."
    new "Luego, unos días más tarde, ella te llamará y te pedirá que vayas a su laboratorio. Te llamará un par de veces más durante los próximos días."

