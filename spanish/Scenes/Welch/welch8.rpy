# game/Scenes/Welch/welch8.rpy:165
translate spanish welch8date_1c722351:

    # pc "Yeah she is."
    pc "Sí, lo está."

# game/Scenes/Welch/welch8.rpy:167
translate spanish welch8date_a5af6fb9:

    # "Izzy comes over to take our order."
    "Izzy se acerca para tomar nuestra comanda."

# game/Scenes/Welch/welch8.rpy:170
translate spanish welch8date_0d87a734:

    # gl "Yo, what's up, Nora?"
    gl "Hola, ¿qué tal, Nora?"

