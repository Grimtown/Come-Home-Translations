# game/Scenes/Micha/micha8.rpy:14
translate chinese micha8_5f9760c9:

    # "Before I go to Gertrude's office, Mi-Cha stops me in the lobby."
    "在我去格特鲁德办公室之前，米查在大厅拦住了我。"

# game/Scenes/Micha/micha8.rpy:15
translate chinese micha8_ed6bde86:

    # mc "Hello, [pcname]."
    mc "你好，[pcname]。"

# game/Scenes/Micha/micha8.rpy:16
translate chinese micha8_f481dcaa:

    # pc "Hi, Mi-Cha. How are you?"
    pc "嗨，米查。你好吗？"

# game/Scenes/Micha/micha8.rpy:17
translate chinese micha8_72cb11f5:

    # mc "I am good, thank you."
    mc "我很好，谢谢。"

# game/Scenes/Micha/micha8.rpy:19
translate chinese micha8_bdbd1fa8:

    # mc "I want to tell you that I enjoyed our coffee date."
    mc "我想告诉你，我很喜欢我们的咖啡约会。"

# game/Scenes/Micha/micha8.rpy:20
translate chinese micha8_8a7120da:

    # mc "I apologize for rushing off early and would like to again another sometime."
    mc "很抱歉我提前匆匆离开了，希望以后还能再约一次。"

# game/Scenes/Micha/micha8.rpy:21
translate chinese micha8_3171636b:

    # mc "If you would like to this evening?"
    mc "要不要今晚就约？"

# game/Scenes/Micha/micha8.rpy:25
translate chinese micha8_2d186b97:

    # mc "Good. I will meet you in the Skyhill Cafe this evening then."
    mc "好啊。那今晚我在Skyhill咖啡馆等你。"

# game/Scenes/Micha/micha8.rpy:29
translate chinese micha8_2f88594e:

    # mc "Oh. Okay. Yes, I'm sure you're busy."
    mc "哦。好的。是的，我知道你很忙。"

# game/Scenes/Micha/micha8.rpy:31
translate chinese micha8_08d0510d:

    # mc "Enjoy your visit with Mrs. Spann."
    mc "祝你和斯潘夫人相处愉快。"

# game/Scenes/Micha/micha8.rpy:32
translate chinese micha8_32a03447:

    # pc "Okay. I'll see you later, Mi-Cha."
    pc "好的。米查，待会儿见。"

translate chinese strings:

    # game/Scenes/Micha/micha8.rpy:2
    old "After your first date with Mi-Cha, go talk to her in the counselor's lobby on a weekday morning."
    new "与米查第一次约会后，在工作日的早上到辅导员大厅找她聊聊。"

    # game/Scenes/Micha/micha8.rpy:3
    old "She will want to go on another date with you."
    new "她会想再和你约会一次。"

    # game/Scenes/Micha/micha8.rpy:27
    old "Maybe some other night"
    new "也许改天晚上吧"

