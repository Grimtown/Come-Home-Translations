    # "For now, I should go see Dana."
    "Por ahora, debería ir a ver a Dana."

# game/Scenes/Update20/u20e.rpy:5
translate spanish u20e_8200a66a:

    # "I drive over to Dana's apartment and knock on her door."
    "Conduzco hasta el apartamento de Dana y llamo a su puerta."

# game/Scenes/Update20/u20e.rpy:6
translate spanish u20e_4fc89239:

    # "It's late and I hate to wake her, but I need to see her."
    "Es tarde y no me gusta despertarla, pero necesito verla."

# game/Scenes/Update20/u20e.rpy:10
translate spanish u20e_92b16112:

    # cw "[pcname]? Oh my God!"
    cw "[pcname]? ¡Dios mío!"

# game/Scenes/Update20/u20e.rpy:13
translate spanish u20e_da2e1dbd:

    # "She rushes to me and wraps her arms around me tightly."
    "Se abalanza hacia mí y me rodea con fuerza con sus brazos."

# game/Scenes/Update20/u20e.rpy:14
translate spanish u20e_140e4956:

    # "I hug her back, feeling her warmth and the softness of her body."
    "La abrazo también, sintiendo su calor y la suavidad de su cuerpo."

# game/Scenes/Update20/u20e.rpy:15
translate spanish u20e_ed44c8a5:

    # pc "I missed you."
    pc "Te he echado de menos."

# game/Scenes/Update20/u20e.rpy:18
translate spanish u20e_35280183:

    # cw "I missed you too. What happened? I thought that machine killed you."
    cw "Yo también te he echado de menos. ¿Qué ha pasado? Pensaba que esa máquina te había matado."

# game/Scenes/Update20/u20e.rpy:19
translate spanish u20e_b4f81641:

    # pc "I'm sorry. I didn't mean to leave for so long."
    pc "Lo siento. No era mi intención estar fuera tanto tiempo."

# game/Scenes/Update20/u20e.rpy:20
translate spanish u20e_356f7f42:

    # pc "I'll tell you everything tomorrow, I promise."
    pc "Mañana te lo contaré todo, te lo prometo."

# game/Scenes/Update20/u20e.rpy:23
translate spanish u20e_1569fad0:

    # cw "I'm just glad you're back."
    cw "Me alegro de que hayas vuelto."

# game/Scenes/Update20/u20e.rpy:24
translate spanish u20e_634678a9:

    # cw "Wow, your hair grew a lot."
    cw "Vaya, se te ha crecido mucho el pelo."

# game/Scenes/Update20/u20e.rpy:25
translate spanish u20e_ab3cf051:

    # cw "It looks awful."
    cw "Está horrible."

# game/Scenes/Update20/u20e.rpy:28
translate spanish u20e_7d64063d:

    # "She kisses me softly, her lips warm and inviting."
    "Me besa suavemente, con sus labios cálidos y tentadores."

# game/Scenes/Update20/u20e.rpy:29
translate spanish u20e_9cf9ef15:

    # cw "But I don't care. You came home."
    cw "Pero no me importa. Has vuelto a casa."

# game/Scenes/Update20/u20e.rpy:30
translate spanish u20e_ad7289ff:

    # cw "I missed you so much, [pcname]."
    cw "Te he echado mucho de menos, [pcname]."

# game/Scenes/Update20/u20e.rpy:31
translate spanish u20e_0ea8f604:

    # cw "Let's go to bed. We can talk in the morning."
    cw "Vamos a la cama. Podemos hablar por la mañana."

