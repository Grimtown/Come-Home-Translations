# game/Scenes/MrsMills/mills2.rpy:70
translate spanish mills2_82973669:

    # "Fantasies of how it would happen spin through my head the rest of the day, until it is time to close up and leave."
    "Las fantasías sobre cómo sucedería me dan vueltas en la cabeza el resto del día, hasta que llega la hora de cerrar y marcharme."

# game/Scenes/MrsMills/mills2.rpy:73
translate spanish mills2_bbf9ce82:

    # bs "Good work today. You have a good night."
    bs "Buen trabajo hoy. Que pases buena noche."

# game/Scenes/MrsMills/mills2.rpy:74
translate spanish mills2_27ed6fe0:

