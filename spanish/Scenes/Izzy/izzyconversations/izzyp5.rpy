# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:12
translate spanish izzyp5_97008982:

    # gl "Married?"
    gl "¿Casarse?"

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:13
translate spanish izzyp5_fd9ab24a:

    # gl "I don't know, man..."
    gl "No sé, tío..."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:14
translate spanish izzyp5_f4d0baa9:

    # gl "Marriage always just seemed like ownership to me."
    gl "El matrimonio siempre me ha parecido una forma de posesión."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:15
translate spanish izzyp5_a2a6fb65:

    # pc "What do you mean?"
    pc "¿Qué quieres decir?"

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:17
translate spanish izzyp5_6b0cf353:

    # gl "Well, like one of my cousins is married and one time I was staying over at her house and we were getting ready for bed."
    gl "Bueno, una de mis primas está casada y una vez me quedé a dormir en su casa y nos estábamos preparando para irnos a la cama."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:19
translate spanish izzyp5_fb14eaf2:

    # gl "My cousin was going to stay up and watch a movie with me and some friends, but her husband told her to get in bed."
    gl "Mi prima iba a quedarse despierta para ver una película conmigo y unos amigos, pero su marido le dijo que se metiera en la cama."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:21
translate spanish izzyp5_56b8b1c2:

    # gl "He told her that he wanted her. That he had \"papers on her pussy.\""
    gl "Le dijo que la quería. Que tenía «papeles sobre su coño»."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:22
translate spanish izzyp5_fb9284e4:

    # gl "And she did it. She left and went to him. Because he owned her."
    gl "Y ella lo hizo. Se fue con él. Porque él era su dueño."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:23
translate spanish izzyp5_ea64528c:

    # pc "That's awful. It doesn't have to be like that though."
    pc "Eso es horrible. Aunque no tiene por qué ser así."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:25
translate spanish izzyp5_3786e326:

    # gl "I just haven't ever seen any good marriages."
    gl "Es solo que nunca he visto ningún matrimonio que valga la pena."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:27
translate spanish izzyp5_6c959b11:

    # gl "But I'll tell you something, Twig."
    gl "Pero te diré una cosa, Twig."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:29
translate spanish izzyp5_74feb60f:

    # gl "If there's anybody that I'd even consider settling down with, it'd be you."
    gl "Si hay alguien con quien me plantearía sentar cabeza, ese serías tú."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:30
translate spanish izzyp5_f3f8a6b5:

    # gl "I don't know about marriage, but I do care about you."
    gl "No sé nada de matrimonio, pero sí que me importas."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:31
translate spanish izzyp5_3c07eaab:

    # gl "I could see myself with you. For a long time."
    gl "Me veo contigo. Durante mucho tiempo."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:32
translate spanish izzyp5_86a73502:

    # pc "I'll take it."
    pc "Me lo quedo."

