# game/Scenes/Whitney/whitney10.rpy:10
translate spanish whitney10_be5af3f7:

    # "My phone buzzes in my pocket. It's Whitney calling."
    "Mi teléfono vibra en el bolsillo. Es Whitney llamando."

# game/Scenes/Whitney/whitney10.rpy:15
translate spanish whitney10_cabe2426:

    # pc "Hey, Whitney. What's up?"
    pc "Hola, Whitney. ¿Qué tal?"

# game/Scenes/Whitney/whitney10.rpy:16
translate spanish whitney10_b9006bbe:

    # wt "Oh hey. Are you busy?"
    wt "Oh, hola. ¿Estás ocupado?"

# game/Scenes/Whitney/whitney10.rpy:17
translate spanish whitney10_bc1428f9:

    # pc "Not really."
    pc "La verdad es que no."

# game/Scenes/Whitney/whitney10.rpy:19
translate spanish whitney10_87d76db1:

    # wt "I have this craving for that burger place we went to before. Would you want to go get dinner with me again?"
    wt "Me apetece mucho ir a esa hamburguesería a la que fuimos antes. ¿Te apetece volver a salir a cenar conmigo?"

# game/Scenes/Whitney/whitney10.rpy:20
translate spanish whitney10_240f7709:

    # pc "Are you asking me out on a date?"
    pc "¿Me estás invitando a una cita?"

# game/Scenes/Whitney/whitney10.rpy:22
translate spanish whitney10_b86f93de:

    # wt "You can call it whatever you like. I just want a burger."
    wt "Llámalo como quieras. Solo quiero una hamburguesa."

# game/Scenes/Whitney/whitney10.rpy:23
translate spanish whitney10_91e1bb14:

    # wt "And your company is nice as well."
    wt "Y tu compañía también me gusta."

# game/Scenes/Whitney/whitney10.rpy:27
translate spanish whitney10_7c538ce6:

    # wt "Great! I'll drive over and pick you up at your place in about half an hour."
    wt "¡Genial! Pasaré a recogerte por tu casa dentro de media hora."

# game/Scenes/Whitney/whitney10.rpy:28
translate spanish whitney10_ac8c00ba:

    # pc "Sounds good. See you then."
    pc "Suena bien. Nos vemos entonces."

# game/Scenes/Whitney/whitney10.rpy:29
translate spanish whitney10_2c71ca5c:

    # "We hang up and I go home and get ready."
    "Colgamos y me voy a casa a prepararme."

# game/Scenes/Whitney/whitney10.rpy:33
translate spanish whitney10_2aaf9014:

    # wt "Oh, okay then."
    wt "Ah, vale entonces."

# game/Scenes/Whitney/whitney10.rpy:34
translate spanish whitney10_f7a5b1c0:

    # wt "Well, if you want to sometime, just give me a call in the evening. I'm usually free."
    wt "Bueno, si alguna vez te apetece, llámame por la tarde. Normalmente estoy libre."

# game/Scenes/Whitney/whitney10.rpy:35
translate spanish whitney10_bf0c9413:

    # pc "Okay, Whitney. Talk to you later."
    pc "Vale, Whitney. Hablamos luego."

# game/Scenes/Whitney/whitney10.rpy:36
translate spanish whitney10_a7e7a8bf:

    # wt "Bye, [pcname]."
    wt "Adiós, [pcname]."

