# game/Scenes/Bai/BaiDates/baimoviedate.rpy:25
translate spanish baimovietheaterstartdate_13ddb197:

    # "We get to the theater and find seats in the back."
    "Llegamos al cine y encontramos asientos en la parte de atrás."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:26
translate spanish baimovietheaterstartdate_7b36967b:

    # "We chat for a while before the movie starts."
    "Charlamos un rato antes de que empiece la película."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:31
translate spanish baimovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Por fin empieza la película y nos quedamos en silencio."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:33
translate spanish baimovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Los tráilers duran unos quince minutos, y luego empieza la película de verdad."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:35
translate spanish baimovietheaterstartdate_5e17c29c:

    # "It's a pretty good movie and we laugh all the way through it."
    "Es una película bastante buena y nos reímos durante toda la proyección."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:37
translate spanish baimovietheaterstartdate_a2905b6a:

    # "After the movie ends, we hang out and chat through the credits."
    "Cuando termina la película, nos quedamos charlando durante los créditos."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:42
translate spanish baimovietheaterstartdate_edff30b2:

    # "When the credits end, we walk outside together to my car."
    "Cuando acaban los créditos, salimos juntos hacia mi coche."

