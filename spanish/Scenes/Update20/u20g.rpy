translate spanish u20g_fc5b5a95:

    # "For now, I should go see Juliana."
    "Por ahora, debería ir a ver a Juliana."

# game/Scenes/Update20/u20g.rpy:5
translate spanish u20g_2257ecc3:

    # "I drive over to Juliana's house and knock on her door."
    "Conduzco hasta la casa de Juliana y llamo a la puerta."

# game/Scenes/Update20/u20g.rpy:6
translate spanish u20g_4fc89239:

    # "It's late and I hate to wake her, but I need to see her."
    "Es tarde y no me gusta despertarla, pero necesito verla."

# game/Scenes/Update20/u20g.rpy:9
translate spanish u20g_5ac21d19:

    # "Juliana's grandmother comes to the door, looking surprised."
    "La abuela de Juliana abre la puerta, con cara de sorpresa."

# game/Scenes/Update20/u20g.rpy:10
translate spanish u20g_12baa67b:

    # jg "Oh you're Juliana's friend... I'm sorry, I forgot your name."
    jg "Ah, eres el amigo de Juliana... Lo siento, se me ha olvidado tu nombre."

# game/Scenes/Update20/u20g.rpy:11
translate spanish u20g_529f52b6:

    # pc "It's [pcname]."
    pc "Soy [pcname]."

# game/Scenes/Update20/u20g.rpy:12
translate spanish u20g_0a7b8aae:

    # jg "What happened to your hair, boy? You miss a barber appointment?"
    jg "¿Qué te ha pasado en el pelo, chico? ¿Te has saltado la cita con el peluquero?"

# game/Scenes/Update20/u20g.rpy:13
translate spanish u20g_84c963f6:

    # pc "I'm sorry. I know it's late, but can I see Juliana?"
    pc "Lo siento. Sé que es tarde, pero ¿puedo ver a Juliana?"

# game/Scenes/Update20/u20g.rpy:14
translate spanish u20g_975fcca2:

    # jg "Oh, it's okay. I was up watching Love Island. You know that show?"
    jg "Oh, no pasa nada. Estaba despierta viendo Love Island. ¿Conoces ese programa?"

# game/Scenes/Update20/u20g.rpy:17
translate spanish u20g_70d520dc:

    # jg "I just love all the drama with sexy people trying to get in each other's pants."
    jg "Me encantan todos esos dramas con gente sexy intentando meterse en la cama de los demás."

# game/Scenes/Update20/u20g.rpy:18
translate spanish u20g_5ab1c947:

    # jg "Anyway, come in. Yeah, you can go up to see Juliana."
    jg "En fin, pasa. Sí, puedes subir a ver a Juliana."

# game/Scenes/Update20/u20g.rpy:19
translate spanish u20g_60d8396d:

    # jg "I'll turn up the volume on the TV, so you two can have some privacy."
    jg "Subiré el volumen de la tele para que tengáis un poco de intimidad."

# game/Scenes/Update20/u20g.rpy:20
translate spanish u20g_c6880d17:

    # pc "Thanks!"
    pc "¡Gracias!"

# game/Scenes/Update20/u20g.rpy:24
translate spanish u20g_ea76bd5b:

    # "I walk quietly up the stairs and into Juliana's room. She's in bed, sleeping."
    "Subo las escaleras en silencio y entro en la habitación de Juliana. Está en la cama, durmiendo."

# game/Scenes/Update20/u20g.rpy:27
translate spanish u20g_a95bfc0c:

    # "Trying not to wake her immediately, I lie next to her and wrap her in my arms."
    "Intentando no despertarla de golpe, me acuesto a su lado y la envuelvo en mis brazos."

# game/Scenes/Update20/u20g.rpy:30
translate spanish u20g_c981bd85:

    # "She jolts awake and looks at me, shocked."
    "Se despierta sobresaltada y me mira, sorprendida."

# game/Scenes/Update20/u20g.rpy:31
translate spanish u20g_c026970e:

    # bn "[pcname]? Is it really you?"
    bn "[pcname]? ¿De verdad eres tú?"

# game/Scenes/Update20/u20g.rpy:32
translate spanish u20g_7f340d6d:

    # pc "It's really me."
    pc "Soy yo de verdad."

# game/Scenes/Update20/u20g.rpy:35
translate spanish u20g_b5e336f8:

    # "She leans in and kisses me deeply, her lips soft and warm against mine."
    "Se inclina y me besa profundamente, con sus labios suaves y cálidos contra los míos."

# game/Scenes/Update20/u20g.rpy:36
translate spanish u20g_df5fc180:

    # bn "Oh, I missed you so much."
    bn "Oh, te he echado tanto de menos."

# game/Scenes/Update20/u20g.rpy:39
translate spanish u20g_cfc15aa3:

    # bn "So everything was true? You really saw your dad?"
    bn "¿Entonces todo era verdad? ¿De verdad viste a tu padre?"

# game/Scenes/Update20/u20g.rpy:40
translate spanish u20g_e5c0f2f9:

    # pc "Yeah, I did. It's all true. I'll tell you all about it tomorrow."
    pc "Sí, lo vi. Todo es verdad. Mañana te lo contaré todo."

# game/Scenes/Update20/u20g.rpy:43
translate spanish u20g_2b545022:

    # bn "I'm just glad you're back. I was so worried about you."
    bn "Me alegro de que hayas vuelto. Estaba muy preocupada por ti."

# game/Scenes/Update20/u20g.rpy:44
translate spanish u20g_98d08bed:

    # bn "You look and smell awful though."
    bn "Aunque tienes muy mal aspecto y hueles fatal."

# game/Scenes/Update20/u20g.rpy:47
translate spanish u20g_4aea05d2:

    # bn "I'll go get the bathroom ready for you."
    bn "Voy a prepararte el baño."

# game/Scenes/Update20/u20g.rpy:48
translate spanish u20g_a3acbba5:

    # bn "If you're going to stay the night in my bed, you need to shower and shave."
    bn "Si vas a pasar la noche en mi cama, tienes que ducharte y afeitarte."

