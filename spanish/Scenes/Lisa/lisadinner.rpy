# game/Scenes/Lisa/lisadinner.rpy:3
translate spanish lisadinner_e20dd2c0:

    # "Usually Lisa would be cooking dinner here on the weekend, but she's not here."
    "Normalmente Lisa estaría preparando la cena aquí el fin de semana, pero no está."

# game/Scenes/Lisa/lisadinner.rpy:4
translate spanish lisadinner_7b04e990:

    # "I wonder if she's still upset about before?"
    "Me pregunto si seguirá enfadada por lo de antes."

# game/Scenes/Lisa/lisadinner.rpy:5
translate spanish lisadinner_6a8bd90c:

    # "I guess she just needs some more time."
    "Supongo que solo necesita un poco más de tiempo."

# game/Scenes/Lisa/lisadinner.rpy:8
translate spanish lisadinner_17ebb7b6:

    # "Lisa stands in the kitchen, cooking dinner at the stove."
    "Lisa está en la cocina, preparando la cena en los fogones."

# game/Scenes/Lisa/lisadinner.rpy:9
translate spanish lisadinner_622e58a4:

    # "She looks tired, but still turns towards me with a smile."
    "Parece cansada, pero aun así se gira hacia mí con una sonrisa."

# game/Scenes/Lisa/lisadinner.rpy:12
translate spanish lisadinner_dbdf9d75:

    # sp "Hey honey. You joining me for dinner?"
    sp "Hola, cariño. ¿Te unes a mí para cenar?"

# game/Scenes/Lisa/lisadinner.rpy:21
translate spanish lisadinner_d0417e78:

    # sp "Okay honey, let me know if you change your mind."
    sp "Vale, cariño, avísame si cambias de opinión."

# game/Scenes/Lisa/lisadinner.rpy:67
translate spanish lisadinnerconversation_18c6396f:

    # sp "I'm glad. It gets lonely eating by myself."
    sp "Me alegro. Me siento solo comiendo solo."

# game/Scenes/Lisa/lisadinner.rpy:69
translate spanish lisadinnerconversation_f7385cce:

    # "She returns to the stove and cooks us both dinner."
    "Vuelve a los fogones y nos prepara la cena a los dos."

# game/Scenes/Lisa/lisadinner.rpy:73
translate spanish lisadinnerconversation_2aba8403:

    # "Then we sit together in the dining room and have a nice conversation while eating."
    "Luego nos sentamos juntos en el comedor y tenemos una agradable conversación mientras comemos."

# game/Scenes/Lisa/lisadinner.rpy:76
translate spanish lisadinnerconversation_ac9094b5:

    # "Afterwards, we go to the kitchen and I help with the dishes."
    "Después, vamos a la cocina y le ayudo con los platos."

# game/Scenes/Lisa/lisadinner.rpy:77
translate spanish lisadinnerconversation_74aec54b:

    # sp "Thanks for having dinner with me honey. I really enjoyed it."
    sp "Gracias por cenar conmigo, cariño. Lo he disfrutado mucho."

# game/Scenes/Lisa/lisadinner.rpy:78
translate spanish lisadinnerconversation_6ecfecf0:

    # pc "Any time, [mom]."
    pc "Cuando quieras, [mom]."

# game/Scenes/Lisa/lisadinner.rpy:80
translate spanish lisadinnerconversation_79c86a4f:

    # sp "Love you, baby."
    sp "Te quiero, cariño."

# game/Scenes/Lisa/lisadinner.rpy:81
translate spanish lisadinnerconversation_ce2ae2bf:

    # pc "Love you too."
    pc "Yo también te quiero."

# game/Scenes/Lisa/lisadinner.rpy:82
translate spanish lisadinnerconversation_db14aa5a:

    # "We finish up and Lisa goes to her bedroom for the night."
    "Terminamos y Lisa se va a su dormitorio a dormir."

