translate chinese jez17_e76a33e5:

    # "Javi puts the controller down and runs over to Abuela and hugs her leg."
    "哈维放下手柄，跑过去抱住阿布埃拉的腿。"

# game/Scenes/Jez/jez17.rpy:154
translate chinese jez17_a1f68f1a:

    # jav "Adios, Abuelita. Te quiero."
    jav "再见啦，阿布埃利塔。我爱你。"

# game/Scenes/Jez/jez17.rpy:155
translate chinese jez17_2e1c5b12:

    # mama "Te quiero, mi hijo."
    mama "我爱你，我的孩子。"

# game/Scenes/Jez/jez17.rpy:158
translate chinese jez17_7e222f3a:

    # mama "I get a hug from you too, okay?"
    mama "我也抱抱你，好吗？"

# game/Scenes/Jez/jez17.rpy:159
translate chinese jez17_2cd33def:

    # pc "Absolutely."
    pc "当然好。"

# game/Scenes/Jez/jez17.rpy:160
translate chinese jez17_d5953dd9:

    # mama "You two have a good night."
    mama "你们俩晚安。"

# game/Scenes/Jez/jez17.rpy:163
translate chinese jez17_5ecc32e2:

    # "After Abuela leaves, we all three hang out in the living room for a while, playing Minecraft a little longer."
    "阿布埃拉走后，我们三个人在客厅待了一会儿，又玩了一会儿《我的世界》。"

# game/Scenes/Jez/jez17.rpy:164
translate chinese jez17_04940183:

    # "Javi talks the whole time."
    "哈维一直叽叽喳喳说个不停。"

# game/Scenes/Jez/jez17.rpy:165
translate chinese jez17_1bdd4bb1:

    # "I'm not sure what he's talking about, but he's having fun, and it's nice to spend time with them together like this."
    "虽然我不确定他在说什么，但他玩得很开心，能像这样和他们在一起真好。"

# game/Scenes/Jez/jez17.rpy:169
translate chinese jez17_d41d8cd9_5:

    # voice 'voices/jez_17_5.mp3'
    voice 'voices/jez_17_5.mp3'

# game/Scenes/Jez/jez17.rpy:170
translate chinese jez17_0bd1f9c3:

    # det "Alright, boys. It's time for bed."
    det "好了，孩子们。该睡觉了。"

