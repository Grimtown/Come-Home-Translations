    # pc "I'm in."
    pc "我进来了。"

# game/Scenes/Whitney/whitney14.rpy:216
translate chinese rjwhitneywarning_6f8a5328:

    # wt "Good job. Now just take it easy. You're not in a rush."
    wt "干得不错。现在别着急，慢慢来。"

