# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:13
translate chinese julianaq5_d7b3a43b:

    # bn "Oh, I wanted to tell you something!"
    bn "哦，我有一件事想告诉你！"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:14
translate chinese julianaq5_d46ae01b:

    # bn "I sent my manuscript off to some agents!"
    bn "我把我的手稿寄给了一些经纪人！"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:15
translate chinese julianaq5_6e79e066:

    # pc "Oh cool! That's great!"
    pc "哦，太棒了！真好！"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:16
translate chinese julianaq5_bab2577e:

    # pc "What does that mean, exactly?"
    pc "这具体是什么意思？"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:18
translate chinese julianaq5_fb2fde6c:

    # bn "Well, it means that I picked out some literary agents that I would like to be represented by."
    bn "嗯，就是我挑了一些我想让他们代理的文学经纪人。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:19
translate chinese julianaq5_931baa71:

    # bn "Then I sent them copies of my manuscript."
    bn "然后我把手稿寄给了他们。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:21
translate chinese julianaq5_7ef626af:

    # bn "If they like it, they might offer to represent me."
    bn "如果他们喜欢，可能会提议代理我。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:23
translate chinese julianaq5_3a46a9c6:

    # bn "So they would contact publishers for me and maybe get my book published."
    bn "这样他们就会替我联系出版社，说不定就能把我的书出版了。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:24
translate chinese julianaq5_d3b4b3bd:

    # pc "That's really exciting! I'm sure you'll find somebody who loves it."
    pc "这太令人兴奋了！我相信你一定能找到喜欢它的人。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:26
translate chinese julianaq5_6f1f05fe:

    # bn "I sure hope so."
    bn "我真希望如此。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:27
translate chinese julianaq5_ae0df945:

    # pc "It will be cool to go into a book store and see your name on the shelf."
    pc "走进书店，看到书架上印着你的名字，那感觉一定很棒。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:29
translate chinese julianaq5_a84646b1:

    # bn "Oh, not my name."
    bn "哦，不是我的名字。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:30
translate chinese julianaq5_9804851d:

    # bn "I'm writing under a pseudonym."
    bn "我是用笔名写的。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:32
translate chinese julianaq5_12e18d7a:

    # bn "I couldn't bear it if my grandmother or her friends at church read the things that I wrote."
    bn "要是我的奶奶或者她教会里的朋友们读到我写的东西，我可受不了。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:34
translate chinese julianaq5_36f06bbe:

    # pc "Your grandmother might be more okay with it than you think."
    pc "你奶奶可能比你想象的要更能接受。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:35
translate chinese julianaq5_ff3bc13c:

    # bn "I don't know..."
    bn "我不知道……"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:36
translate chinese julianaq5_342ddaf3:

    # pc "Well, you'll get to see your book on the shelf, no matter what name you chose to put on it."
    pc "不管你选什么名字，你都能在书架上看到自己的书。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:37
translate chinese julianaq5_a964ed5d:

    # pc "And that's going to be awesome."
    pc "那一定会很棒。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:39
translate chinese julianaq5_53ddd9f6:

    # bn "Thanks, [pcname]."
    bn "谢谢，[pcname]。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:40
translate chinese julianaq5_1a0c3cb4:

    # bn "I really am very excited about it."
    bn "我真的非常期待。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:42
translate chinese julianaq5_c8743fb1:

    # bn "Excited and scared."
    bn "既兴奋又害怕。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:43
translate chinese julianaq5_a8e6a699:

    # pc "It's normal to be scared before a big step. And this is a big step for you."
    pc "在迈出重要一步之前感到害怕是很正常的。而这对你来说确实是重要的一步。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:45
translate chinese julianaq5_c29a0a8b:

    # bn "I don't know that I would have ever had the courage to do it without you."
    bn "如果没有你，我可能永远都不敢这么做。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:46
translate chinese julianaq5_26573cf2:

    # bn "Thanks for being such a good friend..."
    bn "谢谢你，这么好的朋友……"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:48
translate chinese julianaq5_a4e6ff0f:

    # bn "... and more."
    bn "……还有更多。"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:49
translate chinese julianaq5_dfc66a3b:

    # pc "Juliana, I'm very proud to be your friend..."
    pc "朱莉安娜，能成为你的朋友……"

# game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:50
translate chinese julianaq5_4dff1734:

    # pc "... and more."
    pc "……还有更多，我感到非常自豪。"

translate chinese strings:

    # game/Scenes/Juliana/JulianaConversations/julianaq5.rpy:2
    old "To unlock this conversation, you must have finished reading Juliana's manuscript."
    new "要解锁这段对话，你必须已经读完朱莉安娜的手稿。"

