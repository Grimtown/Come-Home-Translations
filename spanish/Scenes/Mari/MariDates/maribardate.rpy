# game/Scenes/Mari/MariDates/maribardate.rpy:38
translate spanish maripitstartdate_998ad3c4:

    # "We drink a little bit more."
    "Tomamos un poco más."

# game/Scenes/Mari/MariDates/maribardate.rpy:42
translate spanish maripitstartdate_53becc9f:

    # fr "Well that's enough drinks for me."
    fr "Bueno, ya he bebido suficiente."

# game/Scenes/Mari/MariDates/maribardate.rpy:43
translate spanish maripitstartdate_5428c2a4:

    # "I only had a beer, so I feel fine to drive."
    "Solo me he tomado una cerveza, así que me siento bien para conducir."

# game/Scenes/Mari/MariDates/maribardate.rpy:44
translate spanish maripitstartdate_5e357f23:

    # "We walk out to the car together and start back towards her house."
    "Salimos juntos hacia el coche y nos dirigimos de vuelta a su casa."

