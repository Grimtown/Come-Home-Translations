# game/Scenes/Izzy/izzy11.rpy:168
translate spanish izzy11_4be9cb45:

    # "After we have cleaned up, we lie down together in her bed to sleep."
    "Después de limpiarnos, nos tumbamos juntos en su cama para dormir."

# game/Scenes/Izzy/izzy11.rpy:169
translate spanish izzy11_12bbe6a9:

    # gl "Thank you for being here for me, [pcname]."
    gl "Gracias por estar aquí para mí, [pcname]."

# game/Scenes/Izzy/izzy11.rpy:170
translate spanish izzy11_eab1a7c7:

    # gl "The house is so quiet. I'm not sure I'd be able to get any sleep here alone."
    gl "La casa está tan tranquila. No estoy seguro de poder dormir aquí solo."

# game/Scenes/Izzy/izzy11.rpy:171
translate spanish izzy11_ed4d1a05:

    # pc "It's no problem. It was nice to spend time with just me and you."
    pc "No hay problema. Ha sido agradable pasar tiempo solo contigo."

# game/Scenes/Izzy/izzy11.rpy:172
translate spanish izzy11_d1f60530:

    # gl "Yeah, it was nice."
    gl "Sí, ha sido agradable."

# game/Scenes/Izzy/izzy11.rpy:173
translate spanish izzy11_02b88afc:

    # gl "I'm going to get things sorted out. I'm going to change."
    gl "Voy a poner las cosas en orden. Voy a cambiarme."

# game/Scenes/Izzy/izzy11.rpy:174
translate spanish izzy11_274abca9:

    # pc "I know, Izzy. I'm here for you, if you need me."
    pc "Lo sé, Izzy. Estoy aquí para ti, si me necesitas."

# game/Scenes/Izzy/izzy11.rpy:177
translate spanish izzy11_43dea266:

    # "She falls asleep very quickly. It's been a rough day for her. I know she's exhausted."
    "Se queda dormida muy rápido. Ha sido un día duro para ella. Sé que está agotada."

# game/Scenes/Izzy/izzy11.rpy:178
translate spanish izzy11_ef175c38:

    # "It takes longer for me to fall asleep. Her neighborhood is loud - I hear music playing somewhere, and what sounds like an argument in the distance."
    "A mí me cuesta más conciliar el sueño. Su barrio es ruidoso: oigo música en alguna parte y lo que parece una discusión a lo lejos."

# game/Scenes/Izzy/izzy11.rpy:179
translate spanish izzy11_9cc81585:

    # "Her bed is not as comfortable as mine either."
    "Además, su cama no es tan cómoda como la mía."

# game/Scenes/Izzy/izzy11.rpy:182
translate spanish izzy11_86f8f1ac:

    # "But after lying there for I don't know how long, eventually I fall asleep as well."
    "Pero después de estar tumbado allí no sé cuánto tiempo, al final también me quedo dormido."

# game/Scenes/Izzy/izzy11.rpy:185
translate spanish izzy11_4dc9ce92:

    # "In the morning, I wake up to the sound of the alarm on my phone."
    "Por la mañana, me despierta el sonido de la alarma de mi teléfono."

# game/Scenes/Izzy/izzy11.rpy:186
translate spanish izzy11_28d8e363:

    # "I look over and see that Izzy is still asleep."
    "Miro a mi lado y veo que Izzy sigue durmiendo."

# game/Scenes/Izzy/izzy11.rpy:189
translate spanish izzy11_7ea0c206:

    # pc "Hey, Izzy."
    pc "Hola, Izzy."

# game/Scenes/Izzy/izzy11.rpy:190
translate spanish izzy11_6c3c347d:

    # gl "Huh?"
    gl "¿Eh?"

# game/Scenes/Izzy/izzy11.rpy:191
translate spanish izzy11_79dd1fe0:

    # pc "I have to go. I have to get to school."
    pc "Tengo que irme. Tengo que ir al colegio."

# game/Scenes/Izzy/izzy11.rpy:192
translate spanish izzy11_ed764c8a:

    # gl "Oh okay, Twig."
    gl "Ah, vale, Twig."

# game/Scenes/Izzy/izzy11.rpy:193
translate spanish izzy11_1227be7b:

    # gl "Thanks for last night. You were great."
    gl "Gracias por lo de anoche. Estuviste genial."

# game/Scenes/Izzy/izzy11.rpy:196
translate spanish izzy11_60a26718:

    # "I lean in and kiss her temple."
    "Me inclino y le doy un beso en la sien."

# game/Scenes/Izzy/izzy11.rpy:197
translate spanish izzy11_38c79251:

    # pc "Call me if you need me, okay?"
    pc "Llámame si me necesitas, ¿vale?"

# game/Scenes/Izzy/izzy11.rpy:198
translate spanish izzy11_923d4965:

    # gl "Okay."
    gl "Vale."

# game/Scenes/Izzy/izzy11.rpy:199
translate spanish izzy11_f4a8219d:

    # pc "I'll talk to you later."
    pc "Hablamos luego."

# game/Scenes/Izzy/izzy11.rpy:201
translate spanish izzy11_d41d8cd9_8:

    # voice 'voices/izzy_seeya.mp3'
    voice 'voices/izzy_seeya.mp3'

# game/Scenes/Izzy/izzy11.rpy:202
translate spanish izzy11_cb6c5e7b:

    # gl "Okay, Twig. See ya."
    gl "Vale, Twig. Nos vemos."

# game/Scenes/Izzy/izzy11.rpy:205
translate spanish izzy11_826e63a8:

    # "I leave Izzy's house, hoping that she'll be okay. Hoping that I helped her in some way last night."
    "Salgo de casa de Izzy, con la esperanza de que esté bien. Con la esperanza de haberla ayudado de alguna manera anoche."

# game/Scenes/Izzy/izzy11.rpy:206
translate spanish izzy11_7d7221ce:

    # "Then I rush home and get ready for school."
    "Luego me apresuro a volver a casa y me preparo para ir al colegio."

translate spanish strings:

    # game/Scenes/Izzy/izzy11.rpy:2
    old "This scene happens automatically a few days after the previous scene."
    new "Esta escena ocurre automáticamente unos días después de la escena anterior."

    # game/Scenes/Izzy/izzy11.rpy:3
    old "Then she will call you in the evening."
    new "Entonces ella te llamará por la tarde."

