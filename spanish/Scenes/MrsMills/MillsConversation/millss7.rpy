# game/Scenes/MrsMills/MillsConversation/millss7.rpy:12
translate spanish millss7_f88c2ee1:

    # bs "Absolutely not."
    bs "Por supuesto que no."

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:13
translate spanish millss7_78f69aae:

    # bs "One person? To have and to hold? Til death do us part?"
    bs "¿Una sola persona? ¿Para amarla y respetarla? ¿Hasta que la muerte nos separe?"

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:15
translate spanish millss7_a4e409f5:

    # bs "No, that's nonsense."
    bs "No, eso es una tontería."

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:16
translate spanish millss7_04a529d0:

    # bs "You wouldn't want to eat the same meal every night, watch the same movie, wear the same clothes."
    bs "No querrías comer lo mismo todas las noches, ver la misma película, llevar la misma ropa."

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:17
translate spanish millss7_4ef95486:

    # bs "Why the hell would you want to sleep with the same person? Forever?"
    bs "¿Por qué demonios querrías acostarte con la misma persona? ¿Para siempre?"

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:18
translate spanish millss7_3b0c8ee2:

    # bs "No. That sounds awful."
    bs "No. Eso suena horrible."

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:20
translate spanish millss7_4cf550cb:

    # bs "I've never met a man who could keep me interested through a dinner conversation, much less the rest of my life."
    bs "Nunca he conocido a un hombre que pudiera mantener mi interés durante una conversación en la cena, y mucho menos durante el resto de mi vida."

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:21
translate spanish millss7_f52de415:

    # bs "That sounds like the most boring life imaginable."
    bs "Eso suena como la vida más aburrida que se pueda imaginar."

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:23
translate spanish millss7_53506f2e:

    # bs "Plus, if I marry somebody, eventually they'll get {i}old{/i}!"
    bs "Además, si me caso con alguien, ¡al final se hará {i}viejo{/i}!"

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:24
translate spanish millss7_af6ec24a:

    # bs "I am {i}not{/i} into old men."
    bs "No me {i}gustan{/i} los hombres mayores."

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:26
translate spanish millss7_86beed9b:

    # bs "No, I prefer finding a young stud, riding him for a while, then switching him out for a new model."
    bs "No, prefiero encontrarme un joven semental, montarlo un rato y luego cambiarlo por un modelo nuevo."

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:27
translate spanish millss7_9ddf8938:

    # pc "You don't get lonely like that?"
    pc "¿No te sientes sola así?"

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:29
translate spanish millss7_abefb195:

    # bs "Sometimes."
    bs "A veces."

# game/Scenes/MrsMills/MillsConversation/millss7.rpy:30
translate spanish millss7_e3f9c5b2:

    # bs "But when I do, there's usually some young man who is willing to keep me company."
    bs "Pero cuando me pasa, suele haber algún joven dispuesto a hacerme compañía."

