    # voice 'voices/jez_myplace.mp3'
    voice 'voices/jez_myplace.mp3'

# game/Scenes/Jez/JezDates/jezenddate.rpy:8
translate chinese jezenddate_687d0176:

    # det "So, do you want to come back to my place for a while?"
    det "“那，你想来我家待会儿吗？”"

# game/Scenes/Jez/JezDates/jezenddate.rpy:9
translate chinese jezenddate_30d6b817:

    # det "Mamá's got Javi for a bit. We could spend some time together."
    det "“妈妈暂时帮我照看哈维。我们可以独处一会儿。”"

# game/Scenes/Jez/JezDates/jezenddate.rpy:12
translate chinese jezenddate_3ba845d3:

    # det "Good, let's go."
    det "“好，走吧。”"

# game/Scenes/Jez/JezDates/jezenddate.rpy:15
translate chinese jezenddate_588b9a6e:

    # "We get in our cars and I follow her back to her house, where we quickly make our way inside to her bedroom."
    "我们各自上车，我跟在她后面回到她家，随即快步走进她的卧室。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:19
translate chinese jezenddate_77b42da9:

    # det "Oh, alright then. Well I had a nice date anyway. I'll see you later, [pcname]."
    det "哦，那好吧。反正约会挺愉快的。回头见，[pcname]。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:21
translate chinese jezenddate_b4d69820:

    # "I lean in and we kiss, my arms wrapped around her."
    "我俯身吻了她，双臂环住她。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:22
translate chinese jezenddate_3091dff1:

    # pc "Bye, Jez. See you again soon."
    pc "再见，杰兹。很快再见。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:25
translate chinese jezenddate_f48c2630:

    # "She leaves, and I go back out to my car and drive away."
    "她离开了，我回到车里，开车离开了。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:29
translate chinese jezenddate_716db417:

    # det "I had a really good time. I'm looking forward to doing this again soon."
    det "我玩得很开心。期待很快能再这样约会。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:30
translate chinese jezenddate_03eaad50:

    # pc "Me too."
    pc "我也是。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:33
translate chinese jezenddate_398aacb4:

    # det "I'd invite you over to my place, but I'm not quite ready for my son to meet you yet."
    det "我本想邀请你去我家，但我还没准备好让儿子见你。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:34
translate chinese jezenddate_70367ea3:

    # det "I don't want him to get confused by male figures being in his life for only a short time."
    det "我不希望他因为生活中出现只停留短暂时间的男性而感到困惑。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:35
translate chinese jezenddate_6cf8b822:

    # det "I want to make sure that this thing between me and you is real before we do that. I hope you understand."
    det "在那之前，我想确保我们之间的感情是真实的。希望你能理解。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:36
translate chinese jezenddate_cca20d9e:

    # pc "I do understand."
    pc "我理解。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:38
translate chinese jezenddate_3239d4cf:

    # det "Thanks."
    det "谢谢。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:41
translate chinese jezenddate_b4d69820_1:

    # "I lean in and we kiss, my arms wrapped around her."
    "我俯身吻了她，双臂环住她。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:43
translate chinese jezenddate_ef81804e:

    # det "Wow, that was nice. Making it really hard for me to say goodbye."
    det "哇，真美妙。这让我很难说再见。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:44
translate chinese jezenddate_c18fe3a7:

    # det "But I have to. Bye, [pcname]."
    det "但我必须走了。再见，[pcname]。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:45
translate chinese jezenddate_3091dff1_1:

    # pc "Bye, Jez. See you again soon."
    pc "再见，杰兹。很快再见。"

# game/Scenes/Jez/JezDates/jezenddate.rpy:48
translate chinese jezenddate_f48c2630_1:

    # "She leaves, and I go back out to my car and drive away."
    "她离开了，我回到车里，开车离去。"

