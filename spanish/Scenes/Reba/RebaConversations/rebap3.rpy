# game/Scenes/Reba/RebaConversations/rebap3.rpy:12
translate spanish rebap3_fc159134:

    # rb "Yeah, sometimes."
    rb "Sí, a veces."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:13
translate spanish rebap3_18c34bd7:

    # rb "Not for sport though. I hate the idea of killing something just to say that you did."
    rb "Aunque no por deporte. Odio la idea de matar a algo solo por decir que lo has hecho."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:14
translate spanish rebap3_e242bcdf:

    # rb "My daddy always taught me that if you kill it, you better eat it."
    rb "Mi padre siempre me enseñó que si lo matas, más vale que te lo comas."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:15
translate spanish rebap3_82708f76:

    # rb "Otherwise, you're just wasting life, which is the worst thing you can do."
    rb "Si no, solo estás desperdiciando una vida, que es lo peor que puedes hacer."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:17
translate spanish rebap3_b5c6b1de:

    # rb "Of course, he ended up wasting his life with alcohol."
    rb "Por supuesto, él acabó desperdiciando su vida con el alcohol."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:19
translate spanish rebap3_d7a1d5ad:

    # rb "But anyway, yeah, I hunt, but only for food, and we never waste anything."
    rb "Pero bueno, sí, cazo, pero solo para comer, y nunca desperdiciamos nada."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:20
translate spanish rebap3_eef2f0e9:

    # rb "I love animals. I don't enjoy killing anything."
    rb "Me encantan los animales. No disfruto matando a nada."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:21
translate spanish rebap3_47894b44:

    # rb "But I think it's better to see the thing that gave its life to nourish you."
    rb "Pero creo que es mejor ver a la criatura que dio su vida para alimentarte."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:22
translate spanish rebap3_7e5208fa:

    # rb "It gives you a certain respect, you know?"
    rb "Te hace sentir cierto respeto, ¿sabes?"

# game/Scenes/Reba/RebaConversations/rebap3.rpy:23
translate spanish rebap3_246abc7d:

    # rb "Most people just buy ground meat in tubes at the grocery store and don't even think about the life that was given."
    rb "La mayoría de la gente solo compra carne picada en tubos en el supermercado y ni siquiera piensa en la vida que se ha sacrificado."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:24
translate spanish rebap3_4bf9e4a6:

    # pc "Yeah, that makes a lot of sense."
    pc "Sí, eso tiene mucho sentido."

# game/Scenes/Reba/RebaConversations/rebap3.rpy:26
translate spanish rebap3_bebfbba6:

    # rb "My daddy was smart about a few things anyway."
    rb "Mi padre era inteligente en algunas cosas, al menos."

