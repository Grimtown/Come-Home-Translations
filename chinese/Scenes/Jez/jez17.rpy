    # pc "I'm something of a scientist myself."
    pc "我算是个科学家。"

# game/Scenes/Jez/jez17.rpy:103
translate chinese jez17_9578b401:

    # pc "You see, the mitochondria is the powerhouse of the cell."
    pc "你看，线粒体是细胞的能量工厂。"

# game/Scenes/Jez/jez17.rpy:104
translate chinese jez17_6f4f4e4b:

    # "I spend the next fifteen minutes helping Javi with his Science homework."
    "接下来的十五分钟里，我帮哈维做科学作业。"

# game/Scenes/Jez/jez17.rpy:105
translate chinese jez17_826b2809:

    # "Then Jez and her mother come in with the food."
    "随后杰兹和她妈妈端着饭菜进来了。"

# game/Scenes/Jez/jez17.rpy:108
translate chinese jez17_ad56d26c:

    # det "Did you finish everything, mijo?"
    det "都做完了吗，孩子？"

# game/Scenes/Jez/jez17.rpy:109
translate chinese jez17_ba29bac8:

    # jav "Si, Mamá. [pcname] helped me."
    jav "做完了，妈妈。[pcname]帮了我。"

# game/Scenes/Jez/jez17.rpy:110
translate chinese jez17_5f4d3585:

    # det "He didn't {i}do{/i} the homework for you though, right?"
    det "但他没{i}替{/i}你做作业吧？"

