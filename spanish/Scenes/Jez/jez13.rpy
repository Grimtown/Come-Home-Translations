translate spanish jez13_502389b1:

    # det "Then when I got in the shower, something in my head snapped."
    det "Luego, cuando me metí en la ducha, algo en mi cabeza se rompió."

# game/Scenes/Jez/jez13.rpy:124
translate spanish jez13_d41d8cd9_11:

    # voice 'voices/jez_13_12.mp3'
    voice 'voices/jez_13_12.mp3'

# game/Scenes/Jez/jez13.rpy:125
