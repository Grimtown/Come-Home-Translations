# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:12
translate chinese tammyp2_7dfa5cfc:

    # tm "No."
    tm "不。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:13
translate chinese tammyp2_f11da2d4:

    # tm "I don't even know who my real dad was."
    tm "我甚至不知道我亲生父亲是谁。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:14
translate chinese tammyp2_b75ca282:

    # tm "Mom wasn't exactly a single-man woman, and she wasn't ever sure which of the guys was my dad."
    tm "我妈算不上专一，她自己也不确定哪个男人是我爸。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:15
translate chinese tammyp2_1ec895a8:

    # tm "She says she thinks she knows who it was, and that he was a piece of shit."
    tm "她说她大概知道是谁，而且那人是个混蛋。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:16
translate chinese tammyp2_e9f6b080:

    # tm "I believe her. She has a history of hooking up with pieces of shit."
    tm "我相信她。她以前就常跟那种混蛋鬼混。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:17
translate chinese tammyp2_28727b7a:

    # tm "So I have no interest in him really."
    tm "所以我对他真的没啥兴趣。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:18
translate chinese tammyp2_d83c8e41:

    # pc "I get that."
    pc "我懂。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:19
translate chinese tammyp2_dc345411:

    # tm "I envy people with good parents. I really do."
    tm "我羡慕那些有好父母的人。真的。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:20
translate chinese tammyp2_7722cce2:

    # tm "I came out of it okay, I guess, but it was not a good childhood."
    tm "我算是挺过来了，但那绝不是个美好的童年。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:21
translate chinese tammyp2_13b080d2:

    # pc "I'm sorry you had to go through that."
    pc "很抱歉你经历了那些。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:22
translate chinese tammyp2_7778cec8:

    # tm "Eh, it's over now. Mostly, I guess."
    tm "唉，都过去了。大概吧。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:23
translate chinese tammyp2_5d99ef46:

    # pc "Mostly?"
    pc "“差不多”？"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:24
translate chinese tammyp2_30dbb2e7:

    # tm "Well I still have to get out of my mom's house at some point."
    tm "毕竟我迟早得搬出我妈家。"

# game/Scenes/Tammy/TammyConversations/tammyp2.rpy:25
translate chinese tammyp2_0c496d09:

    # tm "Man, am I looking forward to that!"
    tm "天啊，我太期待那一天了！"

