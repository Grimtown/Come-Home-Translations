# game/Scenes/Mari/mari1.rpy:15
translate spanish mari1_d41d8cd9:

    # voice 'voices/mari_heysweetie.mp3'
    voice 'voices/mari_heysweetie.mp3'

# game/Scenes/Mari/mari1.rpy:16
translate spanish mari1_64c354b8:

    # fr "Hey there sweetie, good to see you. How are you doing today?"
    fr "Hola, cariño, me alegro de verte. ¿Cómo te va hoy?"

# game/Scenes/Mari/mari1.rpy:19
translate spanish mari1_223b1496:

    # fr "Good, I'm glad. It's nice to see you in here again, let me know if I can get you anything."
    fr "Bien, me alegro. Me gusta verte por aquí otra vez, dime si puedo traerte algo."

# game/Scenes/Mari/mari1.rpy:22
translate spanish mari1_fe03e5ca:

    # fr "You're such a charmer. Keep going, I like it."
    fr "Eres todo un encanto. Sigue así, me gusta."

# game/Scenes/Mari/mari1.rpy:23
translate spanish mari1_4d51f194:

    # pc "I mean, the burgers here are great, but I'm really here just to chat with you."
    pc "Quiero decir, las hamburguesas aquí están buenísimas, pero en realidad solo he venido para charlar contigo."

# game/Scenes/Mari/mari1.rpy:25
translate spanish mari1_67fd9cd9:

    # fr "Really?"
    fr "¿En serio?"

# game/Scenes/Mari/mari1.rpy:26
translate spanish mari1_18128c18:

    # pc "Really."
    pc "En serio."

# game/Scenes/Mari/mari1.rpy:28
translate spanish mari1_8aa0b3f4:

    # fr "You're so sweet. Thanks for the compliments, but I better get back to work. Let me know if I can get you anything."
    fr "Eres tan dulce. Gracias por los cumplidos, pero mejor vuelvo al trabajo. Dime si te puedo traer algo."

# game/Scenes/Mari/mari1.rpy:29
translate spanish mari1_c0bafa60:

    # pc "Can I get a straw for my drink?"
    pc "¿Me puedes dar una pajita para mi bebida?"

# game/Scenes/Mari/mari1.rpy:31
translate spanish mari1_d41d8cd9_1:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari1.rpy:32
translate spanish mari1_f2433589:

    # fr "Sure thing, honey."
    fr "Claro, cariño."

# game/Scenes/Mari/mari1.rpy:33
translate spanish mari1_ab35ef2d:

    # "She reaches into her pocket to pull out one of the straws and a dozen more pop out and fall onto the floor, scattering around."
    "Mete la mano en el bolsillo para sacar una de las pajitas y se le caen una docena más al suelo, esparciéndose por todas partes."

# game/Scenes/Mari/mari1.rpy:36
translate spanish mari1_d41d8cd9_2:

    # voice 'voices/mari_shoot2.mp3'
    voice 'voices/mari_shoot2.mp3'

# game/Scenes/Mari/mari1.rpy:37
translate spanish mari1_aaf7d6fa:

    # fr "Ah shoot, sorry about that."
    fr "Ay, vaya, lo siento."

# game/Scenes/Mari/mari1.rpy:38
translate spanish mari1_76e2166e:

    # fr "Just a second, let me get these."
    fr "Un momento, voy a recogerlas."

# game/Scenes/Mari/mari1.rpy:40
translate spanish mari1_29517e2b:

    # "She kneels down and gets on hands and knees on the floor, picking up the straws that had scattered around."
    "Se arrodilla y se pone a cuatro patas en el suelo, recogiendo las pajitas que se habían esparcido por todas partes."

# game/Scenes/Mari/mari1.rpy:41
translate spanish mari1_fa53362f:

    # fr "I'm so sorry."
    fr "Lo siento mucho."

# game/Scenes/Mari/mari1.rpy:44
translate spanish mari1_6ce37599:

    # fr "I'm so clumsy sometimes."
    fr "A veces soy tan torpe."

# game/Scenes/Mari/mari1.rpy:45
translate spanish mari1_bdb852f0:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Rápidamente termina de recoger el resto de las pajitas y se vuelve a levantar."

# game/Scenes/Mari/mari1.rpy:48
translate spanish mari1_c84cc9f0:

    # fr "What?"
    fr "¿Qué?"

# game/Scenes/Mari/mari1.rpy:50
translate spanish mari1_d41d8cd9_3:

    # voice 'voices/mari_youlikethat.mp3'
    voice 'voices/mari_youlikethat.mp3'

# game/Scenes/Mari/mari1.rpy:51
translate spanish mari1_50b1ddec:

    # fr "Oh. You like that do you?"
    fr "Oh. ¿Te gusta eso, verdad?"

# game/Scenes/Mari/mari1.rpy:53
translate spanish mari1_7fbd7f76:

    # fr "What about this? You like this?"
    fr "¿Y esto? ¿Te gusta esto?"

# game/Scenes/Mari/mari1.rpy:54
translate spanish mari1_9bf0a886:

    # pc "I definitely do."
    pc "Claro que sí."

# game/Scenes/Mari/mari1.rpy:55
translate spanish mari1_bdb852f0_1:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Rápidamente termina de recoger el resto de las pajitas y se vuelve a levantar."

# game/Scenes/Mari/mari1.rpy:57
translate spanish mari1_2771e6a1:

    # fr "I hope that was worth a little bit more of a tip?"
    fr "¿Espero que eso merezca una propina un poco mayor?"

# game/Scenes/Mari/mari1.rpy:58
translate spanish mari1_81450635:

    # pc "Oh I could give you more than the tip."
    pc "Oh, podría darte más que la propina."

# game/Scenes/Mari/mari1.rpy:60
translate spanish mari1_053e79a0:

    # fr "You're so bad!"
    fr "¡Eres tan mala!"

# game/Scenes/Mari/mari1.rpy:63
translate spanish mari1_bab66bf3:

    # fr "I'll be right back with a straw that hasn't been on the floor."
    fr "Ahora mismo vuelvo con una pajita que no haya estado en el suelo."

# game/Scenes/Mari/mari1.rpy:64
translate spanish mari1_c8cd6f6b:

    # "She comes back with my straw and then my food shortly after that."
    "Vuelve con mi pajita y, poco después, con mi comida."

# game/Scenes/Mari/mari1.rpy:65
translate spanish mari1_2e5f61be:

    # "We don't talk much more, but she gives me a beautiful smile every time I look up at her."
    "No hablamos mucho más, pero me dedica una preciosa sonrisa cada vez que la miro."

# game/Scenes/Mari/mari1.rpy:69
translate spanish mari1_e88fc8e1:

    # "When I finish and it's time to leave, she waves at me."
    "Cuando termino y llega la hora de irme, me dice adiós con la mano."

# game/Scenes/Mari/mari1.rpy:71
translate spanish mari1_d41d8cd9_4:

    # voice 'voices/mari_thanksgoodnight.mp3'
    voice 'voices/mari_thanksgoodnight.mp3'

# game/Scenes/Mari/mari1.rpy:72
translate spanish mari1_7949c609:

    # fr "Thanks for coming in! You have a good night!"
    fr "¡Gracias por venir! ¡Que pases buena noche!"

# game/Scenes/Mari/mari1.rpy:75
translate spanish maritip2_1ce16e45:

    # "I walk up to her and put a ten-dollar bill into her hand."
    "Me acerco a ella y le pongo un billete de diez dólares en la mano."

# game/Scenes/Mari/mari1.rpy:78
translate spanish maritip2_d41d8cd9:

    # voice 'voices/mari_thankyousomuch.mp3'
    voice 'voices/mari_thankyousomuch.mp3'

# game/Scenes/Mari/mari1.rpy:79
translate spanish maritip2_1e720979:

    # fr "Thanks so much, you're the best."
    fr "Muchas gracias, eres la mejor."

# game/Scenes/Mari/mari1.rpy:81
translate spanish maritip2_890abf2a:

    # "Without warning, she lunges forward and wraps her arms around me, pulling me into a close hug."
    "Sin previo aviso, se lanza hacia delante y me rodea con los brazos, atrayéndome hacia ella en un fuerte abrazo."

# game/Scenes/Mari/mari1.rpy:82
translate spanish maritip2_9ba61eed:

    # "She's so warm and soft."
    "Es tan cálida y suave."

# game/Scenes/Mari/mari1.rpy:83
translate spanish maritip2_23314f60:

    # "And bonus - she smells like burgers."
    "Y, de regalo, huele a hamburguesas."

# game/Scenes/Mari/mari1.rpy:84
translate spanish maritip2_c96f83e2:

    # pc "Well you're a great waitress."
    pc "Bueno, eres una camarera estupenda."

# game/Scenes/Mari/mari1.rpy:85
translate spanish maritip2_d1889969:

    # fr "It's easy when the customers are as nice as you are."
    fr "Es fácil cuando los clientes son tan simpáticos como tú."

# game/Scenes/Mari/mari1.rpy:86
translate spanish maritip2_9bc4e48c:

    # fr "Come back and see me again soon, okay?"
    fr "Vuelve a verme pronto, ¿vale?"

# game/Scenes/Mari/mari1.rpy:87
translate spanish maritip2_9782867b:

    # pc "Oh I'm sure I will."
    pc "Oh, seguro que lo haré."

# game/Scenes/Mari/mari1.rpy:89
translate spanish maritip2_fb1fac0d:

    # fr "Have a good night, sweetie."
    fr "Que pases buena noche, cariño."

# game/Scenes/Mari/mari1.rpy:90
translate spanish maritip2_eb61ef6e:

    # pc "You too."
    pc "Tú también."

# game/Scenes/Mari/mari1.rpy:92
translate spanish maritip2_3cb27537:

    # "I give her a wave."
    "Le hago un gesto de despedida con la mano."

# game/Scenes/Mari/mari1.rpy:93
translate spanish maritip2_739d2b0c:

    # "With that, I go back outside and head to my car."
    "Con eso, vuelvo a salir y me dirijo a mi coche."

