    # voice 'voices/suzy_8_6.mp3'
    voice 'voices/suzy_8_6.mp3'

# game/Scenes/Suzy/suzy8.rpy:64
translate spanish suzy8_b9711d8f:

    # ss "I've had a bad night, but I know you were just trying to be nice."
    ss "He tenido una mala noche, pero sé que solo intentabas ser amable."

# game/Scenes/Suzy/suzy8.rpy:65
translate spanish suzy8_90fab666:

    # pc "It's okay, [sis]. What's wrong?"
