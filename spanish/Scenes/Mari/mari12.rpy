    voice 'voices/mari12audio42.mp3'

# game/Scenes/Mari/mari12.rpy:239
translate spanish mari12b_92a46e68:

    # fr "Please, make love to me, [pcname]."
    fr "Por favor, hazme el amor, [pcname]."

# game/Scenes/Mari/mari12.rpy:241
translate spanish mari12b_47510abd:

    # "We kiss as I sink into her."
    "Nos besamos mientras me hundo en ella."

# game/Scenes/Mari/mari12.rpy:242
translate spanish mari12b_1becc9d2:

    # "Then we move together, every part of us connected."
    "Luego nos movemos juntos, cada parte de nosotros conectada."

# game/Scenes/Mari/mari12.rpy:243
translate spanish mari12b_f4010c57:

    # "It's the closest I've ever felt to her."
    "Es lo más cerca que me he sentido de ella."

# game/Scenes/Mari/mari12.rpy:247
translate spanish mari12b_e219a86e:

    # "And when we cum together, I feel everything that she feels."
    "Y cuando nos corremos juntos, siento todo lo que ella siente."

# game/Scenes/Mari/mari12.rpy:248
translate spanish mari12b_e721ecdf:

    # "We hold each other close as I empty myself into her."
    "Nos abrazamos con fuerza mientras me vacío dentro de ella."

# game/Scenes/Mari/mari12.rpy:251
translate spanish mari12b_743db198:

    # "Afterwards, we continue holding each other."
    "Después, seguimos abrazados."

# game/Scenes/Mari/mari12.rpy:252
translate spanish mari12b_2a4dc283:

    # "No words are needed. We both know what the other is thinking."
    "No hacen falta palabras. Ambos sabemos lo que piensa el otro."

# game/Scenes/Mari/mari12.rpy:253
translate spanish mari12b_b73d7100:

    # "Our minds and hearts and bodies are all one."
    "Nuestras mentes, corazones y cuerpos son uno solo."

# game/Scenes/Mari/mari12.rpy:256
translate spanish mari12b_3e0dbf15:

    # "And in the comfort of each other, we fall asleep."
    "Y, reconfortados el uno por el otro, nos quedamos dormidos."

# game/Scenes/Mari/mari12.rpy:259
translate spanish mari12b_a10928f0:

    # "The next day, she has to go to work, so we say goodbye early."
    "Al día siguiente, ella tiene que ir a trabajar, así que nos despedimos temprano."

# game/Scenes/Mari/mari12.rpy:260
translate spanish mari12b_ceb21b0a:

    # "But our lips linger on each other."
    "Pero nuestros labios se demoran el uno en el otro."

# game/Scenes/Mari/mari12.rpy:262
translate spanish mari12b_d41d8cd9_40:

    # voice 'voices/mari12audio43.mp3'
    voice 'voices/mari12audio43.mp3'

# game/Scenes/Mari/mari12.rpy:263
translate spanish mari12b_02e21aa9:

    # fr "You know you're welcome here any time. Any night."
    fr "Sabes que eres bienvenida aquí en cualquier momento. Cualquier noche."

# game/Scenes/Mari/mari12.rpy:265
translate spanish mari12b_d41d8cd9_41:

    # voice 'voices/mari12audio44.mp3'
    voice 'voices/mari12audio44.mp3'

# game/Scenes/Mari/mari12.rpy:266
translate spanish mari12b_7ccfda96:

    # fr "I'd spend every day with you, like yesterday, if I could."
    fr "Pasaría cada día contigo, como ayer, si pudiera."

# game/Scenes/Mari/mari12.rpy:267
translate spanish mari12b_5addd2db:

    # pc "It was pretty great. Don't worry. We'll do it again soon."
    pc "Ha sido genial. No te preocupes. Lo repetiremos pronto."

# game/Scenes/Mari/mari12.rpy:269
translate spanish mari12b_d41d8cd9_42:

    # voice 'voices/mari_okay1.mp3'
    voice 'voices/mari_okay1.mp3'

