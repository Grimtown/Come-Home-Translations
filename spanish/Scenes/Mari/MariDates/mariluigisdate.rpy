# game/Scenes/Mari/MariDates/mariluigisdate.rpy:28
translate spanish mariluigisstartdate_1ee44fe2:

    # "Mari and I sit next to each other at one of the booths at Luigi's."
    "Mari y yo nos sentamos uno al lado del otro en una de las mesas de Luigi's."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:29
translate spanish mariluigisstartdate_0d18b373:

    # "We are chatting the whole time about this and that."
    "Estamos charlando todo el rato de esto y aquello."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:30
translate spanish mariluigisstartdate_5bdbd1f6:

    # "The waitress comes by and takes our order, we continue talking."
    "La camarera se acerca y nos toma nota, seguimos hablando."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:34
translate spanish mariluigisstartdate_f9e372f9:

    # "After a short time, the waitress brings our food out to us and we continue talking while we eat."
    "Al poco rato, la camarera nos trae la comida y seguimos hablando mientras comemos."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:37
translate spanish mariluigisstartdate_54f7ac2e:

    # "We take our time eating while we talk, just enjoying one another's company."
    "Nos tomamos nuestro tiempo para comer mientras hablamos, simplemente disfrutando de la compañía del otro."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:40
translate spanish mariluigisstartdate_764eafa0:

    # fr "Good salad, but the service here isn't great huh?"
    fr "La ensalada está buena, pero el servicio aquí no es muy bueno, ¿eh?"

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:41
translate spanish mariluigisstartdate_407731d1:

    # fr "Waiter didn't even face the dang silverware the correct way."
    fr "El camarero ni siquiera colocó los cubiertos en la dirección correcta."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:42
translate spanish mariluigisstartdate_c54b50c7:

    # pc "Well they can't all be as good as you."
    pc "Bueno, no todos pueden ser tan buenos como tú."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:44
translate spanish mariluigisstartdate_a4da275d:

    # fr "Aww..."
    fr "Ay..."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:48
translate spanish mariluigisstartdate_360f4aaa:

    # "When we're done with the meal, I pay the waitress and Mari and I walk out to the car together and start back towards her house."
    "Cuando terminamos de comer, le pago a la camarera y Mari y yo salimos juntos hacia el coche y nos dirigimos de vuelta a su casa."

