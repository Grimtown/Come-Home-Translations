translate spanish jez13_66e2454b:

    # det "I, uh... I see bad stuff at work all the time."
    det "Yo, eh... Veo cosas malas en el trabajo todo el tiempo."

# game/Scenes/Jez/jez13.rpy:95
translate spanish jez13_d41d8cd9_2:

    # voice 'voices/jez_13_3.mp3'
    voice 'voices/jez_13_3.mp3'

