translate chinese jez17_6701d3b9:

    # jav "Science."
    jav "科学。"

# game/Scenes/Jez/jez17.rpy:97
translate chinese jez17_e89e0515:

    # pc "Oh really?"
    pc "哦，是吗？"

# game/Scenes/Jez/jez17.rpy:100
