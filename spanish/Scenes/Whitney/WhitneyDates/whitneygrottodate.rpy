# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:24
translate spanish whitneygrottostartdate_77cf85fd:

    # "Whitney and I go out to The Grotto and look over the menus before ordering."
    "Whitney y yo vamos a The Grotto y echamos un vistazo a los menús antes de pedir."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:27
translate spanish whitneygrottostartdate_358134f0:

    # "After chatting for a while, the waiter brings out the food."
    "Después de charlar un rato, el camarero nos trae la comida."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:29
translate spanish whitneygrottostartdate_484d8b28:

    # "The food is delicious, and conversation with Whitney is always good."
    "La comida está deliciosa, y la conversación con Whitney siempre es buena."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:32
translate spanish whitneygrottostartdate_cf98ece3:

    # "When we're done eating, we keep chatting for a while, until eventually it's time to leave."
    "Cuando terminamos de comer, seguimos charlando un rato, hasta que finalmente llega la hora de irnos."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:35
translate spanish whitneygrottostartdate_d3ad0d0d:

    # "Before we leave, we take in the view one last time, but I can't keep my eyes off of Whitney."
    "Antes de irnos, contemplamos las vistas por última vez, pero no puedo apartar la mirada de Whitney."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:37
translate spanish whitneygrottostartdate_6c23e5af:

    # "I lean in and kiss her. How could I resist?"
    "Me inclino y la beso. ¿Cómo iba a resistirme?"

