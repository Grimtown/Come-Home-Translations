# game/Scenes/Mari/MariConversations/mariq2.rpy:12
translate chinese mariq2_346def11:

    # fr "So, do you have a job?"
    fr "对了，你有工作吗？"

# game/Scenes/Mari/MariConversations/mariq2.rpy:13
translate chinese mariq2_6275f344:

    # pc "I do. I'm working at a law office right now as an assistant."
    pc "有。我现在在一家律师事务所当助理。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:15
translate chinese mariq2_d41d8cd9:

    # voice 'voices/mari_ohcool1.mp3'
    voice 'voices/mari_ohcool1.mp3'

# game/Scenes/Mari/MariConversations/mariq2.rpy:16
translate chinese mariq2_d77b9f15:

    # fr "Oh, cool!"
    fr "哦，真棒！"

# game/Scenes/Mari/MariConversations/mariq2.rpy:17
translate chinese mariq2_8665228e:

    # fr "I thought you were doing the quantum thing though, not law?"
    fr "不过我以为你在搞量子那套，不是法律？"

# game/Scenes/Mari/MariConversations/mariq2.rpy:18
translate chinese mariq2_444088d1:

    # pc "Yeah I'm just working there to make a little money, not going into it as a profession."
    pc "是啊，我只是在那儿赚点外快，没打算以此为职业。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:20
translate chinese mariq2_50746f94:

    # fr "That's good. My dad always said that \"lawyer\" was just another word for \"liar\"."
    fr "这样也好。我爸总是说“律师”就是“骗子”的别称。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:21
translate chinese mariq2_cb627aeb:

    # pc "That's a little harsh, but not entirely incorrect."
    pc "这话说得有点重，但也不完全错。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:23
translate chinese mariq2_31e2b90d:

    # fr "I shouldn't judge them all based on their profession. I'm sure they're not all liars."
    fr "我不该光凭职业就给他们贴标签。我相信他们并不是全都撒谎。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:24
translate chinese mariq2_36aa0e0f:

    # pc "No, they're not all."
    pc "不，确实不是全都这样。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:25
translate chinese mariq2_39fbb139:

    # pc "A lot of them are though. They'll do anything to win a case."
    pc "不过很多人确实是。为了赢官司，他们什么都做得出来。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:26
translate chinese mariq2_d86e2a5f:

    # pc "Whether that means lying to defend a client they know is guilty, or lying to put away a defendant that they know is innocent."
    pc "无论是为了辩护一个明知有罪的当事人而撒谎，还是为了定罪一个明知无辜的被告而撒谎。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:28
translate chinese mariq2_01a923d9:

    # fr "That's horrible. I hope that the office you're working at isn't like that."
    fr "太可怕了。希望你工作的律所不是那样的。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:29
translate chinese mariq2_9997b322:

    # pc "Mrs. Mills? I don't think she is. I haven't seen her in court really, but I've helped her with her speeches."
    pc "米尔斯夫人？我不觉得她是那种人。虽然我没在法庭上见过她，但我帮她写过辩词。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:30
translate chinese mariq2_e9023c87:

    # pc "Nothing in those has been lying."
    pc "那些内容里没有一句是谎言。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:32
translate chinese mariq2_5b8c91bf:

    # fr "That's good."
    fr "那很好。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:33
translate chinese mariq2_0eb4169c:

    # fr "Would you lie to win a case?"
    fr "你会为了赢官司而撒谎吗？"

# game/Scenes/Mari/MariConversations/mariq2.rpy:38
translate chinese mariq2_a4ff0e5e:

    # fr "Good. I hate liars. I'm glad you're not one."
    fr "好。我讨厌骗子。很高兴你不是那种人。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:41
translate chinese mariq2_e512351e:

    # fr "Oh. So you'd be a bad lawyer."
    fr "哦。那你当不了好律师。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:42
translate chinese mariq2_f91d4e7b:

    # fr "Or a good one, I guess, since you'd be winning no matter what."
    fr "或者说是个好律师吧，反正你不管怎样都能赢。"

# game/Scenes/Mari/MariConversations/mariq2.rpy:43
translate chinese mariq2_79360ea1:

    # fr "I don't like liars. I hope you'd never lie to me."
    fr "我不喜欢骗子。希望你永远不会对我撒谎。"

translate chinese strings:

    # game/Scenes/Mari/MariConversations/mariq2.rpy:35
    old "No, never."
    new "不会，绝不会。"

    # game/Scenes/Mari/MariConversations/mariq2.rpy:39
    old "If it was my job."
    new "哪怕那是我的工作。"

