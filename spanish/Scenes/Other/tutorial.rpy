    new "Muéstrame todo el tutorial"

    # game/Scenes/Other/tutorial.rpy:99
    old "Just show me what has changed"
    new "Solo muéstrame lo que ha cambiado"

    # game/Scenes/Other/tutorial.rpy:102
    old "Skip all of this"
    new "Sáltate todo esto"

