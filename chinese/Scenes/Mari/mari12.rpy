    # pc "Of course."
    pc "当然。"

# game/Scenes/Mari/mari12.rpy:34
translate chinese mari12_f8e19e76:

    # pc "I'll get ready and pick you up in just a bit."
    pc "我这就准备好，一会儿去接你。"

# game/Scenes/Mari/mari12.rpy:37
translate chinese mari12_d41d8cd9_5:

    # voice 'voices/mari12audio6.mp3'
