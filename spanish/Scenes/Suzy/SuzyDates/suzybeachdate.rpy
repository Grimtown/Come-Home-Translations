# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:16
translate spanish suzybeachdate_e0e387e2:

    # "Suzy gets ready and we drive out to the beach together."
    "Suzy se prepara y nos vamos juntos en coche a la playa."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:19
translate spanish suzybeachdate_a4746763:

    # "We spend some time swimming around and chatting with each other."
    "Pasamos un rato nadando y charlando."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:22
translate spanish suzybeachdate_da78be7b:

    # "The water is nice and she's just fun to be with."
    "El agua está agradable y es muy divertido estar con ella."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:25
translate spanish suzybeachdate_e8a06208:

    # "When we're both tired from swimming and the sun is starting to set, we sit on the beach together and eat the dinner that we packed."
    "Cuando los dos estamos cansados de nadar y el sol empieza a ponerse, nos sentamos juntos en la playa y cenamos lo que hemos traído."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:28
translate spanish suzybeachdate_e615ede1:

    # "Then we lean back and talk for a while about whatever comes to mind."
    "Luego nos recostamos y hablamos un rato de lo que se nos ocurre."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:38
translate spanish suzybeachdate_90f82d97:

    # "When the sun starts to set, we sit and watch it together, the sky growing darker and the air cooler."
    "Cuando el sol empieza a ponerse, nos sentamos y lo vemos juntos, mientras el cielo se oscurece y el aire se enfría."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:39
translate spanish suzybeachdate_a8ff3746:

    # "Until the last ray of sunlight dips below the horizon."
    "Hasta que el último rayo de sol se sumerge bajo el horizonte."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:42
translate spanish suzybeachdate_dd9441ef:

    # ss "That was beautiful."
    ss "Ha sido precioso."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:43
translate spanish suzybeachdate_805db1af:

    # pc "You're beautiful."
    pc "Tú eres preciosa."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:44
translate spanish suzybeachdate_68db0d5c:

    # ss "You're a dork. Let's go home."
    ss "Eres un idiota. Vamos a casa."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:47
translate spanish suzybeachdate_7804a69a:

    # "We drive back home, both of us tired, Suzy dozing off against the window."
    "Volvemos a casa en coche, los dos cansados, con Suzy dormitando contra la ventanilla."

translate spanish strings:

    # game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:2
    old "After the first time you and Suzy go to the beach together,"
    new "Después de la primera vez que tú y Suzy vayáis juntos a la playa,"

    # game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:3
    old "you can go to her room in the evening to invite her out to the beach any day."
    new "puedes ir a su habitación por la tarde para invitarla a ir a la playa cualquier día."

