# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:83
translate chinese rebajacksonburgerstartdate_b65adab5:

    # gl "Yeah we're really good friends."
    gl "是啊，我们关系特别好。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:84
translate chinese rebajacksonburgerstartdate_6d4704a2:

    # gl "So what do y'all want to eat?"
    gl "那你们想吃点什么？"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:85
translate chinese rebajacksonburgerstartdate_3216701a:

    # "We order our food and Izzy takes off towards the back."
    "我们点了餐，伊兹转身走向后厨。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:88
translate chinese rebajacksonburgerstartdate_fe54d255_1:

    # rb "So, you're dating her too?"
    rb "所以，你也在和她约会？"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:89
translate chinese rebajacksonburgerstartdate_18333171:

    # pc "Yeah, we've been together some. I like Izzy a lot."
    pc "是啊，我们在一起有一阵子了。我很喜欢伊兹。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:90
translate chinese rebajacksonburgerstartdate_326c5253:

    # rb "She seems cool."
    rb "她看起来挺酷的。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:92
translate chinese rebajacksonburgerstartdate_3c5a813d:

    # "We both order burgers and fries, and the waitress walks back towards the kitchen, leaving Reba and me to continue talking."
    "我们都点了汉堡和薯条，女服务员走向后厨，留下丽贝卡和我继续聊天。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:100
translate chinese rebajacksonburgerstartdate_c38e7520:

    # "We sit and chat more while eating our burgers."
    "我们一边吃汉堡一边继续聊着天。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:103
translate chinese rebajacksonburgerstartdate_e1932e3a:

    # "When we're finished, I pay for the food, leave a tip, and we go outside."
    "吃完后，我结了账，留了小费，然后我们走出了餐厅。"

translate chinese strings:

    # game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:2
    old "A few days after you have the encounter with Reba's brother after mudding,"
    new "在你泥地驾驶后遇到瑞芭的哥哥几天后，"

