translate spanish jamie13_f1a6c37e:

    # pc "You should stay."
    pc "Deberías quedarte."

# game/Scenes/Jamie/jamie13.rpy:193
translate spanish jamie13_6d9c381a:

    # gnd "Okay. I think I will."
    gnd "Vale. Creo que lo haré."

# game/Scenes/Jamie/jamie13.rpy:195
translate spanish jamie13_d41d8cd9_8:

    # voice "voices/jamie_028.mp3"
    voice "voices/jamie_028.mp3"

# game/Scenes/Jamie/jamie13.rpy:196
translate spanish jamie13_b095ff70:

    # gnd "Like you said. I'm an adult. I can do what I want."
    gnd "Como tú has dicho. Soy adulto. Puedo hacer lo que quiera."

# game/Scenes/Jamie/jamie13.rpy:199
translate spanish jamie13_94cd612d:

    # "She moves to look at me, her eyes locked onto mine."
    "Se gira para mirarme, con los ojos clavados en los míos."

# game/Scenes/Jamie/jamie13.rpy:201
translate spanish jamie13_d41d8cd9_9:

    # voice "voices/jamie_022.mp3"
    voice "voices/jamie_022.mp3"

# game/Scenes/Jamie/jamie13.rpy:202
translate spanish jamie13_f9831d1e:

    # gnd "I love you, [pcname]."
    gnd "Te quiero, [pcname]."

# game/Scenes/Jamie/jamie13.rpy:203
translate spanish jamie13_5e3e613a:

    # pc "I love you too, Jamie."
    pc "Yo también te quiero, Jamie."

# game/Scenes/Jamie/jamie13.rpy:204
translate spanish jamie13_59e15393:

    # "We lie there like that, sweat cooling on our skin, until I hear her soft snoring."
    "Nos quedamos allí tumbados así, con el sudor enfriándose en nuestra piel, hasta que oigo su suave ronquido."

# game/Scenes/Jamie/jamie13.rpy:207
translate spanish jamie13_ae4b475d:

    # "Then I fall asleep shortly after."
    "Luego me quedo dormido poco después."

# game/Scenes/Jamie/jamie13.rpy:215
translate spanish jamie13_f6d0406e:

    # "In the morning, I wake up to her face, sleeping next to me."
    "Por la mañana, me despierto con su cara, durmiendo a mi lado."

# game/Scenes/Jamie/jamie13.rpy:216
translate spanish jamie13_fc00fd18:

    # "I softly caress her cheek to wake her up."
    "Le acaricio suavemente la mejilla para despertarla."

# game/Scenes/Jamie/jamie13.rpy:219
translate spanish jamie13_a336655c:

    # pc "Hey beautiful."
    pc "Hola, preciosa."

# game/Scenes/Jamie/jamie13.rpy:221
translate spanish jamie13_d41d8cd9_10:

    # voice "voices/jamie_029a.mp3"
    voice "voices/jamie_029a.mp3"

# game/Scenes/Jamie/jamie13.rpy:222
translate spanish jamie13_c59c4cdd:

    # gnd "Oh geez, what time is it?"
    gnd "Ay, Dios, ¿qué hora es?"

# game/Scenes/Jamie/jamie13.rpy:224
translate spanish jamie13_d41d8cd9_11:

    # voice "voices/jamie_029b.mp3"
    voice "voices/jamie_029b.mp3"

# game/Scenes/Jamie/jamie13.rpy:225
translate spanish jamie13_9a2ed43d:

    # gnd "I have to get home before Dad gets upset."
    gnd "Tengo que irme a casa antes de que papá se enfade."

# game/Scenes/Jamie/jamie13.rpy:227
translate spanish jamie13_d41d8cd9_12:

    # voice "voices/jamie_029c.mp3"
    voice "voices/jamie_029c.mp3"

# game/Scenes/Jamie/jamie13.rpy:228
translate spanish jamie13_c042afc8:

    # gnd "I need a shower too. I smell like sex so bad."
    gnd "También necesito una ducha. Huelo fatal a sexo."

# game/Scenes/Jamie/jamie13.rpy:231
translate spanish jamie13_dffd2cad:

    # "She jumps up out of bed, seemingly completely awake now, and starts getting dressed."
    "Se levanta de un salto de la cama, aparentemente ya completamente despierta, y empieza a vestirse."

# game/Scenes/Jamie/jamie13.rpy:232
translate spanish jamie13_8d3da257:

    # gnd "Seriously though, [pcname], last night was amazing."
    gnd "En serio, [pcname], anoche fue increíble."

# game/Scenes/Jamie/jamie13.rpy:233
translate spanish jamie13_ec35244f:

    # gnd "I wish I could sleep with you every night."
    gnd "Ojalá pudiera acostarme contigo todas las noches."

# game/Scenes/Jamie/jamie13.rpy:234
translate spanish jamie13_ef7afd6d:

    # pc "You could if you wanted."
    pc "Podrías si quisieras."

# game/Scenes/Jamie/jamie13.rpy:235
translate spanish jamie13_bbd8e0f5:

    # gnd "Maybe one day."
    gnd "Quizás algún día."

# game/Scenes/Jamie/jamie13.rpy:238
translate spanish jamie13_b00d8df6:

    # "I put on my pajamas and walk her down the stairs."
    "Me pongo el pijama y la acompaño bajando las escaleras."

# game/Scenes/Jamie/jamie13.rpy:239
translate spanish jamie13_9b857853:

    # "The morning light shining on her from the front windows of the house makes her seem like she's glowing."
    "La luz de la mañana que la ilumina desde las ventanas delanteras de la casa hace que parezca que brilla."

# game/Scenes/Jamie/jamie13.rpy:242
translate spanish jamie13_5eb86a54:

    # "We stop at the door, kissing goodbye before we open it."
    "Nos detenemos en la puerta y nos damos un beso de despedida antes de abrirla."

# game/Scenes/Jamie/jamie13.rpy:243
translate spanish jamie13_9cdd394e:

    # gnd "Bye, [pcname]. We'll talk later."
    gnd "Adiós, [pcname]. Hablaremos más tarde."

# game/Scenes/Jamie/jamie13.rpy:244
translate spanish jamie13_92be29ee:

    # gnd "And hopefully do this again very soon."
    gnd "Y con suerte, volveremos a hacer esto muy pronto."

# game/Scenes/Jamie/jamie13.rpy:245
translate spanish jamie13_72475059:

    # pc "I can't wait."
    pc "No puedo esperar."

# game/Scenes/Jamie/jamie13.rpy:249
translate spanish jamie13_7660a175:

    # "Then she turns and opens the door and her father is standing on my front porch."
    "Entonces ella se gira y abre la puerta, y su padre está de pie en mi porche."

# game/Scenes/Jamie/jamie13.rpy:251
translate spanish jamie13_d41d8cd9_13:

    # voice "voices/jamie_030.mp3"
    voice "voices/jamie_030.mp3"

# game/Scenes/Jamie/jamie13.rpy:252
translate spanish jamie13_a60f4c8e:

    # gnd "Oh! Daddy, I just..."
    gnd "¡Oh! Papá, es que..."

# game/Scenes/Jamie/jamie13.rpy:253
translate spanish jamie13_d6386a6a:

    # "Jamie's Dad" "Let's go."
    "Jamie's Dad" "Vamos."

# game/Scenes/Jamie/jamie13.rpy:254
translate spanish jamie13_64554391:

    # gnd "...okay."
    gnd "...vale."

# game/Scenes/Jamie/jamie13.rpy:257
translate spanish jamie13_c5786232:

    # "They walk away. I can't see Jamie's face, but I can tell she's crying."
    "Se alejan. No puedo ver la cara de Jamie, pero me doy cuenta de que está llorando."

# game/Scenes/Jamie/jamie13.rpy:258
translate spanish jamie13_d519e179:

    # "I don't know what to do, so I just let them go."
    "No sé qué hacer, así que los dejo marchar."

# game/Scenes/Jamie/jamie13.rpy:259
translate spanish jamie13_0833f49b:

    # "He needs to get over this shit. I know I hurt her in the past, but it was so long ago. And she's an adult now. I just wish she would stand up to him."
    "Tiene que superar esta mierda. Sé que le hice daño en el pasado, pero fue hace mucho tiempo. Y ahora es adulta. Ojalá se enfrentara a él."

# game/Scenes/Jamie/jamie13.rpy:260
translate spanish jamie13_fe41f349:

    # "Hopefully, she will talk to him and get this all sorted out."
    "Con suerte, hablará con él y lo aclararán todo."

# game/Scenes/Jamie/jamie13.rpy:263
translate spanish jamie13_1dc304ca:

    # "I shut the door and go back inside and get ready for my day."
    "Cierro la puerta, vuelvo dentro y me preparo para el día."

# game/Scenes/Jamie/jamie13.rpy:264
translate spanish jamie13_6888669d:

    # "I try to focus on the amazing night and not the bad morning."
    "Intento centrarme en la noche increíble y no en la mala mañana."

# game/Scenes/Jamie/jamie13.rpy:266
translate spanish jamie13_ab079190:

    # "Later that night..."
    "Más tarde esa noche..."

# game/Scenes/Jamie/jamie13.rpy:278
translate spanish jamie13b_e331f532:

    # "My phone starts buzzing in my pocket. Jamie's calling. I hope she worked out stuff with her dad."
    "Mi teléfono empieza a vibrar en el bolsillo. Es Jamie. Espero que haya arreglado las cosas con su padre."

# game/Scenes/Jamie/jamie13.rpy:282
translate spanish jamie13b_db1adf95:

    # pc "Hey, baby."
    pc "Hola, cariño."

# game/Scenes/Jamie/jamie13.rpy:284
translate spanish jamie13b_d41d8cd9:

    # voice "voices/jamie_084.mp3"
    voice "voices/jamie_084.mp3"

# game/Scenes/Jamie/jamie13.rpy:285
translate spanish jamie13b_db3d91ac:

    # gnd "I need to tell you something, [pcname]."
    gnd "Tengo que decirte algo, [pcname]."

# game/Scenes/Jamie/jamie13.rpy:287
translate spanish jamie13b_d41d8cd9_1:

    # voice "voices/jamie_085.mp3"
    voice "voices/jamie_085.mp3"

# game/Scenes/Jamie/jamie13.rpy:288
translate spanish jamie13b_ec3e201c:

    # gnd "I'm sorry, but our relationship is not going to work out."
    gnd "Lo siento, pero nuestra relación no va a funcionar."

# game/Scenes/Jamie/jamie13.rpy:289
translate spanish jamie13b_a2a6fb65:

    # pc "What do you mean?"
    pc "¿Qué quieres decir?"

# game/Scenes/Jamie/jamie13.rpy:291
translate spanish jamie13b_d41d8cd9_2:

    # voice "voices/jamie_086.mp3"
    voice "voices/jamie_086.mp3"

# game/Scenes/Jamie/jamie13.rpy:292
translate spanish jamie13b_cab545aa:

    # gnd "I have to choose between you and my dad. I'm choosing my dad."
    gnd "Tengo que elegir entre ti y mi padre. Elijo a mi padre."

# game/Scenes/Jamie/jamie13.rpy:294
translate spanish jamie13b_d41d8cd9_3:

    # voice "voices/jamie_087.mp3"
    voice "voices/jamie_087.mp3"

# game/Scenes/Jamie/jamie13.rpy:295
translate spanish jamie13b_9a5ae475:

    # gnd "I'm sorry. It's over."
    gnd "Lo siento. Se acabó."

# game/Scenes/Jamie/jamie13.rpy:298
translate spanish jamie13b_d41d8cd9_4:

    # voice "voices/jamie_088.mp3"
    voice "voices/jamie_088.mp3"

# game/Scenes/Jamie/jamie13.rpy:299
translate spanish jamie13b_77f7fa61:

    # gnd "Good luck with everything. Please don't try to contact me anymore."
    gnd "Buena suerte con todo. Por favor, no intentes volver a contactar conmigo."

# game/Scenes/Jamie/jamie13.rpy:300
translate spanish jamie13b_33949145:

    # pc "What? Wait..."
    pc "¿Qué? Espera..."

# game/Scenes/Jamie/jamie13.rpy:303
translate spanish jamie13b_bcbbe2f1:

    # "She hung up."
    "Ha colgado."

# game/Scenes/Jamie/jamie13.rpy:304
translate spanish jamie13b_439a8efe:

    # "What the fuck? What am I supposed to do now?"
    "¿Qué coño? ¿Qué se supone que debo hacer ahora?"

# game/Scenes/Jamie/jamie13.rpy:305
translate spanish jamie13b_a1814c52:

    # "I guess if she doesn't want to be with me, and doesn't want me to talk to her, I have to respect her wishes."
    "Supongo que si ella no quiere estar conmigo y no quiere que le hable, tengo que respetar sus deseos."

# game/Scenes/Jamie/jamie13.rpy:306
translate spanish jamie13b_f87ec8ec:

    # "But it's bullshit!"
    "¡Pero es una mierda!"

# game/Scenes/Jamie/jamie13.rpy:309
translate spanish jamie13b_18c2def7:

    # "I feel like screaming. Like punching something."
    "Tengo ganas de gritar. De darle un puñetazo a algo."

# game/Scenes/Jamie/jamie13.rpy:310
translate spanish jamie13b_32c163d2:

    # "But instead, I lie in bed and seethe in anger until I fall asleep."
    "Pero en lugar de eso, me tumbo en la cama y hiervo de rabia hasta que me quedo dormido."

