# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:12
translate chinese whitneyq2_29acda57:

    # wt "What are you planning for after college?"
    wt "大学毕业后你有什么打算？"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:14
translate chinese whitneyq2_28276084:

    # pc "I'm not sure. Working in a lab somewhere probably. Maybe where my dad works."
    pc "还不确定。大概会在某个实验室工作吧。也许去我爸爸工作的地方。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:15
translate chinese whitneyq2_e37a9d5d:

    # wt "That's not a bad idea. They're a good company doing good things, though a bit unimaginative."
    wt "这主意不错。那是一家做着正经事的好公司，虽然有点缺乏创意。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:17
translate chinese whitneyq2_3f970292:

    # wt "I've been thinking about starting my own lab."
    wt "我一直在考虑自己开个实验室。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:18
translate chinese whitneyq2_40ff646e:

    # wt "I've made enough money working for others that I'd like to focus on my own pursuits now."
    wt "给别人打工赚够了钱，现在我想专注于自己的追求。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:19
translate chinese whitneyq2_5838daaa:

    # pc "Stuff like alternate universes?"
    pc "比如平行宇宙之类的事？"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:21
translate chinese whitneyq2_fbb4f39e:

    # wt "Among other useful things!"
    wt "还有其他有用的东西！"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:23
translate chinese whitneyq2_2b6961ab:

    # wt "Curing sickness, solving world hunger, restoring the Earth's environment, instant teleportation, interstellar travel, eternal life."
    wt "治愈疾病、解决世界饥饿、恢复地球环境、瞬间传送、星际旅行、永生。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:24
translate chinese whitneyq2_8d5d4423:

    # pc "Wow. So just the little stuff huh?"
    pc "哇。所以只是些小事对吧？"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:28
translate chinese whitneyq2_c320ba54:

    # wt "I think so."
    wt "我觉得是。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:32
translate chinese whitneyq2_f9fc9074:

    # wt "I'm not mad."
    wt "我没疯。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:33
translate chinese whitneyq2_5ae98453:

    # wt "Every scientist is considered mad until they accomplish their goals."
    wt "在达成目标之前，每个科学家都被视为疯子。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:34
translate chinese whitneyq2_fe5d5afd:

    # wt "I believe that all of these things are possible. Some within our lifetime."
    wt "我相信这一切都是可能的。有些甚至在我们有生之年就能实现。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:36
translate chinese whitneyq2_453ab0ca:

    # wt "Anyway, I could use a couple of assistants with these projects, if you're interested in pursuing that."
    wt "总之，这些项目需要几位助手，如果你有兴趣的话。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:40
translate chinese whitneyq2_62d418b5:

    # wt "I'm glad."
    wt "我很高兴。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:41
translate chinese whitneyq2_214e8d99:

    # wt "I've enjoyed working with you so far and I think that we could do good things together."
    wt "到目前为止，我很享受与你共事的时光，我相信我们能一起做些好事。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:43
translate chinese whitneyq2_6c16cd66:

    # pc "I think so too."
    pc "我也这么认为。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:46
translate chinese whitneyq2_119fcf3f:

    # wt "Yes, please do."
    wt "是的，请务必加入。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:47
translate chinese whitneyq2_214e8d99_1:

    # wt "I've enjoyed working with you so far and I think that we could do good things together."
    wt "到目前为止，我很享受和你一起工作的时光，我觉得我们能一起做些了不起的事。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:48
translate chinese whitneyq2_d4519477:

    # pc "Maybe we could."
    pc "也许吧。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:52
translate chinese whitneyq2_f9bd4feb:

    # wt "Oh, that's too bad."
    wt "哦，那太遗憾了。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:53
translate chinese whitneyq2_d452d931:

    # pc "I'm sorry. I'm just not interested."
    pc "对不起。我只是没兴趣。"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:55
translate chinese whitneyq2_3fa39adf:

    # wt "That's okay. Let's move on then."
    wt "没关系。那我们继续吧。"

