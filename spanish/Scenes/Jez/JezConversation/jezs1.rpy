translate spanish jezs1_3e02f843:

    # det "Then I moved here to be with some guy. The guy who ended up being my son's father."
    det "Luego me mudé aquí para estar con un chico. El chico que acabó siendo el padre de mi hijo."

# game/Scenes/Jez/JezConversation/jezs1.rpy:23
