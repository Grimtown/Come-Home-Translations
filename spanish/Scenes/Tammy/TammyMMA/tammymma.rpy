# game/Scenes/Tammy/TammyMMA/tammymma.rpy:17
translate spanish tammymmanormal_55eb3e45:

    # tm "All right! I'm glad you came. Let's get to business."
    tm "¡Muy bien! Me alegro de que hayas venido. Vamos al grano."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:18
translate spanish tammymmanormal_095f6c6f:

    # tm "We're going to start with some stand-up. Get you started on the base punching and kicking technique."
    tm "Vamos a empezar con algo de combate de pie. Te enseñaré las técnicas básicas de puñetazos y patadas."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:19
translate spanish tammymmanormal_bccaba74:

    # pc "You're going to punch me, aren't you?"
    pc "Vas a darme un puñetazo, ¿verdad?"

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:21
translate spanish tammymmanormal_e526c3d8:

    # tm "Oh definitely."
    tm "Oh, sin duda."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:23
translate spanish tammymmanormal_98c55581:

    # "I get up into the ring with Tammy and she demonstrates punching."
    "Subo al ring con Tammy y ella me enseña a dar puñetazos."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:24
translate spanish tammymmanormal_65f9479a:

    # "I try to block, but I just don't have the motions down yet."
    "Intento bloquear, pero aún no domino los movimientos."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:26
translate spanish tammymmanormal_295f5a57:

    # "And kicking."
    "Y patadas."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:27
translate spanish tammymmanormal_70863c7f:

    # "It hurts, but I can tell she's not going full-strength."
    "Duele, pero se nota que no está poniendo toda su fuerza."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:29
translate spanish tammymmanormal_8aa64221:

    # "Then she gives me a chance to try to hit her."
    "Luego me da la oportunidad de intentar golpearla."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:30
translate spanish tammymmanormal_90068145:

    # "But she blocks every punch I throw."
    "Pero bloquea todos los puñetazos que le lanzo."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:32
translate spanish tammymmanormal_dd5027d0:

    # tm "Focus on technique. Don't worry about actually hitting me, just make sure that your movements are correct."
    tm "Céntrate en la técnica. No te preocupes por golpearme de verdad, solo asegúrate de que tus movimientos sean correctos."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:35
translate spanish tammymmanormal_bfe308ae:

    # "Tammy and I spar in the ring for a while."
    "Tammy y yo entrenamos en el ring durante un rato."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:39
translate spanish tammymmanormal_0bc42d9a:

    # tm "You did good for a first session."
    tm "Lo has hecho bien para ser tu primera sesión."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:42
translate spanish tammymmanormal_a242518d:

    # tm "Good job. Keep training with me and you'll be a fighting machine in no time."
    tm "Buen trabajo. Sigue entrenando conmigo y te convertirás en una máquina de combate en un abrir y cerrar de ojos."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:45
translate spanish tammymmanormal_cc85c375:

    # "Now I need to hurry and get to school."
    "Ahora tengo que darme prisa y llegar al colegio."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:48
translate spanish tammymmanormal_7844d429:

    # tm "Want to hit the showers with me?"
    tm "¿Quieres ir a ducharte conmigo?"

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:52
translate spanish tammymmanormal_f7e04aed:

    # "I feel sore and tired, but it was fun and I did learn a lot."
    "Me duele todo y estoy cansada, pero ha sido divertido y he aprendido mucho."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:53
translate spanish tammymmanormal_37ff6d3e:

    # "We say our goodbyes and go our separate ways."
    "Nos despedimos y tomamos caminos separados."

