# game/Scenes/Micha/MichaConversations/michas5.rpy:15
translate spanish michas5_46497d29:

    # mc "Um... what kind of dancing are you asking about?"
    mc "Eh... ¿a qué tipo de baile te refieres?"

# game/Scenes/Micha/MichaConversations/michas5.rpy:16
translate spanish michas5_cd68f95f:

    # pc "Well, you know..."
    pc "Bueno, ya sabes..."

# game/Scenes/Micha/MichaConversations/michas5.rpy:17
translate spanish michas5_b482daa9:

    # pc "When there's music playing and you're moving your body to it."
    pc "Cuando suena la música y mueves el cuerpo al ritmo."

# game/Scenes/Micha/MichaConversations/michas5.rpy:19
translate spanish michas5_ddc58ed0:

    # mc "Yes, I know what dancing is."
    mc "Sí, sé lo que es bailar."

# game/Scenes/Micha/MichaConversations/michas5.rpy:20
translate spanish michas5_8d34a9d2:

    # mc "But there are different types of dancing."
    mc "Pero hay diferentes tipos de baile."

# game/Scenes/Micha/MichaConversations/michas5.rpy:21
translate spanish michas5_733c2689:

    # pc "Do you like to do any of them?"
    pc "¿Te gusta alguno de ellos?"

# game/Scenes/Micha/MichaConversations/michas5.rpy:23
translate spanish michas5_2f068911:

    # mc "I do."
    mc "A mí sí."

# game/Scenes/Micha/MichaConversations/michas5.rpy:24
translate spanish michas5_7b0ec773:

    # mc "Sometimes, when my roommate goes to her parents' house on the weekend, I like to turn on my music and dance by myself in my room."
    mc "A veces, cuando mi compañera de piso se va a casa de sus padres el fin de semana, me gusta poner música y bailar sola en mi habitación."

# game/Scenes/Micha/MichaConversations/michas5.rpy:25
translate spanish michas5_d10f6c20:

    # pc "That's awesome."
    pc "Eso es genial."

# game/Scenes/Micha/MichaConversations/michas5.rpy:27
translate spanish michas5_7602eb9a:

    # mc "No. It is silly and pointless."
    mc "No. Es una tontería y no tiene sentido."

# game/Scenes/Micha/MichaConversations/michas5.rpy:29
translate spanish michas5_5bec66da:

    # mc "But I enjoy it."
    mc "Pero lo disfruto."

# game/Scenes/Micha/MichaConversations/michas5.rpy:30
translate spanish michas5_2747dc0e:

    # pc "Would you ever want to dance with me?"
    pc "¿Te gustaría bailar conmigo alguna vez?"

# game/Scenes/Micha/MichaConversations/michas5.rpy:32
translate spanish michas5_069a21cc:

    # mc "Oh! I don't know. I have never danced in front of anybody else."
    mc "¡Oh! No lo sé. Nunca he bailado delante de nadie."

# game/Scenes/Micha/MichaConversations/michas5.rpy:34
translate spanish michas5_cf130ebb:

    # mc "I don't even know how to dance with another person."
    mc "Ni siquiera sé cómo se baila con otra persona."

# game/Scenes/Micha/MichaConversations/michas5.rpy:35
translate spanish michas5_1837a399:

    # pc "I'm no expert, but I think you just sort of get into a rhythm together and your movements just kind of match each other."
    pc "No soy una experta, pero creo que simplemente hay que encontrar el ritmo juntos y que los movimientos se sincronicen."

# game/Scenes/Micha/MichaConversations/michas5.rpy:37
translate spanish michas5_df286499:

    # mc "That could be interesting..."
    mc "Eso podría ser interesante..."

# game/Scenes/Micha/MichaConversations/michas5.rpy:39
translate spanish michas5_262810e0:

    # mc "But I don't think I could do that in front of other people."
    mc "Pero no creo que pudiera hacerlo delante de otras personas."

# game/Scenes/Micha/MichaConversations/michas5.rpy:40
translate spanish michas5_ece59090:

    # mc "I would be embarrassed."
    mc "Me daría vergüenza."

# game/Scenes/Micha/MichaConversations/michas5.rpy:42
translate spanish michas5_a73c76a9:

    # mc "And I should focus on my studies. I should not waste time doing pointless things like that."
    mc "Y debería centrarme en mis estudios. No debería perder el tiempo haciendo cosas sin sentido como esa."

# game/Scenes/Micha/MichaConversations/michas5.rpy:43
translate spanish michas5_0e102dfc:

    # pc "Doing things that make you happy isn't pointless though."
    pc "Aunque hacer cosas que te hacen feliz no es sin sentido."

# game/Scenes/Micha/MichaConversations/michas5.rpy:44
translate spanish michas5_404a00fd:

    # mc "Happiness is not as important as success."
    mc "La felicidad no es tan importante como el éxito."

# game/Scenes/Micha/MichaConversations/michas5.rpy:45
translate spanish michas5_a2d27467:

    # pc "I don't think I agree with that."
    pc "No creo que esté de acuerdo con eso."

# game/Scenes/Micha/MichaConversations/michas5.rpy:47
translate spanish michas5_a120bc39:

    # mc "Sometimes I do not agree with it either. It is something my parents say."
    mc "A veces yo tampoco estoy de acuerdo. Es algo que dicen mis padres."

# game/Scenes/Micha/MichaConversations/michas5.rpy:48
translate spanish michas5_ea5f4c21:

    # pc "Well, I hope you keep dancing."
    pc "Bueno, espero que sigas bailando."

# game/Scenes/Micha/MichaConversations/michas5.rpy:50
translate spanish michas5_21a465d3:

    # mc "I am sure that I will."
    mc "Estoy segura de que lo haré."

