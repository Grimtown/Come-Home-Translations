translate spanish jezluigisstartdate_ec0fa6ca:

    # "I meet Jez at Luigi's and we sit and order our meals."
    "Quedo con Jez en Luigi's, nos sentamos y pedimos la comida."

# game/Scenes/Jez/JezDates/jezluigisdate.rpy:30
translate spanish jezluigisstartdate_c57a5228:

    # "Then we chat for a while."
    "Luego charlamos un rato."

# game/Scenes/Jez/JezDates/jezluigisdate.rpy:33
translate spanish jezluigisstartdate_0875967f:

    # "The server brings our food out, and we continue talking while we eat."
    "El camarero nos trae la comida y seguimos hablando mientras comemos."

# game/Scenes/Jez/JezDates/jezluigisdate.rpy:35
translate spanish jezluigisstartdate_3c0f7991:

    # "When we're done eating, we just hang around and talk for a while longer."
    "Cuando terminamos de comer, nos quedamos un rato más charlando."

# game/Scenes/Jez/JezDates/jezluigisdate.rpy:38
translate spanish jezluigisstartdate_e9a5d339:

    # "We could probably sit and chat all night, but it's starting to get late."
    "Probablemente podríamos sentarnos a charlar toda la noche, pero se está haciendo tarde."

