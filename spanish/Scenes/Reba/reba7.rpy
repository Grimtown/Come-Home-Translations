    # rb "Not in the water. So many germs and nasty things in here. Bad idea."
    rb "No en el agua. Hay muchos gérmenes y cosas asquerosas aquí. Mala idea."

# game/Scenes/Reba/reba7.rpy:373
translate spanish reba7_dcc718c1:

    # pc "The woods then."
    pc "En el bosque, entonces."

# game/Scenes/Reba/reba7.rpy:376
translate spanish reba7_bd4e14c7:

    # rb "Better not. My brother might actually shoot you."
    rb "Mejor no. Mi hermano podría llegar a dispararte."

# game/Scenes/Reba/reba7.rpy:377
translate spanish reba7_74378985:

    # rb "Soon though. I want you really bad."
    rb "Pero pronto. Te deseo muchísimo."

# game/Scenes/Reba/reba7.rpy:378
translate spanish reba7_09a6ad88:

    # rb "For now, we'll just have to settle for this."
    rb "Por ahora, tendremos que conformarnos con esto."

# game/Scenes/Reba/reba7.rpy:381
translate spanish reba7_a68f90a6:

    # "We make out in the water like that for a long time. Rubbing against each other under the water."
    "Nos besamos en el agua así durante mucho tiempo. Frotándonos el uno contra el otro bajo el agua."

# game/Scenes/Reba/reba7.rpy:382
translate spanish reba7_5d723f7a:

    # "I actually get pretty close to cumming just from that, but never quite all the way there."
    "De hecho, estoy a punto de correrme solo con eso, pero nunca llego del todo."

# game/Scenes/Reba/reba7.rpy:383
translate spanish reba7_751a0240:

    # "Still. It's very nice."
    "Aun así. Es muy agradable."

# game/Scenes/Reba/reba7.rpy:385
translate spanish reba7_33ce95fb:

    # rb "You know. He thinks that we'd be fucking like rabbits out here, and he don't want that."
    rb "Ya sabes. Él cree que aquí fuera nos lo haríamos como conejos, y no quiere eso."

# game/Scenes/Reba/reba7.rpy:386
translate spanish reba7_bf7b9047:

    # rb "But we're just friends. He's just being protective."
    rb "Pero solo somos amigos. Solo está siendo protector."

# game/Scenes/Reba/reba7.rpy:389
translate spanish reba7_f7c133f3:

    # "After a couple of hours in the water, we go fishing again for our dinner."
    "Después de un par de horas en el agua, volvemos a pescar para cenar."

# game/Scenes/Reba/reba7.rpy:390
translate spanish reba7_480eb598:

    # "This time, we both catch one."
    "Esta vez, los dos pescamos uno."

# game/Scenes/Reba/reba7.rpy:393
translate spanish reba7_58728e1b:

    # "After getting the fire going, we sit on the pier and watch the sun set over the water in the distance."
    "Después de encender el fuego, nos sentamos en el muelle y vemos la puesta de sol sobre el agua en la distancia."

# game/Scenes/Reba/reba7.rpy:394
translate spanish reba7_c8c46b33:

    # "She was right. It's beautiful."
    "Tenía razón. Es precioso."

# game/Scenes/Reba/reba7.rpy:398
translate spanish reba7_acf03818:

    # "When it is at its most gorgeous, looking like fire on the water, I lean over and kiss her."
    "Cuando está en su momento más bello, pareciendo fuego sobre el agua, me inclino y la beso."

# game/Scenes/Reba/reba7.rpy:399
translate spanish reba7_9d16e3b9:

    # "She practically melts into my arms."
    "Ella prácticamente se derrite en mis brazos."

# game/Scenes/Reba/reba7.rpy:402
translate spanish reba7_37c17d16:

    # "Then, I notice that she is crying."
    "Entonces, me doy cuenta de que está llorando."

# game/Scenes/Reba/reba7.rpy:403
translate spanish reba7_9305d4e7:

    # rb "Thank you."
    rb "Gracias."

# game/Scenes/Reba/reba7.rpy:404
translate spanish reba7_ee3d1dfb:

    # pc "For what?"
    pc "¿Por qué?"

# game/Scenes/Reba/reba7.rpy:405
translate spanish reba7_b8e1df88:

    # rb "For creating the best moment in my life so far."
    rb "Por crear el mejor momento de mi vida hasta ahora."

# game/Scenes/Reba/reba7.rpy:406
translate spanish reba7_f3fd561f:

    # rb "This was wonderful."
    rb "Ha sido maravilloso."

# game/Scenes/Reba/reba7.rpy:407
translate spanish reba7_b92e81d8:

    # pc "I hope there will be many more best moments to come."
    pc "Espero que haya muchos más momentos así por venir."

# game/Scenes/Reba/reba7.rpy:408
translate spanish reba7_0b06bd6f:

    # rb "Me too."
    rb "Yo también."

# game/Scenes/Reba/reba7.rpy:409
translate spanish reba7_2434ac11:

    # "Then the moment is broken by the sound of what I am beginning to think might be the most obnoxious voice I've ever heard."
    "Entonces, el momento se ve interrumpido por el sonido de lo que empiezo a pensar que podría ser la voz más odiosa que he oído nunca."

# game/Scenes/Reba/reba7.rpy:410
translate spanish reba7_86e86025:

    # mk "Better watch your hands there, city-boy!"
    mk "¡Cuidado con las manos, chico de ciudad!"

# game/Scenes/Reba/reba7.rpy:413
translate spanish reba7_6e186834:

    # "Reba and I walk back up to the camp."
    "Reba y yo volvemos al campamento."

# game/Scenes/Reba/reba7.rpy:414
translate spanish reba7_b8405508:

    # rb "Did you catch any dinner?"
    rb "¿Habéis pescado algo para cenar?"

# game/Scenes/Reba/reba7.rpy:415
translate spanish reba7_36bfb963:

    # mk "Didn't get a single bite."
    mk "No hemos picado ni una sola vez."

# game/Scenes/Reba/reba7.rpy:416
translate spanish reba7_60ebb942:

    # rb "Were you even fishing?"
    rb "¿Acaso estabais pescando?"

# game/Scenes/Reba/reba7.rpy:417
translate spanish reba7_80fe67ac:

    # mk "Sure, we were."
    mk "Claro que sí."

# game/Scenes/Reba/reba7.rpy:418
translate spanish reba7_ad137b03:

    # lee "Ain't nothing else to do out here."
    lee "No hay nada más que hacer por aquí."

# game/Scenes/Reba/reba7.rpy:421
translate spanish reba7_38e46686:

    # "As soon as we approach them, I can smell the sort of sweet, but sulfuric scent of meth surrounding them."
    "En cuanto nos acercamos a ellos, puedo oler el aroma dulce, pero sulfuroso, de la metanfetamina que los envuelve."

# game/Scenes/Reba/reba7.rpy:422
translate spanish reba7_4623c3f3:

    # "It makes me nauseous immediately."
    "Me da náuseas al instante."

# game/Scenes/Reba/reba7.rpy:423
translate spanish reba7_7b3d1e5e:

    # rb "Well we caught enough for everybody I think. I guess we could share some."
    rb "Bueno, creo que hemos pescado suficiente para todos. Supongo que podríamos compartir un poco."

# game/Scenes/Reba/reba7.rpy:424
translate spanish reba7_08e2eb97:

    # mk "Thanks, baby sister. It smells really good."
    mk "Gracias, hermanita. Huele muy bien."

# game/Scenes/Reba/reba7.rpy:425
translate spanish reba7_d90a80a3:

    # rb "Yeah, yeah."
    rb "Sí, sí."

# game/Scenes/Reba/reba7.rpy:428
translate spanish reba7_35f4b1bf:

    # mk "So what have you two been doing? Nothing sinful, I hope?"
    mk "¿Y qué habéis estado haciendo vosotros dos? Nada pecaminoso, espero."

# game/Scenes/Reba/reba7.rpy:429
translate spanish reba7_ccd5cd52:

    # rb "We didn't do nothing you need to worry about."
    rb "No hemos hecho nada de lo que tengas que preocuparte."

# game/Scenes/Reba/reba7.rpy:430
translate spanish reba7_401f8051:

    # rb "Fishin' and swimmin', that's all."
    rb "Pescar y nadar, eso es todo."

# game/Scenes/Reba/reba7.rpy:431
translate spanish reba7_b0d99df0:

    # lee "Sounds pretty boring to me."
    lee "A mí me parece bastante aburrido."

# game/Scenes/Reba/reba7.rpy:432
translate spanish reba7_6a03439c:

    # rb "Yeah, well some people actually have things to talk about besides who won the last NASCAR race."
    rb "Sí, bueno, hay gente que tiene cosas de las que hablar aparte de quién ganó la última carrera de NASCAR."

# game/Scenes/Reba/reba7.rpy:433
translate spanish reba7_984938d7:

    # mk "Now don't you be talking bad about Kurt Busch, Reba."
    mk "No hables mal de Kurt Busch, Reba."

# game/Scenes/Reba/reba7.rpy:436
translate spanish reba7_462b2dd0:

    # mk "You two must've done a lot of talking while we were away."
    mk "Vosotros dos debéis de haber hablado mucho mientras estábamos fuera."

# game/Scenes/Reba/reba7.rpy:437
translate spanish reba7_aee6ddfc:

    # mk "You ain't been talking about anything you isn't supposed to be, were you, Reba?"
    mk "No habrás estado hablando de nada que no debieras, ¿verdad, Reba?"

# game/Scenes/Reba/reba7.rpy:440
translate spanish reba7_ed32a189:

    # rb "I wasn't."
    rb "No lo he hecho."

# game/Scenes/Reba/reba7.rpy:441
translate spanish reba7_ddd1f738:

    # mk "You sure?"
    mk "¿Seguro?"

# game/Scenes/Reba/reba7.rpy:442
translate spanish reba7_0abcd332:

    # rb "I'm sure, Mickey. Just been talking about our lives and such. Nothing you need to worry about."
    rb "Estoy segura, Mickey. Solo hemos estado hablando de nuestras vidas y cosas así. Nada de lo que tengas que preocuparte."

# game/Scenes/Reba/reba7.rpy:443
translate spanish reba7_35b7436d:

    # pc "What's all this about?"
    pc "¿A qué viene todo esto?"

# game/Scenes/Reba/reba7.rpy:446
translate spanish reba7_b16df20c:

    # mk "Nothing, city-boy. Just keep your nose out of things and don't get my sister pregnant and we'll be just fine."
    mk "Nada, chico de ciudad. No te metas en lo que no te incumbe y no dejes embarazada a mi hermana, y todo irá bien."

# game/Scenes/Reba/reba7.rpy:447
translate spanish reba7_f8c1462a:

    # rb "Oh shut up, Mickey!"
    rb "¡Cállate, Mickey!"

# game/Scenes/Reba/reba7.rpy:450
translate spanish reba7_7a27a459:

    # "After we eat, we set up the tents, then Mickey and Lee take off into the woods again, likely to smoke more."
    "Después de comer, montamos las tiendas, y luego Mickey y Lee se van otra vez al bosque, seguramente a fumar más."

# game/Scenes/Reba/reba7.rpy:451
translate spanish reba7_5e23e6d3:

    # "Reba and I sit in front of the fire, watching the embers die down."
    "Reba y yo nos sentamos frente al fuego, viendo cómo se apagan las brasas."

# game/Scenes/Reba/reba7.rpy:452
translate spanish reba7_52d048bf:

    # pc "What was all that stuff Mickey was saying about you not talking about certain things."
    pc "¿Qué era todo eso que decía Mickey de que no hablas de ciertas cosas?"

# game/Scenes/Reba/reba7.rpy:453
translate spanish reba7_28a00dff:

    # rb "Well that's the thing isn't it. I can't talk about it, else he'll get really mad."
    rb "Bueno, esa es la cuestión, ¿no? No puedo hablar de ello, si no se enfadará mucho."

# game/Scenes/Reba/reba7.rpy:454
translate spanish reba7_9c317c4a:

    # pc "Who cares?"
    pc "¿A quién le importa?"

# game/Scenes/Reba/reba7.rpy:455
translate spanish reba7_c58f81b1:

    # rb "I care. I don't want to deal with it, [pcname]."
    rb "A mí me importa. No quiero lidiar con eso, [pcname]."

# game/Scenes/Reba/reba7.rpy:456
translate spanish reba7_6c40a428:

    # rb "Maybe one day I will, but it just isn't worth it right now. Better to just let it go and move on."
    rb "Quizá algún día lo haga, pero ahora mismo no merece la pena. Mejor dejarlo pasar y seguir adelante."

# game/Scenes/Reba/reba7.rpy:457
translate spanish reba7_dcbbd7b6:

    # pc "Okay, but you know I'm here for you if you need me, right?"
    pc "Vale, pero sabes que estoy aquí para ti si me necesitas, ¿verdad?"

# game/Scenes/Reba/reba7.rpy:458
translate spanish reba7_a05c49fb:

    # rb "Thanks, [pcname]. I've had such a good time with you. I hope we can do it again sometime, without the chaperone."
    rb "Gracias, [pcname]. Lo he pasado muy bien contigo. Espero que podamos volver a hacerlo alguna vez, sin chaperón."

# game/Scenes/Reba/reba7.rpy:459
translate spanish reba7_097223de:

    # pc "That would be nice."
    pc "Eso estaría bien."

# game/Scenes/Reba/reba7.rpy:463
translate spanish reba7_a72f9bf7:

    # "I lean in and kiss her, holding her close while we make out."
    "Me inclino y la beso, abrazándola fuerte mientras nos besamos."

# game/Scenes/Reba/reba7.rpy:464
translate spanish reba7_c38f2a38:

    # "We spend the rest of the night like that, just talking, and drinking, and listening to the sounds of the woods around us."
    "Pasamos el resto de la noche así, simplemente hablando, bebiendo y escuchando los sonidos del bosque a nuestro alrededor."

# game/Scenes/Reba/reba7.rpy:465
translate spanish reba7_23efc2bd:

    # "It's really peaceful and nice."
    "Es muy tranquilo y agradable."

# game/Scenes/Reba/reba7.rpy:468
translate spanish reba7_aee802c6:

    # "Eventually, Mickey and Lee come back, and we decide that it's a good time to go to sleep."
    "Al final, Mickey y Lee vuelven, y decidimos que es un buen momento para irnos a dormir."

# game/Scenes/Reba/reba7.rpy:469
translate spanish reba7_b76c1e79:

    # "I have no idea what time it actually is. My phone has been in the truck all day and I'd completely forgotten about it."
    "No tengo ni idea de qué hora es realmente. Mi teléfono ha estado en la camioneta todo el día y me había olvidado por completo de él."

# game/Scenes/Reba/reba7.rpy:471
translate spanish reba7_c5f9b780:

    # pc "You sure you don't want to just come sleep in my tent?"
    pc "¿Seguro que no quieres venir a dormir a mi tienda?"

# game/Scenes/Reba/reba7.rpy:472
translate spanish reba7_a3c9637a:

    # rb "I do want to. I really do."
    rb "Sí que quiero. De verdad que sí."

# game/Scenes/Reba/reba7.rpy:473
translate spanish reba7_6308f2d5:

    # rb "But I don't want to piss off my brother tonight."
    rb "Pero no quiero cabrear a mi hermano esta noche."

# game/Scenes/Reba/reba7.rpy:474
translate spanish reba7_65ff68b4:

    # rb "He gets pretty mean when he's high."
    rb "Se pone bastante desagradable cuando está colocado."

# game/Scenes/Reba/reba7.rpy:475
translate spanish reba7_dbbd47f9:

    # pc "Okay then. Good night."
    pc "Vale, entonces. Buenas noches."

# game/Scenes/Reba/reba7.rpy:478
translate spanish reba7_246290cc:

    # rb "Good night, [pcname]."
    rb "Buenas noches, [pcname]."

# game/Scenes/Reba/reba7.rpy:481
translate spanish reba7_dca909c3:

    # "Damn, I wish we were sleeping in the same tent."
    "Joder, ojalá estuviéramos durmiendo en la misma tienda."

# game/Scenes/Reba/reba7.rpy:482
translate spanish reba7_2085cc25:

    # "I really like her. Too bad her brother is such a POS."
    "Me gusta mucho. Lástima que su hermano sea tan capullo."

# game/Scenes/Reba/reba7.rpy:485
translate spanish reba7_01f07121:

    # "I crawl inside my tent and fall asleep much quicker than I expected. I thought that the hard ground and the night's noises would keep me awake, but I'm so exhausted after the long day."
    "Me meto en mi tienda y me quedo dormido mucho más rápido de lo que esperaba. Pensaba que el suelo duro y los ruidos de la noche me mantendrían despierto, pero estoy tan agotado después de este largo día."

# game/Scenes/Reba/reba7.rpy:486
translate spanish reba7_d419a81c:

    # "I wake up a couple of times throughout the night, hearing movement outside the tent, but I don't leave to check it out."
    "Me despierto un par de veces durante la noche, al oír movimientos fuera de la tienda, pero no salgo a ver qué pasa."

# game/Scenes/Reba/reba7.rpy:489
translate spanish reba7_2d373d49:

    # "Then, quite suddenly, it's morning."
    "Entonces, de repente, es de mañana."

# game/Scenes/Reba/reba7.rpy:492
translate spanish reba7_3ebecdd9:

    # rb "Time to get up, [pcname]. We have to pack up and leave."
    rb "Hora de levantarse, [pcname]. Tenemos que recoger y marcharnos."

# game/Scenes/Reba/reba7.rpy:495
translate spanish reba7_33b1e5ea:

    # "I crawl out of my tent and stretch."
    "Salgo de mi tienda y me estiro."

# game/Scenes/Reba/reba7.rpy:496
translate spanish reba7_4d6bd7ed:

    # pc "We in a hurry?"
    pc "¿Tenemos prisa?"

# game/Scenes/Reba/reba7.rpy:497
translate spanish reba7_b7c9e3f9:

    # rb "Yeah, my brother's friends are coming today. We don't want to be here when they get here."
    rb "Sí, los amigos de mi hermano vienen hoy. No queremos estar aquí cuando lleguen."

# game/Scenes/Reba/reba7.rpy:498
translate spanish reba7_238bde54:

    # pc "Got it."
    pc "Entendido."

# game/Scenes/Reba/reba7.rpy:501
translate spanish reba7_a7052671:

    # rb "Also, you might want to hide that. Wouldn't want my brother to get the wrong idea, you know?"
    rb "Además, quizá quieras esconder eso. No querrás que mi hermano se haga una idea equivocada, ¿sabes?"

# game/Scenes/Reba/reba7.rpy:502
translate spanish reba7_877ec67b:

    # pc "Right. Sorry."
    pc "Claro. Lo siento."

# game/Scenes/Reba/reba7.rpy:503
translate spanish reba7_3580a76c:

    # rb "Don't be. It's very impressive. Go get dressed and pack up."
    rb "No te preocupes. Es muy impresionante. Ve a vestirte y a recoger."

# game/Scenes/Reba/reba7.rpy:507
translate spanish reba7_d56dc11d:

    # "Ten minutes later and we are back on the road towards Skyhill."
    "Diez minutos más tarde estamos de nuevo en la carretera hacia Skyhill."

# game/Scenes/Reba/reba7.rpy:508
translate spanish reba7_359e6396:

    # rb "Sorry to kind of rush off like this. I had a great time yesterday."
    rb "Siento tener que irme tan deprisa. Me lo pasé genial ayer."

# game/Scenes/Reba/reba7.rpy:509
translate spanish reba7_29138066:

    # pc "Me too. Even though your brother was there, it was still a fun time."
    pc "Yo también. Aunque estuviera tu hermano, lo pasamos muy bien."

# game/Scenes/Reba/reba7.rpy:510
translate spanish reba7_585deea4:

    # rb "I'm glad you enjoyed it. We'll go sometime without him, I promise. And maybe we could spend some more time together in other places too."
    rb "Me alegro de que lo disfrutaras. Algún día saldremos sin él, te lo prometo. Y quizá podamos pasar más tiempo juntos en otros sitios también."

# game/Scenes/Reba/reba7.rpy:511
translate spanish reba7_afe67284:

    # pc "I'd like that."
    pc "Me encantaría."

# game/Scenes/Reba/reba7.rpy:515
translate spanish reba7_8e271706:

    # "After what felt like a much shorter drive this time, she pulls back into my driveway at home."
    "Después de un trayecto que esta vez me ha parecido mucho más corto, entra en el camino de acceso a mi casa."

# game/Scenes/Reba/reba7.rpy:516
translate spanish reba7_1629bcc9:

    # rb "Thanks for coming with me."
    rb "Gracias por acompañarme."

# game/Scenes/Reba/reba7.rpy:517
translate spanish reba7_c036bada:

    # pc "Thank you for inviting me."
    pc "Gracias por invitarme."

# game/Scenes/Reba/reba7.rpy:518
translate spanish reba7_bf8e692b:

    # rb "I wish I had more time to spend with you, but I gotta get home to Mama. She already blew up my phone with like a hundred messages."
    rb "Ojalá tuviera más tiempo para pasar contigo, pero tengo que volver a casa con mamá. Ya me ha llenado el móvil con como cien mensajes."

# game/Scenes/Reba/reba7.rpy:519
translate spanish reba7_c7fd7916:

    # pc "I understand. I'll talk to you later then."
    pc "Lo entiendo. Entonces hablamos más tarde."

# game/Scenes/Reba/reba7.rpy:520
translate spanish reba7_ff5d4456:

    # rb "I hope so."
    rb "Espero que sí."

# game/Scenes/Reba/reba7.rpy:524
translate spanish reba7_69cdfbbf:

    # "I lean over and kiss her passionately."
    "Me inclino y la beso apasionadamente."

# game/Scenes/Reba/reba7.rpy:525
translate spanish reba7_63a78e6a:

    # "She returns the kiss, her lips gripping mine like she doesn't ever want to let me go."
    "Ella me devuelve el beso, con sus labios apretando los míos como si no quisiera soltarme nunca."

# game/Scenes/Reba/reba7.rpy:526
translate spanish reba7_c2cb9fa1:

    # rb "I want you so bad, [pcname]."
    rb "Te deseo tanto, [pcname]."

# game/Scenes/Reba/reba7.rpy:527
translate spanish reba7_87a95130:

    # rb "I want you to ravage me, like in one of those romance novels."
    rb "Quiero que me devores, como en una de esas novelas románticas."

# game/Scenes/Reba/reba7.rpy:528
translate spanish reba7_d49690de:

    # pc "I want that too."
    pc "Yo también quiero eso."

# game/Scenes/Reba/reba7.rpy:529
translate spanish reba7_362e5729:

    # rb "Soon. I have to go for now."
    rb "Pronto. Ahora tengo que irme."

# game/Scenes/Reba/reba7.rpy:530
translate spanish reba7_ca9c8d38:

    # rb "You have my phone number. Call me some time, okay? We can just talk. I'm available pretty much every evening and night."
    rb "Tienes mi número de teléfono. Llámame alguna vez, ¿vale? Podemos simplemente hablar. Estoy disponible casi todas las tardes y noches."

# game/Scenes/Reba/reba7.rpy:531
translate spanish reba7_2a935884:

    # pc "Okay. Bye, Reba."
    pc "Vale. Adiós, Reba."

# game/Scenes/Reba/reba7.rpy:532
translate spanish reba7_55779d91:

    # rb "Bye-bye, baby."
    rb "Adiós, cariño."

# game/Scenes/Reba/reba7.rpy:538
translate spanish reba7_73f1e4f2:

    # "I get out of the truck and she pulls away."
    "Me bajo de la camioneta y ella se aleja."

translate spanish strings:

    # game/Scenes/Reba/reba7.rpy:3
    old "A few days after you have dinner with Reba and her family,"
    new "Unos días después de cenar con Reba y su familia,"

    # game/Scenes/Reba/reba7.rpy:4
    old "she will call you on a Friday evening and invite you camping for the weekend."
    new "ella te llamará un viernes por la tarde y te invitará a acampar el fin de semana."

    # game/Scenes/Reba/reba7.rpy:25
