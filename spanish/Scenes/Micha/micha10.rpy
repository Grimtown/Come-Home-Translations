# game/Scenes/Micha/micha10.rpy:15
translate spanish micha10_53d7eff6:

    # "She gets in my car and we drive back towards the school and park near the dorms."
    "Se sube a mi coche y volvemos hacia la escuela y aparcamos cerca de las residencias."

# game/Scenes/Micha/micha10.rpy:18
translate spanish micha10_0ba0ce57:

    # mc "Would you walk to my dorm with me?"
    mc "¿Me acompañas a mi residencia?"

# game/Scenes/Micha/micha10.rpy:19
translate spanish micha10_61f77a4c:

    # pc "Sure."
    pc "Claro."

# game/Scenes/Micha/micha10.rpy:26
translate spanish micha10_fc5b71e7:

    # "We walk through the school courtyard, towards her dorm building."
    "Caminamos por el patio de la escuela, hacia su edificio de residencias."

# game/Scenes/Micha/micha10.rpy:27
translate spanish micha10_9c8bddba:

    # "The night air is cool, and the school is surprisingly peaceful and quiet."
    "El aire nocturno es fresco, y la escuela está sorprendentemente tranquila y en silencio."

# game/Scenes/Micha/micha10.rpy:34
translate spanish micha10_8f3659cb:

    # "She glances over at me and then slides her hand into mine."
    "Me echa un vistazo y luego desliza su mano en la mía."

# game/Scenes/Micha/micha10.rpy:35
translate spanish micha10_b17081d9:

    # "Her hand is cold and small and soft. I hold it gently as we continue walking."
    "Su mano es fría, pequeña y suave. La sostengo con delicadeza mientras seguimos caminando."

# game/Scenes/Micha/micha10.rpy:42
translate spanish micha10_9207436c:

    # mc "Would you maybe want to sit and chat for a while before I go inside?"
    mc "¿Te apetece sentarnos a charlar un rato antes de que entre?"

# game/Scenes/Micha/micha10.rpy:43
translate spanish micha10_8fefe090:

    # mc "I had such a good time with you today. I am not quite ready for it to end."
    mc "Me lo he pasado muy bien contigo hoy. No estoy preparada para que esto termine."

# game/Scenes/Micha/micha10.rpy:44
translate spanish micha10_4476e592:

    # pc "Sure, we can do that."
    pc "Claro, podemos hacerlo."

# game/Scenes/Micha/micha10.rpy:51
translate spanish micha10_d96ba613:

    # "We sit on the bench together, her hand still enveloped in mine."
    "Nos sentamos juntos en el banco, con su mano aún envuelta en la mía."

# game/Scenes/Micha/micha10.rpy:52
translate spanish micha10_5e2207f4:

    # "I wonder what she would want to talk about? She barely talks about anything at all."
    "Me pregunto de qué querrá hablar. Apenas habla de nada."

# game/Scenes/Micha/micha10.rpy:59
translate spanish micha10_5ec89b3b:

    # mc "I like it here."
    mc "Me gusta estar aquí."

# game/Scenes/Micha/micha10.rpy:60
translate spanish micha10_00ff76ff:

    # pc "Yeah, the fresh air feels really nice. And the trees are pretty."
    pc "Sí, el aire fresco sienta muy bien. Y los árboles son bonitos."

# game/Scenes/Micha/micha10.rpy:61
translate spanish micha10_277d368d:

    # mc "No. I meant I like it here... in America."
    mc "No. Me refería a que me gusta estar aquí... en Estados Unidos."

# game/Scenes/Micha/micha10.rpy:62
translate spanish micha10_193e6392:

    # mc "I wish that I could stay."
    mc "Ojalá pudiera quedarme."

# game/Scenes/Micha/micha10.rpy:69
translate spanish micha10_4354fa16:

    # pc "What do you mean? You have to go back to Korea?"
    pc "¿Qué quieres decir? ¿Tienes que volver a Corea?"

# game/Scenes/Micha/micha10.rpy:71
translate spanish micha10_d41d8cd9:

    # voice 'voices/micha_yes2.mp3'
    voice 'voices/micha_yes2.mp3'

# game/Scenes/Micha/micha10.rpy:72
translate spanish micha10_b63541c5:

    # mc "Yes. I have to return and become married after I finish this semester."
    mc "Sí. Tengo que volver y casarme cuando termine este semestre."

# game/Scenes/Micha/micha10.rpy:73
translate spanish micha10_1ae5f5f0:

    # pc "What? Why?"
    pc "¿Qué? ¿Por qué?"

# game/Scenes/Micha/micha10.rpy:74
translate spanish micha10_97c2ea57:

    # mc "My parents have arranged it. They have chosen a man. I will become his wife when I return."
    mc "Mis padres lo han arreglado. Han elegido a un hombre. Me convertiré en su esposa cuando vuelva."

# game/Scenes/Micha/micha10.rpy:75
translate spanish micha10_29f911d6:

    # pc "Is that what you want? Do you even like him?"
    pc "¿Es eso lo que quieres? ¿Te gusta siquiera?"

# game/Scenes/Micha/micha10.rpy:76
translate spanish micha10_e1f07ca9:

    # mc "I have never met him. I am sure that he is nice though. My parents chose him."
    mc "Nunca lo he conocido. Aunque estoy segura de que es un buen chico. Mis padres lo han elegido."

# game/Scenes/Micha/micha10.rpy:77
translate spanish micha10_51e20623:

    # pc "You want that though?"
    pc "¿Pero es eso lo que quieres?"

# game/Scenes/Micha/micha10.rpy:78
translate spanish micha10_4989970d:

    # mc "I want to be a wife, yes. But I do like it here."
    mc "Quiero ser esposa, sí. Pero me gusta estar aquí."

# game/Scenes/Micha/micha10.rpy:79
translate spanish micha10_22cefe33:

    # pc "Why don't you just stay then? Why don't you tell your parents no, and stay here?"
    pc "¿Por qué no te quedas entonces? ¿Por qué no les dices que no a tus padres y te quedas aquí?"

# game/Scenes/Micha/micha10.rpy:86
translate spanish micha10_d64f1fa7:

    # mc "It does not work that way."
    mc "Las cosas no funcionan así."

# game/Scenes/Micha/micha10.rpy:89
translate spanish micha10_14baa1d2:

    # mc "I really like you too, [pcname]."
    mc "A mí también me gustas mucho, [pcname]."

# game/Scenes/Micha/micha10.rpy:91
translate spanish micha10_24676458:

    # mc "Yes, I guess so."
    mc "Sí, supongo que sí."

# game/Scenes/Micha/micha10.rpy:98
translate spanish micha10_52765170:

    # "We grow silent again, looking up at the stars."
    "Volvemos a quedarnos en silencio, mirando las estrellas."

# game/Scenes/Micha/micha10.rpy:99
translate spanish micha10_9e978195:

    # "She has to go back to Korea after this semester. I doubt I would see her again."
    "Tiene que volver a Corea después de este semestre. Dudo que vuelva a verla."

# game/Scenes/Micha/micha10.rpy:100
translate spanish micha10_494d2b9e:

    # "I can't help but feel really sad about that."
    "No puedo evitar sentirme muy triste por eso."

# game/Scenes/Micha/micha10.rpy:107
translate spanish micha10_06878b88:

    # "As we're watching the sky, a shooting star flies past. She gasps."
    "Mientras miramos el cielo, pasa una estrella fugaz. Ella da un grito ahogado."

# game/Scenes/Micha/micha10.rpy:108
translate spanish micha10_05fba3d4:

    # mc "Oh! It's so beautiful."
    mc "¡Oh! Es tan bonito."

# game/Scenes/Micha/micha10.rpy:109
translate spanish micha10_013ea0ef:

    # pc "You should make a wish."
    pc "Deberías pedir un deseo."

# game/Scenes/Micha/micha10.rpy:110
translate spanish micha10_9d8e700d:

    # mc "A wish?"
    mc "¿Un deseo?"

# game/Scenes/Micha/micha10.rpy:111
translate spanish micha10_10994647:

    # pc "Yeah, when you see a shooting star, you make a wish and it might come true."
    pc "Sí, cuando ves una estrella fugaz, pides un deseo y puede que se cumpla."

# game/Scenes/Micha/micha10.rpy:118
translate spanish micha10_74c726d2:

    # "She looks at me and speaks in a low, shy voice."
    "Me mira y habla con voz baja y tímida."

# game/Scenes/Micha/micha10.rpy:120
translate spanish micha10_d41d8cd9_1:

    # voice 'voices/micha_10_1.mp3'
    voice 'voices/micha_10_1.mp3'

# game/Scenes/Micha/micha10.rpy:121
translate spanish micha10_c0a252cf:

    # mc "I wish you would kiss me."
    mc "Deseo que me beses."

# game/Scenes/Micha/micha10.rpy:122
translate spanish micha10_2b10aa09:

    # pc "Oh. Well you're not supposed to tell anybody, or it won't happen."
    pc "Oh. Bueno, no se supone que se lo digas a nadie, o no se cumplirá."

# game/Scenes/Micha/micha10.rpy:123
translate spanish micha10_23b76a7a:

    # mc "Oh... I did not know that."
    mc "Oh... No lo sabía."

# game/Scenes/Micha/micha10.rpy:139
translate spanish micha10kiss_4cdfc044:

    # "I lean in and kiss her."
    "Me inclino y la beso."

# game/Scenes/Micha/micha10.rpy:140
translate spanish micha10kiss_ca40b1c0:

    # pc "It's just dumb superstition anyway."
    pc "De todos modos, solo es una superstición tonta."

# game/Scenes/Micha/micha10.rpy:141
translate spanish micha10kiss_39894277:

    # "At first, she is stiff, not moving at all as I kiss her lips. It's like kissing a mannequin."
    "Al principio, ella está rígida, sin moverse en absoluto mientras le beso los labios. Es como besar a un maniquí."

# game/Scenes/Micha/micha10.rpy:154
translate spanish micha10kiss_4319b810:

    # "But then I feel her body loosen, she puts her hand on my arm and leans in further, her lips moving against mine, breath coming quicker."
    "Pero luego noto que su cuerpo se relaja, pone la mano en mi brazo y se inclina más hacia mí, sus labios se mueven contra los míos, su respiración se acelera."

# game/Scenes/Micha/micha10.rpy:155
translate spanish micha10kiss_b9bbd6df:

    # "We kiss like that, under the stars, until the moment turns into minutes, and time seems to float away on the cool night breeze."
    "Nos besamos así, bajo las estrellas, hasta que el momento se convierte en minutos, y el tiempo parece desvanecerse con la fresca brisa nocturna."

# game/Scenes/Micha/micha10.rpy:167
translate spanish micha10kiss_a2abceb1:

    # "I have no idea how much time has passed when she finally, reluctantly, pulls away."
    "No tengo ni idea de cuánto tiempo ha pasado cuando ella, finalmente, a regañadientes, se separa de mí."

# game/Scenes/Micha/micha10.rpy:168
translate spanish micha10kiss_e9b48769:

    # mc "I should go."
    mc "Debería irme."

# game/Scenes/Micha/micha10.rpy:169
translate spanish micha10kiss_7cf89165:

    # pc "You have to?"
    pc "¿Tienes que irte?"

# game/Scenes/Micha/micha10.rpy:170
translate spanish micha10kiss_1145978d:

    # mc "Yes, I apologize."
    mc "Sí, lo siento."

# game/Scenes/Micha/micha10.rpy:173
translate spanish micha10kiss_d89f8402:

    # pc "I should probably go home."
    pc "Probablemente debería irme a casa."

# game/Scenes/Micha/micha10.rpy:174
translate spanish micha10kiss_2148e939:

    # mc "Okay. Me too then."
    mc "Vale. Yo también, entonces."

# game/Scenes/Micha/micha10.rpy:186
translate spanish micha10kiss_53fd2d63:

    # mc "I had a very good time tonight, [pcname]. Thank you."
    mc "Me lo he pasado muy bien esta noche, [pcname]. Gracias."

# game/Scenes/Micha/micha10.rpy:187
translate spanish micha10kiss_445c1419:

    # pc "I'm glad. I did too."
    pc "Me alegro. Yo también."

# game/Scenes/Micha/micha10.rpy:188
translate spanish micha10kiss_7aea7a63:

    # mc "I hope we can do this again soon."
    mc "Espero que podamos volver a hacerlo pronto."

# game/Scenes/Micha/micha10.rpy:190
translate spanish micha10kiss_d41d8cd9:

    # voice 'voices/micha_goodnight1.mp3'
    voice 'voices/micha_goodnight1.mp3'

# game/Scenes/Micha/micha10.rpy:191
translate spanish micha10kiss_9b0423ef:

    # mc "Good night."
    mc "Buenas noches."

# game/Scenes/Micha/micha10.rpy:192
translate spanish micha10kiss_c2ed5d6f:

    # pc "Good night, Mi-Cha."
    pc "Buenas noches, Mi-Cha."

# game/Scenes/Micha/micha10.rpy:195
translate spanish micha10kiss_17735f99:

    # "With that, she goes inside of her dorm building and I walk back to my car and drive away."
    "Con eso, ella entra en su residencia y yo vuelvo a mi coche y me marcho."

# game/Scenes/Micha/micha10.rpy:196
translate spanish micha10kiss_de8a7413:

    # "Maybe Mi-Cha and I will only get the rest of the semester together, but we'll be sure to make it count."
    "Quizá Mi-Cha y yo solo pasemos juntos el resto del semestre, pero nos aseguraremos de que valga la pena."

translate spanish strings:

    # game/Scenes/Micha/micha10.rpy:3
    old "Take Mi-Cha on more dates by calling her in the evening. Eventually she will ask you to walk her back to her dorm after one."
    new "Queda más veces con Mi-Cha llamándola por la tarde. Al final, ella te pedirá que la acompañes a su residencia después de la una."

    # game/Scenes/Micha/micha10.rpy:4
    old "Take your opportunity and kiss her when the moment arises."
    new "Aprovecha la oportunidad y bésala cuando surja el momento."

    # game/Scenes/Micha/micha10.rpy:88
    old "That sucks, because I really like you"
    new "Qué pena, porque me gustas mucho."

    # game/Scenes/Micha/micha10.rpy:90
    old "I guess we're just temporary friends then, huh?"
    new "Supongo que entonces solo somos amigos temporales, ¿no?"

    # game/Scenes/Micha/micha10.rpy:172
    old "Tell her good night"
    new "Dale las buenas noches."

