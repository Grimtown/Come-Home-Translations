    tm "Sí. Yo también os quiero."

# game/Scenes/Tammy/tammy14.rpy:147
translate spanish tammy14_02e5361e:

    # tm "Both of you."
    tm "A las dos."

# game/Scenes/Tammy/tammy14.rpy:148
translate spanish tammy14_5346a3b9:

    # tm "Thanks for tonight."
    tm "Gracias por esta noche."

# game/Scenes/Tammy/tammy14.rpy:151
translate spanish tammy14_b5ba8a4e:

    # pc "Any time you need anything, I'll be here for you."
    pc "Siempre que necesites algo, estaré aquí para ti."

# game/Scenes/Tammy/tammy14.rpy:152
translate spanish tammy14_68ef5b0d:

    # tm "Thanks, [pcname]. Really."
    tm "Gracias, [pcname]. De verdad."

# game/Scenes/Tammy/tammy14.rpy:153
translate spanish tammy14_450f2c68:

    # tm "You guys mean the world to me."
    tm "Sois lo más importante para mí."

# game/Scenes/Tammy/tammy14.rpy:156
translate spanish tammy14_0aaa364a:

    # tm "Ahh! You're squishing me!"
    tm "¡Ahh! ¡Me estás aplastando!"

