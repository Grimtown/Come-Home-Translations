# game/Scenes/Update20/u20j.rpy:2
translate spanish u20j_be7d1e50:

    # "For now, I should go see Adrian."
    "Por ahora, debería ir a ver a Adrian."

# game/Scenes/Update20/u20j.rpy:5
translate spanish u20j_33260fe1:

    # "I drive over to Adrian's house and ring the doorbell."
    "Conduzco hasta la casa de Adrian y llamo al timbre."

# game/Scenes/Update20/u20j.rpy:6
translate spanish u20j_4fc89239:

    # "It's late and I hate to wake her, but I need to see her."
    "Es tarde y odio despertarla, pero necesito verla."

# game/Scenes/Update20/u20j.rpy:9
translate spanish u20j_494a3331:

    # "Adrian's Mom" "Hello? Do you know how late it is?"
    "Adrian's Mom" "¿Hola? ¿Sabes lo tarde que es?"

# game/Scenes/Update20/u20j.rpy:10
translate spanish u20j_7d43c485:

    # pc "I'm sorry, I know. I'm a friend of Adrian's."
    pc "Lo siento, lo sé. Soy amigo de Adrian."

# game/Scenes/Update20/u20j.rpy:11
translate spanish u20j_87309e2a:

    # pc "Could I talk to her, please?"
    pc "¿Podría hablar con ella, por favor?"

# game/Scenes/Update20/u20j.rpy:12
translate spanish u20j_ad012933:

    # "Adrian's Mom" "Oh, are you [pcname]? She's been worried about you for weeks."
    "Adrian's Mom" "Oh, ¿eres tú [pcname]? Lleva semanas preocupada por ti."

# game/Scenes/Update20/u20j.rpy:13
translate spanish u20j_332de7e5:

    # pc "Yes, I'm sorry. That's me."
    pc "Sí, lo siento. Soy yo."

# game/Scenes/Update20/u20j.rpy:16
translate spanish u20j_1a0d366a:

    # "Adrian's Mom" "She's going to be really happy to see you."
    "Adrian's Mom" "Se va a alegrar mucho de verte."

# game/Scenes/Update20/u20j.rpy:17
translate spanish u20j_1108c1b8:

    # "Adrian's Mom" "You can go up and see her, just keep things PG, okay?"
    "Adrian's Mom" "Puedes subir a verla, pero que no haya nada inapropiado, ¿vale?"

# game/Scenes/Update20/u20j.rpy:18
translate spanish u20j_e170ff6c:

    # pc "Yes, ma'am. Thank you."
    pc "Sí, señora. Gracias."

# game/Scenes/Update20/u20j.rpy:22
translate spanish u20j_f5638052:

    # "I walk quietly up the stairs and into Adrian's room. She's in bed, sleeping."
    "Subo las escaleras en silencio y entro en la habitación de Adrian. Está en la cama, durmiendo."

# game/Scenes/Update20/u20j.rpy:25
translate spanish u20j_cbba5bfa:

    # "Trying not to wake her immediately, I lie next to her and wrap my arms around her."
    "Intentando no despertarla de golpe, me acuesto a su lado y la rodeo con mis brazos."

# game/Scenes/Update20/u20j.rpy:28
translate spanish u20j_c981bd85:

    # "She jolts awake and looks at me, shocked."
    "Se despierta sobresaltada y me mira, sorprendida."

# game/Scenes/Update20/u20j.rpy:29
translate spanish u20j_a857ee55:

    # gg "What the fuck? [pcname]?"
    gg "¿Qué coño? [pcname]?"

# game/Scenes/Update20/u20j.rpy:32
translate spanish u20j_0f0952fe:

    # "I don't answer. I just pull her close and kiss her deeply."
    "No respondo. Solo la atraigo hacia mí y la beso profundamente."

# game/Scenes/Update20/u20j.rpy:33
translate spanish u20j_09b23034:

    # gg "Fuck, I was so worried about you. I thought you weren't ever coming back."
    gg "Joder, estaba tan preocupada por ti. Pensé que no ibas a volver nunca."

# game/Scenes/Update20/u20j.rpy:36
translate spanish u20j_b1adfb65:

    # gg "So you went to another world, for real?"
    gg "¿Así que te fuiste a otro mundo, de verdad?"

# game/Scenes/Update20/u20j.rpy:37
translate spanish u20j_e5f2498c:

    # pc "Yeah, I did."
    pc "Sí, lo hice."

# game/Scenes/Update20/u20j.rpy:38
translate spanish u20j_29a8b357:

    # gg "And you saw your dad?"
    gg "¿Y viste a tu padre?"

# game/Scenes/Update20/u20j.rpy:39
translate spanish u20j_c417e350:

    # pc "Yeah."
    pc "Sí."

# game/Scenes/Update20/u20j.rpy:40
translate spanish u20j_fa6e7016:

    # gg "You have to tell me everything."
    gg "Tienes que contármelo todo."

# game/Scenes/Update20/u20j.rpy:41
translate spanish u20j_0bb899f2:

    # pc "I will, I promise. Tomorrow."
    pc "Lo haré, te lo prometo. Mañana."

# game/Scenes/Update20/u20j.rpy:44
translate spanish u20j_92c42e64:

    # gg "Right. Tomorrow. I'm just glad you're back!"
    gg "Vale. Mañana. ¡Me alegro de que hayas vuelto!"

# game/Scenes/Update20/u20j.rpy:45
translate spanish u20j_d2639c3b:

    # gg "I can't believe you're back."
    gg "No puedo creer que hayas vuelto."

# game/Scenes/Update20/u20j.rpy:46
translate spanish u20j_c01c395d:

    # gg "I'm so happy, I can't stand it."
    gg "Estoy tan feliz que no puedo soportarlo."

# game/Scenes/Update20/u20j.rpy:49
translate spanish u20j_f432b969:

    # "I pull her close and kiss her again, feeling her warmth."
    "La atraigo hacia mí y la beso de nuevo, sintiendo su calor."

# game/Scenes/Update20/u20j.rpy:50
translate spanish u20j_bf4f63bf:

    # gg "Good idea. Shut me up with your mouth."
    gg "Buena idea. Cállame con tu boca."

# game/Scenes/Update20/u20j.rpy:51
translate spanish u20j_1530bf0e:

    # gg "I just missed you so much."
    gg "Te echaba tanto de menos."

# game/Scenes/Update20/u20j.rpy:52
translate spanish u20j_9c24a5ca:

    # pc "I missed you too, Adrian."
    pc "Yo también te echaba de menos, Adrian."

