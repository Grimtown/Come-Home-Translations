# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:15
translate spanish adrians2_1153c5b6:

    # gg "No, I'm pretty focused on school."
    gg "No, estoy bastante centrado en los estudios."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:17
translate spanish adrians2_890b7d8e:

    # gg "Actually that's kind of a lie."
    gg "En realidad, eso es un poco mentira."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:19
translate spanish adrians2_0a40fc4a:

    # gg "School is easy. I haven't had any problems at all really."
    gg "Los estudios son fáciles. La verdad es que no he tenido ningún problema."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:20
translate spanish adrians2_6967b4f8:

    # gg "I could definitely get a job if I wanted and still be fine in school."
    gg "Sin duda podría conseguir un trabajo si quisiera y seguir yendo bien en los estudios."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:21
translate spanish adrians2_24c19f10:

    # gg "I just don't want to right away. And I don't have to, so I'm not going to."
    gg "Es solo que no quiero hacerlo ahora mismo. Y no tengo por qué, así que no lo voy a hacer."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:22
translate spanish adrians2_57cd481f:

    # pc "Nothing wrong with that."
    pc "No hay nada de malo en eso."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:23
translate spanish adrians2_3298487a:

    # gg "I guess. I feel bad sometimes though. Like people look down on me because I don't have a job."
    gg "Supongo. Aunque a veces me siento mal. Como si la gente me mirara por encima del hombro porque no tengo trabajo."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:24
translate spanish adrians2_946ae6f7:

    # pc "Fuck 'em. You live your life."
    pc "Que les den. Tú vive tu vida."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:26
translate spanish adrians2_92420bc9:

    # gg "Fuck yeah, man. That's why I like you, [pcname]."
    gg "Joder, sí, tío. Por eso me caes bien, [pcname]."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:28
translate spanish adrians2_61fb90d2:

    # gg "I'm not sure about work though."
    gg "Aunque no estoy seguro sobre lo del trabajo."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:29
translate spanish adrians2_9f0324ca:

    # gg "I just have a hard time seeing myself happy if I have to work at some business with hours I have to be there and a boss and..."
    gg "Me cuesta mucho imaginarme feliz si tengo que trabajar en algún sitio con un horario al que tengo que acudir, un jefe y..."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:31
translate spanish adrians2_6a0cc34f:

    # gg "Zzzzzz..."
    gg "Zzzzzz..."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:33
translate spanish adrians2_844cb536:

    # gg "Just thinking about it puts me to sleep. So boring."
    gg "Solo de pensarlo me entra sueño. Qué aburrido."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:34
translate spanish adrians2_cafb26cc:

    # gg "I don't know what I'm going to do after school honestly."
    gg "Sinceramente, no sé qué voy a hacer cuando termine el instituto."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:35
translate spanish adrians2_8d86f101:

    # gg "It stresses me out to think about it."
    gg "Me estresa pensar en ello."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:36
translate spanish adrians2_69a6cb52:

    # pc "Sorry. I didn't mean to stress you out."
    pc "Lo siento. No quería estresarte."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:37
translate spanish adrians2_9c2c85b4:

    # gg "No, it's okay. It's not you."
    gg "No, no pasa nada. No es culpa tuya."

# game/Scenes/Adrian/AdrianConversations/adrians2.rpy:38
translate spanish adrians2_b342ddbc:

    # gg "Anyway..."
    gg "En fin..."

