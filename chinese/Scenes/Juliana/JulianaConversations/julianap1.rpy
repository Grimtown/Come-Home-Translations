# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:12
translate chinese julianap1_ed53db64:

    # bn "Yes."
    bn "好的。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:13
translate chinese julianap1_27676c4a:

    # bn "I've never been very good at talking to people."
    bn "我从来都不太擅长和人聊天。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:14
translate chinese julianap1_352a044d:

    # bn "I have a tendency to make people mad and they don't hang around long enough to develop any real attraction."
    bn "我总是不小心惹人发火，别人根本没耐心待到能产生真正好感的时候。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:15
translate chinese julianap1_be31a32e:

    # bn "And I don't want to just sleep with somebody who I don't have feelings for."
    bn "而且我不想和没有感情的人上床。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:16
translate chinese julianap1_dca084ed:

    # pc "Do you have feelings for me?"
    pc "你对我有什么感觉吗？"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:18
translate chinese julianap1_71f798a0:

    # bn "Yeah…"
    bn "嗯……"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:19
translate chinese julianap1_e42fd050:

    # bn "I do."
    bn "有。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:20
translate chinese julianap1_59ec3549:

    # bn "And I'm looking forward to exploring those feelings further."
    bn "我很期待进一步探索这些感觉。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:21
translate chinese julianap1_5762362e:

    # bn "Very soon."
    bn "很快。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:22
translate chinese julianap1_b29b0e0d:

    # bn "Just give me some time."
    bn "只是给我点时间。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:23
translate chinese julianap1_845ead68:

    # bn "It's a big deal to me, and I'm a little nervous about it."
    bn "这对我来说很重要，我有点紧张。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:24
translate chinese julianap1_34b44705:

    # pc "I understand."
    pc "我理解。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:25
translate chinese julianap1_c4c118ef:

    # pc "There's nothing to be nervous about though."
    pc "不过没什么好紧张的。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:26
translate chinese julianap1_65e280df:

    # pc "I like you and I'll be there to help guide you through it, if you want."
    pc "我喜欢你，如果你愿意，我会陪在你身边，引导你度过这一关。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:28
translate chinese julianap1_7767853c:

    # bn "Thank you, [pcname]."
    bn "谢谢你，[pcname]。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:29
translate chinese julianap1_3f6b03a9:

    # bn "I very much want."
    bn "我非常希望如此。"

# game/Scenes/Juliana/JulianaConversations/julianap1.rpy:30
translate chinese julianap1_fe333677:

    # bn "I'll let you know when I'm ready."
    bn "等我准备好了，我会告诉你。"

