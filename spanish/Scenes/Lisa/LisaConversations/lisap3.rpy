# game/Scenes/Lisa/LisaConversations/lisap3.rpy:10
translate spanish lisap3_77ff83b8:

    # sp "Never."
    sp "Nunca."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:12
translate spanish lisap3_8f1fcc3a:

    # sp "I could have too!"
    sp "¡Yo también podría haberlo hecho!"

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:14
translate spanish lisap3_0eeb5db0:

    # sp "But I was always completely faithful."
    sp "Pero siempre fui completamente fiel."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:15
translate spanish lisap3_1ef0014d:

    # sp "Even though we never married, I didn't even consider cheating on him."
    sp "Aunque nunca nos casamos, ni siquiera me planteé engañarle."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:16
translate spanish lisap3_d80d7713:

    # sp "I loved him, and I would never want to hurt somebody that I loved like that."
    sp "Le quería, y nunca querría hacer daño a alguien a quien quería así."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:17
translate spanish lisap3_ddb94d63:

    # pc "What do you mean that you could have?"
    pc "¿Qué quieres decir con que podrías haberlo hecho?"

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:19
translate spanish lisap3_1ef1f5a3:

    # sp "Oh, there was this guy that I used to work with."
    sp "Oh, había un chico con el que solía trabajar."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:20
translate spanish lisap3_a80d2212:

    # sp "Cute guy. A couple of years younger than me."
    sp "Un chico guapo. Un par de años más joven que yo."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:22
translate spanish lisap3_eab4f0ee:

    # sp "He was real flirty with me for a long time... and I might have flirted back with him a little."
    sp "Llevaba mucho tiempo coqueteando conmigo... y puede que yo le devolviera un poco el coqueteo."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:24
translate spanish lisap3_89ea561c:

    # sp "But I thought we were just being silly at work, you know?"
    sp "Pero pensaba que solo estábamos haciendo el tonto en el trabajo, ¿sabes?"

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:26
translate spanish lisap3_623233f4:

    # sp "Then he made a pass at me. He tried to kiss me in the break room."
    sp "Entonces intentó ligar conmigo. Intentó besarme en la sala de descanso."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:28
translate spanish lisap3_a447503b:

    # sp "But I turned him down. I told him I wasn't interested in him like that."
    sp "Pero lo rechacé. Le dije que no me interesaba de esa manera."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:29
translate spanish lisap3_a0a12a4b:

    # pc "What happened to him?"
    pc "¿Qué pasó con él?"

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:31
translate spanish lisap3_bd50ed7a:

    # sp "Well, things were awkward for a while..."
    sp "Bueno, las cosas estuvieron un poco incómodas durante un tiempo..."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:32
translate spanish lisap3_860e56ba:

    # sp "... then he got fired for sleeping with another co-worker. They both got fired."
    sp "... luego lo despidieron por acostarse con otra compañera de trabajo. Los despidieron a los dos."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:33
translate spanish lisap3_04c20983:

    # sp "There's a strict policy against romantic affairs in the office."
    sp "Hay una política estricta contra las relaciones sentimentales en la oficina."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:34
translate spanish lisap3_c0f8cd2a:

    # pc "I guess you dodged a bullet then."
    pc "Supongo que entonces esquivaste una bala."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:36
translate spanish lisap3_7fc2894d:

    # sp "Yeah... but if I wasn't with your father, I would have gone for it anyway."
    sp "Sí... pero si no hubiera estado con tu padre, me habría lanzado de todos modos."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:37
translate spanish lisap3_399bdc0f:

    # pc "Really?"
    pc "¿En serio?"

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:39
translate spanish lisap3_d8f6fe03:

    # sp "He was very cute and funny."
    sp "Era muy guapo y divertido."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:41
translate spanish lisap3_613cdb94:

    # sp "I gave up a lot of things being with your father."
    sp "Renuncié a muchas cosas por estar con tu padre."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:42
translate spanish lisap3_92d3db67:

    # sp "But I guess it led to a lot of good things too."
    sp "Pero supongo que eso también me trajo muchas cosas buenas."

# game/Scenes/Lisa/LisaConversations/lisap3.rpy:44
translate spanish lisap3_e973c65c:

    # sp "Like you."
    sp "Como a ti."

