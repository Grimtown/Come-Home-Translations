translate spanish suzys8_f646bf54:

    # ss "His car? I have no idea."
    ss "¿Su coche? Ni idea."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:15
translate spanish suzys8_1446ff69:

    # ss "I'm not sure I've ever even seen those keys."
    ss "No estoy segura de haber visto siquiera esas llaves."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:16
translate spanish suzys8_569338fe:

    # pc "You've never ridden in the car with him?"
    pc "¿Nunca has ido en el coche con él?"

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:18
translate spanish suzys8_1d0237b1:

    # ss "Never. If we went somewhere together it was always in Mom's car."
    ss "Nunca. Si íbamos a algún sitio juntos, siempre era en el coche de mamá."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:19
translate spanish suzys8_c1971cf2:

    # ss "He almost never left the house in the last, like, year or so though."
    ss "Aunque casi nunca ha salido de casa en el último año más o menos."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:20
translate spanish suzys8_c7effbef:

    # pc "Dang. It's so weird that I can't find his keys anywhere."
    pc "Vaya. Es muy raro que no encuentre sus llaves por ningún lado."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:22
translate spanish suzys8_7f01995f:

    # ss "Why do you want that car so bad?"
    ss "¿Por qué quieres tanto ese coche?"

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:23
translate spanish suzys8_b0004592:

    # pc "I'd like to drive the car! You've seen what I've been driving."
    pc "¡Me gustaría conducirlo! Ya has visto lo que he estado conduciendo."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:25
translate spanish suzys8_0e2b81f6:

    # ss "What? I think the Beetle is cute!"
    ss "¿Qué? ¡A mí el Beetle me parece monísimo!"

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:26
translate spanish suzys8_345a6dbf:

    # pc "Cute, yeah, but Dad's car is badass."
    pc "Monísimo, sí, pero el coche de papá es una pasada."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:28
translate spanish suzys8_f1ccabba:

    # "She snorts."
    "Ella resopla."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:29
translate spanish suzys8_c42fae1e:

    # ss "Yeah, if you think a mid-life crisis car is badass."
    ss "Sí, si crees que un coche de crisis de mediana edad es una pasada."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:30
translate spanish suzys8_ba755708:

    # ss "That car is for balding men with beer bellies and micropenises."
    ss "Ese coche es para hombres calvos con barriga cervecera y micropenes."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:31
translate spanish suzys8_5b43040e:

    # "I gasp."
    "Me quedo sin aliento."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:32
translate spanish suzys8_4c43d079:

    # pc "You take that back."
    pc "Retira lo que has dicho."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:34
translate spanish suzys8_50ba42a3:

    # ss "I won't."
    ss "No lo haré."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:36
translate spanish suzys8_21f491e9:

    # ss "The Beetle suits you better."
    ss "El Beetle te queda mejor."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:37
translate spanish suzys8_ee1b4e76:

    # pc "Whatever. I still want those keys."
    pc "Da igual. Sigo queriendo esas llaves."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:38
translate spanish suzys8_5a2d1a3f:

    # ss "I'll let you know if I see them."
    ss "Te diré si las veo."

