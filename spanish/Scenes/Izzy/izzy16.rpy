    gl "Joder, no lo sé. No podemos fumar. Supongo que nos sentaremos y charlaremos."

# game/Scenes/Izzy/izzy16.rpy:31
translate spanish izzy16_fa1766ba:

    # gl "You could bring that cat game you were talking about."
    gl "Podrías traer ese juego de gatos del que me hablabas."

# game/Scenes/Izzy/izzy16.rpy:32
translate spanish izzy16_1b7d40a4:

    # pc "Cat game?"
    pc "¿Juego de gatos?"

# game/Scenes/Izzy/izzy16.rpy:33
translate spanish izzy16_af533933:

    # gl "Yeah, that board game you were telling me about."
    gl "Sí, ese juego de mesa del que me contabas."

# game/Scenes/Izzy/izzy16.rpy:34
translate spanish izzy16_d2ae88c3:

    # pc "Oh, Settlers of Catan?"
    pc "Ah, ¿Los Colonos de Catán?"

