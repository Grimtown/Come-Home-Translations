# game/Scenes/Micha/MichaDates/michabeachdate.rpy:34
translate chinese michabeachdate_93419ef3:

    # "We spend some time swimming around and chatting."
    "我们花了一些时间在海里游来游去，聊着天。"

# game/Scenes/Micha/MichaDates/michabeachdate.rpy:37
