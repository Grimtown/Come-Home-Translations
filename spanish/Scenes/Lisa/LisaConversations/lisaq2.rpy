# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:13
translate spanish lisaq2_db9895bd:

    # sp "Do you really think you're going to find your dad?"
    sp "¿De verdad crees que vas a encontrar a tu padre?"

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:15
translate spanish lisaq2_607dbba1:

    # pc "Yeah, I think so. I'm on the right track anyway."
    pc "Sí, eso creo. De todas formas, voy por buen camino."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:17
translate spanish lisaq2_c37e7dd9:

    # sp "Really?"
    sp "¿En serio?"

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:18
translate spanish lisaq2_55c49e34:

    # sp "His note said something about getting your mom back."
    sp "En su nota decía algo sobre recuperar a tu madre."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:19
translate spanish lisaq2_07c6b414:

    # sp "It sounds like he had a complete psychotic breakdown. I'm just hoping he didn't hurt himself."
    sp "Parece que ha sufrido un colapso psicótico total. Solo espero que no se haya hecho daño."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:21
translate spanish lisaq2_5c12f8d4:

    # sp "What have you found out?"
    sp "¿Qué has averiguado?"

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:26
translate spanish lisaq2_46868dd6:

    # "I tell her everything about the hoop, about Whitney, about our plan to go through the hoop to bring Dad back home."
    "Le cuento todo sobre el aro, sobre Whitney, sobre nuestro plan de atravesar el aro para traer a papá de vuelta a casa."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:27
translate spanish lisaq2_628e5397:

    # "She looks at me as I talk as if I'm speaking another language."
    "Me mira mientras hablo como si estuviera hablando en otro idioma."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:28
translate spanish lisaq2_91073664:

    # sp "[pcname]... that sounds completely insane."
    sp "[pcname]... eso suena completamente descabellado."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:29
translate spanish lisaq2_366869bb:

    # sp "It sounds like science fiction."
    sp "Parece ciencia ficción."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:30
translate spanish lisaq2_d4e5760c:

    # pc "I know. But I think it's going to work, [mom]."
    pc "Lo sé. Pero creo que va a funcionar, [mom]."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:32
translate spanish lisaq2_bd3f2bae:

    # sp "It doesn't make sense."
    sp "No tiene sentido."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:33
translate spanish lisaq2_fc7ff67b:

    # sp "Out of all the smart people in the world - the Albert Einsteins, the Bill Gates, the Steve Jobs - {i}your father{/i} builds a device in our basement that lets him travel to other worlds?"
    sp "De entre toda la gente inteligente del mundo —los Albert Einstein, los Bill Gates, los Steve Jobs—, ¿{i}tu padre{/i} construye un aparato en nuestro sótano que le permite viajar a otros mundos?"

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:34
translate spanish lisaq2_77dc712a:

    # pc "Yeah. I think so."
    pc "Sí. Creo que sí."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:36
translate spanish lisaq2_5ac0f4e2:

    # sp "It's ridiculous."
    sp "Es ridículo."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:37
translate spanish lisaq2_1a7dea6d:

    # sp "Well, whatever you're doing, just be careful."
    sp "Bueno, hagas lo que hagas, ten cuidado."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:38
translate spanish lisaq2_8dc54287:

    # sp "Don't get into any trouble and don't get yourself hurt."
    sp "No te metas en líos y no te hagas daño."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:39
translate spanish lisaq2_4c3fa554:

    # pc "I know, [mom]. I'll be careful."
    pc "Lo sé, [mom]. Tendré cuidado."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:41
translate spanish lisaq2_03bd97a8:

    # sp "You better. I can't lose another man."
    sp "Más te vale. No puedo perder a otro hombre."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:43
translate spanish lisaq2_ff063ae5:

    # pc "I've just been following his trail."
    pc "Solo he estado siguiendo su rastro."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:44
translate spanish lisaq2_1ee6ebf5:

    # pc "I think I'm getting close to figuring out where he's gone."
    pc "Creo que estoy a punto de averiguar adónde se ha ido."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:46
translate spanish lisaq2_269a8c78:

    # sp "Well, that's good."
    sp "Bueno, eso está bien."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:47
translate spanish lisaq2_6ca871f1:

    # sp "I hope you find him."
    sp "Espero que lo encuentres."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:49
translate spanish lisaq2_e25799a9:

    # sp "Then we can finally put all this behind us and move on with our lives."
    sp "Así podremos dejar todo esto atrás de una vez por todas y seguir adelante con nuestras vidas."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:51
translate spanish lisaq2_affd5675:

    # pc "I haven't found anything yet, really."
    pc "La verdad es que aún no he encontrado nada."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:53
translate spanish lisaq2_16b3838e:

    # sp "Really? That's too bad."
    sp "¿En serio? Qué pena."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:55
translate spanish lisaq2_062701f1:

    # sp "I thought you were spending a lot of time investigating."
    sp "Pensaba que dedicabas mucho tiempo a investigar."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:56
translate spanish lisaq2_a47aae01:

    # sp "I thought that's what you've been doing when you go out every evening."
    sp "Pensaba que eso era lo que hacías cuando salías todas las noches."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:57
translate spanish lisaq2_944b5ed3:

    # pc "Well..."
    pc "Bueno..."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:59
translate spanish lisaq2_09a4e091:

    # sp "I just want to find him."
    sp "Solo quiero encontrarlo."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:60
translate spanish lisaq2_aaf2f6c5:

    # sp "Then we can put all of this behind us and move on with our lives."
    sp "Así podremos dejar todo esto atrás y seguir adelante con nuestras vidas."

# game/Scenes/Lisa/LisaConversations/lisaq2.rpy:61
translate spanish lisaq2_e6cd3dee:

    # pc "Yeah. Me too."
    pc "Sí. Yo también."

