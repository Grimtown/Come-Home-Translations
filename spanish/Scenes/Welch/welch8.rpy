translate spanish welch8date_7288cc24:

    # sst "Super sexy too."
    sst "Y súper sexy también."

# game/Scenes/Welch/welch8.rpy:197
translate spanish welch8date_2951ed74:

    # pc "Definitely."
    pc "Sin duda."

# game/Scenes/Welch/welch8.rpy:199
translate spanish welch8date_650af916:

    # sst "So, [pcname], I wanted to talk to you about something."
    sst "Bueno, [pcname], quería hablar contigo de algo."

# game/Scenes/Welch/welch8.rpy:200
translate spanish welch8date_3e09ca60:

    # sst "I kind of have a crush on you."
    sst "Me gustas un poco."

# game/Scenes/Welch/welch8.rpy:201
translate spanish welch8date_65a7cfea:

    # sst "I think you're funny, you're cute, and I love how you actually care about social problems."
    sst "Creo que eres divertido, eres guapo y me encanta que te preocupes de verdad por los problemas sociales."

# game/Scenes/Welch/welch8.rpy:202
translate spanish welch8date_97bcec87:

    # sst "I was just wondering... do you like me too?"
    sst "Me preguntaba... ¿tú también me gustas?"

# game/Scenes/Welch/welch8.rpy:205
translate spanish welch8date_51ff6f14:

    # sst "Oh, thank the gods, I was afraid I might have made a big mistake here."
    sst "Oh, gracias a los dioses, temía haber cometido un gran error."

# game/Scenes/Welch/welch8.rpy:208
translate spanish welch8date_1f998150:

    # sst "Oh okay. No problem then."
    sst "Oh, vale. Entonces no hay problema."

# game/Scenes/Welch/welch8.rpy:210
translate spanish welch8date_c63e8c62:

    # "Ms. Welch and I have a somewhat uncomfortable dinner, then I take her back to the school and drop her off near her car."
    "La Sra. Welch y yo tenemos una cena un poco incómoda, luego la llevo de vuelta al colegio y la dejo cerca de su coche."

# game/Scenes/Welch/welch8.rpy:211
translate spanish welch8date_070b1822:

    # "It's not a good idea to get involved with her any more than I already am."
    "No es buena idea involucrarme con ella más de lo que ya lo estoy."

# game/Scenes/Welch/welch8.rpy:216
translate spanish welch8date_a7710f60:

    # sst "I'm really happy that you feel the same way."
    sst "Me alegro mucho de que sientas lo mismo."

# game/Scenes/Welch/welch8.rpy:217
translate spanish welch8date_2103e901:

    # sst "I should tell you, I'm really bad at controlling my urges. And sometimes my urges get me into trouble."
    sst "Tengo que decirte que se me da muy mal controlar mis impulsos. Y a veces mis impulsos me meten en líos."

# game/Scenes/Welch/welch8.rpy:218
translate spanish welch8date_27c38463:

    # sst "We need to wait until you graduate and you're not in my class before we pursue any kind of relationship, okay?"
    sst "Tenemos que esperar a que te gradúes y ya no estés en mi clase antes de seguir adelante con cualquier tipo de relación, ¿vale?"

# game/Scenes/Welch/welch8.rpy:219
translate spanish welch8date_4e669a5e:

    # sst "If anybody suspects that our relationship is anything more than friendly, I could lose my job."
    sst "Si alguien sospecha que nuestra relación es algo más que de amistad, podría perder mi trabajo."

# game/Scenes/Welch/welch8.rpy:220
translate spanish welch8date_e86f9bb1:

    # sst "I like you a lot, but I love my job and I don't want to lose it."
    sst "Me gustas mucho, pero amo mi trabajo y no quiero perderlo."

# game/Scenes/Welch/welch8.rpy:221
translate spanish welch8date_34b44705:

    # pc "I understand."
    pc "Lo entiendo."

# game/Scenes/Welch/welch8.rpy:223
translate spanish welch8date_4a831597:

    # sst "If we can keep things calm and on the down-low for now though, after you graduate, maybe we could see where things go, okay?"
    sst "Pero si podemos mantener las cosas tranquilas y discretas por ahora, después de que te gradúes, quizá podamos ver cómo van las cosas, ¿vale?"

# game/Scenes/Welch/welch8.rpy:224
translate spanish welch8date_6c48c73f:

    # pc "That sounds good Ms. Welch."
    pc "Me parece bien, Sra. Welch."

# game/Scenes/Welch/welch8.rpy:225
translate spanish welch8date_5ff805f3:

    # sst "Please, outside of class, you can call me Nora, okay?"
    sst "Por favor, fuera de clase, puedes llamarme Nora, ¿vale?"

# game/Scenes/Welch/welch8.rpy:226
translate spanish welch8date_001845b4:

    # pc "Okay, Nora."
    pc "Vale, Nora."

# game/Scenes/Welch/welch8.rpy:229
translate spanish welch8date_ea33992e:

    # "We chit-chat a little while we eat, just about school and politics. Nothing super interesting."
    "Charlamos un rato mientras comemos, solo sobre la escuela y la política. Nada muy interesante."

# game/Scenes/Welch/welch8.rpy:230
translate spanish welch8date_586b1732:

    # "Then, when we're done, I drive her back to her car at the school."
    "Luego, cuando terminamos, la llevo en coche hasta su coche en la escuela."

# game/Scenes/Welch/welch8.rpy:235
translate spanish welch8date_e684ed1f:

    # sst "Bye, [pcname]. Thanks for hanging out with me tonight. I really enjoyed it."
    sst "Adiós, [pcname]. Gracias por pasar la noche conmigo. Me ha encantado."

# game/Scenes/Welch/welch8.rpy:236
translate spanish welch8date_7ebf0e6b:

    # pc "Me too, Nora."
    pc "A mí también, Nora."

# game/Scenes/Welch/welch8.rpy:237
translate spanish welch8date_3daf6d31:

    # sst "Ooh, something about you saying my name kinda gets me hot."
    sst "Ooh, hay algo en cómo dices mi nombre que me pone a mil."

# game/Scenes/Welch/welch8.rpy:238
translate spanish welch8date_f13707ef:

    # sst "I wish I could invite you over to my house. I'd love to spend some more time with you. Hear you say my name some more."
    sst "Ojalá pudiera invitarte a mi casa. Me encantaría pasar más tiempo contigo. Oírte decir mi nombre unas cuantas veces más."

# game/Scenes/Welch/welch8.rpy:239
translate spanish welch8date_0ef672f8:

    # sst "But I'll be good."
    sst "Pero me portaré bien."

# game/Scenes/Welch/welch8.rpy:241
translate spanish welch8date_d41d8cd9:

    # voice 'voices/welch_goodnight2.mp3'
    voice 'voices/welch_goodnight2.mp3'

# game/Scenes/Welch/welch8.rpy:242
translate spanish welch8date_a53d3b6c:

    # sst "Good night, [pcname]."
    sst "Buenas noches, [pcname]."

# game/Scenes/Welch/welch8.rpy:243
translate spanish welch8date_a629b7f0:

    # pc "Bye, Nora."
    pc "Adiós, Nora."

# game/Scenes/Welch/welch8.rpy:247
translate spanish welch8date_8f81c243:

    # "She gets out of the car and I watch her walk over to hers, get in, and drive away."
    "Ella sale del coche y la veo caminar hacia el suyo, subirse y marcharse."

# game/Scenes/Welch/welch8.rpy:249
translate spanish welch8date_757b78b4:

    # "I have no idea how I'm going to hold off until graduation with her. She's so fucking hot. I just want her right now."
    "No tengo ni idea de cómo voy a aguantar hasta la graduación con ella. Está jodidamente buena. La quiero ahora mismo."

# game/Scenes/Welch/welch8.rpy:250
translate spanish welch8date_6f95dc85:

    # "After taking a few moments to just breathe, I drive off."
    "Después de tomarme unos momentos para respirar, me marcho."

