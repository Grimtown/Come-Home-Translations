    # bn "Maybe we should plan instead, so we don't die? No? Okay."
    bn "也许我们该先做点计划，这样才不会死？不行？好吧。"

# game/Scenes/Update19/Act2/act2scene11.rpy:150
translate chinese u19a2s11_7c8b1299:

    # "We eat the stew. It's delicious."
    "我们吃着炖菜。真好吃。"

# game/Scenes/Update19/Act2/act2scene11.rpy:151
translate chinese u19a2s11_e88b25bd:

    # "And we chat, talking about our lives and our goals."
    "我们边吃边聊，聊聊彼此的生活和目标。"

# game/Scenes/Update19/Act2/act2scene11.rpy:154
translate chinese u19a2s11_92760214:

    # fd "I love traveling, trying new foods, cooking new things for new people."
    fd "我喜欢旅行，尝试新食物，为新朋友做新菜。"

# game/Scenes/Update19/Act2/act2scene11.rpy:155
translate chinese u19a2s11_20999f03:

    # fd "Making people smile is the best thing in the world, I think."
    fd "我觉得，让别人微笑是世界上最棒的事。"

# game/Scenes/Update19/Act2/act2scene11.rpy:158
translate chinese u19a2s11_cc3dbbc6:

    # fd "Speaking of which, how about some music?"
    fd "说到这个，来点音乐怎么样？"

# game/Scenes/Update19/Act2/act2scene11.rpy:159
translate chinese u19a2s11_eab110cf:

    # pc "You can play music?"
    pc "你会弹琴吗？"

# game/Scenes/Update19/Act2/act2scene11.rpy:162
translate chinese u19a2s11_2b6705cc:

    # fd "I have all sorts of talents."
    fd "我可是多才多艺的。"

# game/Scenes/Update19/Act2/act2scene11.rpy:164
translate chinese u19a2s11_7378a0d4:

    # "She gives me a wink, then starts playing some lively music to go along with our meal."
    "她冲我眨眨眼，随即开始弹奏欢快的乐曲，为我们的晚餐助兴。"

# game/Scenes/Update19/Act2/act2scene11.rpy:165
translate chinese u19a2s11_0da6d727:

    # "Then, when we finish eating, we dance."
    "然后，吃完饭后，我们就跳舞。"

# game/Scenes/Update19/Act2/act2scene11.rpy:169
translate chinese u19a2s11_f838913d:

    # sst "I'm sorry if I'm clumsy. I'm not really used to having legs."
    sst "如果我跳得笨拙，请原谅。我还没习惯用双腿。"

# game/Scenes/Update19/Act2/act2scene11.rpy:170
translate chinese u19a2s11_b7404c90:

    # pc "I'm much more clumsy underwater than you are on land."
    pc "我在水下比你在陆地上还要笨拙得多。"

# game/Scenes/Update19/Act2/act2scene11.rpy:171
translate chinese u19a2s11_a6989975:

    # sst "You weren't so clumsy last night. I really enjoyed that."
    sst "昨晚你可没那么笨拙。我真的很享受那段时光。"

# game/Scenes/Update19/Act2/act2scene11.rpy:172
translate chinese u19a2s11_4e1e42c3:

    # pc "I did too."
    pc "我也是。"

# game/Scenes/Update19/Act2/act2scene11.rpy:176
translate chinese u19a2s11_f6a02324:

    # rb "I've never danced with a boy before."
    rb "我以前从没和男生跳过舞。"

# game/Scenes/Update19/Act2/act2scene11.rpy:177
translate chinese u19a2s11_81bda1bf:

    # pc "You're good at it though."
    pc "不过你跳得挺好的。"

# game/Scenes/Update19/Act2/act2scene11.rpy:178
translate chinese u19a2s11_9a662c74:

    # rb "Was I good at what we did last night?"
    rb "我昨晚做的那件事也做得好吗？"

# game/Scenes/Update19/Act2/act2scene11.rpy:179
translate chinese u19a2s11_bdcb291d:

    # pc "You were amazing."
    pc "你太棒了。"

# game/Scenes/Update19/Act2/act2scene11.rpy:180
translate chinese u19a2s11_25dbb93e:

    # rb "The other me is so lucky. I wish I had a guy like you."
    rb "另一个我真幸运。真希望我也能遇到像你这样的男生。"

# game/Scenes/Update19/Act2/act2scene11.rpy:184
translate chinese u19a2s11_9bc7575b:

    # cw "This is really nice. Almost as nice as our time in the woods last night."
    cw "这样真好。几乎和昨晚我们在树林里的时光一样美好。"

# game/Scenes/Update19/Act2/act2scene11.rpy:185
translate chinese u19a2s11_fda3a980:

    # pc "Yeah, that was definitely nice."
    pc "是啊，那确实很美好。"

# game/Scenes/Update19/Act2/act2scene11.rpy:186
translate chinese u19a2s11_b5ba2ff0:

    # cw "I wish I could find a guy like you. The other me is so lucky."
    cw "真希望我也能遇到像你这样的男生。另一个我真幸运。"

# game/Scenes/Update19/Act2/act2scene11.rpy:187
translate chinese u19a2s11_56554a50:

    # pc "I'm sure you will. There's got to be some decent guys in this place, right?"
    pc "我相信你一定能找到的。这地方肯定也有不错的男生吧？"

# game/Scenes/Update19/Act2/act2scene11.rpy:188
translate chinese u19a2s11_bca66348:

    # cw "I hope so."
    cw "希望如此。"

# game/Scenes/Update19/Act2/act2scene11.rpy:192
translate chinese u19a2s11_3d7381c8:

    # gg "Wow, this feels nice. Do you do this with the other me?"
    gg "哇，这种感觉真好。 你也会和另一个我这样吗？"

# game/Scenes/Update19/Act2/act2scene11.rpy:193
translate chinese u19a2s11_a1a40b20:

    # pc "Dance? Hm... no we've never actually danced."
    pc "跳舞？嗯……不，其实我们从来没跳过舞。"

# game/Scenes/Update19/Act2/act2scene11.rpy:194
translate chinese u19a2s11_54b29341:

    # gg "So, what do you two do together?"
    gg "那你们俩平时都一起做什么？"

# game/Scenes/Update19/Act2/act2scene11.rpy:195
translate chinese u19a2s11_3eeb7162:

    # pc "Uh... well, play games and stuff..."
    pc "呃……嘛，玩游戏之类的……"

# game/Scenes/Update19/Act2/act2scene11.rpy:196
translate chinese u19a2s11_93d66341:

    # gg "Maybe we could play games and stuff too... before you leave."
    gg "也许我们也可以玩游戏之类的……在你走之前。"

# game/Scenes/Update19/Act2/act2scene11.rpy:197
translate chinese u19a2s11_5b22d737:

    # pc "Maybe."
    pc "也许吧。"

# game/Scenes/Update19/Act2/act2scene11.rpy:201
translate chinese u19a2s11_6ba3e4a7:

    # sg "Sorry I'm so small. It's probably not fun to dance with me, huh?"
    sg "抱歉我这么小。跟我跳舞大概没啥意思吧？"

# game/Scenes/Update19/Act2/act2scene11.rpy:202
translate chinese u19a2s11_1c284234:

    # pc "No, it's fun."
    pc "不，很有趣。"

# game/Scenes/Update19/Act2/act2scene11.rpy:203
translate chinese u19a2s11_6ff4e07d:

    # sg "I'm too small to do anything fun."
    sg "我太小了，做不了什么有趣的事。"

# game/Scenes/Update19/Act2/act2scene11.rpy:204
translate chinese u19a2s11_45e67051:

    # pc "What do you mean? Everything about you is fun."
    pc "什么意思？你的一切都很有趣。"

# game/Scenes/Update19/Act2/act2scene11.rpy:205
translate chinese u19a2s11_f5f287fa:

    # sg "Do you think so?"
    sg "你这么觉得吗？"

# game/Scenes/Update19/Act2/act2scene11.rpy:206
translate chinese u19a2s11_61f77a4c:

    # pc "Sure."
    pc "当然。"

# game/Scenes/Update19/Act2/act2scene11.rpy:207
translate chinese u19a2s11_e220707c:

    # sg "Ugh, I just want to fuck so bad!"
    sg "唉，我好想做爱啊！"

# game/Scenes/Update19/Act2/act2scene11.rpy:211
translate chinese u19a2s11_19677897:

    # bn "This is nice. I've never danced before."
    bn "这样真好。我以前从来没跳过舞。"

# game/Scenes/Update19/Act2/act2scene11.rpy:212
translate chinese u19a2s11_7486e142:

    # pc "Why not?"
    pc "为什么不跳？"

# game/Scenes/Update19/Act2/act2scene11.rpy:213
translate chinese u19a2s11_90bb4fce:

    # bn "I guess it always seemed pointless."
    bn "大概总觉得没意义吧。"

# game/Scenes/Update19/Act2/act2scene11.rpy:214
translate chinese u19a2s11_b4e45d3a:

    # bn "There's always something else to study or learn, why waste time frivolously?"
    bn "总有其他东西要学，为什么要浪费时间做这种无聊的事？"

# game/Scenes/Update19/Act2/act2scene11.rpy:215
translate chinese u19a2s11_f6d94c63:

    # pc "You read to learn, right?"
    pc "你读书是为了学习，对吧？"

# game/Scenes/Update19/Act2/act2scene11.rpy:216
translate chinese u19a2s11_ed53db64:

    # bn "Yes."
    bn "是的。"

# game/Scenes/Update19/Act2/act2scene11.rpy:217
translate chinese u19a2s11_1ffb0547:

    # pc "You can learn things by being frivolous too. About yourself. About your feelings."
    pc "但通过放纵自己也能学到东西。关于你自己。关于你的感受。"

# game/Scenes/Update19/Act2/act2scene11.rpy:218
translate chinese u19a2s11_33b4649c:

    # bn "I suppose so. I feel like I've learned something by being this close to you."
    bn "大概吧。感觉和你这么亲近，我好像学到了些什么。"

# game/Scenes/Update19/Act2/act2scene11.rpy:222
translate chinese u19a2s11_8fead5a0:

    # mc "You are a pretty good dancer! This is fun!"
    mc "你跳得挺不错的！真好玩！"

# game/Scenes/Update19/Act2/act2scene11.rpy:223
translate chinese u19a2s11_96aa7c91:

    # pc "Thanks. Not as good as you, of course."
    pc "谢谢。当然，没你跳得好。"

# game/Scenes/Update19/Act2/act2scene11.rpy:224
translate chinese u19a2s11_4c06cee0:

    # mc "I can teach you. Private lessons."
    mc "我可以教你。私教课。"

# game/Scenes/Update19/Act2/act2scene11.rpy:225
translate chinese u19a2s11_ae871f39:

    # pc "Oh yeah?"
    pc "哦，是吗？"

# game/Scenes/Update19/Act2/act2scene11.rpy:226
translate chinese u19a2s11_4d5d6f96:

    # mc "Sure. Anything you want."
    mc "当然。你想学什么都可以。"

# game/Scenes/Update19/Act2/act2scene11.rpy:230
translate chinese u19a2s11_3da28829:

    # fr "It's been a while since I've been around people this much."
    fr "好久没跟这么多人待在一起了。"

# game/Scenes/Update19/Act2/act2scene11.rpy:231
translate chinese u19a2s11_6a7b73ba:

    # pc "And? How do we compare with your animal friends?"
    pc "那？跟你的动物朋友们比起来，我们怎么样？"

# game/Scenes/Update19/Act2/act2scene11.rpy:232
translate chinese u19a2s11_f351366e:

    # fr "Poorly."
    fr "差远了。"

# game/Scenes/Update19/Act2/act2scene11.rpy:233
translate chinese u19a2s11_c46fa0c1:

    # pc "Ouch."
    pc "哎哟。"

# game/Scenes/Update19/Act2/act2scene11.rpy:234
translate chinese u19a2s11_8d92fe46:

    # fr "But you have your positive qualities as well."
    fr "不过你们也有优点。"

# game/Scenes/Update19/Act2/act2scene11.rpy:235
translate chinese u19a2s11_3c5f6478:

    # fr "You dance better than a wolf anyway."
    fr "反正你们跳得比狼强多了。"

# game/Scenes/Update19/Act2/act2scene11.rpy:239
translate chinese u19a2s11_d1ca677b:

    # det "It's been a while since I've danced. Not since my husband. That man was a good dancer."
    det "我好久没跳舞了。自从我丈夫去世后就没跳过。那人可是个好舞者。"

# game/Scenes/Update19/Act2/act2scene11.rpy:240
translate chinese u19a2s11_93c35be1:

    # pc "I'm sorry you lost him."
    pc "很遗憾你失去了他。"

# game/Scenes/Update19/Act2/act2scene11.rpy:241
