# game/Scenes/Mari/MariConversations/maris2.rpy:14
translate chinese maris2_783e4efc:

    # fr "You can't tell?"
    fr "你看不出来吗？"

# game/Scenes/Mari/MariConversations/maris2.rpy:15
translate chinese maris2_85821b8d:

    # fr "I'm definitely more of an outdoors person."
    fr "我绝对更喜欢户外活动。"

# game/Scenes/Mari/MariConversations/maris2.rpy:16
translate chinese maris2_8ee66dab:

    # fr "I can't even stay indoors too long without needing to go out and be in nature for a while."
    fr "我甚至无法在室内待太久，总得出去亲近大自然一会儿。"

# game/Scenes/Mari/MariConversations/maris2.rpy:18
translate chinese maris2_d9c008f0:

    # fr "Sometimes I even forget to go inside at night and just fall asleep in the grass outside my house and sleep there."
    fr "有时我甚至忘了晚上进屋，就在家门口的草地上睡着了。"

# game/Scenes/Mari/MariConversations/maris2.rpy:19
translate chinese maris2_42ee6e1b:

    # fr "I think that I might have been an animal in a previous life or something - like a wolf or something, you know?"
    fr "我觉得我前世可能是一只动物——比如狼之类的，你知道吗？"

# game/Scenes/Mari/MariConversations/maris2.rpy:24
translate chinese maris2_3794e26d:

    # fr "It's just a thought I have sometimes."
    fr "这只是我偶尔会有的想法。"

# game/Scenes/Mari/MariConversations/maris2.rpy:25
translate chinese maris2_6784b437:

    # fr "I don't know if I really believe it, but it's interesting to think about."
    fr "我不确定自己是不是真的相信，但想想挺有意思的。"

# game/Scenes/Mari/MariConversations/maris2.rpy:28
translate chinese maris2_a713cad0:

    # fr "You think so?"
    fr "你这么觉得吗？"

# game/Scenes/Mari/MariConversations/maris2.rpy:29
translate chinese maris2_8240a8b8:

    # pc "For sure. Wolves are sleek and sexy and beautiful, just like you."
    pc "当然啦。狼既优雅又性感，还很漂亮，就像你一样。"

# game/Scenes/Mari/MariConversations/maris2.rpy:30
translate chinese maris2_df1d7d0b:

    # fr "What would you be then?"
    fr "那你会是什么呢？"

# game/Scenes/Mari/MariConversations/maris2.rpy:34
translate chinese maris2_219506c1:

    # pc "I'm a wolf too obviously."
    pc "我当然也是狼。"

# game/Scenes/Mari/MariConversations/maris2.rpy:36
translate chinese maris2_346436bf:

    # fr "Oh yeah?"
    fr "哦，是吗？"

# game/Scenes/Mari/MariConversations/maris2.rpy:37
translate chinese maris2_c417e350:

    # pc "Yeah."
    pc "是啊。"

# game/Scenes/Mari/MariConversations/maris2.rpy:38
translate chinese maris2_90be1d29:

    # fr "And you want to curl up in our den together?"
    fr "那你想一起蜷缩在我们的巢穴里吗？"

# game/Scenes/Mari/MariConversations/maris2.rpy:39
translate chinese maris2_98020fd4:

    # pc "That sounds nice."
    pc "听起来不错。"

# game/Scenes/Mari/MariConversations/maris2.rpy:40
translate chinese maris2_69fbca97:

    # fr "Yeah it does."
    fr "是啊，听起来很棒。"

# game/Scenes/Mari/MariConversations/maris2.rpy:43
translate chinese maris2_f3017f0b:

    # pc "I'm a rabbit, and you're definitely going to catch me."
    pc "我是只兔子，而你肯定会抓到我。"

# game/Scenes/Mari/MariConversations/maris2.rpy:45
translate chinese maris2_851db092:

    # fr "And then what?"
    fr "然后呢？"

# game/Scenes/Mari/MariConversations/maris2.rpy:46
translate chinese maris2_04568ed0:

    # fr "I could never eat you."
    fr "我绝不会吃掉你。"

# game/Scenes/Mari/MariConversations/maris2.rpy:49
translate chinese maris2_b67ddcc6:

    # fr "Maybe just chew on you a bit."
    fr "也许只是啃你几口。"

# game/Scenes/Mari/MariConversations/maris2.rpy:50
translate chinese maris2_d4745ed4:

    # pc "Not too rough, I hope?"
    pc "希望别太粗暴？"

# game/Scenes/Mari/MariConversations/maris2.rpy:51
translate chinese maris2_07df37bc:

    # fr "Never too rough. Just rough enough."
    fr "绝不会太粗暴。只是恰到好处。"

# game/Scenes/Mari/MariConversations/maris2.rpy:54
translate chinese maris2_bf649d16:

    # fr "What does that mean? That you're hunting me down?"
    fr "那是什么意思？你是说你要追捕我？"

# game/Scenes/Mari/MariConversations/maris2.rpy:55
translate chinese maris2_7d80d203:

    # fr "And you're going to shoot me?"
    fr "然后开枪打我？"

# game/Scenes/Mari/MariConversations/maris2.rpy:56
translate chinese maris2_532482d6:

    # pc "No, that's not what I meant!"
    pc "不，我不是那个意思！"

# game/Scenes/Mari/MariConversations/maris2.rpy:57
translate chinese maris2_dc45f32e:

    # pc "Just that I'm going to catch you and then you'll be mine."
    pc "只是说我会抓住你，然后你就属于我了。"

# game/Scenes/Mari/MariConversations/maris2.rpy:58
translate chinese maris2_d81b5a6b:

    # fr "That's still creepy."
    fr "这听起来还是有点毛骨悚然。"

# game/Scenes/Mari/MariConversations/maris2.rpy:59
translate chinese maris2_49cf32c0:

    # pc "Sorry, I didn't mean it like that."
    pc "抱歉，我不是那个意思。"

# game/Scenes/Mari/MariConversations/maris2.rpy:60
translate chinese maris2_1bbda5fd:

    # fr "Okay. Well, don't be creepy, okay?"
    fr "好吧。总之，别那么让人毛骨悚然，行吗？"

# game/Scenes/Mari/MariConversations/maris2.rpy:64
translate chinese maris2_72e94a73:

    # fr "Junk? Why do you have to be so judgmental about it?"
    fr "垃圾？你为什么非要对它评头论足？"

# game/Scenes/Mari/MariConversations/maris2.rpy:65
translate chinese maris2_daadc639:

    # fr "I don't know if I really believe it or not, but it's interesting to think about."
    fr "我不知道自己到底信不信，但想想挺有意思的。"

# game/Scenes/Mari/MariConversations/maris2.rpy:66
translate chinese maris2_71b2b94a:

    # fr "Just because you don't believe the same thing as somebody else doesn't mean you should make fun of it."
    fr "就因为你不信别人信的东西，不代表你就能取笑它。"

# game/Scenes/Mari/MariConversations/maris2.rpy:67
translate chinese maris2_fb77c6d3:

    # pc "Okay sorry, I didn't mean anything by it."
    pc "好吧，对不起，我没别的意思。"

# game/Scenes/Mari/MariConversations/maris2.rpy:68
translate chinese maris2_3325e215:

    # fr "Just be nice."
    fr "就别这么刻薄。"

# game/Scenes/Mari/MariConversations/maris2.rpy:69
translate chinese maris2_6e2709bd:

    # pc "Right, I will."
    pc "行，我会的。"

