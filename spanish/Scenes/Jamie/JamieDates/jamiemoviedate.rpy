# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:14
translate spanish jamiemoviedate_ddd48024:

    # gnd "Give me just a few minutes to get ready."
    gnd "Dame solo unos minutos para prepararme."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:33
translate spanish jamiemovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Llegamos al cine y nos sentamos en las últimas filas."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:34
translate spanish jamiemovietheaterstartdate_c9878d77:

    # gnd "So what are we watching anyway?"
    gnd "¿Qué vamos a ver, por cierto?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:38
translate spanish jamiemovietheaterstartdate_b4720e01:

    # gnd "Oh, I like it."
    gnd "Oh, me gusta."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:39
translate spanish jamiemovietheaterstartdate_45ba22b9:

    # gnd "Trying to put me in the mood huh?"
    gnd "¿Intentas ponerme de humor, eh?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:44
translate spanish jamiemovietheaterstartdate_d41d8cd9:

    # voice "voices/jamie_003.mp3"
    voice "voices/jamie_003.mp3"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:45
translate spanish jamiemovietheaterstartdate_642253e9:

    # gnd "Oh okay. I guess that's fine."
    gnd "Oh, vale. Supongo que está bien."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:49
translate spanish jamiemovietheaterstartdate_b7b6ccce:

    # gnd "Oh okay."
    gnd "Oh, vale."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:50
translate spanish jamiemovietheaterstartdate_984d111e:

    # gnd "Just a warning though. I might be grabbing onto you a lot."
    gnd "Pero te aviso. Puede que te esté agarrando mucho."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:51
translate spanish jamiemovietheaterstartdate_e17b2a96:

    # gnd "Like a lot a lot."
    gnd "Muchísimo."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:55
translate spanish jamiemovietheaterstartdate_0ae36cfd:

    # gnd "Oh, I like funny movies."
    gnd "Oh, me gustan las películas divertidas."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:56
translate spanish jamiemovietheaterstartdate_a8e40a21:

    # gnd "I hope it's good."
    gnd "Espero que sea buena."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:58
translate spanish jamiemovietheaterstartdate_a311ea1d:

    # "There's a little time before the movie starts."
    "Queda un rato antes de que empiece la película."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:62
translate spanish jamiemovietheaterstartdate_8da0039f:

    # "We just hang out and chat for a while."
    "Nos quedamos charlando un rato."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:65
translate spanish jamiemovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Por fin empieza la película y nos quedamos en silencio."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:67
translate spanish jamiemovietheaterstartdate_b58e95c5:

    # "Jamie leans against me."
    "Jamie se apoya contra mí."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:69
translate spanish jamiemovietheaterstartdate_d41d8cd9_1:

    # voice "voices/jamie_049.mp3"
    voice "voices/jamie_049.mp3"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:70
translate spanish jamiemovietheaterstartdate_40bb361a:

    # gnd "Want to mess around some?"
    gnd "¿Te apetece tontear un poco?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:84
translate spanish jamiemovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Se inclina y me coge la mano por encima del reposabrazos."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:87
translate spanish jamiemovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Los tráilers duran unos quince minutos, y luego empieza la película de verdad."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:91
translate spanish jamiemovietheaterstartdate_f9b1cbb0:

    # "During the movie, she keeps looking over at me."
    "Durante la película, no deja de mirarme."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:92
translate spanish jamiemovietheaterstartdate_d6b093f3:

    # pc "You like the movie?"
    pc "¿Te gusta la película?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:93
translate spanish jamiemovietheaterstartdate_18de1f8c:

    # gnd "Yeah, it's good. I just really want to kiss you right now."
    gnd "Sí, está bien. Es solo que ahora mismo me apetece mucho besarte."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:95
translate spanish jamiemovietheaterstartdate_4cdfc044:

    # "I lean in and kiss her."
    "Me inclino y la beso."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:96
translate spanish jamiemovietheaterstartdate_22ba9c92:

    # "We hold like that for some time before she finally pulls away."
    "Nos quedamos así un rato antes de que ella finalmente se aparte."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:97
translate spanish jamiemovietheaterstartdate_9e25dd4e:

    # gnd "Okay, that will hold me over."
    gnd "Vale, con eso me conformo."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:98
translate spanish jamiemovietheaterstartdate_3784a641:

    # gnd "Back to the movie."
    gnd "Volvamos a la película."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:101
translate spanish jamiemovietheaterstartdate_43311053:

    # "During the movie, she keeps looking over at me and smiling."
    "Durante la película, no deja de mirarme y sonreírme."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:103
translate spanish jamiemovietheaterstartdate_610dce56:

    # "She seems to be liking the movie okay."
    "Parece que la película le está gustando bastante."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:106
translate spanish jamiemovietheaterstartdate_ffcd1a92:

    # "She seems to lose interest in the movie fairly quickly."
    "Parece que pierde interés en la película bastante rápido."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:107
translate spanish jamiemovietheaterstartdate_5973f780:

    # "I don't know. It's pretty fun to me. I guess she just doesn't like this kind of movie."
    "No sé. A mí me parece bastante divertida. Supongo que simplemente no le gusta este tipo de películas."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:110
translate spanish jamiemovietheaterstartdate_4f23a069:

    # "During every scary scene that happens she tenses up and covers her mouth."
    "Cada vez que hay una escena de miedo, se pone tensa y se tapa la boca."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:111
translate spanish jamiemovietheaterstartdate_603a9a9b:

    # "Sometimes she even puts her hands over her eyes."
    "A veces incluso se tapa los ojos con las manos."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:112
translate spanish jamiemovietheaterstartdate_288b2f3c:

    # "Then the music goes quiet, and I know that a jumpscare is coming."
    "Luego la música se silencia, y sé que viene un susto."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:115
translate spanish jamiemovietheaterstartdate_e86e1727:

    # "She grabs my arm and tucks her head down into it."
    "Me agarra del brazo y esconde la cabeza en él."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:116
translate spanish jamiemovietheaterstartdate_6bdb4e54:

    # "Her fingers dig into my arm, grasping it so tight."
    "Sus dedos se clavan en mi brazo, agarrándolo con mucha fuerza."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:118
translate spanish jamiemovietheaterstartdate_e7200fcd:

    # "For the rest of the movie, I put my arm around her and hold her while we watch."
    "Durante el resto de la película, la rodeo con el brazo y la abrazo mientras la vemos."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:121
translate spanish jamiemovietheaterstartdate_ec13a563:

    # "The movie is funny from pretty much the very beginning."
    "La película es divertida prácticamente desde el principio."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:122
translate spanish jamiemovietheaterstartdate_4caf9a58:

    # "And we laugh together all the way through it."
    "Y nos reímos juntos durante toda la película."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:123
translate spanish jamiemovietheaterstartdate_7ad920fe:

    # "Even some of the scenes that aren't as funny, she laughs at."
    "Incluso se ríe incluso de algunas de las escenas que no son tan divertidas."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:124
translate spanish jamiemovietheaterstartdate_0d1cfe15:

    # "And seeing her laugh just makes me laugh too."
    "Y verla reírme hace que yo también me ría."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:125
translate spanish jamiemovietheaterstartdate_d855e56b:

    # "Eventually the movie ends and the credits start rolling."
    "Al final, la película termina y empiezan a aparecer los créditos."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:128
translate spanish jamiemovietheaterstartdate_0bcfb0ae:

    # gnd "That was a really sweet movie. Thanks for taking me."
    gnd "Ha sido una película muy bonita. Gracias por traerme."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:129
translate spanish jamiemovietheaterstartdate_4de625af:

    # pc "Of course you're welcome."
    pc "Por supuesto, de nada."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:132
translate spanish jamiemovietheaterstartdate_f9724275:

    # gnd "That movie wasn't really my thing, but I hope you liked it."
    gnd "Esa película no era realmente lo mío, pero espero que te haya gustado."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:133
translate spanish jamiemovietheaterstartdate_bfe93711:

    # pc "Yeah I though it was pretty cool."
    pc "Sí, me pareció bastante chula."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:134
translate spanish jamiemovietheaterstartdate_045099e4:

    # gnd "I guess so."
    gnd "Supongo que sí."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:137
translate spanish jamiemovietheaterstartdate_6d2df7c7:

    # gnd "That movie was SO scary!"
    gnd "¡Esa película daba TANTO miedo!"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:138
translate spanish jamiemovietheaterstartdate_5fcae4fe:

    # gnd "Thanks for being there for me though."
    gnd "Pero gracias por estar ahí para mí."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:139
translate spanish jamiemovietheaterstartdate_737a7b53:

    # gnd "Sorry if I hurt your arm."
    gnd "Siento si te he hecho daño en el brazo."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:140
translate spanish jamiemovietheaterstartdate_00d236b5:

    # pc "It'll heal... eventually."
    pc "Se curará... con el tiempo."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:143
translate spanish jamiemovietheaterstartdate_cd12116f:

    # gnd "That movie was SO funny!"
    gnd "¡Esa película era TAN divertida!"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:144
translate spanish jamiemovietheaterstartdate_e1a20436:

    # gnd "My chest hurts from laughing so much."
    gnd "Me duele el pecho de tanto reírme."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:145
translate spanish jamiemovietheaterstartdate_262d3cf7:

    # gnd "I loved it. Thanks for bringing me."
    gnd "Me encantó. Gracias por traerme."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:147
translate spanish jamiemovietheaterend_1a39771f:

    # gnd "Want to just sit and chat through the credits?"
    gnd "¿Quieres quedarte sentada charlando mientras pasan los créditos?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:148
translate spanish jamiemovietheaterend_61f77a4c:

    # pc "Sure."
    pc "Claro."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:152
translate spanish jamiemovietheaterend_34bf5b34:

    # "When the credits end, we walk outside together and out to our cars."
    "Cuando terminan los créditos, salimos juntos y nos dirigimos a nuestros coches."

