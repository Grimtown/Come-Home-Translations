# game/Scenes/Jamie/jamie8.rpy:13
translate spanish jamie8_98ca1a51:

    # "My phone buzzes in my pocket."
    "Mi teléfono vibra en mi bolsillo."

# game/Scenes/Jamie/jamie8.rpy:15
translate spanish jamie8_7a608d10:

    # "It's Jamie. I lie on my bed and answer the phone."
    "Es Jamie. Me tumbo en la cama y contesto el teléfono."

# game/Scenes/Jamie/jamie8.rpy:19
translate spanish jamie8_80c674d7:

    # pc "Hey, Jamie."
    pc "Hola, Jamie."

# game/Scenes/Jamie/jamie8.rpy:20
translate spanish jamie8_3d698c03:

    # gnd "Hey. You busy?"
    gnd "Hola. ¿Estás ocupado?"

# game/Scenes/Jamie/jamie8.rpy:21
translate spanish jamie8_4474e21b:

    # pc "Nah. What's up?"
    pc "No. ¿Qué pasa?"

# game/Scenes/Jamie/jamie8.rpy:22
translate spanish jamie8_34eb8872:

    # gnd "Nothing really. Just wanted to talk to you. Miss you."
    gnd "Nada en realidad. Solo quería hablar contigo. Te echo de menos."

# game/Scenes/Jamie/jamie8.rpy:23
translate spanish jamie8_71edcec9:

    # pc "Well.. you could come over?"
    pc "Bueno... ¿podrías venir?"

# game/Scenes/Jamie/jamie8.rpy:25
translate spanish jamie8_a38e761a:

    # gnd "You know I can't really do that. My dad would be so mad."
    gnd "Sabes que no puedo hacer eso. Mi padre se enfadaría mucho."

# game/Scenes/Jamie/jamie8.rpy:26
translate spanish jamie8_9f0961af:

    # pc "Why? You're an adult. Why does he get a say in what you do?"
    pc "¿Por qué? Eres adulta. ¿Por qué tiene él voz y voto en lo que haces?"

# game/Scenes/Jamie/jamie8.rpy:27
translate spanish jamie8_57cb5e24:

    # gnd "I know. I just don't want him to be mad."
    gnd "Lo sé. Es solo que no quiero que se enfade."

# game/Scenes/Jamie/jamie8.rpy:28
translate spanish jamie8_0833b2b4:

    # gnd "I'll talk to him soon though, I promise."
    gnd "Pero hablaré con él pronto, te lo prometo."

# game/Scenes/Jamie/jamie8.rpy:29
translate spanish jamie8_b1a2e372:

    # gnd "I know I need to. It's just hard, because I know he's not going to like what I have to say."
    gnd "Sé que tengo que hacerlo. Es solo que es difícil, porque sé que no le va a gustar lo que tengo que decirle."

# game/Scenes/Jamie/jamie8.rpy:30
translate spanish jamie8_6cd88cb3:

    # gnd "And he works so hard, and I love him so much. I just hate to make him upset."
    gnd "Y trabaja tan duro, y le quiero tanto. Es que odio hacerle sentir mal."

# game/Scenes/Jamie/jamie8.rpy:32
translate spanish jamie8_dbc86daf:

    # gnd "But you mean so much to me. I don't want to have to keep sneaking around, keeping us a secret."
    gnd "Pero tú significas mucho para mí. No quiero tener que seguir a escondidas, manteniendo nuestra relación en secreto."

# game/Scenes/Jamie/jamie8.rpy:33
translate spanish jamie8_aa61dfea:

    # gnd "I just need to build up the courage to do it."
    gnd "Solo necesito reunir el valor para hacerlo."

# game/Scenes/Jamie/jamie8.rpy:37
translate spanish jamie8_07bcbb36:

    # gnd "Thank you. I'm glad. You've been very patient with me."
    gnd "Gracias. Me alegro. Has sido muy paciente conmigo."

# game/Scenes/Jamie/jamie8.rpy:39
translate spanish jamie8_a5d0737c:

    # gnd "I'll make it worth it for you, I promise."
    gnd "Haré que merezca la pena, te lo prometo."

# game/Scenes/Jamie/jamie8.rpy:40
translate spanish jamie8_5de186d8:

    # pc "It's already worth it, Jamie."
    pc "Ya merece la pena, Jamie."

# game/Scenes/Jamie/jamie8.rpy:43
translate spanish jamie8_911c62b3:

    # gnd "You're right. I'm sorry."
    gnd "Tienes razón. Lo siento."

# game/Scenes/Jamie/jamie8.rpy:44
translate spanish jamie8_d5112d06:

    # gnd "You shouldn't have to deal with all of this drama. I know you're dealing with your own things, with your dad missing and all."
    gnd "No deberías tener que lidiar con todo este lío. Sé que ya tienes tus propios problemas, con la desaparición de tu padre y todo eso."

# game/Scenes/Jamie/jamie8.rpy:45
translate spanish jamie8_5a747778:

    # gnd "I should be there for you more."
    gnd "Debería estar más ahí para ti."

# game/Scenes/Jamie/jamie8.rpy:47
translate spanish jamie8_9d979554:

    # gnd "And I will be. I promise. I'll tell him soon."
    gnd "Y lo estaré. Te lo prometo. Se lo diré pronto."

# game/Scenes/Jamie/jamie8.rpy:49
translate spanish jamie8_d41d8cd9:

    # voice "voices/jamie_022.mp3"        
    voice "voices/jamie_022.mp3"        

# game/Scenes/Jamie/jamie8.rpy:50
translate spanish jamie8_f9831d1e:

    # gnd "I love you, [pcname]."
    gnd "Te quiero, [pcname]."

# game/Scenes/Jamie/jamie8.rpy:56
translate spanish jamie8_b629d4db:

    # gnd "That feels good to say... and to hear."
    gnd "Me siento bien al decirlo... y al oírlo."

# game/Scenes/Jamie/jamie8.rpy:58
translate spanish jamie8_4d7bfc98:

    # gnd "I really mean it too."
    gnd "Y lo digo de verdad."

# game/Scenes/Jamie/jamie8.rpy:60
translate spanish jamie8_d41d8cd9_1:

    # voice "voices/jamie_019.mp3"
    voice "voices/jamie_019.mp3"

# game/Scenes/Jamie/jamie8.rpy:61
translate spanish jamie8_8cee1605:

    # gnd "Ever since you came back, I've been feeling it building up, like my heart is growing bigger and bigger until it's close to bursting."
    gnd "Desde que volviste, he sentido cómo crecía este sentimiento, como si mi corazón se hiciera cada vez más grande hasta estar a punto de estallar."

# game/Scenes/Jamie/jamie8.rpy:63
translate spanish jamie8_d41d8cd9_2:

    # voice "voices/jamie_020.mp3"
    voice "voices/jamie_020.mp3"

# game/Scenes/Jamie/jamie8.rpy:64
translate spanish jamie8_55ac6cf8:

    # gnd "I smile every time I think about you, and I find myself thinking about you all the time."
    gnd "Sonrío cada vez que pienso en ti, y me doy cuenta de que pienso en ti todo el tiempo."

# game/Scenes/Jamie/jamie8.rpy:67
translate spanish jamie8_d41d8cd9_3:

    # voice "voices/jamie_021.mp3"
    voice "voices/jamie_021.mp3"

# game/Scenes/Jamie/jamie8.rpy:68
translate spanish jamie8_a90d9888:

    # gnd "I'm completely in love with you, [pcname]. I just wanted you to know that."
    gnd "Estoy completamente enamorado de ti, [pcname]. Solo quería que lo supieras."

# game/Scenes/Jamie/jamie8.rpy:69
translate spanish jamie8_9fc0bac9:

    # pc "I feel the same way, Jamie. You're amazing."
    pc "Yo siento lo mismo, Jamie. Eres increíble."

# game/Scenes/Jamie/jamie8.rpy:71
translate spanish jamie8_ff198159:

    # gnd "I'm so happy."
    gnd "Estoy tan feliz."

# game/Scenes/Jamie/jamie8.rpy:72
translate spanish jamie8_69aafc54:

    # "We talk a little longer about other less important things, until we're both practically falling asleep on the phone."
    "Hablamos un rato más de otras cosas menos importantes, hasta que los dos estamos prácticamente quedándonos dormidos al teléfono."

# game/Scenes/Jamie/jamie8.rpy:74
translate spanish jamie8_fcdf2655:

    # gnd "I better get some sleep."
    gnd "Será mejor que duerma un poco."

# game/Scenes/Jamie/jamie8.rpy:75
translate spanish jamie8_fdc5f0f0:

    # pc "Yeah, me too."
    pc "Sí, yo también."

# game/Scenes/Jamie/jamie8.rpy:77
translate spanish jamie8_d41d8cd9_4:

    # voice "voices/jamie_010.mp3"
    voice "voices/jamie_010.mp3"

# game/Scenes/Jamie/jamie8.rpy:78
translate spanish jamie8_63e5a3ef:

    # gnd "Good night, [pcname]. Love you."
    gnd "Buenas noches, [pcname]. Te quiero."

# game/Scenes/Jamie/jamie8.rpy:79
translate spanish jamie8_727173cd:

    # pc "Love you too, Jamie. Good night."
    pc "Yo también te quiero, Jamie. Buenas noches."

# game/Scenes/Jamie/jamie8.rpy:82
translate spanish jamie8_a25f5d31:

    # gnd "I mean it."
    gnd "Lo digo en serio."

# game/Scenes/Jamie/jamie8.rpy:84
translate spanish jamie8_d41d8cd9_5:

    # voice "voices/jamie_019.mp3"
    voice "voices/jamie_019.mp3"

# game/Scenes/Jamie/jamie8.rpy:85
translate spanish jamie8_796c0fbd:

    # gnd "Ever since you came back, I've been feeling it building up, like my heart growing bigger and bigger until it's almost bursting now."
    gnd "Desde que volviste, he sentido cómo crecía, como si mi corazón se hiciera cada vez más grande hasta que ahora casi estalla."

# game/Scenes/Jamie/jamie8.rpy:87
translate spanish jamie8_d41d8cd9_6:

    # voice "voices/jamie_020.mp3"
    voice "voices/jamie_020.mp3"

# game/Scenes/Jamie/jamie8.rpy:88
translate spanish jamie8_0d1296eb:

    # gnd "I smile every time I think about you, and I find myself thinking about you a lot."
    gnd "Sonrío cada vez que pienso en ti, y me doy cuenta de que pienso mucho en ti."

# game/Scenes/Jamie/jamie8.rpy:90
translate spanish jamie8_d41d8cd9_7:

    # voice "voices/jamie_021.mp3"
    voice "voices/jamie_021.mp3"

# game/Scenes/Jamie/jamie8.rpy:91
translate spanish jamie8_a90d9888_1:

    # gnd "I'm completely in love with you, [pcname]. I just wanted you to know that."
    gnd "Estoy completamente enamorado de ti, [pcname]. Solo quería que lo supieras."

# game/Scenes/Jamie/jamie8.rpy:92
translate spanish jamie8_fb4ce796:

    # pc "Oh, okay. Good to know."
    pc "Ah, vale. Me alegro de saberlo."

# game/Scenes/Jamie/jamie8.rpy:94
translate spanish jamie8_5b0a7e45:

    # "We talk awkwardly a little bit longer about less important things, then there's just silence between us for a while."
    "Hablamos un rato más, un poco incómodos, de cosas sin importancia, y luego solo hay silencio entre nosotros durante un rato."

# game/Scenes/Jamie/jamie8.rpy:95
translate spanish jamie8_fcdf2655_1:

    # gnd "I better get some sleep."
    gnd "Será mejor que me vaya a dormir."

# game/Scenes/Jamie/jamie8.rpy:96
translate spanish jamie8_fdc5f0f0_1:

    # pc "Yeah, me too."
    pc "Sí, yo también."

# game/Scenes/Jamie/jamie8.rpy:97
translate spanish jamie8_76e2f41b:

    # gnd "Okay. Good night, [pcname]."
    gnd "Vale. Buenas noches, [pcname]."

# game/Scenes/Jamie/jamie8.rpy:98
translate spanish jamie8_6fd39c33:

    # pc "Night!"
    pc "¡Buenas noches!"

# game/Scenes/Jamie/jamie8.rpy:99
translate spanish jamie8_39ca4ede:

    # "I hang up and go to sleep."
    "Cuelgo y me voy a dormir."

