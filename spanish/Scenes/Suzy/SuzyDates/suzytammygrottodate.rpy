translate spanish suzytammygrottodate_edef91a3:

    # "We get ready and go out to The Grotto together."
    "Nos preparamos y salimos juntos a The Grotto."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:19
translate spanish suzytammygrottodate_a118cb72:

    # ss "I love this place."
    ss "Me encanta este sitio."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:21
translate spanish suzytammygrottodate_f556393a:

    # tm "Me too. Thanks for taking us, [pcname]."
    tm "A mí también. Gracias por traernos, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:23
translate spanish suzytammygrottodate_ad1121f0:

    # ss "Yeah, thanks [bro]."
    ss "Sí, gracias [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:25
translate spanish suzytammygrottodate_a91a4522:

    # "We chat while we eat and enjoy the atmosphere."
    "Charlamos mientras comemos y disfrutamos del ambiente."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:33
translate spanish suzytammygrottodate_a306e385:

    # "After we eat, we dance to a couple of songs."
    "Después de comer, bailamos un par de canciones."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:36
translate spanish suzytammygrottodate_ffb49b98:

    # "Fuck, they're gorgeous. I can't help but to stare at them and wonder how I got to be so lucky."
    "Joder, son preciosas. No puedo evitar quedarme mirándolas y preguntarme cómo he tenido tanta suerte."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:39
translate spanish suzytammygrottodate_7909898e:

    # ss "You ready to take us home, [bro]?"
    ss "¿Estás listo para llevarnos a casa, [bro]?"

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:40
translate spanish suzytammygrottodate_3dae9d31:

    # pc "Uh, yeah... we should go."
    pc "Eh, sí... deberíamos irnos."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:46
translate spanish suzytammygrottodate_d41d8cd9:

    # voice 'voices/suzy_enditproperly.mp3'
    voice 'voices/suzy_enditproperly.mp3'

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:47
translate spanish suzytammygrottodate_643c2201:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "Parece que mamá ya está dormida. Entonces, ¿quieres terminar la cita aquí, o subir a tu habitación y terminarla como es debido?"

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:50
translate spanish suzytammygrottodate_df8719cf:

    # tm "Fuck yes."
    tm "Joder, sí."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:53
translate spanish suzytammygrottodate_621e1461:

    # "We quietly walk upstairs together, go into my bedroom, and lock the door."
    "Subimos juntos en silencio, entramos en mi dormitorio y cerramos la puerta con llave."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:58
translate spanish suzytammygrottodate_acfb634b:

    # ss "Okay, well I had a fun date, [bro]."
    ss "Vale, bueno, he tenido una cita divertida, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:59
translate spanish suzytammygrottodate_be17834a:

    # tm "Yeah, me too."
    tm "Sí, yo también."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:60
translate spanish suzytammygrottodate_644a5289:

    # ss "Sleep well. See you tomorrow."
    ss "Que duermas bien. Nos vemos mañana."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:61
translate spanish suzytammygrottodate_d35669a0:

    # tm "Good night, [pcname]."
    tm "Buenas noches, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:64
translate spanish suzytammygrottodate_d747330a:

    # "They go up to Suzy's bedroom, leaving me to decide what I want to do with my night."
    "Suben al dormitorio de Suzy, dejándome decidir qué quiero hacer con mi noche."

