# game/Scenes/Mari/MariDates/marimoviedate.rpy:26
translate spanish marimovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Llegamos al cine y nos sentamos en las últimas filas."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:27
translate spanish marimovietheaterstartdate_d03e5a70:

    # fr "So what are we watching anyway?"
    fr "¿Qué vamos a ver, por cierto?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:31
translate spanish marimovietheaterstartdate_346436bf:

    # fr "Oh yeah?"
    fr "¿Ah, sí?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:32
translate spanish marimovietheaterstartdate_3aed9093:

    # fr "I love romance movies. As long as they're not too corny."
    fr "Me encantan las películas románticas. Siempre que no sean demasiado cursis."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:35
translate spanish marimovietheaterstartdate_337ed84d:

    # fr "Hrm, okay well that sounds fun."
    fr "Mmm, vale, pues eso suena divertido."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:36
translate spanish marimovietheaterstartdate_7a1524b8:

    # fr "As long as it isn't just two buff guys slapping their meat together."
    fr "Siempre que no sean solo dos tíos musculosos dándose golpes con sus músculos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:38
translate spanish marimovietheaterstartdate_d3cf7e4e:

    # fr "Actually, that sounds pretty fun too."
    fr "La verdad, eso también suena bastante divertido."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:43
translate spanish marimovietheaterstartdate_d41d8cd9:

    # voice 'voices/mari_really.mp3'
    voice 'voices/mari_really.mp3'

# game/Scenes/Mari/MariDates/marimoviedate.rpy:44
translate spanish marimovietheaterstartdate_67fd9cd9:

    # fr "Really?"
    fr "¿En serio?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:45
translate spanish marimovietheaterstartdate_8b77409f:

    # fr "I don't really do scary movies very well."
    fr "No se me dan muy bien las películas de miedo."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:46
translate spanish marimovietheaterstartdate_cb84ad92:

    # fr "I might just have my eyes closed and be holding you through the whole thing."
    fr "Puede que tenga los ojos cerrados y te esté abrazando durante toda la película."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:51
translate spanish marimovietheaterstartdate_321fa232:

    # fr "Oh good, I need a good laugh."
    fr "Oh, bien, necesito reírme un rato."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:52
translate spanish marimovietheaterstartdate_76b9da8b:

    # fr "As long as it's not one of those gross-out sex comedies. I'm not really into those."
    fr "Siempre que no sea una de esas comedias sexuales asquerosas. No me gustan mucho esas."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:56
translate spanish marimovietheaterstartdate_f3087137:

    # fr "Oh good! You know what I like."
    fr "¡Oh, bien! Sabes lo que me gusta."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:57
translate spanish marimovietheaterstartdate_3224e393:

    # fr "I love animated stuff. Especially when it's about talking animals."
    fr "Me encantan las películas de animación. Especialmente cuando tratan de animales que hablan."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:60
translate spanish marimovietheaterstartdate_f45af0c0:

    # "There's a little time before the movie starts for us to chat."
    "Tenemos un poco de tiempo antes de que empiece la película para charlar."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:64
translate spanish marimovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Por fin empieza la película y nos quedamos en silencio."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:66
translate spanish marimovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Ella se inclina y me coge la mano por encima del reposabrazos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:67
translate spanish marimovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Los tráilers duran unos quince minutos, y luego empieza la película de verdad."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:71
translate spanish marimovietheaterstartdate_17eefcb1:

    # "During the movie, she leans on my shoulder, really getting into the story."
    "Durante la película, ella se apoya en mi hombro, metiéndose de lleno en la historia."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:73
translate spanish marimovietheaterstartdate_1b60b301:

    # "Then during a particularly romantic scene, she raises her head and puts her lips to mine."
    "Luego, durante una escena especialmente romántica, levanta la cabeza y acerca sus labios a los míos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:74
translate spanish marimovietheaterstartdate_787192bc:

    # "We don't really watch a lot of the rest of the movie, instead focusing on making out."
    "No vemos gran parte del resto de la película, sino que nos centramos en besarnos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:77
translate spanish marimovietheaterstartdate_d17a4ae6:

    # "During the movie, she leans against my shoulder, really getting into the story."
    "Durante la película, ella se apoya en mi hombro, metiéndose de lleno en la historia."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:80
translate spanish marimovietheaterstartdate_284094da:

    # "Mari watches the movie, but I'm not really sure how much she likes it."
    "Mari ve la película, pero no estoy muy seguro de cuánto le gusta."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:83
translate spanish marimovietheaterstartdate_26b74708:

    # "Eventually, she turns towards me and whispers."
    "Al final, se gira hacia mí y me susurra:"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:84
translate spanish marimovietheaterstartdate_5aa661f3:

    # fr "I'm not really into this movie. Want to just make out?"
    fr "«Esta película no me gusta mucho. ¿No queremos simplemente besarnos?»."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:86
translate spanish marimovietheaterstartdate_d0a52fcf:

    # "I lean in and kiss her and we don't really watch much else of the movie, instead focusing on each other."
    "Me inclino y la beso, y ya no vemos mucho más de la película, sino que nos centramos el uno en el otro."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:89
translate spanish marimovietheaterstartdate_ae5e6aa0:

    # "To give her some credit, she tries to watch a little bit of the movie."
    "Hay que reconocerle el mérito de que intenta ver un poco la película."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:90
translate spanish marimovietheaterstartdate_c601de66:

    # "But by the time the scary parts start, she is pretty much done."
    "Pero cuando empiezan las partes de miedo, ya está bastante harta."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:92
translate spanish marimovietheaterstartdate_fafc8629:

    # "She tucks her head down against me and hides the movie from her sight."
    "Apoya la cabeza contra mí y se tapa la pantalla con la mano."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:93
translate spanish marimovietheaterstartdate_324b6470:

    # "She stays right there, not watching anything for the rest of the movie."
    "Se queda así, sin ver nada durante el resto de la película."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:96
translate spanish marimovietheaterstartdate_b27a7e4c:

    # "Mari's eyes are focused on the movie throughout the whole thing."
    "Los ojos de Mari están fijos en la película durante toda la proyección."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:97
translate spanish marimovietheaterstartdate_125a0ff3:

    # "She laughs, she cries, she taps her foot along with the music."
    "Se ríe, llora, da golpecitos con el pie al ritmo de la música."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:98
translate spanish marimovietheaterstartdate_e4a43b4e:

    # "We have a great time."
    "Lo pasamos genial."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:101
translate spanish marimovietheaterstartdate_8f27901e:

    # "The movie is pretty funny all the way through and Mari and I laugh a lot."
    "La película es bastante divertida de principio a fin y Mari y yo nos reímos mucho."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:104
translate spanish marimovietheaterstartdate_abcf9a29:

    # "Then somehow that turns into us making out."
    "Luego, de alguna manera, eso acaba en que nos besamos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:105
translate spanish marimovietheaterstartdate_46b84a07:

    # "We don't really watch much of the movie after that."
    "La verdad es que no vemos gran parte de la película después de eso."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:106
translate spanish marimovietheaterstartdate_d855e56b:

    # "Eventually the movie ends and the credits start rolling."
    "Al final, la película termina y empiezan a aparecer los créditos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:109
translate spanish marimovietheaterstartdate_f176d1eb:

    # fr "That was a cute movie."
    fr "Ha sido una película bonita."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:111
translate spanish marimovietheaterstartdate_b1836b04:

    # fr "What little I saw of it anyway."
    fr "Por lo poco que he visto, al menos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:112
translate spanish marimovietheaterstartdate_91db2110:

    # fr "I like what we did even more than the movie."
    fr "Me gusta lo que hemos hecho incluso más que la película."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:113
translate spanish marimovietheaterstartdate_e25ed9ba:

    # fr "Thanks for taking me."
    fr "Gracias por llevarme."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:116
translate spanish marimovietheaterstartdate_eb286352:

    # fr "Well the movie wasn't really my thing."
    fr "Bueno, la película no era realmente lo mío."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:118
translate spanish marimovietheaterstartdate_8fc45fba:

    # fr "But seeing it with you made it a lot better."
    fr "Pero verla contigo la hizo mucho mejor."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:121
translate spanish marimovietheaterstartdate_c58b0ecd:

    # fr "I'm a big baby, I know."
    fr "Soy un gran bebé, lo sé."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:122
translate spanish marimovietheaterstartdate_acdb9025:

    # fr "But I hated that. Even when I stopped watching it, the noises were still scary."
    fr "Pero la odié. Incluso cuando dejé de verla, los ruidos seguían dando miedo."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:123
translate spanish marimovietheaterstartdate_26d0b7c9:

    # pc "I'm sorry, I didn't realize that you disliked horror movies so much."
    pc "Lo siento, no me había dado cuenta de que te disgustaban tanto las películas de terror."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:124
translate spanish marimovietheaterstartdate_30078caa:

    # fr "They just bring back bad memories and make me think about sad things."
    fr "Es que me traen malos recuerdos y me hacen pensar en cosas tristes."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:127
translate spanish marimovietheaterstartdate_c3aec289:

    # fr "That movie was so cute! I loved it!"
    fr "¡Esa película era tan bonita! ¡Me encantó!"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:128
translate spanish marimovietheaterstartdate_070969bf:

    # fr "Thanks so much for bringing me."
    fr "Muchas gracias por traerme."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:131
translate spanish marimovietheaterstartdate_4549f151:

    # fr "That was a fun movie."
    fr "Ha sido una película divertida."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:133
translate spanish marimovietheaterstartdate_b1836b04_1:

    # fr "What little I saw of it anyway."
    fr "Por lo poco que he visto, al menos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:134
translate spanish marimovietheaterstartdate_91db2110_1:

    # fr "I like what we did even more than the movie."
    fr "Me gusta más lo que hemos hecho que la película."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:135
translate spanish marimovietheaterstartdate_233f5bf6:

    # "When the credits start rolling, we hang out and chat through them."
    "Cuando empiezan a aparecer los créditos, nos quedamos charlando mientras pasan."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:139
translate spanish marimovietheaterstartdate_972891e3:

    # "When the credits end, we walk outside together and out to my car."
    "Cuando terminan los créditos, salimos juntos y nos dirigimos a mi coche."

translate spanish strings:

    # game/Scenes/Mari/MariDates/marimoviedate.rpy:2
    old "When you are able to ask Mari out on a date, take her to the movie theater."
    new "Cuando consigas invitar a Mari a salir, llévala al cine."

    # game/Scenes/Mari/MariDates/marimoviedate.rpy:3
    old "She will only be able to go to the movies in the evening on weekends."
    new "Solo podrá ir al cine por la tarde los fines de semana."

    # game/Scenes/Mari/MariDates/marimoviedate.rpy:54
    old "Something animated"
    new "Algo de animación"

