translate chinese bai1d_8c24f368:

    # bai "So would you be up for one of these little dates again?"
    bai "那你愿意再约一次这种小约会吗？"

# game/Scenes/Bai/bai1.rpy:242
translate chinese bai1d_802bd748:

    # bai "I'm glad to hear it. Can't wait for our next one."
    bai "听到你这么说真好。已经等不及下次了。"

# game/Scenes/Bai/bai1.rpy:245
translate chinese bai1d_3c769f7a:

    # bai "I mean we don't have to call it that, I was just joking."
    bai "我的意思是，我们不必非得这么称呼，我只是开个玩笑。"

# game/Scenes/Bai/bai1.rpy:249
translate chinese bai1d_96804e49:

    # bai "Okay."
    bai "好的。"

# game/Scenes/Bai/bai1.rpy:250
translate chinese bai1d_b5ad529f:

    # bai "Well I can't wait for our next one then."
    bai "那我也很期待下次了。"

# game/Scenes/Bai/bai1.rpy:254
translate chinese bai1d_8844c594:

    # bai "Okay, that's cool."
    bai "好的，没问题。"

# game/Scenes/Bai/bai1.rpy:255
translate chinese bai1d_681f0b18:

    # bai "Well I'm looking forward to the next time we can hang out then."
    bai "那我就期待下次能再一起出去玩了。"

# game/Scenes/Bai/bai1.rpy:257
translate chinese bai1d_d0ca3261:

    # bai "Hope we can hang out like this again soon."
    bai "希望我们能很快再这样聚聚。"

# game/Scenes/Bai/bai1.rpy:258
translate chinese bai1d_03eaad50_1:

    # pc "Me too."
    pc "我也是。"

# game/Scenes/Bai/bai1.rpy:260
translate chinese bai1d_30423311:

    # bai "Hey before we leave, let me give you my phone number."
    bai "嘿，走之前，让我把电话号码给你。"

# game/Scenes/Bai/bai1.rpy:261
translate chinese bai1d_0b8345e6:

    # bai "I don't have a lot of friends around here, so I'd love to just chat with you whenever you feel up to it."
    bai "我在这儿没多少朋友，所以只要你有空，我很乐意和你聊聊天。"

# game/Scenes/Bai/bai1.rpy:262
translate chinese bai1d_465c988e:

    # bai "And maybe we can go out again sometime soon."
    bai "说不定我们很快就能再出去玩一次。"

# game/Scenes/Bai/bai1.rpy:263
translate chinese bai1d_50eb93b7:

    # pc "Okay, sounds good."
    pc "好的，听起来不错。"

# game/Scenes/Bai/bai1.rpy:270
translate chinese bai1d_0e8a2008:

    # "We finish up our food, he leaves some money on the table, then we head outside."
    "我们吃完饭，他把钱留在桌上，然后我们走出了餐厅。"

# game/Scenes/Bai/bai1.rpy:271
translate chinese bai1d_630eae85:

    # bai "Well that was the most fun I've had in a while."
    bai "这真是我最近玩得最开心的一次。"

# game/Scenes/Bai/bai1.rpy:272
translate chinese bai1d_a96bfd7d:

    # bai "Thanks again for hanging out with me tonight."
    bai "谢谢你今晚陪我。"

# game/Scenes/Bai/bai1.rpy:273
translate chinese bai1d_fe5246ec:

    # pc "No problem. I had fun too."
    pc "不客气。我也玩得很开心。"

# game/Scenes/Bai/bai1.rpy:274
translate chinese bai1d_b6980062:

    # bai "Alright, well I better head home."
    bai "好吧，我该回家了。"

# game/Scenes/Bai/bai1.rpy:276
translate chinese bai1d_5d4a4d14:

    # bai "I'll see you later."
    bai "回头见。"

# game/Scenes/Bai/bai1.rpy:277
translate chinese bai1d_1aff6c8c:

    # pc "See ya, Bai."
    pc "再见，白。"

# game/Scenes/Bai/bai1.rpy:278
translate chinese bai1d_ba9439b8:

    # "He goes to his car and drives off and I walk to mine."
    "他走到车旁开走了，我则走向自己的车。"

