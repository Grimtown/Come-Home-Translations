# game/Scenes/Update20/u20f.rpy:2
translate spanish u20f_7d92946f:

    # "For now, I should go see Mari."
    "Por ahora, debería ir a ver a Mari."

# game/Scenes/Update20/u20f.rpy:5
translate spanish u20f_2bb3b023:

    # "I drive to Mari's house and knock on her door."
    "Conduzco hasta la casa de Mari y llamo a la puerta."

# game/Scenes/Update20/u20f.rpy:6
translate spanish u20f_0b175aad:

    # "Her dogs start barking at the door and I hear footsteps approaching."
    "Sus perros empiezan a ladrar en la puerta y oigo pasos que se acercan."

# game/Scenes/Update20/u20f.rpy:7
translate spanish u20f_be91a4c9:

    # fr "Who is it?"
    fr "¿Quién es?"

# game/Scenes/Update20/u20f.rpy:8
translate spanish u20f_1063bb8b:

    # pc "It's me! [pcname]."
    pc "¡Soy yo! [pcname]."

# game/Scenes/Update20/u20f.rpy:12
translate spanish u20f_a9b3d399:

    # fr "Oh my God, [pcname]!"
    fr "¡Dios mío, [pcname]!"

# game/Scenes/Update20/u20f.rpy:13
translate spanish u20f_ea03fec2:

    # "She opens the door and stares at me for a moment, shocked."
    "Abre la puerta y se queda mirándome un momento, sorprendida."

# game/Scenes/Update20/u20f.rpy:14
translate spanish u20f_40412d0f:

    # "I can see her eyes welling up with tears."
    "Veo cómo se le llenan los ojos de lágrimas."

# game/Scenes/Update20/u20f.rpy:15
translate spanish u20f_23647146:

    # fr "I thought..."
    fr "Pensé que..."

# game/Scenes/Update20/u20f.rpy:18
translate spanish u20f_540e25ed:

    # "She rushes into my arms and hugs me tightly."
    "Se lanza a mis brazos y me abraza con fuerza."

# game/Scenes/Update20/u20f.rpy:19
translate spanish u20f_140e4956:

    # "I hug her back, feeling her warmth and the softness of her body."
    "Yo también la abrazo, sintiendo su calor y la suavidad de su cuerpo."

# game/Scenes/Update20/u20f.rpy:20
translate spanish u20f_dddaeb84:

    # pc "I missed you, Mari. I'm sorry I was gone for so long."
    pc "Te he echado de menos, Mari. Siento haber estado fuera tanto tiempo."

# game/Scenes/Update20/u20f.rpy:23
translate spanish u20f_b77230d2:

    # fr "I was so worried about you. I thought that machine killed you."
    fr "Estaba muy preocupada por ti. Pensé que esa máquina te había matado."

# game/Scenes/Update20/u20f.rpy:24
translate spanish u20f_40e4fe9b:

    # pc "I fought so hard to get back."
    pc "Luché con todas mis fuerzas para volver."

# game/Scenes/Update20/u20f.rpy:25
translate spanish u20f_356f7f42:

    # pc "I'll tell you everything tomorrow, I promise."
    pc "Mañana te lo contaré todo, te lo prometo."

# game/Scenes/Update20/u20f.rpy:28
translate spanish u20f_e5e85df6:

    # fr "I'm just glad you're back."
    fr "Me alegro de que hayas vuelto."

# game/Scenes/Update20/u20f.rpy:29
translate spanish u20f_1f943087:

    # fr "Wow, your hair grew a lot."
    fr "Vaya, se te ha crecido mucho el pelo."

# game/Scenes/Update20/u20f.rpy:30
translate spanish u20f_c49af8d0:

    # fr "It makes you look all rugged."
    fr "Te da un aire muy rudo."

# game/Scenes/Update20/u20f.rpy:33
translate spanish u20f_7d64063d:

    # "She kisses me softly, her lips warm and inviting."
    "Me besa suavemente, con unos labios cálidos y tentadores."

# game/Scenes/Update20/u20f.rpy:34
translate spanish u20f_e6ca1864:

    # fr "I'm so happy you came home."
    fr "Me alegro mucho de que hayas vuelto a casa."

# game/Scenes/Update20/u20f.rpy:35
translate spanish u20f_402e55b1:

    # fr "Let's go to bed. We can talk in the morning."
    fr "Vamos a la cama. Podemos hablar por la mañana."

