# TODO: Translation updated at 2026-04-15 14:25

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:29
translate spanish rebamovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Llegamos al cine y nos sentamos en las últimas filas."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:30
translate spanish rebamovietheaterstartdate_29279ffb:

    # rb "So what are we watching anyway?"
    rb "¿Qué vamos a ver, por cierto?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:34
translate spanish rebamovietheaterstartdate_bb40bd64:

    # rb "Oh yeah?"
    rb "¿Ah, sí?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:36
translate spanish rebamovietheaterstartdate_efb601e5:

    # rb "I hope it's the sexy kind. Where they get all sweaty and the lighting is dim, then it pans away right before they start going at it."
    rb "Espero que sea de esas pelis sexys. Donde se ponen todos sudados y la luz está tenue, y luego la cámara se aleja justo antes de que empiecen a hacerlo."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:37
translate spanish rebamovietheaterstartdate_516fc9fb:

    # rb "Is it that kind of romantic?"
    rb "¿Es de ese tipo de románticas?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:38
translate spanish rebamovietheaterstartdate_f9e1c11e:

    # pc "Um, I don't know? Maybe?"
    pc "Eh, no sé. ¿Quizás?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:42
translate spanish rebamovietheaterstartdate_e0c6223d:

    # rb "Yeah! Big macho guys with guns and explosions! I love that stuff!"
    rb "¡Sí! ¡Tíos machotes con armas y explosiones! ¡Me encanta eso!"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:46
translate spanish rebamovietheaterstartdate_832a0115:

    # rb "Oh yeah? I'm not really into scary movies much. They never seem to really be scary to me."
    rb "¿Ah, sí? No me gustan mucho las películas de miedo. A mí nunca me parecen realmente de miedo."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:47
translate spanish rebamovietheaterstartdate_10e4b7a7:

    # rb "But I'll give it a try. It'll give me an excuse to cuddle up next to you, at least."
    rb "Pero le daré una oportunidad. Al menos me dará una excusa para acurrucarme a tu lado."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:51
translate spanish rebamovietheaterstartdate_eb93d29d:

    # rb "Oh God, you're going to hear my horse laugh then."
    rb "Dios mío, entonces vas a oír mi risa de caballo."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:53
translate spanish rebamovietheaterstartdate_6cc4cd44:

    # "There's a little time to chat before the movie starts."
    "Tenemos un rato para charlar antes de que empiece la película."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:57
translate spanish rebamovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Por fin empieza la película y nos quedamos en silencio."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:59
translate spanish rebamovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Ella se inclina y me coge la mano por encima del reposabrazos."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:60
translate spanish rebamovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Los tráilers duran unos quince minutos, y luego empieza de verdad la película."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:62
translate spanish rebamovietheaterstartdate_610dce56:

    # "She seems to be liking the movie okay."
    "Parece que la película le está gustando bastante."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:64
translate spanish rebamovietheaterstartdate_1e52f74a:

    # "During the movie, she leans against my shoulder, looking happy, if a little bored."
    "Durante la película, se apoya en mi hombro, con cara de felicidad, aunque un poco aburrida."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:67
translate spanish rebamovietheaterstartdate_e7628aae:

    # "Reba really gets into the movie. When there's a big action scene, she's even mimicking punches and cheering at the explosions."
    "A Reba le engancha mucho la película. Cuando hay una gran escena de acción, incluso imita los puñetazos y anima ante las explosiones."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:69
translate spanish rebamovietheaterstartdate_8197bbed:

    # "Reba looks bored through most of the movie."
    "Reba parece aburrida durante la mayor parte de la película."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:71
translate spanish rebamovietheaterstartdate_2bff2bcf:

    # "She leans against my shoulder and watches silently. Even the jump scares that make me jolt a bit don't seem to have any effect on her."
    "Se apoya en mi hombro y mira en silencio. Ni siquiera los sustos que me hacen sobresaltar un poco parecen tener ningún efecto en ella."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:74
translate spanish rebamovietheaterstartdate_427a223e:

    # "Reba laughs pretty frequently throughout the movie. At first, just little chuckles, but then her laughs turn into loud horse-like whinnies."
    "Reba se ríe bastante a menudo durante toda la película. Al principio, solo son risitas, pero luego sus risas se convierten en fuertes relinchos parecidos a los de un caballo."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:75
translate spanish rebamovietheaterstartdate_8c6a087e:

    # "A few of the people in seats nearby turn and look at us."
    "Algunas de las personas de los asientos cercanos se giran y nos miran."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:76
translate spanish rebamovietheaterstartdate_65ecd1be:

    # "I'm a little embarrassed at first, but fuck them, she's having a good time and I love that."
    "Al principio me da un poco de vergüenza, pero que les den, ella se lo está pasando bien y eso me encanta."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:79
translate spanish rebamovietheaterstartdate_65588a69:

    # rb "That movie was cute. I wish there was a little bit more of the adult stuff in it though, you know?"
    rb "Esa película era mona. Aunque me hubiera gustado que tuviera un poco más de contenido para adultos, ¿sabes?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:80
translate spanish rebamovietheaterstartdate_73b7e285:

    # rb "Thanks for bringing me."
    rb "Gracias por traerme."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:83
translate spanish rebamovietheaterstartdate_0ffc7e30:

    # rb "That movie was freaking awesome!"
    rb "¡Esa película fue alucinante!"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:85
translate spanish rebamovietheaterstartdate_06b31029:

    # rb "Like when he went wham, blam, kapow, krakaTHOOM!"
    rb "¡Como cuando él hizo «wham, blam, kapow, krakaTHOOM»!"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:87
translate spanish rebamovietheaterstartdate_f9b2297b:

    # rb "I loved it! Thanks for bringing me."
    rb "¡Me encantó! Gracias por traerme."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:90
translate spanish rebamovietheaterstartdate_6f921b8c:

    # rb "Wow that was boring. Horror movies just don't do anything for me. Everybody is so dang stupid."
    rb "Vaya, qué aburrido. Las películas de terror no me dicen nada. Todo el mundo es tan estúpido."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:91
translate spanish rebamovietheaterstartdate_a692f6a1:

    # rb "Let's watch something different next time. Horror movies are dumb."
    rb "Veamos algo diferente la próxima vez. Las películas de terror son una tontería."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:94
translate spanish rebamovietheaterstartdate_4449a4f2:

    # rb "Sorry for laughing so hard. It was really funny though, right?"
    rb "Perdón por reírme tanto. Pero fue muy divertido, ¿verdad?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:95
translate spanish rebamovietheaterstartdate_e8d58dda:

    # pc "Yeah it was. Your laugh made me laugh even harder."
    pc "Sí, lo fue. Tu risa me hizo reír aún más."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:96
translate spanish rebamovietheaterstartdate_19609177:

    # rb "I know, it's an annoying laugh, but it's mine. Can't do anything for it, ya know?"
    rb "Lo sé, es una risa molesta, pero es la mía. No puedo evitarlo, ¿sabes?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:99
translate spanish rebamovietheaterstartdate_233f5bf6:

    # "When the credits start rolling, we hang out and chat through them."
    "Cuando empiezan a aparecer los créditos, nos quedamos charlando mientras pasan."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:103
translate spanish rebamovietheaterstartdate_029f1c23:

    # "Then when the screen goes black, we walk outside together to my car."
    "Luego, cuando la pantalla se queda en negro, salimos juntos hacia mi coche."

