    old "Nope. Just you"
    new "不，只有你"

    # game/Scenes/Mari/mari13.rpy:274
    old "You'd be up for a threesome?"
    new "你想来个三人行吗？"

    # game/Scenes/Mari/mari13.rpy:277
    old "Agree"
    new "同意"

    # game/Scenes/Mari/mari13.rpy:285
    old "Reject"
    new "拒绝"

    # game/Scenes/Mari/mari13.rpy:670
    old "Nah, I better get home"
    new "算了，我还是回家吧"

