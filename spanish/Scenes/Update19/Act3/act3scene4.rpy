# TODO: Translation updated at 2026-04-15 14:25

# game/Scenes/Update19/Act3/act3scene4.rpy:4
translate spanish act3scene4_594c2912:

    # "In a blink, I'm suddenly back in the Ice Queen's throne room."
    "En un abrir y cerrar de ojos, de repente estoy de vuelta en la sala del trono de la Reina de Hielo."

# game/Scenes/Update19/Act3/act3scene4.rpy:6
translate spanish act3scene4_41d6859f:

    # "My friends are still frozen around me, but I feel my body thawing."
    "Mis amigos siguen congelados a mi alrededor, pero siento que mi cuerpo se descongela."

# game/Scenes/Update19/Act3/act3scene4.rpy:9
translate spanish act3scene4_785bdb9f:

    # "When I can move again, I stumble forward and almost fall."
    "Cuando puedo volver a moverme, tropiezo hacia delante y casi me caigo."

# game/Scenes/Update19/Act3/act3scene4.rpy:10
translate spanish act3scene4_9fe7bb42:

    # "But I'm able to stop myself and it seems that the Ice Queen didn't notice."
    "Pero consigo detenerme y parece que la Reina de Hielo no se ha dado cuenta."

# game/Scenes/Update19/Act3/act3scene4.rpy:11
translate spanish act3scene4_269679eb:

    # "Time to make my move."
    "Es hora de actuar."

# game/Scenes/Update19/Act3/act3scene4.rpy:15
translate spanish act3scene4_f4ddd564:

    # "I rush up and hug her from behind, pulling her close to me."
    "Corro hacia ella y la abrazo por detrás, atrayéndola hacia mí."

# game/Scenes/Update19/Act3/act3scene4.rpy:16
translate spanish act3scene4_6145e44f:

    # sp "WHAT!?"
    sp "¡¿QUÉ?!"

# game/Scenes/Update19/Act3/act3scene4.rpy:17
translate spanish act3scene4_d519fcc2:

    # sp "{i}WHAT{/i} are you doing? Unhand me!"
    sp "{i}¿QUÉ{/i} estás haciendo? ¡Suéltame!"

# game/Scenes/Update19/Act3/act3scene4.rpy:20
translate spanish act3scene4_0d90b60a:

    # pc "I'm sorry that you lost Suzy. I'm so sorry that happened to you."
    pc "Siento que hayas perdido a Suzy. Siento mucho lo que te ha pasado."

# game/Scenes/Update19/Act3/act3scene4.rpy:21
translate spanish act3scene4_641a9d68:

    # sp "Don't say her name--"
    sp "No digas su nombre..."

# game/Scenes/Update19/Act3/act3scene4.rpy:22
translate spanish act3scene4_ad5d8a1e:

    # pc "I know your heart is broken."
    pc "Sé que tienes el corazón roto."

# game/Scenes/Update19/Act3/act3scene4.rpy:23
translate spanish act3scene4_c39f9ad8:

    # pc "That just shows how much love you had."
    pc "Eso solo demuestra cuánto la querías."

# game/Scenes/Update19/Act3/act3scene4.rpy:24
translate spanish act3scene4_eb5ca914:

    # sp "You don't know--"
    sp "No sabes..."

# game/Scenes/Update19/Act3/act3scene4.rpy:27
translate spanish act3scene4_82d048f3:

    # pc "Suzy wants you to know that she loves you so much."
    pc "Suzy quiere que sepas que te quiere muchísimo."

# game/Scenes/Update19/Act3/act3scene4.rpy:28
translate spanish act3scene4_acba1f83:

    # sp "Stop--"
    sp "Para..."

# game/Scenes/Update19/Act3/act3scene4.rpy:31
translate spanish act3scene4_cdd644dd:

    # pc "She wants you to know that she's going to always be with you."
    pc "Quiere que sepas que siempre estará contigo."

# game/Scenes/Update19/Act3/act3scene4.rpy:32
translate spanish act3scene4_10d0ad27:

    # sp "How do you--"
    sp "¿Cómo sabes...?"

# game/Scenes/Update19/Act3/act3scene4.rpy:35
translate spanish act3scene4_978f88d1:

    # pc "And she doesn't like seeing what you've become."
    pc "Y no le gusta ver en lo que te has convertido."

# game/Scenes/Update19/Act3/act3scene4.rpy:36
translate spanish act3scene4_8144a68d:

    # pc "She wants you to be warm and loving again, like she remembers you."
    pc "Quiere que vuelvas a ser cálida y cariñosa, como te recuerda."

# game/Scenes/Update19/Act3/act3scene4.rpy:37
translate spanish act3scene4_ad07f09a:

    # sp "I'm not--"
    sp "Yo no..."

# game/Scenes/Update19/Act3/act3scene4.rpy:40
translate spanish act3scene4_38d06822:

    # "She doesn't finish her sentence, instead bursting into tears and crumpling in my arms."
    "No termina la frase, sino que estalla en llanto y se derrumba en mis brazos."

# game/Scenes/Update19/Act3/act3scene4.rpy:41
translate spanish act3scene4_5b98a3b5:

    # pc "I'm sorry, Lisa. I'm sorry she's gone."
    pc "Lo siento, Lisa. Siento que se haya ido."

# game/Scenes/Update19/Act3/act3scene4.rpy:42
translate spanish act3scene4_d761b7e0:

    # pc "I love you."
    pc "Te quiero."

# game/Scenes/Update19/Act3/act3scene4.rpy:45
translate spanish act3scene4_3689094d:

    # "I hold her for a long time while she cries."
    "La abrazo durante un buen rato mientras llora."

# game/Scenes/Update19/Act3/act3scene4.rpy:46
translate spanish act3scene4_fcd85bea:

    # "I wonder if she's ever let herself really feel the loss."
    "Me pregunto si alguna vez se ha permitido sentir de verdad la pérdida."

# game/Scenes/Update19/Act3/act3scene4.rpy:47
translate spanish act3scene4_6f05f3c1:

    # "I wonder if she's ever had anybody to hold her like this."
    "Me pregunto si alguna vez ha tenido a alguien que la abrazara así."

# game/Scenes/Update19/Act3/act3scene4.rpy:50
translate spanish act3scene4_49651a35:

    # "After some time, she stops crying and sits up again."
    "Al cabo de un rato, deja de llorar y se incorpora."

# game/Scenes/Update19/Act3/act3scene4.rpy:51
translate spanish act3scene4_77d46c18:

    # sp "Who {i}are{/i} you?"
    sp "¿Quién {i}eres{/i}?"

# game/Scenes/Update19/Act3/act3scene4.rpy:52
translate spanish act3scene4_22be1576:

    # pc "It's a long story..."
    pc "Es una larga historia..."

# game/Scenes/Update19/Act3/act3scene4.rpy:53
translate spanish act3scene4_0eb855c9:

    # "So I tell her everything about the other world, about the bracelet, about coming here to see her."
    "Así que le cuento todo sobre el otro mundo, sobre la pulsera, sobre venir aquí a verla."

# game/Scenes/Update19/Act3/act3scene4.rpy:56
translate spanish act3scene4_299824e4:

    # sp "You did so much to find your father."
    sp "Hiciste mucho por encontrar a tu padre."

# game/Scenes/Update19/Act3/act3scene4.rpy:57
translate spanish act3scene4_4aa0965e:

    # pc "Well yeah... I love him."
    pc "Bueno, sí... Lo quiero."

# game/Scenes/Update19/Act3/act3scene4.rpy:58
translate spanish act3scene4_2c93668b:

    # sp "I suppose so. I'd do anything to get Suzy back."
    sp "Supongo que sí. Yo haría cualquier cosa por recuperar a Suzy."

# game/Scenes/Update19/Act3/act3scene4.rpy:61
translate spanish act3scene4_f8215d8f:

    # pc "I know, [mom]... but sometimes people can't come back."
    pc "Lo sé, [mom]... pero a veces la gente no puede volver."

# game/Scenes/Update19/Act3/act3scene4.rpy:62
translate spanish act3scene4_2022e63e:

    # pc "We lose people that we love sometimes..."
    pc "A veces perdemos a personas que queremos..."

# game/Scenes/Update19/Act3/act3scene4.rpy:63
translate spanish act3scene4_d1689608:

    # pc "...and we have to find a way to deal with that without hurting ourselves or others."
    pc "...y tenemos que encontrar una forma de lidiar con eso sin hacernos daño a nosotros mismos ni a los demás."

# game/Scenes/Update19/Act3/act3scene4.rpy:66
translate spanish act3scene4_c3dfeaa2:

    # sp "How? How can a person deal with that sort of loss?"
    sp "¿Cómo? ¿Cómo puede una persona lidiar con ese tipo de pérdida?"

# game/Scenes/Update19/Act3/act3scene4.rpy:68
translate spanish act3scene4_8b7fb492:

    # pc "Well, in my world..."
    pc "Bueno, en mi mundo..."

# game/Scenes/Update19/Act3/act3scene4.rpy:72
translate spanish act3scene4_22817e0f:

    # pc "... Nora lost what she thought her life was going to be."
    pc "... Nora perdió lo que creía que iba a ser su vida."

# game/Scenes/Update19/Act3/act3scene4.rpy:73
translate spanish act3scene4_a6290b41:

    # pc "The man that was supposed to love her treated her badly and she was forced into this new life."
    pc "El hombre que se suponía que la amaba la trató mal y se vio obligada a llevar esta nueva vida."

# game/Scenes/Update19/Act3/act3scene4.rpy:74
translate spanish act3scene4_1e07804a:

    # pc "But she dove in and accepted it and is thriving on her own now."
    pc "Pero se lanzó a ella, la aceptó y ahora está prosperando por su cuenta."

# game/Scenes/Update19/Act3/act3scene4.rpy:75
translate spanish act3scene4_03b53305:

    # pc "She's discovering that there's a lot of love out there if you let yourself be open to it."
    pc "Está descubriendo que hay mucho amor ahí fuera si te permites abrirte a él."

# game/Scenes/Update19/Act3/act3scene4.rpy:79
translate spanish act3scene4_ff6ea314:

    # pc "... Reba's father passed away and it put her whole family in a sort of limbo."
    pc "... El padre de Reba falleció y eso dejó a toda su familia en una especie de limbo."

# game/Scenes/Update19/Act3/act3scene4.rpy:80
translate spanish act3scene4_0115c38f:

    # pc "Her mother seems to have given up on her own life and Reba has been forced to take care of her."
    pc "Su madre parece haber renunciado a su propia vida y Reba se ha visto obligada a cuidar de ella."

# game/Scenes/Update19/Act3/act3scene4.rpy:81
translate spanish act3scene4_233c26c0:

    # pc "But she's trying her best to move on and be a better version of herself, while also not forgetting about her family."
    pc "Pero está haciendo todo lo posible por seguir adelante y ser una mejor versión de sí misma, sin olvidarse de su familia."

# game/Scenes/Update19/Act3/act3scene4.rpy:85
translate spanish act3scene4_b0752170:

    # pc "... Dana lost what she thought her life was going to be."
    pc "... Dana perdió lo que creía que iba a ser su vida."

# game/Scenes/Update19/Act3/act3scene4.rpy:86
translate spanish act3scene4_4054bf2c:

    # pc "The man that was supposed to love her treated her badly and her family didn't support her."
    pc "El hombre que se suponía que la amaba la trató mal y su familia no la apoyó."

# game/Scenes/Update19/Act3/act3scene4.rpy:87
translate spanish act3scene4_e1dbd7a3:

    # pc "But she's finding herself again, and discovering that there's a lot of love out there if you let yourself be open to it."
    pc "Pero está volviendo a encontrarse a sí misma y descubriendo que hay mucho amor ahí fuera si te permites abrirte a él."

# game/Scenes/Update19/Act3/act3scene4.rpy:91
translate spanish act3scene4_684ddcd7:

    # pc "... Adrian embraced her true self and some of the people she loved didn't support her."
    pc "... Adrian aceptó su verdadero yo y algunas de las personas a las que quería no la apoyaron."

# game/Scenes/Update19/Act3/act3scene4.rpy:92
translate spanish act3scene4_0baf3bdf:

    # pc "She lost her father because he loved {i}his{/i} idea of who she was more than her actual self."
    pc "Perdió a su padre porque él amaba {i}su{/i} idea de quién era ella más que a su verdadero yo."

# game/Scenes/Update19/Act3/act3scene4.rpy:93
translate spanish act3scene4_0778a7bc:

    # pc "But she's happier than she's ever been and finding people who love her for who she really is."
    pc "Pero es más feliz que nunca y está encontrando personas que la quieren tal y como es."

# game/Scenes/Update19/Act3/act3scene4.rpy:97
translate spanish act3scene4_9eadd263:

    # pc "... Kendra is sick and will likely not live to be very old."
    pc "... Kendra está enferma y es probable que no viva hasta una edad muy avanzada."

# game/Scenes/Update19/Act3/act3scene4.rpy:98
translate spanish act3scene4_5cec7ee5:

    # pc "When she dies, she will lose everybody and everybody will lose her."
    pc "Cuando muera, perderá a todo el mundo y todo el mundo la perderá a ella."

# game/Scenes/Update19/Act3/act3scene4.rpy:99
translate spanish act3scene4_fa1731ad:

    # pc "But she's determined to still love as hard as she can and enjoy life as much as she can while she's alive."
    pc "Pero está decidida a seguir amando con todas sus fuerzas y a disfrutar de la vida tanto como pueda mientras esté viva."

# game/Scenes/Update19/Act3/act3scene4.rpy:103
translate spanish act3scene4_a64c27f0:

    # pc "... Juliana lost both of her parents and has grown up with her grandmother."
    pc "... Juliana perdió a sus dos padres y ha crecido con su abuela."

# game/Scenes/Update19/Act3/act3scene4.rpy:104
translate spanish act3scene4_1653b6af:

    # pc "She's had a hard time making friends and has a lot of fear about loving someone and losing them."
    pc "Le ha costado mucho hacer amigos y tiene mucho miedo de amar a alguien y perderlo."

# game/Scenes/Update19/Act3/act3scene4.rpy:105
translate spanish act3scene4_3e7f244a:

    # pc "But she's learning to put herself out there anyways, to make herself vulnerable."
    pc "Pero está aprendiendo a abrirse de todos modos, a mostrarse vulnerable."

# game/Scenes/Update19/Act3/act3scene4.rpy:106
translate spanish act3scene4_57cb2c2d:

    # pc "Because the rewards are worth it."
    pc "Porque las recompensas merecen la pena."

# game/Scenes/Update19/Act3/act3scene4.rpy:110
translate spanish act3scene4_6fd90af8:

    # pc "... Mi-Cha hasn't lost anything yet, but she knows she will."
    pc "... Mi-Cha aún no ha perdido nada, pero sabe que lo hará."

# game/Scenes/Update19/Act3/act3scene4.rpy:111
translate spanish act3scene4_c726ce2f:

    # pc "She came to a place, gave her heart to somebody, and now she's being forced to leave that place and her love behind."
    pc "Llegó a un lugar, entregó su corazón a alguien y ahora se ve obligada a dejar atrás ese lugar y a su amor."

# game/Scenes/Update19/Act3/act3scene4.rpy:112
translate spanish act3scene4_3d2ddad3:

    # pc "Maybe it'll work out, but in the end. She knows it's better to love and lose than never love at all."
    pc "Quizá todo salga bien, pero al final... Sabe que es mejor amar y perder que no amar nunca."

# game/Scenes/Update19/Act3/act3scene4.rpy:119
translate spanish act3scene4_322b87f1:

    # pc "... Mari has lost everything. Her whole family taken from her in a moment."
    pc "... Mari lo ha perdido todo. Le arrebataron a toda su familia en un instante."

# game/Scenes/Update19/Act3/act3scene4.rpy:120
translate spanish act3scene4_29625c9a:

    # pc "She still lives in the shadow of that tragedy, but she shines brightly anyways."
    pc "Sigue viviendo a la sombra de esa tragedia, pero brilla con fuerza de todos modos."

# game/Scenes/Update19/Act3/act3scene4.rpy:121
translate spanish act3scene4_6a46eb5e:

    # pc "She carries on with their love inside of her, knowing that they would be proud of her."
    pc "Sigue adelante con su amor dentro de ella, sabiendo que estarían orgullosos de ella."

# game/Scenes/Update19/Act3/act3scene4.rpy:125
translate spanish act3scene4_62feec4d:

    # pc "... Izzy lost both of her parents and has been put into a position where she has to care for her two little brothers."
    pc "... Izzy perdió a sus dos padres y se ha visto en la situación de tener que cuidar de sus dos hermanos pequeños."

# game/Scenes/Update19/Act3/act3scene4.rpy:126
translate spanish act3scene4_e5564799:

    # pc "She could be resentful of this, but she loves those two boys so much."
    pc "Podría estar resentida por ello, pero quiere muchísimo a esos dos niños."

# game/Scenes/Update19/Act3/act3scene4.rpy:127
translate spanish act3scene4_289024f9:

    # pc "When she thought she lost them, she fought so hard to get them back."
    pc "Cuando pensó que los había perdido, luchó con todas sus fuerzas para recuperarlos."

# game/Scenes/Update19/Act3/act3scene4.rpy:131
translate spanish act3scene4_a06ddb36:

    # pc "... Jamie loved a boy so much, but he tossed her aside without a word."
    pc "... Jamie quería muchísimo a un chico, pero él la dejó de lado sin decir una palabra."

# game/Scenes/Update19/Act3/act3scene4.rpy:132
translate spanish act3scene4_9714d5b1:

    # pc "But she kept moving forward, just being herself."
    pc "Pero ella siguió adelante, siendo simplemente ella misma."

# game/Scenes/Update19/Act3/act3scene4.rpy:133
translate spanish act3scene4_7f79356e:

    # pc "And eventually, things came back around and worked out for her."
    pc "Y, al final, las cosas dieron un giro y le salieron bien."

# game/Scenes/Update19/Act3/act3scene4.rpy:137
translate spanish act3scene4_d7d23337:

    # pc "And then there's me..."
    pc "Y luego estoy yo..."

# game/Scenes/Update19/Act3/act3scene4.rpy:139
translate spanish act3scene4_6cc0d265:

    # pc "Well, I can only talk about myself..."
    pc "Bueno, solo puedo hablar de mí misma..."

# game/Scenes/Update19/Act3/act3scene4.rpy:140
translate spanish act3scene4_cdb25042:

    # pc "I lost my mom when I was a teenager and it was really hard on me."
    pc "Perdí a mi madre cuando era adolescente y me costó mucho."

# game/Scenes/Update19/Act3/act3scene4.rpy:141
translate spanish act3scene4_739643a0:

    # pc "I took it out on the people around me and did things I regret."
    pc "Me desquité con la gente que me rodeaba e hice cosas de las que me arrepiento."

# game/Scenes/Update19/Act3/act3scene4.rpy:142
translate spanish act3scene4_ac0e651a:

    # pc "But I've done my best to change that and make things right."
    pc "Pero he hecho todo lo posible por cambiar eso y arreglar las cosas."

# game/Scenes/Update19/Act3/act3scene4.rpy:145
translate spanish act3scene4_e7e67352:

    # sp "I suppose that's what I should do now."
    sp "Supongo que eso es lo que debería hacer ahora."

# game/Scenes/Update19/Act3/act3scene4.rpy:146
translate spanish act3scene4_1e770403:

    # pc "I think so."
    pc "Eso creo."

# game/Scenes/Update19/Act3/act3scene4.rpy:147
translate spanish act3scene4_2610ae2e:

    # sp "I feel so ashamed. How can I face people?"
    sp "Me siento tan avergonzada. ¿Cómo voy a mirar a la gente a la cara?"

# game/Scenes/Update19/Act3/act3scene4.rpy:150
translate spanish act3scene4_5c7a5888:

    # pc "The ones that really matter still love you, Lisa."
    pc "Los que realmente importan siguen queriéndote, Lisa."

# game/Scenes/Update19/Act3/act3scene4.rpy:151
translate spanish act3scene4_34903c2d:

    # pc "They feel the same loss that you feel."
    pc "Sienten la misma pérdida que tú."

# game/Scenes/Update19/Act3/act3scene4.rpy:152
translate spanish act3scene4_a346789c:

    # pc "But they feel like they lost {i}you{/i} as well."
    pc "Pero sienten que también te han perdido a {i}ti{/i}."

# game/Scenes/Update19/Act3/act3scene4.rpy:155
translate spanish act3scene4_02541c65:

    # tm "It's true, Your Majesty."
    tm "Es cierto, Majestad."

# game/Scenes/Update19/Act3/act3scene4.rpy:156
translate spanish act3scene4_e56ac275:

    # tm "I miss Suzy so much."
    tm "Echo mucho de menos a Suzy."

# game/Scenes/Update19/Act3/act3scene4.rpy:157
translate spanish act3scene4_2b1387cd:

    # tm "And I miss you too."
    tm "Y a ti también te echo de menos."

# game/Scenes/Update19/Act3/act3scene4.rpy:160
translate spanish act3scene4_909876ef:

    # sp "Oh God, I'm so sorry, Tammy. Of course you miss her too."
    sp "Oh, Dios, lo siento mucho, Tammy. Por supuesto que tú también la echas de menos."

# game/Scenes/Update19/Act3/act3scene4.rpy:161
translate spanish act3scene4_ddc42ef4:

    # sp "I'll fix this. I'll make it better."
    sp "Arreglaré esto. Lo arreglaré."

# game/Scenes/Update19/Act3/act3scene4.rpy:165
translate spanish act3scene4_f8a1c7af:

    # sp "Starting with this."
    sp "Empezando por esto."

