# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:26
translate chinese rebajacksonburgerstartdate_65a4a9d8:

    # "I meet Reba in front of Jackson Burger and we walk in together."
    "我在杰克逊汉堡店门口和丽贝卡碰头，我们一起走了进去。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:29
translate chinese rebajacksonburgerstartdate_aee9ac2a:

    # "We sit in the back in my usual booth."
    "我们坐在后面我常坐的卡座里。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:31
translate chinese rebajacksonburgerstartdate_3f6c7563:

    # rb "I love this place. I don't get to come here very often, but it's so good when I do."
    rb "我超爱这家店。虽然不常来，但每次来都特别棒。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:34
translate chinese rebajacksonburgerstartdate_e0d8209b:

    # "A few moments after we sit down, Mari walks up to take our order."
    "刚坐下没多久，玛丽就走过来点单。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:36
translate chinese rebajacksonburgerstartdate_32aad169:

    # fr "Hey, [pcname]. Who's your date?"
    fr "嘿，[pcname]。你约会对象是谁？"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:37
translate chinese rebajacksonburgerstartdate_293f257d:

    # pc "This is Reba. We met a little while back and have started dating a bit."
    pc "这是丽贝卡。我们前阵子认识的，最近开始约会。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:38
translate chinese rebajacksonburgerstartdate_50370da8:

    # fr "Hi, Reba. Nice to meet you."
    fr "嗨，丽贝卡。很高兴见到你。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:41
translate chinese rebajacksonburgerstartdate_b8319afc:

    # "Reba stands up and throws her arms around Mari, pulling her into a tight hug."
    "丽贝卡站起身，张开双臂把玛丽紧紧搂在怀里。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:42
translate chinese rebajacksonburgerstartdate_fb8c8e3b:

    # rb "Aw girl, it's nice to meet you too."
    rb "哎呀姑娘，我也高兴见到你。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:43
translate chinese rebajacksonburgerstartdate_9ab5b8d9:

    # rb "I guess you're another one of [pcname]'s friends?"
    rb "“我想你也是[pcname]的朋友之一吧？”"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:45
translate chinese rebajacksonburgerstartdate_8a01148f:

    # fr "Yep, that I am."
    fr "“没错，我就是。”"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:47
translate chinese rebajacksonburgerstartdate_eedef566:

    # fr "Yeah we're friends. Hopefully more eventually."
    fr "“是啊，我们是朋友。希望以后能有更多发展。”"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:49
translate chinese rebajacksonburgerstartdate_c260d345:

    # fr "Yeah, we're friends."
    fr "“是啊，我们是朋友。”"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:52
translate chinese rebajacksonburgerstartdate_d628d3cf:

    # rb "Well he sure knows how to pick them, huh?"
    rb "“他挑人眼光真不错，对吧？”"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:53
translate chinese rebajacksonburgerstartdate_32597348:

    # rb "You're just adorable."
    rb "“你真是太可爱了。”"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:54
translate chinese rebajacksonburgerstartdate_39dfd60b:

    # fr "Thanks! You're quite the cutie yourself."
    fr "“谢谢！你自己也很可爱哦。”"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:57
translate chinese rebajacksonburgerstartdate_a33dd63e:

    # fr "Well, I hope you two have a great date. I'll go get your food ready."
    fr "“那，祝你们约会愉快。我去给你们准备餐点。”"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:58
translate chinese rebajacksonburgerstartdate_099fcc61:

    # fr "Let me know if you need anything else."
    fr "如果还需要什么，随时告诉我。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:61
translate chinese rebajacksonburgerstartdate_fe54d255:

    # rb "So, you're dating her too?"
    rb "所以，你也在和她约会吗？"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:63
translate chinese rebajacksonburgerstartdate_19c47387:

    # pc "Yeah, we've been together some. I like Mari a lot."
    pc "是啊，我们在一起有一阵子了。我很喜欢玛丽。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:64
translate chinese rebajacksonburgerstartdate_3b2e5030:

    # rb "I get it. I'm not usually into girls, but she's real pretty."
    rb "我懂。我平时不太喜欢女生，但她真的很漂亮。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:66
translate chinese rebajacksonburgerstartdate_fed76fa3:

    # pc "Not dating really, just flirting a bit."
    pc "其实不算约会，只是稍微调情一下。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:67
translate chinese rebajacksonburgerstartdate_3b2e5030_1:

    # rb "I get it. I'm not usually into girls, but she's real pretty."
    rb "我懂。我平时不太喜欢女生，但她真的很漂亮。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:69
translate chinese rebajacksonburgerstartdate_d6ec9221:

    # pc "Not really. I'm not really into her."
    pc "其实不是。我其实对她没啥感觉。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:70
translate chinese rebajacksonburgerstartdate_b7082ba6:

    # rb "Ah okay. I think she's real pretty."
    rb "啊，好的。我觉得她真的很漂亮。"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:73
translate chinese rebajacksonburgerstartdate_2d703f5a:

