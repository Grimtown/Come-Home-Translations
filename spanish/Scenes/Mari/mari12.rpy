translate spanish mari12b_d7d09581:

    # fr "I'd love to do it more often."
    fr "Me encantaría hacerlo más a menudo."

# game/Scenes/Mari/mari12.rpy:203
translate spanish mari12b_f2e427de:

    # "Then Mari cooks up dinner. It's a mix of different vegetables sauteed together."
    "Luego Mari prepara la cena. Es una mezcla de diferentes verduras salteadas juntas."

# game/Scenes/Mari/mari12.rpy:204
translate spanish mari12b_169a82ad:

    # "No meat, because she's vegetarian and doesn't have any at the house, but the vegetables are all fresh, and the bread is homemade as well."
    "Sin carne, porque es vegetariana y no tiene en casa, pero las verduras son todas frescas, y el pan también es casero."

# game/Scenes/Mari/mari12.rpy:205
translate spanish mari12b_d574565c:

    # "It's very tasty."
    "Está muy rico."

# game/Scenes/Mari/mari12.rpy:208
translate spanish mari12b_756b3b11:

    # "After that, we sit in her living room and watch a movie. The Disney animated Robin Hood - her favorite."
    "Después de eso, nos sentamos en su salón y vemos una película. La película animada de Disney Robin Hood, su favorita."

# game/Scenes/Mari/mari12.rpy:209
translate spanish mari12b_50d1a5c2:

    # "She hums along with all the songs."
    "Ella tararea todas las canciones."

# game/Scenes/Mari/mari12.rpy:210
translate spanish mari12b_bb444f7c:

    # pc "These are definitely going to be in my head for the next week."
    pc "Seguro que estas me van a dar vueltas en la cabeza durante toda la semana que viene."

# game/Scenes/Mari/mari12.rpy:212
translate spanish mari12b_d41d8cd9_33:

    # voice 'voices/mari12audio37-2.mp3'
    voice 'voices/mari12audio37-2.mp3'

# game/Scenes/Mari/mari12.rpy:213
translate spanish mari12b_8da90cc3:

    # fr "Join the club!"
    fr "¡Bienvenido al club!"

# game/Scenes/Mari/mari12.rpy:216
translate spanish mari12b_af7d8e81:

    # "We take a shower together."
    "Nos duchamos juntos."

# game/Scenes/Mari/mari12.rpy:217
translate spanish mari12b_fdf6b91c:

    # "I scrub her back, taking extra time to massage her shoulders."
    "Le froto la espalda, dedicando un tiempo extra a masajearle los hombros."

# game/Scenes/Mari/mari12.rpy:220
translate spanish mari12b_5e90d934:

    # "Then we go to bed."
    "Luego nos vamos a la cama."

# game/Scenes/Mari/mari12.rpy:222
translate spanish mari12b_d41d8cd9_34:

    # voice 'voices/mari12audio38.mp3'
    voice 'voices/mari12audio38.mp3'

# game/Scenes/Mari/mari12.rpy:223
translate spanish mari12b_637f5924:

    # fr "We spent the entire day together, huh?"
    fr "Hemos pasado todo el día juntos, ¿eh?"

# game/Scenes/Mari/mari12.rpy:225
translate spanish mari12b_d41d8cd9_35:

    # voice 'voices/mari12audio39.mp3'
    voice 'voices/mari12audio39.mp3'

# game/Scenes/Mari/mari12.rpy:226
translate spanish mari12b_47dbf3dc:

    # fr "I know I was sad through some of it, but even though this is the anniversary of the worst day in my life..."
    fr "Sé que he estado triste durante parte del día, pero aunque hoy sea el aniversario del peor día de mi vida..."

# game/Scenes/Mari/mari12.rpy:228
translate spanish mari12b_d41d8cd9_36:

    # voice 'voices/mari12audio40.mp3'
    voice 'voices/mari12audio40.mp3'

# game/Scenes/Mari/mari12.rpy:229
translate spanish mari12b_eeeeced3:

    # fr "Somehow you turned today into the best day."
    fr "De alguna manera, tú has convertido hoy en el mejor día."

# game/Scenes/Mari/mari12.rpy:231
translate spanish mari12b_d41d8cd9_37:

    # voice 'voices/mari_lovesomuch2.mp3'
    voice 'voices/mari_lovesomuch2.mp3'

# game/Scenes/Mari/mari12.rpy:232
translate spanish mari12b_546fd524:

    # fr "I love you so much."
    fr "Te quiero muchísimo."

# game/Scenes/Mari/mari12.rpy:233
translate spanish mari12b_51fe7806:

    # pc "I love you too, Mari."
    pc "Yo también te quiero, Mari."

# game/Scenes/Mari/mari12.rpy:235
