    fr "Vale."

# game/Scenes/Mari/mari12.rpy:272
translate spanish mari12b_d41d8cd9_43:

    # voice 'voices/mari_loveyou1.mp3'
    voice 'voices/mari_loveyou1.mp3'

# game/Scenes/Mari/mari12.rpy:273
translate spanish mari12b_f3511250:

    # fr "Bye, [pcname]. I love you."
    fr "Adiós, [pcname]. Te quiero."

# game/Scenes/Mari/mari12.rpy:274
translate spanish mari12b_93754ce5:

    # pc "Love you too, Mari."
    pc "Yo también te quiero, Mari."

# game/Scenes/Mari/mari12.rpy:279
translate spanish mari12b_a71ca6f3:

    # "I leave her farm and drive back towards home."
    "Salgo de su granja y conduzco de vuelta a casa."

# game/Scenes/Mari/mari12.rpy:280
translate spanish mari12b_a94d9d83:

    # "I'm not quite ready to settle down yet, but when I am, I could definitely see it being with her."
    "Aún no estoy del todo listo para sentar cabeza, pero cuando lo esté, sin duda me veo a mí mismo con ella."

# game/Scenes/Mari/mari12.rpy:281
translate spanish mari12b_f9b60f9c:

    # "Being with her is just so easy. It feels natural."
    "Estar con ella es tan fácil. Se siente natural."

# game/Scenes/Mari/mari12.rpy:282
translate spanish mari12b_811aa5f5:

    # "She's amazing."
    "Es increíble."

