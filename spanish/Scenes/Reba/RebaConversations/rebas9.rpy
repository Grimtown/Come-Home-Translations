# game/Scenes/Reba/RebaConversations/rebas9.rpy:14
translate spanish rebas9_2faa8ce2:

    # rb "Back when Daddy was alive, we would sometimes go to concerts, yeah."
    rb "Cuando papá aún vivía, a veces íbamos a conciertos, sí."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:16
translate spanish rebas9_10645864:

    # rb "Mostly country western shows. Just little local bands."
    rb "Sobre todo a conciertos de country. Solo pequeñas bandas locales."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:18
translate spanish rebas9_cedd72f5:

    # rb "Anything we could pull the truck up close to and listen to for free."
    rb "Cualquier cosa a la que pudiéramos acercar la camioneta y escuchar gratis."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:19
translate spanish rebas9_98020fd4:

    # pc "That sounds nice."
    pc "Suena bien."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:21
translate spanish rebas9_b50b918f:

    # rb "It was nice. Really nice."
    rb "Era bonito. Muy bonito."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:23
translate spanish rebas9_23751885:

    # rb "Daddy would grill hot dogs and hamburgers out of the back of the truck."
    rb "Papá asaba perritos calientes y hamburguesas en la parte trasera de la camioneta."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:24
translate spanish rebas9_dbab54af:

    # rb "And we'd eat and drink Cokes and Mama and Daddy would dance to the music through the whole thing."
    rb "Y comíamos y bebíamos Coca-Cola, y mamá y papá bailaban al ritmo de la música durante todo el rato."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:26
translate spanish rebas9_55b70070:

    # rb "It was so much fun. Everybody was so happy."
    rb "Era muy divertido. Todo el mundo estaba tan feliz."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:28
translate spanish rebas9_fa1028a8:

    # rb "Dang, I miss Daddy. He really held our family together."
    rb "Maldita sea, echo de menos a papá. Él era quien mantenía unida a nuestra familia."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:29
translate spanish rebas9_447175e1:

    # rb "When he died, everything kind of just fell apart."
    rb "Cuando murió, todo se vino abajo."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:30
translate spanish rebas9_ac8cb927:

    # pc "I'm sorry, Reba. I know that's rough."
    pc "Lo siento, Reba. Sé que es duro."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:32
translate spanish rebas9_92681bbd:

    # rb "I think I'd give just about anything to get him back."
    rb "Creo que daría cualquier cosa por recuperarlo."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:33
translate spanish rebas9_f7ecfaf0:

    # rb "But I know I can't."
    rb "Pero sé que no puedo."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:34
translate spanish rebas9_61640156:

    # rb "He's with Jesus now and we have to somehow pick up the pieces and put them back together again and move on."
    rb "Ahora está con Jesús y tenemos que, de alguna manera, recoger los pedazos, volver a juntarlos y seguir adelante."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:35
translate spanish rebas9_e0fd3510:

    # pc "Yeah. Sometimes that's really hard to do."
    pc "Sí. A veces eso es muy difícil de hacer."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:37
translate spanish rebas9_866e6159:

    # rb "It sure as heck is."
    rb "Desde luego que lo es."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:39
translate spanish rebas9_699bad32:

    # rb "But I'm doing my best."
    rb "Pero lo estoy haciendo lo mejor que puedo."

# game/Scenes/Reba/RebaConversations/rebas9.rpy:40
translate spanish rebas9_22a833ec:

    # pc "You're doing great."
    pc "Lo estás haciendo muy bien."

