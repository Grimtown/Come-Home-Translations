# game/Scenes/Suzy/Suzy3.rpy:14
translate spanish suzy3_4cd33d0d:

    # "I decide that I need a shower before bed tonight."
    "Decido que necesito darme una ducha antes de acostarme esta noche."

# game/Scenes/Suzy/Suzy3.rpy:15
translate spanish suzy3_0aad95b6:

    # "I peek into the bathroom to make sure that Suzy isn't in there, then I go in and start running water."
    "Echo un vistazo al baño para asegurarme de que Suzy no está dentro, luego entro y abro el grifo."

# game/Scenes/Suzy/Suzy3.rpy:16
translate spanish suzy3_ef339027:

    # "When the water is warm, I strip down and get in."
    "Cuando el agua está caliente, me desnudo y me meto dentro."

# game/Scenes/Suzy/Suzy3.rpy:18
translate spanish suzy3_2e55107f:

    # "I stand there, washing myself, closing my eyes and just relaxing, thinking about the day."
    "Me quedo allí de pie, lavándome, cerrando los ojos y simplemente relajándome, pensando en el día."

# game/Scenes/Suzy/Suzy3.rpy:19
translate spanish suzy3_926119ff:

    # "I'm tired and so relaxed, I feel as though I could just fall asleep standing there."
    "Estoy cansada y tan relajada que siento que podría quedarme dormida allí de pie."

# game/Scenes/Suzy/Suzy3.rpy:22
translate spanish suzy3_01439eb0:

    # "I let the water run down over my face, down my body."
    "Dejo que el agua me corra por la cara y por el cuerpo."

# game/Scenes/Suzy/Suzy3.rpy:23
translate spanish suzy3_fe18b581:

    # "I rub the soap in with a rag, getting every part of my body."
    "Me froto con el jabón y un trapo, llegando a cada parte de mi cuerpo."

# game/Scenes/Suzy/Suzy3.rpy:25
translate spanish suzy3_88cfebd1:

    # "Then I finally open my eyes again."
    "Entonces, por fin, vuelvo a abrir los ojos."

# game/Scenes/Suzy/Suzy3.rpy:26
translate spanish suzy3_bd18bade:

    # "I'm startled to see Suzy standing in the doorway to my room, staring at me."
    "Me sobresalto al ver a Suzy de pie en la puerta de mi habitación, mirándome fijamente."

# game/Scenes/Suzy/Suzy3.rpy:28
translate spanish suzy3_34856c07:

    # "She is staring directly at my dick and smiling, enjoying what she is seeing."
    "Está mirando directamente a mi polla y sonriendo, disfrutando de lo que ve."

# game/Scenes/Suzy/Suzy3.rpy:31
translate spanish suzy3_e1d0918a:

    # "I turn off the water and step out of the shower, giving her a full-on view."
    "Cierro el grifo y salgo de la ducha, ofreciéndole una vista completa."

# game/Scenes/Suzy/Suzy3.rpy:32
