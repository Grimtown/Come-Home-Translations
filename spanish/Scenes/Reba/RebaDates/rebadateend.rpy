# game/Scenes/Reba/RebaDates/rebadateend.rpy:5
translate spanish rebadateend_4407114d:

    # rb "That was fun, I had a really good time."
    rb "Ha sido divertido, lo he pasado muy bien."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:10
translate spanish rebadateend_86e2c035:

    # "I step up and pull her into a kiss, which she returns enthusiastically."
    "Me acerco y la atraigo hacia mí para darle un beso, que ella me devuelve con entusiasmo."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:11
translate spanish rebadateend_39c7b3ca:

    # rb "Wow, I wish I could do more of that, but I gotta get home and make some supper for Mama."
    rb "Vaya, ojalá pudiera hacer esto más a menudo, pero tengo que irme a casa a preparar la cena para mamá."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:13
translate spanish rebadateend_895c572b:

    # rb "I hope we can do this again soon. And maybe more. I want so much more."
    rb "Espero que podamos volver a hacerlo pronto. Y quizá algo más. Quiero mucho más."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:16
translate spanish rebadateend_744ec225:

    # "I step up and pull her into a hug. She wraps her arms around me and squeezes me close."
    "Me acerco y la atraigo hacia mí para darle un abrazo. Ella me rodea con sus brazos y me aprieta contra ella."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:17
translate spanish rebadateend_91433507:

    # rb "Thanks for taking me out. I hope we can do this again soon."
    rb "Gracias por llevarme a salir. Espero que podamos volver a hacerlo pronto."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:18
translate spanish rebadateend_4f8314b3:

    # rb "But I better get home. Gotta make supper for Mama."
    rb "Pero mejor me voy a casa. Tengo que preparar la cena para mamá."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:21
translate spanish rebadateend_24de817d:

    # pc "Do you want to come back to my house for a while?"
    pc "¿Quieres venir a mi casa un rato?"

# game/Scenes/Reba/RebaDates/rebadateend.rpy:23
translate spanish rebadateend_c8f7ca44:

    # rb "You want a little hanky-panky?"
    rb "¿Te apetece un poco de acción?"

# game/Scenes/Reba/RebaDates/rebadateend.rpy:24
translate spanish rebadateend_f4be2d3d:

    # rb "Good, because I {i}really{/i} do too. Let's go."
    rb "Bien, porque a mí {i}también{/i} me apetece de verdad. Vamos."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:28
translate spanish rebadateend_ed307571:

    # "We drive back to my house and go up to my bedroom, where things quickly lead to us being naked on the bed."
    "Conducimos de vuelta a mi casa y subimos a mi habitación, donde las cosas se precipitan rápidamente hasta que acabamos desnudos en la cama."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:32
translate spanish rebadateend_52303b0f:

    # pc "Yeah, it was good. I'll see you later Reba."
    pc "Sí, ha estado bien. Nos vemos luego, Reba."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:33
translate spanish rebadateend_7657b93c:

    # rb "Uh, okay."
    rb "Eh, vale."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:34
translate spanish rebadateend_46d8c374:

    # rb "I'll see you later, [pcname]."
    rb "Nos vemos luego, [pcname]."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:35
translate spanish rebadateend_2fd019a4:

    # "She waves goodbye and gets into her truck and drives away."
    "Me dice adiós con la mano, se sube a su camioneta y se marcha."

