    pc "好吧，是啊。你说得对。"

# game/Scenes/Whitney/whitney14.rpy:187
translate chinese rjwhitneywarning_9745900d:

    # pc "I want to help my dad."
    pc "我想帮爸爸。"

# game/Scenes/Whitney/whitney14.rpy:188
translate chinese rjwhitneywarning_60450ec1:

    # wt "I do too. So let's do it, [pcname]."
    wt "我也是。所以，我们动手吧，[pcname]。"

# game/Scenes/Whitney/whitney14.rpy:189
translate chinese rjwhitneywarning_c043f0da:

    # wt "Let's steal some diamonds."
    wt "去偷些钻石吧。"

# game/Scenes/Whitney/whitney14.rpy:193
