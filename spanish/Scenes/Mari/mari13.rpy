# game/Scenes/Mari/mari13.rpy:88
translate spanish mari13_94d84e9b:

    # rj "Okay, I'm gonna get out of your way now. Have fun!"
    rj "Vale, ahora me voy a quitar de en medio. ¡Diviértete!"

# game/Scenes/Mari/mari13.rpy:90
