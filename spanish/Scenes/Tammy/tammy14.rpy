translate spanish tammy14_092737ee:

    # ss "Good night, Mom!"
    ss "¡Buenas noches, mamá!"

# game/Scenes/Tammy/tammy14.rpy:90
translate spanish tammy14_ffdf8a5b:

    # tm "Good night, Mom!"
    tm "¡Buenas noches, mamá!"

