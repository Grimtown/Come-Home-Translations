# game/Scenes/Suzy/SuzyTammyConversations/suzytammys5.rpy:23
translate spanish suzytammys5_505d1c69:

    # ss "Or a Fiat! A yellow Fiat. That's my answer."
    ss "¡O un Fiat! Un Fiat amarillo. Esa es mi respuesta."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys5.rpy:25
translate spanish suzytammys5_131e6e55:

    # tm "Those {i}are{/i} cute."
