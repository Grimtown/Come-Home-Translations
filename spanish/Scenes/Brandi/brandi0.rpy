translate spanish brandi0_07c9c5ab:

    # pc "You're welcome."
    pc "De nada."

# game/Scenes/Brandi/brandi0.rpy:106
translate spanish brandi0_c2531072:

    # "With that, she grabs her laptop from the table and rushes out the door."
    "Dicho esto, coge su portátil de la mesa y sale corriendo por la puerta."

# game/Scenes/Brandi/brandi0.rpy:110
translate spanish brandi0_d3463004:

    # "I eat the free burger that Brandi bought for me, then head back out to my car."
    "Me como la hamburguesa gratis que Brandi me ha comprado y luego vuelvo a mi coche."

# game/Scenes/Brandi/brandi0.rpy:112
translate spanish brandi0_3b75386f:

    # "I'm not really hungry, so I just head back out to my car."
    "No tengo mucha hambre, así que me voy directamente al coche."

