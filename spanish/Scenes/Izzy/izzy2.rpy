    # voice 'voices/izzy_2_5.mp3'
    voice 'voices/izzy_2_5.mp3'

# game/Scenes/Izzy/izzy2.rpy:44
translate spanish izzy2_b260b0b6:

    # gl "You know Moose. The shirtless Bruce Lee-looking boy-toy over there is Mal."
    gl "Ya conoces a Moose. El chico sin camiseta que parece Bruce Lee de por ahí es Mal."

# game/Scenes/Izzy/izzy2.rpy:45
translate spanish izzy2_3e106586:

    # mal "Wassup?"
    mal "¿Qué tal?"

# game/Scenes/Izzy/izzy2.rpy:47
translate spanish izzy2_d41d8cd9_5:

    # voice 'voices/izzy_2_7.mp3'
    voice 'voices/izzy_2_7.mp3'

# game/Scenes/Izzy/izzy2.rpy:48
translate spanish izzy2_45725a14:

    # gl "And tall, dark and skinny behind me is Devon. He don't talk much."
    gl "Y el alto, moreno y delgado que está detrás de mí es Devon. No habla mucho."

# game/Scenes/Izzy/izzy2.rpy:49
translate spanish izzy2_dc8cb990:

    # "Devon nods his head slightly at me."
    "Devon me hace un ligero gesto con la cabeza."

# game/Scenes/Izzy/izzy2.rpy:50
translate spanish izzy2_522e1448:

    # gl "And that's the gang. Except now there's you - Twig."
    gl "Y esa es la pandilla. Excepto que ahora estás tú, Twig."

# game/Scenes/Izzy/izzy2.rpy:51
translate spanish izzy2_8b86df4b:

    # pc "My name is--"
    pc "Me llamo..."

# game/Scenes/Izzy/izzy2.rpy:52
translate spanish izzy2_28bea8fd:

    # "Just then the chirp of a police siren and a flashing light in the distance catches everyone's attention."
    "Justo entonces, el chirrido de una sirena de policía y una luz intermitente en la distancia llaman la atención de todos."

# game/Scenes/Izzy/izzy2.rpy:55
translate spanish izzy2_40384605:

    # mal "Cops!"
    mal "¡La policía!"

# game/Scenes/Izzy/izzy2.rpy:56
translate spanish izzy2_3a4267e8:

    # moose "Oh shit, I gotta get out of here!"
    moose "¡Mierda, tengo que largarme de aquí!"

# game/Scenes/Izzy/izzy2.rpy:57
translate spanish izzy2_db9ea3d3:

    # gl "Damn, gotta split."
    gl "Maldita sea, tengo que largarme."

# game/Scenes/Izzy/izzy2.rpy:60
translate spanish izzy2_84f98777:

    # gl "You come back and hang out with us sometime."
    gl "Vuelve y quédate con nosotros alguna vez."

# game/Scenes/Izzy/izzy2.rpy:61
translate spanish izzy2_37f4bf94:

    # gl "We know how to have a good time."
    gl "Sabemos cómo pasarlo bien."

# game/Scenes/Izzy/izzy2.rpy:62
translate spanish izzy2_d2b269a7:

    # gl "See you later, Twig."
    gl "Hasta luego, Twig."

# game/Scenes/Izzy/izzy2.rpy:65
translate spanish izzy2_dbce667a:

    # "With that, she runs off in the same direction as the others."
    "Dicho esto, sale corriendo en la misma dirección que los demás."

# game/Scenes/Izzy/izzy2.rpy:66
translate spanish izzy2_4f647b81:

    # "I turn and walk back to my car."
    "Me doy la vuelta y vuelvo a mi coche."

# game/Scenes/Izzy/izzy2.rpy:67
translate spanish izzy2_56b73e22:

    # "The police sirens and lights fade away. I'm not even sure they were aware of Izzy and her gang."
    "Las sirenas y las luces de la policía se desvanecen. Ni siquiera estoy seguro de que se hayan dado cuenta de Izzy y su pandilla."

# game/Scenes/Izzy/izzy2.rpy:68
translate spanish izzy2_b8cda32c:

    # "I wonder why they are so jumpy?"
    "Me pregunto por qué están tan nerviosos."

# game/Scenes/Izzy/izzy2.rpy:69
translate spanish izzy2_b0b60482:

    # "I'll have to come back and hang out with them some other time. For now I get in my car and drive away."
    "Tendré que volver a pasar el rato con ellos en otra ocasión. Por ahora me subo al coche y me alejo."

