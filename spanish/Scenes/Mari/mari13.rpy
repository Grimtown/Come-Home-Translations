    # fr "Oh, cool! That would be great."
    fr "¡Oh, genial! Eso sería estupendo."

# game/Scenes/Mari/mari13.rpy:120
translate spanish mari13phone_28ca97d1:

    # pc "Okay, I'll call her real quick. Just a sec."
    pc "Vale, la llamaré enseguida. Un momento."

# game/Scenes/Mari/mari13.rpy:127
translate spanish mari13rebahelp_589dd85f:

    # pc "Hey, Reba? You busy?"
    pc "Hola, ¿Reba? ¿Estás ocupada?"

# game/Scenes/Mari/mari13.rpy:128
translate spanish mari13rebahelp_c6aaa4b5:

    # rb "Naw, what's up?"
    rb "No, ¿qué pasa?"

# game/Scenes/Mari/mari13.rpy:129
translate spanish mari13rebahelp_6033c0b7:

    # pc "I have a friend whose truck isn't starting and I was wondering..."
    pc "Tengo una amiga cuya camioneta no arranca y me preguntaba..."

# game/Scenes/Mari/mari13.rpy:131
translate spanish mari13rebahelp_c2ea06eb:

    # rb "Gimme the address and I'm on my way!"
    rb "¡Dame la dirección y voy para allá!"

# game/Scenes/Mari/mari13.rpy:132
translate spanish mari13rebahelp_a8e3c862:

    # pc "Haha, okay."
    pc "Jaja, vale."

# game/Scenes/Mari/mari13.rpy:135
translate spanish mari13rebahelp_ee70a372:

    # "I give Reba directions to Mari's farm and a few minutes later she meets us there."
    "Le doy a Reba las indicaciones para llegar a la granja de Mari y, unos minutos más tarde, se reúne con nosotros allí."

# game/Scenes/Mari/mari13.rpy:138
translate spanish mari13rebahelp_05b2461c:

    # rb "Oh my God! Your dogs are {i}so{/i} cute."
    rb "¡Dios mío! Tus perros son {i}tan{/i} monos."

# game/Scenes/Mari/mari13.rpy:139
translate spanish mari13rebahelp_22df0ba2:

    # fr "They seem to like you."
    fr "Parece que les gustas."

# game/Scenes/Mari/mari13.rpy:140
translate spanish mari13rebahelp_68c9b491:

    # rb "What's their names?"
    rb "¿Cómo se llaman?"

# game/Scenes/Mari/mari13.rpy:142
translate spanish mari13rebahelp_d41d8cd9:

    # voice 'voices/mari_appaandmomo.mp3'
    voice 'voices/mari_appaandmomo.mp3'

# game/Scenes/Mari/mari13.rpy:143
translate spanish mari13rebahelp_0ede8f0a:

    # fr "The big one is Appa, and the little guy is Momo."
    fr "El grande es Appa, y el pequeño es Momo."

# game/Scenes/Mari/mari13.rpy:144
translate spanish mari13rebahelp_b4839da7:

    # rb "Oh my God, I love them!"
    rb "¡Dios mío, me encantan!"

# game/Scenes/Mari/mari13.rpy:147
translate spanish mari13rebahelp_34d27c0e:

    # rb "You didn't tell me that I was fixin' this car for a cute girlfriend of yours, [pcname]."
    rb "No me dijiste que estaba arreglando este coche para una novia monísima tuya, [pcname]."

# game/Scenes/Mari/mari13.rpy:148
translate spanish mari13rebahelp_be9414f2:

    # pc "Oh, sorry."
    pc "Oh, lo siento."

# game/Scenes/Mari/mari13.rpy:149
translate spanish mari13rebahelp_380ac7ef:

    # rb "Naw, it's no problem, I'm just messin'."
    rb "No, no pasa nada, solo bromeaba."

# game/Scenes/Mari/mari13.rpy:151
translate spanish mari13rebahelp_f7c6563e:

    # rb "Aw, hey I remember you from the burger place."
    rb "Ay, oye, te recuerdo de la hamburguesería."

# game/Scenes/Mari/mari13.rpy:152
translate spanish mari13rebahelp_11d0fe17:

    # fr "Hey, yeah that's me."
    fr "Oye, sí, soy yo."

# game/Scenes/Mari/mari13.rpy:154
translate spanish mari13rebahelp_2acf7aec:

    # rb "I'm Reba, by the way."
    rb "Por cierto, soy Reba."

# game/Scenes/Mari/mari13.rpy:155
translate spanish mari13rebahelp_6f785a5d:

    # fr "Hello. I'm Mari. Nice to meet you."
    fr "Hola. Soy Mari. Encantada de conocerte."

# game/Scenes/Mari/mari13.rpy:156
translate spanish mari13rebahelp_a9aba0f6:

    # rb "Okay, let's see what this thing is doing."
    rb "Vale, veamos qué le pasa a este coche."

# game/Scenes/Mari/mari13.rpy:159
translate spanish mari13rebahelp_1a16e9d4:

    # rb "So how long you say it's been sitting here?"
    rb "¿Cuánto tiempo llevas aquí parado, decías?"

# game/Scenes/Mari/mari13.rpy:160
translate spanish mari13rebahelp_8ebf8623:

    # fr "About four years."
    fr "Unos cuatro años."

# game/Scenes/Mari/mari13.rpy:161
translate spanish mari13rebahelp_90a271fa:

    # rb "Alright, and y'all replaced the battery already, so that's good."
    rb "Muy bien, y ya habéis cambiado la batería, así que eso está bien."

# game/Scenes/Mari/mari13.rpy:162
translate spanish mari13rebahelp_22d6811f:

    # rb "I'm gonna try a few things, but I expect we'll have to change the gas in the tank, because it's probably gone bad."
    rb "Voy a probar algunas cosas, pero supongo que tendremos que cambiar la gasolina del depósito, porque probablemente se haya echado a perder."

# game/Scenes/Mari/mari13.rpy:163
translate spanish mari13rebahelp_2dc05954:

    # rb "And I'll clean out the air filter and change the oil and might have to replace the fuel pump too."
    rb "Y limpiaré el filtro de aire y cambiaré el aceite, y puede que también tenga que cambiar la bomba de combustible."

# game/Scenes/Mari/mari13.rpy:164
translate spanish mari13rebahelp_1bccde91:

    # rb "Then after all that, if the engine starts, we'll have to get those tires aired up. They don't look like they've rotted, which is good. Hopefully they'll still hold air."
    rb "Luego, después de todo eso, si el motor arranca, tendremos que hinchar esos neumáticos. No parece que se hayan pudrido, lo cual es bueno. Con suerte, aún mantendrán el aire."

# game/Scenes/Mari/mari13.rpy:168
translate spanish mari13rebahelp_d41d8cd9_1:

    # voice 'voices/mari_shoot1.mp3'
    voice 'voices/mari_shoot1.mp3'

# game/Scenes/Mari/mari13.rpy:169
translate spanish mari13rebahelp_8f74c366:

    # fr "Aw, shoot. How much is all of that going to cost?"
    fr "Ay, vaya. ¿Cuánto va a costar todo eso?"

# game/Scenes/Mari/mari13.rpy:170
translate spanish mari13rebahelp_8f3b3d9a:

    # rb "I can get you a new fuel pump for about $100. New oil filter and oil is like $30. Then just a tank of gas to replace the old junk."
    rb "Puedo conseguirte una bomba de combustible nueva por unos 100 dólares. El filtro de aceite nuevo y el aceite cuestan unos 30 dólares. Luego solo un depósito de gasolina para reemplazar la basura vieja."

# game/Scenes/Mari/mari13.rpy:171
translate spanish mari13rebahelp_428bb652:

    # rb "And all the labor is on the house, because I like that guy over there, and you seem like a pretty cool chick too."
    rb "Y toda la mano de obra corre a cargo de la casa, porque me cae bien ese chico de ahí, y tú también pareces una chica muy maja."

# game/Scenes/Mari/mari13.rpy:172
translate spanish mari13rebahelp_3eeb60d9:

    # rb "Y'all just gotta hang out and keep me company and hand me junk when I ask for it, alright?"
    rb "Solo tenéis que quedaros por aquí, hacerme compañía y pasarme las cosas cuando os las pida, ¿vale?"

# game/Scenes/Mari/mari13.rpy:174
translate spanish mari13rebahelp_d41d8cd9_2:

    # voice 'voices/mari_surething2.mp3'
    voice 'voices/mari_surething2.mp3'

# game/Scenes/Mari/mari13.rpy:175
translate spanish mari13rebahelp_9af4e82f:

    # fr "Sure thing!"
    fr "¡Claro que sí!"

# game/Scenes/Mari/mari13.rpy:178
translate spanish mari13rebahelp_ab992a3c:

    # rb "So you don't drive?"
    rb "¿Entonces no conduces?"

# game/Scenes/Mari/mari13.rpy:179
translate spanish mari13rebahelp_205c26d0:

    # fr "No, I haven't ever learned. My parents were killed in a car accident and I've been kind of scared of them since then."
    fr "No, nunca he aprendido. Mis padres murieron en un accidente de coche y desde entonces les tengo un poco de miedo."

# game/Scenes/Mari/mari13.rpy:180
translate spanish mari13rebahelp_b0f6c8c0:

    # rb "Aw dang, I'm sorry. My daddy's gone too. I know it hurts."
    rb "Vaya, lo siento. Mi padre también se ha ido. Sé que duele."

# game/Scenes/Mari/mari13.rpy:181
translate spanish mari13rebahelp_254e65aa:

    # fr "Yeah it does. But I'm ready to learn how to drive now. I think I need to."
    fr "Sí, duele. Pero ahora estoy lista para aprender a conducir. Creo que lo necesito."

# game/Scenes/Mari/mari13.rpy:182
translate spanish mari13rebahelp_d2c576b2:

    # rb "Yeah, we'll get this truck going and you can drive all over the place."
    rb "Sí, pondremos esta camioneta a punto y podrás conducir por todas partes."

# game/Scenes/Mari/mari13.rpy:185
translate spanish mari13rebahelp_28f72a61:

    # rb "So you and [pcname]. Are you two serious?"
    rb "Así que tú y [pcname]. ¿Lo vais en serio?"

# game/Scenes/Mari/mari13.rpy:186
translate spanish mari13rebahelp_1ac8f72e:

    # fr "Yeah, I think so."
    fr "Sí, eso creo."

# game/Scenes/Mari/mari13.rpy:187
translate spanish mari13rebahelp_f2f3bd20:

    # rb "But you're okay that he's been dating me too?"
    rb "¿Pero te parece bien que él también haya estado saliendo conmigo?"

# game/Scenes/Mari/mari13.rpy:188
translate spanish mari13rebahelp_93575294:

    # fr "I'm not sure. Like, I want to be with him only, but we're not married and I'm okay with not being exclusive for now."
    fr "No estoy segura. Es decir, quiero estar solo con él, pero no estamos casados y por ahora me parece bien que no seamos exclusivos."

# game/Scenes/Mari/mari13.rpy:189
translate spanish mari13rebahelp_401f266e:

