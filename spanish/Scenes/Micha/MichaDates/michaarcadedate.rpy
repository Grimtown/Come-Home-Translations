# game/Scenes/Micha/MichaDates/michaarcadedate.rpy:119
translate spanish michaarcadestartdate_17d62fc5:

    # "After a few songs, we take a break, catch our breath and chat for a while."
    "Después de unas cuantas canciones, nos tomamos un descanso, recuperamos el aliento y charlamos un rato."

# game/Scenes/Micha/MichaDates/michaarcadedate.rpy:127
