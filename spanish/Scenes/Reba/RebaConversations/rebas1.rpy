# game/Scenes/Reba/RebaConversations/rebas1.rpy:14
translate spanish rebas1_703a7a1f:

    # rb "Well you've met Mama and Mickey."
    rb "Bueno, ya has conocido a mamá y a Mickey."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:15
translate spanish rebas1_96542516:

    # rb "Mama used to be a teacher. Now she's on disability. Bad knees."
    rb "Mamá solía ser profesora. Ahora está de baja por discapacidad. Le duelen las rodillas."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:17
translate spanish rebas1_a876459e:

    # rb "And Mickey. Ugh."
    rb "Y Mickey. Uf."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:18
translate spanish rebas1_e06598b6:

    # rb "I love my brother, but he drives me bananas."
    rb "Quiero a mi hermano, pero me saca de quicio."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:19
translate spanish rebas1_a078429c:

    # rb "He's just always messing things up, gettin' into trouble, causing problems."
    rb "Siempre está estropeándolo todo, metiéndose en líos, causando problemas."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:21
translate spanish rebas1_8f0c1d05:

    # rb "Mama says he's got too much of Daddy in him."
    rb "Mamá dice que se parece demasiado a papá."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:22
translate spanish rebas1_de773d17:

    # rb "And he acts like he's Daddy too, always trying to tell me what to do."
    rb "Y actúa como si fuera papá también, siempre intentando decirme lo que tengo que hacer."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:23
translate spanish rebas1_6e032bd6:

    # rb "Just want to clobber him sometimes."
    rb "A veces solo quiero darle una paliza."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:24
translate spanish rebas1_fa340cd0:

    # pc "And your dad? He's in prison?"
    pc "¿Y tu padre? ¿Está en la cárcel?"

# game/Scenes/Reba/RebaConversations/rebas1.rpy:26
translate spanish rebas1_2ef44ad1:

    # rb "No, Daddy's in heaven."
    rb "No, papá está en el cielo."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:27
translate spanish rebas1_6c6d9416:

    # pc "Oh, I'm sorry."
    pc "Oh, lo siento."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:28
translate spanish rebas1_096f84a0:

    # rb "He got sick in prison. Died there. It was real hard on Mama. On me and Mickey too, of course, but Mama took it real bad."
    rb "Se puso enfermo en la cárcel. Murió allí. Fue muy duro para mamá. Para mí y para Mickey también, claro, pero mamá se lo tomó muy mal."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:30
translate spanish rebas1_aa778eb3:

    # rb "That's when she stopped working, gained all the weight, pretty much sits in front of the television now and doesn't do much."
    rb "Fue entonces cuando dejó de trabajar, engordó un montón, ahora se pasa casi todo el tiempo sentada delante de la tele y no hace gran cosa."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:31
translate spanish rebas1_58925e02:

    # rb "So I dropped out of school so that I could help make money. 19 years old now and still in the same place."
    rb "Así que dejé los estudios para poder ayudar a ganar dinero. Ahora tengo 19 años y sigo en el mismo sitio."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:32
translate spanish rebas1_2b85a0c1:

    # pc "Not happy about that?"
    pc "¿No te gusta eso?"

# game/Scenes/Reba/RebaConversations/rebas1.rpy:34
translate spanish rebas1_8ac2576b:

    # rb "No. Not really."
    rb "No. La verdad es que no."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:35
translate spanish rebas1_91097140:

    # rb "But I can't just leave Mama."
    rb "Pero no puedo dejar a mamá así como así."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:36
translate spanish rebas1_d3a89021:

    # rb "She... and Mickey... are all that I have."
    rb "Ella... y Mickey... son todo lo que tengo."

