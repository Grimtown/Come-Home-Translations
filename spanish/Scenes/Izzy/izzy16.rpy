    # pc "Alright then."
    pc "Vale, entonces."

# game/Scenes/Izzy/izzy16.rpy:38
translate spanish izzy16_127e1fc7:

    # gl "Cool. I'll see you when you get here!"
    gl "Genial. ¡Nos vemos cuando llegues!"

# game/Scenes/Izzy/izzy16.rpy:41
translate spanish izzy16_a08c4106:

    # "I go get ready, then drive over to Izzy's house."
    "Me preparo y luego conduzco hasta la casa de Izzy."

# game/Scenes/Izzy/izzy16.rpy:45
translate spanish izzy16_767bf232:

    # "When I get there, I walk in and see Moose and Mal already sitting in Izzy's living room."
    "Cuando llego, entro y veo a Moose y Mal ya sentados en el salón de Izzy."

# game/Scenes/Izzy/izzy16.rpy:46
translate spanish izzy16_333424a0:

    # moose "What's up, [pcname]? It's been a while!"
    moose "¿Qué tal, [pcname]? ¡Cuánto tiempo!"

# game/Scenes/Izzy/izzy16.rpy:47
translate spanish izzy16_321c1c52:

    # pc "Hey guys, what's up?"
    pc "Hola, chicos, ¿qué tal?"

# game/Scenes/Izzy/izzy16.rpy:48
translate spanish izzy16_c6475f56:

    # mal "Yo!"
    mal "¡Hola!"

# game/Scenes/Izzy/izzy16.rpy:49
translate spanish izzy16_926aa461:

    # pc "How have y'all been?"
    pc "¿Cómo os ha ido?"

# game/Scenes/Izzy/izzy16.rpy:50
translate spanish izzy16_04a47828:

    # moose "Just chillin' man."
    moose "Tranquilos, tío."

# game/Scenes/Izzy/izzy16.rpy:51
translate spanish izzy16_bacd00d2:

    # mal "I ain't been doing shit."
    mal "Yo no he hecho una mierda."

# game/Scenes/Izzy/izzy16.rpy:52
translate spanish izzy16_e1fb06f0:

    # moose "Missing y'all."
    moose "Os echo de menos."

# game/Scenes/Izzy/izzy16.rpy:55
translate spanish izzy16_bdc09ed2:

    # gl "Yeah, sorry I haven't been able to smoke and hang out with y'all as much anymore."
    gl "Sí, lo siento por no haber podido fumar y pasar el rato con vosotros tanto como antes."

# game/Scenes/Izzy/izzy16.rpy:56
translate spanish izzy16_b6562171:

    # moose "Girl, we don't have to smoke. I know why you can't do that anymore."
    moose "Chica, no hace falta que fumemos. Sé por qué ya no puedes hacerlo."

# game/Scenes/Izzy/izzy16.rpy:57
translate spanish izzy16_ecdc8e86:

    # mal "Yeah, we just miss seeing you. We don't have to get high to have a good time."
    mal "Sí, solo es que echamos de menos verte. No hace falta colocarnos para pasarlo bien."

# game/Scenes/Izzy/izzy16.rpy:58
translate spanish izzy16_65034032:

    # moose "I mean, it helps, but yeah, we can have fun without it."
    moose "Bueno, ayuda, pero sí, podemos divertirnos sin eso."

# game/Scenes/Izzy/izzy16.rpy:59
translate spanish izzy16_ca248697:

    # moose "So it's nice just to come over and hang out, you know?"
    moose "Así que está bien venir a pasar el rato, ¿sabes?"

# game/Scenes/Izzy/izzy16.rpy:60
translate spanish izzy16_0a48f232:

    # gl "Oh, I finally got a letter from Devon! I wanted to read it to you all."
    gl "¡Oh, por fin me ha llegado una carta de Devon! Quería leérosla a todos."

# game/Scenes/Izzy/izzy16.rpy:64
translate spanish izzy16_5a9155a5:

    # "Izzy runs off to her bedroom and comes back with a handwritten letter."
    "Izzy corre a su habitación y vuelve con una carta escrita a mano."

# game/Scenes/Izzy/izzy16.rpy:65
translate spanish izzy16_b761674c:

    # gl "So, he says \"Hey girl. I miss you. Hope you're doing okay. I'm sorry you lost custody of your bros. That's fucked.\""
    gl "Bueno, dice: «Hola, chica. Te echo de menos. Espero que estés bien. Siento que hayas perdido la custodia de tus hermanos. Es una mierda»."

# game/Scenes/Izzy/izzy16.rpy:66
translate spanish izzy16_64564cc0:

    # gl "\"It's looking like I'm going to be in here for a few years. Lawyer says I'll probably get sentenced 5-10 years, but I'll get out in 3 on good behavior.\""
    gl "«Parece que voy a estar aquí unos años. El abogado dice que probablemente me condenen a entre 5 y 10 años, pero que saldré en 3 por buen comportamiento»."

# game/Scenes/Izzy/izzy16.rpy:69
translate spanish izzy16_f069ccf9:

    # moose "Five to ten. Damn..."
    moose "De cinco a diez. Joder..."

# game/Scenes/Izzy/izzy16.rpy:70
translate spanish izzy16_14fc56d2:

    # mal "Fuck, that sucks."
    mal "Joder, qué mierda."

# game/Scenes/Izzy/izzy16.rpy:73
translate spanish izzy16_178fa0ad:

    # gl "\"I want you to know that it's not your fault. I don't blame you for anything. You did what you had to do to try to protect your brothers. I get that.\""
    gl "«Quiero que sepas que no es culpa tuya. No te culpo de nada. Hiciste lo que tenías que hacer para intentar proteger a tus hermanos. Lo entiendo»."

# game/Scenes/Izzy/izzy16.rpy:74
translate spanish izzy16_f52d83b3:

    # gl "\"Lawyer says I can take some college classes in here. I'm gonna do that. Make myself better, you know?\""
    gl "«El abogado dice que puedo dar algunas clases universitarias aquí dentro. Voy a hacerlo. Mejorarme a mí mismo, ¿sabes?»."

# game/Scenes/Izzy/izzy16.rpy:75
translate spanish izzy16_1e43860e:

    # gl "\"I couldn't afford college out there, but here I can do something with myself.\""
    gl "«Allí fuera no podía permitirme la universidad, pero aquí puedo hacer algo con mi vida»."

# game/Scenes/Izzy/izzy16.rpy:76
translate spanish izzy16_05190c64:

    # gl "\"So that when I get out, I can get a real job, you know? I don't want to go back to slinging this shit.\""
    gl "«Así, cuando salga, podré conseguir un trabajo de verdad, ¿sabes? No quiero volver a traficar con esta mierda»."

# game/Scenes/Izzy/izzy16.rpy:77
translate spanish izzy16_d23f399d:

    # gl "\"I love you, girl. You know that. But I know you don't feel the same way about me. That's on me. I gotta deal with that.\""
    gl "«Te quiero, chica. Ya lo sabes. Pero sé que tú no sientes lo mismo por mí. Es culpa mía. Tengo que aceptarlo»."

# game/Scenes/Izzy/izzy16.rpy:78
translate spanish izzy16_2931e843:

    # gl "\"I just want you to be happy...\""
    gl "«Solo quiero que seas feliz...»"

# game/Scenes/Izzy/izzy16.rpy:81
translate spanish izzy16_226cd458:

    # gl "Blah blah blah, he says some other mushy shit here."
    gl "Bla, bla, bla, aquí suelta alguna otra tontería sentimental."

# game/Scenes/Izzy/izzy16.rpy:82
translate spanish izzy16_52aa579a:

    # gl "\"Tell Moose and Mal... and [pcname] too, that I'm thinking about them and hope for the best for them.\""
    gl "«Dile a Moose y a Mal... y a [pcname] también, que pienso en ellos y les deseo lo mejor»."

# game/Scenes/Izzy/izzy16.rpy:83
translate spanish izzy16_0fa021f6:

    # gl "\"Miss hanging out with all of y'all in the park. Listening to music. Getting high. That's some of my favorite times.\""
    gl "«Echo de menos salir con todos vosotros al parque. Escuchar música. Colocarnos. Esos son algunos de mis momentos favoritos»."

# game/Scenes/Izzy/izzy16.rpy:84
translate spanish izzy16_39c3b21b:

    # gl "\"Fucking the shit out of you was pretty great too. I think about that a lot. Especially at night, in this cell by myself.\""
    gl "«Follarte a lo bestia también fue genial. Pienso mucho en eso. Sobre todo por la noche, aquí solo en esta celda»."

# game/Scenes/Izzy/izzy16.rpy:88
translate spanish izzy16_2b1c2043:

    # gl "\"Anyway, I hope I see y'all again someday soon. Take care of each other. Devon.\""
    gl "«En fin, espero volver a veros a todos pronto. Cuidaos unos de otros. Devon»."

# game/Scenes/Izzy/izzy16.rpy:91
translate spanish izzy16_e3f55029:

    # moose "Damn, that got me a bit."
    moose "Joder, eso me ha conmovido un poco."

# game/Scenes/Izzy/izzy16.rpy:92
translate spanish izzy16_6a7a011c:

    # moose "Devon's always been really smart. He writes pretty good."
    moose "Devon siempre ha sido muy inteligente. Escribe bastante bien."

# game/Scenes/Izzy/izzy16.rpy:93
translate spanish izzy16_65c43670:

    # mal "Yeah, that's cool that he's getting some college in there."
    mal "Sí, qué bien que esté estudiando en la universidad."

# game/Scenes/Izzy/izzy16.rpy:94
translate spanish izzy16_3cac1b73:

    # gl "Ugh, that was more of a downer than I expected. We gotta do something fun now."
    gl "Uf, eso ha sido más deprimente de lo que esperaba. Ahora tenemos que hacer algo divertido."

# game/Scenes/Izzy/izzy16.rpy:95
translate spanish izzy16_8e317be9:

    # gl "Pull that board game out, Twig. Let's play."
    gl "Saca ese juego de mesa, Twig. Juguemos."

# game/Scenes/Izzy/izzy16.rpy:99
translate spanish izzy16_07fa2242:

    # "I set up the game. It's all well-played, with some pieces missing and replaced with numbers written in Sharpie on cardstock."
    "Preparo el juego. Está en buen estado, aunque faltan algunas piezas y se han sustituido por números escritos con rotulador Sharpie en cartulina."

# game/Scenes/Izzy/izzy16.rpy:100
translate spanish izzy16_633fff74:

    # "Just seeing the game makes me think of all the times I played with my dad when I was young."
    "Solo con ver el juego me acuerdo de todas las veces que jugaba con mi padre cuando era pequeño."

# game/Scenes/Izzy/izzy16.rpy:103
translate spanish izzy16_51e89ffe:

    # mal "Are we seriously going to play this? It's like the nerdiest thing I've ever seen."
    mal "¿De verdad vamos a jugar a esto? Es lo más friki que he visto en mi vida."

# game/Scenes/Izzy/izzy16.rpy:104
translate spanish izzy16_2245c52c:

    # moose "It looks fun to me. You ever play Trouble? Man, I fucking love Trouble."
    moose "A mí me parece divertido. ¿Has jugado alguna vez al Trouble? Tío, me encanta el Trouble."

# game/Scenes/Izzy/izzy16.rpy:105
translate spanish izzy16_50e6a2c6:

    # mal "Such a dork."
    mal "Qué pringado."

# game/Scenes/Izzy/izzy16.rpy:106
translate spanish izzy16_201e2f96:

    # moose "Fuck you, man. It's cool."
    moose "Que te den, tío. Es genial."

# game/Scenes/Izzy/izzy16.rpy:107
translate spanish izzy16_87262d0d:

    # "I explain the rules to them and we get going."
    "Les explico las reglas y empezamos a jugar."

# game/Scenes/Izzy/izzy16.rpy:110
translate spanish izzy16_e66dc723:

    # moose "This is bullshit man. You never roll my numbers."
    moose "Esto es una mierda, tío. Nunca te salen mis números."

# game/Scenes/Izzy/izzy16.rpy:111
translate spanish izzy16_6272aba7:

    # mal "You set up your towns on twos and twelves man, what do you expect?"
    mal "Tú pones tus ciudades en los dos y los doce, tío, ¿qué esperabas?"

# game/Scenes/Izzy/izzy16.rpy:112
translate spanish izzy16_b1545219:

    # moose "What does that matter?"
    moose "¿Y eso qué importa?"

# game/Scenes/Izzy/izzy16.rpy:113
translate spanish izzy16_74990813:

    # mal "Those numbers don't get rolled as much, dawg."
    mal "Esos números no salen tan a menudo, tío."

# game/Scenes/Izzy/izzy16.rpy:114
translate spanish izzy16_2eeda9f1:

    # moose "What the fuck, why not?"
    moose "¿Qué coño pasa, por qué no?"

# game/Scenes/Izzy/izzy16.rpy:115
translate spanish izzy16_0957cc6d:

    # mal "Man, I ain't got time to explain dice odds to you."
    mal "Tío, no tengo tiempo para explicarte las probabilidades de los dados."

# game/Scenes/Izzy/izzy16.rpy:116
translate spanish izzy16_bf6b13ad:

    # moose "Fuck you, man. Roll and get me some damn wood this time."
    moose "Que te jodan, tío. Tira y consígueme un poco de madera esta vez."

# game/Scenes/Izzy/izzy16.rpy:119
translate spanish izzy16_790ffa79:

    # pc "I have one wool, will one of you trade me a wood for it?"
    pc "Tengo una lana, ¿alguno de vosotros me cambia una madera por ella?"

# game/Scenes/Izzy/izzy16.rpy:120
translate spanish izzy16_beddfc99:

    # moose "Yeah, I'll do that."
    moose "Sí, lo haré."

# game/Scenes/Izzy/izzy16.rpy:121
translate spanish izzy16_5d7c40c3:

    # mal "Wait a second. I need that wood. Trade with me instead."
    mal "Espera un segundo. Yo necesito esa madera. Intercámbiala conmigo en su lugar."

# game/Scenes/Izzy/izzy16.rpy:122
translate spanish izzy16_bc0a1ec8:

    # moose "Well, he asked first."
    moose "Bueno, él lo pidió primero."

# game/Scenes/Izzy/izzy16.rpy:123
translate spanish izzy16_4bdd12e0:

    # mal "I'll give you two wools for it."
    mal "Te daré dos lanas por ella."

# game/Scenes/Izzy/izzy16.rpy:124
translate spanish izzy16_98f16f12:

    # moose "Oh, well I guess I'll trade with you then."
    moose "Oh, bueno, supongo que entonces haré el intercambio contigo."

# game/Scenes/Izzy/izzy16.rpy:125
translate spanish izzy16_c6ff5b4a:

    # pc "I'll give you a wool and two stone."
    pc "Te daré una lana y dos piedras."

# game/Scenes/Izzy/izzy16.rpy:126
translate spanish izzy16_d6290061:

    # moose "Oh damn, I guess everybody wants my wood."
    moose "Oh, joder, parece que todo el mundo quiere mi madera."

# game/Scenes/Izzy/izzy16.rpy:127
translate spanish izzy16_401da916:

    # gl "Fuck yeah! Haha!"
    gl "¡Joder, sí! ¡Jaja!"

# game/Scenes/Izzy/izzy16.rpy:130
translate spanish izzy16_7a25b164:

    # mal "You gotta stop trading with them, man. They're going to win."
    mal "Tienes que dejar de intercambiar con ellos, tío. Van a ganar."

# game/Scenes/Izzy/izzy16.rpy:131
translate spanish izzy16_b8952c17:

    # gl "I ain't gonna win. Twig's gonna win. I'm still like four points away."
    gl "Yo no voy a ganar. Twig va a ganar. Todavía me faltan como cuatro puntos."

# game/Scenes/Izzy/izzy16.rpy:132
translate spanish izzy16_5da39bcb:

    # pc "So am I."
    pc "A mí también."

# game/Scenes/Izzy/izzy16.rpy:133
translate spanish izzy16_740ae061:

    # gl "No you ain't. You got the longest road. So you're two points away."
    gl "No, a ti no. Tienes la carretera más larga. Así que te faltan dos puntos."

# game/Scenes/Izzy/izzy16.rpy:134
translate spanish izzy16_d49ac5a8:

    # moose "What is this longest road, shit?"
    moose "¿Qué es eso de la carretera más larga, joder?"

# game/Scenes/Izzy/izzy16.rpy:137
translate spanish izzy16_c63a510c:

    # gl "Man, he told you about this at the beginning. The person who has the longest road gets that card and gets 2 points."
    gl "Tío, te lo dijo al principio. La persona que tiene la carretera más larga se lleva esa carta y gana 2 puntos."

# game/Scenes/Izzy/izzy16.rpy:138
translate spanish izzy16_0da2fb5f:

    # moose "Why you get points for having a long road?"
    moose "¿Por qué se ganan puntos por tener un camino largo?"

# game/Scenes/Izzy/izzy16.rpy:139
translate spanish izzy16_a4a72943:

    # mal "Yeah dawg, it ain't the length of the road that matters."
    mal "Sí, tío, lo que importa no es la longitud del camino."

# game/Scenes/Izzy/izzy16.rpy:140
translate spanish izzy16_a8d04144:

    # moose "That's right. Just because it's long, don't mean nothing. How girthy is that road?"
    moose "Así es. Que sea largo no significa nada. ¿Qué grosor tiene ese camino?"

# game/Scenes/Izzy/izzy16.rpy:141
translate spanish izzy16_3d5ec17a:

    # mal "Do I get two points for having the chodiest road?"
    mal "¿Me dan dos puntos por tener el camino más gordo?"

# game/Scenes/Izzy/izzy16.rpy:144
translate spanish izzy16_8145f187:

    # gl "Oh my God, shut up. Y'all so stupid."
    gl "Dios mío, cállate. Sois tan estúpidos."

# game/Scenes/Izzy/izzy16.rpy:148
translate spanish izzy16_d41d8cd9_1:

    # voice 'voices/izzy_16_1.mp3'
    voice 'voices/izzy_16_1.mp3'

# game/Scenes/Izzy/izzy16.rpy:149
translate spanish izzy16_77ab14bd:

    # gl "I'll give you an ore for your two wood."
    gl "Te daré un ore por tus dos maderas."

# game/Scenes/Izzy/izzy16.rpy:150
translate spanish izzy16_1c2f6475:

    # moose "Gonna have to do better than that, girl."
    moose "Vas a tener que ofrecer algo mejor que eso, chica."

# game/Scenes/Izzy/izzy16.rpy:151
translate spanish izzy16_838a37fd:

    # pc "I'll give you two ore for the two wood."
    pc "Te daré dos minerales por las dos maderas."

# game/Scenes/Izzy/izzy16.rpy:152
translate spanish izzy16_4346e02a:

    # moose "Nice. I'll do that, unless you can do better, Izzy."
    moose "Genial. Acepto, a menos que puedas ofrecer algo mejor, Izzy."

# game/Scenes/Izzy/izzy16.rpy:154
translate spanish izzy16_d41d8cd9_2:

    # voice 'voices/izzy_16_2.mp3'
    voice 'voices/izzy_16_2.mp3'

# game/Scenes/Izzy/izzy16.rpy:155
translate spanish izzy16_02988a1e:

    # gl "Man, I ain't got two ore."
    gl "Tío, no tengo dos minerales."

# game/Scenes/Izzy/izzy16.rpy:157
translate spanish izzy16_d41d8cd9_3:

    # voice 'voices/izzy_16_3.mp3'
    voice 'voices/izzy_16_3.mp3'

# game/Scenes/Izzy/izzy16.rpy:158
translate spanish izzy16_7154f0b2:

    # gl "I'll give you my one ore, but I'll pop my titties out."
    gl "Te daré mi único mineral, pero me sacaré las tetas."

# game/Scenes/Izzy/izzy16.rpy:159
translate spanish izzy16_d7ba0fa5:

    # moose "Sold. You gotta leave them out though."
    moose "Trato hecho. Pero tienes que dejarlas fuera."

# game/Scenes/Izzy/izzy16.rpy:161
translate spanish izzy16_d41d8cd9_4:

    # voice 'voices/izzy_16_4.mp3'
    voice 'voices/izzy_16_4.mp3'

# game/Scenes/Izzy/izzy16.rpy:162
translate spanish izzy16_7966dacb:

    # gl "You got it."
    gl "De acuerdo."

# game/Scenes/Izzy/izzy16.rpy:163
translate spanish izzy16_a57096d9:

    # pc "Hey, wait a..."
    pc "Oye, espera un..."

# game/Scenes/Izzy/izzy16.rpy:166
translate spanish izzy16_90326d0c:

    # moose "Yeah girl, it's all yours."
    moose "Sí, chica, es todo tuyo."

# game/Scenes/Izzy/izzy16.rpy:167
translate spanish izzy16_4ebd03b0:

    # pc "This doesn't seem fair."
    pc "Esto no me parece justo."

# game/Scenes/Izzy/izzy16.rpy:168
translate spanish izzy16_8add09a3:

    # moose "Sorry man. I love me some titties."
    moose "Lo siento, tío. Me encantan las tetas."

# game/Scenes/Izzy/izzy16.rpy:171
translate spanish izzy16_0e6d6188:

    # mal "If you keep trading with her, we're definitely going to lose."
    mal "Si sigues intercambiando con ella, seguro que vamos a perder."

# game/Scenes/Izzy/izzy16.rpy:172
translate spanish izzy16_79edc41b:

