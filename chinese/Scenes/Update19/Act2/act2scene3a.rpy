# game/Scenes/Update19/Act2/act2scene3a.rpy:45
translate chinese u19a2s3a_4a6014ee:

    # sst "Trolls... I hate trolls. Let's help her."
    sst "巨魔……我讨厌巨魔。去帮帮她吧。"

# game/Scenes/Update19/Act2/act2scene3a.rpy:47
translate chinese u19a2s3a_c989b003:

    # rb "Do you think you're going to be able to fight those things? You'll definitely need my help."
    rb "你觉得你能打赢那些东西吗？你肯定需要我的帮助。"

# game/Scenes/Update19/Act2/act2scene3a.rpy:48
translate chinese u19a2s3a_993e94f1:

    # rb "Let's do this."
    rb "干吧。"

