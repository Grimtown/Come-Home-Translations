translate spanish izzy2_e3c5fbdd:

    # gl "I'm Izzy. These guys are my gang."
    gl "Soy Izzy. Estos chicos son mi pandilla."

# game/Scenes/Izzy/izzy2.rpy:39
translate spanish izzy2_a0189c31:

    # moose "YOUR gang?"
    moose "¿TU pandilla?"

# game/Scenes/Izzy/izzy2.rpy:40
translate spanish izzy2_f87a2e20:

    # gl "Yeah, Moose. MY gang. You have a problem with that?"
    gl "Sí, Moose. MI pandilla. ¿Te molesta?"

# game/Scenes/Izzy/izzy2.rpy:41
translate spanish izzy2_bf630c9b:

    # moose "Naw, sis. No problem."
    moose "No, hermana. No me molesta."

# game/Scenes/Izzy/izzy2.rpy:43
