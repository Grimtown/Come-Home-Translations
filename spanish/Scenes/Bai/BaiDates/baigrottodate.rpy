# game/Scenes/Bai/BaiDates/baigrottodate.rpy:19
translate spanish baigrottodate_d3715341:

    # pc "Do you want to come out to a fancy restaurant with me?"
    pc "¿Quieres venir conmigo a un restaurante elegante?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:20
translate spanish baigrottodate_4243d9c3:

    # pc "It's called The Grotto. It's out on the lake."
    pc "Se llama La Gruta. Está junto al lago."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:23
translate spanish baigrottodate_4f7f94cb:

    # bai "Is it expensive?"
    bai "¿Es caro?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:24
translate spanish baigrottodate_3308b177:

    # pc "Pretty expensive, yeah."
    pc "Bastante caro, sí."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:26
translate spanish baigrottodate_fb59b9b7:

    # bai "Aw, what the hell. Might as well spend it, right?"
    bai "Bah, qué más da. ¿Por qué no gastarlo, no?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:27
translate spanish baigrottodate_f82e580f:

    # bai "I eat cheap every other day, let's get some fancy food!"
    bai "Como barato cada dos días, ¡vamos a por comida de lujo!"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:28
translate spanish baigrottodate_5f71dc40:

    # pc "All right! I'll text you the address and meet you out there."
    pc "¡De acuerdo! Te mando la dirección por mensaje y nos vemos allí."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:29
translate spanish baigrottodate_1bda0dbe:

    # bai "Sounds good! See you there."
    bai "¡Suena bien! Nos vemos allí."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:32
translate spanish baigrottodate_cf65d098:

    # "I get ready and text Bai the address, then about an hour later we're sitting down to eat at The Grotto."
    "Me preparo y le mando la dirección a Bai por mensaje, y una hora más tarde estamos sentados comiendo en The Grotto."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:35
translate spanish baigrottodate_79872e14:

    # bai "That sounds great. Are we going to get all dressed up in suits and stuff?"
    bai "Suena genial. ¿Nos vamos a arreglar con trajes y todo eso?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:36
translate spanish baigrottodate_a9dc377e:

    # pc "Damn right, we are."
    pc "Claro que sí."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:38
translate spanish baigrottodate_bfaba4a8:

    # bai "Oh man. I have to find my suit then. I know I have one in the closet somewhere."
    bai "Vaya. Entonces tengo que encontrar mi traje. Sé que tengo uno en el armario por ahí."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:39
translate spanish baigrottodate_b5cc83ae:

    # bai "I'll go find it."
    bai "Voy a buscarlo."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:40
translate spanish baigrottodate_ffb27a81:

    # pc "Okay. Send me a text when you're ready and I'll come pick you up, okay?"
    pc "Vale. Envíame un mensaje cuando estés listo y iré a recogerte, ¿vale?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:42
translate spanish baigrottodate_9e815b71:

    # bai "Okay! I'm really excited!"
    bai "¡Vale! ¡Tengo muchas ganas!"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:43
translate spanish baigrottodate_f07574ec:

    # pc "Good."
    pc "Bien."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:44
translate spanish baigrottodate_412f6c55:

    # bai "Okay, see you in a bit."
    bai "Vale, nos vemos en un rato."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:47
translate spanish baigrottodate_9bcd7a72:

    # "I get ready to go and wait for Bai's text."
    "Me preparo para salir y espero el mensaje de Bai."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:48
translate spanish baigrottodate_9173db50:

    # "About an hour later, he texts me and I go pick him up, then we walk into The Grotto together."
    "Como una hora más tarde, me envía un mensaje y voy a recogerlo, luego entramos juntos en The Grotto."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:51
translate spanish baigrottodate_9131d6c6:

    # bai "Sounds good! I'll see you there."
    bai "¡Suena bien! Nos vemos allí."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:52
translate spanish baigrottodate_5d3d77d3:

    # pc "Cool. See you."
    pc "Genial. Nos vemos."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:54
translate spanish baigrottodate_299409d0:

    # bai "That sounds great! I'll start getting ready. Come get me."
    bai "¡Suena genial! Empezaré a prepararme. Ven a buscarme."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:55
translate spanish baigrottodate_e3948ee8:

    # pc "Alright, I'll be there in a bit."
    pc "Vale, estaré allí en un rato."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:69
translate spanish baigrottostartdate_ba211ff8:

    # "We walk in together, holding hands."
    "Entramos juntos, cogidos de la mano."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:70
translate spanish baigrottostartdate_fb0e2e4f:

    # bai "This feels very public. More public than we usually are."
    bai "Esto se siente muy público. Más público de lo que solemos estar."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:71
translate spanish baigrottostartdate_a674eec0:

    # pc "Are you okay with that?"
    pc "¿Te parece bien?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:72
translate spanish baigrottostartdate_023cf823:

    # bai "Yeah, with you, I think I am."
    bai "Sí, contigo, creo que sí."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:73
translate spanish baigrottostartdate_e39c1441:

    # pc "Good. You look like a fucking stud right now. I'm proud to be here with you."
    pc "Bien. Ahora mismo pareces un puto semental. Estoy orgulloso de estar aquí contigo."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:74
translate spanish baigrottostartdate_bb37df29:

    # bai "Me too."
    bai "Yo también."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:81
translate spanish baigrottostartdate_a5785e55:

    # "We sit at a table and begin looking over the menus."
    "Nos sentamos en una mesa y empezamos a mirar los menús."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:82
translate spanish baigrottostartdate_a395082c:

    # "Then a server comes by and takes our order."
    "Luego se acerca un camarero y nos toma nota."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:91
translate spanish baigrottostartdate_32733c2f:

    # "After we chat for a while, our food is brought out."
    "Después de charlar un rato, nos traen la comida."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:92
translate spanish baigrottostartdate_501f942a:

    # bai "Wow, this looks amazing."
    bai "Vaya, esto tiene una pinta increíble."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:98
translate spanish baigrottostartdate_28b42b01:

    # "We continue chatting while we eat our meal. Just hanging out and enjoying some good food together."
    "Seguimos charlando mientras comemos. Simplemente pasando el rato y disfrutando de una buena comida juntos."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:101
translate spanish baigrottostartdate_7150c85d:

    # "When we're done eating, we split the bill and say our goodbyes."
    "Cuando terminamos de comer, dividimos la cuenta y nos despedimos."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:105
translate spanish baigrottostartdate_25d6d119:

    # bai "That was fun, man. Good food. Thanks for inviting me."
    bai "Ha sido divertido, tío. Buena comida. Gracias por invitarme."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:106
translate spanish baigrottostartdate_0c975e99:

    # pc "No problem. Good to hang out and talk for a while."
    pc "No hay problema. Me ha gustado pasar el rato y charlar un rato."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:107
translate spanish baigrottostartdate_49b45846:

    # bai "Yeah it was."
    bai "Sí, a mí también."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:108
translate spanish baigrottostartdate_01c7ca57:

    # bai "Alright, well I'll see you later. Take care."
    bai "Vale, pues nos vemos luego. Cuídate."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:109
translate spanish baigrottostartdate_22fbafdc:

    # pc "You too. See ya."
    pc "Tú también. Nos vemos."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:112
translate spanish baigrottostartdate_0c8ca28d:

    # "We get in our cars and go our separate directions."
    "Nos subimos a nuestros coches y nos vamos cada uno por nuestro lado."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:120
translate spanish baigrottostartdate_bfde7d54:

    # "We continue chatting and eating."
    "Seguimos charlando y comiendo."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:126
translate spanish baigrottostartdate_1ef0c0b5:

    # "Bai insists that we split the bill, then we get ready to leave."
    "Bai insiste en que dividamos la cuenta, y luego nos preparamos para irnos."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:132
translate spanish baigrottostartdate_ca01422f:

    # bai "It's so pretty out here, isn't it?"
    bai "Es tan bonito aquí fuera, ¿verdad?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:133
translate spanish baigrottostartdate_44eeaf1a:

    # pc "Yeah it is."
    pc "Sí, lo es."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:139
translate spanish baigrottostartdate_7c70709c:

    # "I lean in and kiss him, uncaring about anybody who might be watching us."
    "Me inclino y lo beso, sin importarme si alguien nos está mirando."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:140
translate spanish baigrottostartdate_61700a7a:

    # "He is surprised at first, but doesn't pull away."
    "Al principio se sorprende, pero no se aparta."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:143
translate spanish baigrottostartdate_4a0dd6f7:

    # bai "I can't believe I just did that. Right in front of everybody."
    bai "No puedo creer que haya hecho eso. Justo delante de todo el mundo."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:144
translate spanish baigrottostartdate_6e718b73:

    # pc "How did it feel?"
    pc "¿Qué tal te ha sentado?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:145
translate spanish baigrottostartdate_3696af55:

    # bai "It felt great."
    bai "Me ha encantado."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:150
translate spanish baigrottostartdate_d90b231d:

    # bai "Want to go back to my apartment now?"
    bai "¿Quieres ir a mi piso ahora?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:153
translate spanish baigrottostartdate_4861bda5:

    # bai "Aw, okay. Well it was a good date, anyway. Thanks for bringing me."
    bai "Ay, vale. Bueno, ha sido una buena cita, de todas formas. Gracias por traerme."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:156
translate spanish baigrottostartdate_29d9625f:

    # "We leave and I drive him to his aparment and say goodbye."
    "Nos vamos y lo llevo a su piso y me despido."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:157
translate spanish baigrottostartdate_f1413fe1:

    # "Then I drive away to do something else with my night."
    "Luego me voy para hacer otra cosa con mi noche."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:164
translate spanish baigrottostartdate_ebdfbc55:

    # "We rush out to the car and drive back to his apartment."
    "Salimos corriendo al coche y volvemos a su piso."

translate spanish strings:

    # game/Scenes/Bai/BaiDates/baigrottodate.rpy:2
    old "After you have gone out to The Grotto with Whitney, you'll unlock it for other characters."
    new "Después de haber ido a The Grotto con Whitney, lo desbloquearás para otros personajes."

    # game/Scenes/Bai/BaiDates/baigrottodate.rpy:3
    old "Call Bai in the evening and invite him to The Grotto. If you're on the romance path with Bai, you'll need to have pizza at his place before this option is available."
    new "Llama a Bai por la noche e invítale a The Grotto. Si estás en la ruta romántica con Bai, tendrás que comer pizza en su casa antes de que esta opción esté disponible."

    # game/Scenes/Bai/BaiDates/baigrottodate.rpy:161
    old "Yeah, let's go"
    new "Sí, vamos."

