# game/Scenes/Izzy/izzy16.rpy:324
translate chinese izzy16_9ea02672:

    # "We tell them goodbye and they leave the house, heading out to Mal's car."
    "我们跟他们道别，他们走出房子，朝玛尔的车走去。"

# game/Scenes/Izzy/izzy16.rpy:327
translate chinese izzy16_e4961fdc:

    # gl "Well... that was a fun game night."
    gl "嗯……今晚的游戏真有趣。"

# game/Scenes/Izzy/izzy16.rpy:328
translate chinese izzy16_31907f49:

    # gl "Sorry I cheated."
    gl "抱歉我作弊了。"

# game/Scenes/Izzy/izzy16.rpy:329
translate chinese izzy16_9171cd52:

    # pc "Ah, it's all right. We all knew where this was going, I think."
    pc "啊，没关系。我觉得我们都知道这会发展成什么样。"

# game/Scenes/Izzy/izzy16.rpy:330
translate chinese izzy16_4abf1190:

    # gl "Thanks for sharing. I really enjoyed it."
    gl "谢谢你分享。我真的很喜欢。"

# game/Scenes/Izzy/izzy16.rpy:331
translate chinese izzy16_53a29a41:

    # pc "I know you did. I did too."
    pc "我知道你喜欢。我也喜欢。"

# game/Scenes/Izzy/izzy16.rpy:334
translate chinese izzy16_e914bfdc:

    # gl "You are a really good boyfriend, you know that?"
    gl "你真是个好男朋友，你知道吗？"

# game/Scenes/Izzy/izzy16.rpy:335
translate chinese izzy16_677ee242:

    # pc "Yeah, you're not so bad yourself."
    pc "是啊，你自己也不赖。"

# game/Scenes/Izzy/izzy16.rpy:336
translate chinese izzy16_6d52d3a6:

    # gl "I may want to marry you one day."
    gl "“说不定哪天我会想嫁给你。”"

# game/Scenes/Izzy/izzy16.rpy:337
translate chinese izzy16_ae871f39:

    # pc "Oh yeah?"
    pc "“哦，是吗？”"

# game/Scenes/Izzy/izzy16.rpy:340
translate chinese izzy16_a3388522:

    # gl "Maybe. Just something I was thinking about."
    gl "“也许吧。只是我突然这么想的。”"

# game/Scenes/Izzy/izzy16.rpy:341
translate chinese izzy16_fc71e7f9:

    # gl "You staying the night?"
    gl "“你今晚留下来吗？”"

# game/Scenes/Izzy/izzy16.rpy:342
translate chinese izzy16_3e51dd6a:

    # pc "Yeah, I'll stay."
    pc "“嗯，我留下来。”"

# game/Scenes/Izzy/izzy16.rpy:346
translate chinese izzy16_c6a7da14:

    # "We go back to her bed and lie down together."
    "我们回到她的床上，并排躺下。"

# game/Scenes/Izzy/izzy16.rpy:349
translate chinese izzy16_033d9c0c:

    # "It doesn't take long before we're both asleep."
    "没过多久，我们就都睡着了。"

# game/Scenes/Izzy/izzy16.rpy:352
translate chinese izzy16_1cee6238:

    # "I wake up to the sound of my phone alarm in the morning."
    "早上，我被手机闹钟的铃声吵醒。"

# game/Scenes/Izzy/izzy16.rpy:355
translate chinese izzy16_bc4ff6d9:

    # pc "Hey, Izzy. I have to go."
    pc "嘿，伊兹。我得走了。"

# game/Scenes/Izzy/izzy16.rpy:356
translate chinese izzy16_4511aa4e:

    # gl "Oh okay, baby."
    gl "哦，好的，亲爱的。"

# game/Scenes/Izzy/izzy16.rpy:357
translate chinese izzy16_475c67d1:

    # gl "Hope you have a good day. Thanks for staying over."
    gl "希望你今天过得愉快。谢谢你留宿。"

# game/Scenes/Izzy/izzy16.rpy:360
translate chinese izzy16_f4a8219d:

    # pc "I'll talk to you later."
    pc "待会儿再聊。"

# game/Scenes/Izzy/izzy16.rpy:361
translate chinese izzy16_923d4965:

    # gl "Okay."
    gl "好的。"

# game/Scenes/Izzy/izzy16.rpy:364
translate chinese izzy16_7db1b4d7:

    # "As I'm walking away, I hear her say, almost too low to make out the words..."
    "当我转身离开时，听到她轻声说道，声音几乎小得听不清……"

# game/Scenes/Izzy/izzy16.rpy:365
translate chinese izzy16_968ee224:

    # gl "Love you, Twig."
    gl "爱你，特威格。"

# game/Scenes/Izzy/izzy16.rpy:366
translate chinese izzy16_5236ef26:

    # "I leave Izzy's house, then head home to change and shower before starting my day."
    "我离开伊兹的家，然后回家换衣服洗澡，准备开始新的一天。"

