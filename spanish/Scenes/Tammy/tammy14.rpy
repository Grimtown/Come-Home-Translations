translate spanish tammy14_ee137836:

    # ss "Good! Squish her, [bro]! Squish her!"
    ss "¡Bien! ¡Aplástala, [bro]! ¡Aplástala!"

# game/Scenes/Tammy/tammy14.rpy:158
