translate spanish julianaluigisstartdate_8b40ce2d:

    # "She gets in the car wearing a pretty dress and a wig."
    "Se sube al coche con un bonito vestido y una peluca."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:37
translate spanish julianaluigisstartdate_c178e9aa:

    # bn "Oh, thank you."
    bn "Oh, gracias."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:38
translate spanish julianaluigisstartdate_c91b3eb2:

    # bn "I sometimes like to wear it when I'm going out on a nice date."
    bn "A veces me gusta ponérmela cuando salgo a una cita especial."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:39
translate spanish julianaluigisstartdate_c295710b:

    # bn "Not that I've had many dates."
    bn "No es que haya tenido muchas citas."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:40
translate spanish julianaluigisstartdate_a71bf22a:

    # pc "Well it's very pretty."
    pc "Bueno, es muy bonita."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:41
translate spanish julianaluigisstartdate_3dc0e34e:

    # "She turns away and blushes a little."
    "Se da la vuelta y se sonroja un poco."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:43
translate spanish julianaluigisstartdate_313b6a1f:

    # bn "Oh, um. I don't know."
    bn "Oh, eh... No sé."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:44
translate spanish julianaluigisstartdate_2f29693a:

    # bn "I like to wear them when I go out somewhere nice."
    bn "Me gusta ponérmelas cuando salgo a algún sitio bonito."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:47
translate spanish julianaluigisstartdate_1431cc27:

    # bn "Thank you."
    bn "Gracias."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:48
translate spanish julianaluigisstartdate_3dc0e34e_1:

    # "She turns away and blushes a little."
    "Se gira y se sonroja un poco."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:50
translate spanish julianaluigisstartdate_563fa2c8:

    # bn "Okay. Well I prefer the wig when I go somewhere nice."
    bn "Vale. Bueno, yo prefiero la peluca cuando voy a algún sitio bonito."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:51
translate spanish julianaluigisstartdate_e256026f:

    # "I'm not really sure how to respond, so we end up driving the rest of the way to the restaurant in an awkward silence."
    "No sé muy bien cómo responder, así que acabamos conduciendo el resto del trayecto hasta el restaurante en un silencio incómodo."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:54
translate spanish julianaluigisstartdate_62345451:

    # "When we get to Luigi's, we sit and order our meals."
    "Cuando llegamos a Luigi's, nos sentamos y pedimos la comida."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:55
translate spanish julianaluigisstartdate_c57a5228:

    # "Then we chat for a while."
    "Luego charlamos un rato."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:58
translate spanish julianaluigisstartdate_0875967f:

    # "The server brings our food out, and we continue talking while we eat."
    "El camarero nos trae la comida y seguimos hablando mientras comemos."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:60
translate spanish julianaluigisstartdate_dbe7b11f:

    # "When we're done eating, we just hang around and talk for a little more."
    "Cuando terminamos de comer, nos quedamos un rato más charlando."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:63
translate spanish julianaluigisstartdate_018a4945:

    # "After our conversation, I pay for the food and we leave the restaurant and drive back to Juliana's house."
    "Después de nuestra conversación, pago la cuenta, salimos del restaurante y volvemos en coche a casa de Juliana."

