# game/Scenes/Update20/u20n.rpy:2
translate spanish u20n_0157cb27:

    # "For now, I should go see Bai."
    "Por ahora, debería ir a ver a Bai."

# game/Scenes/Update20/u20n.rpy:5
translate spanish u20n_5e377e6b:

    # "I drive to Bai's apartment and knock on the door."
    "Conduzco hasta el piso de Bai y llamo a la puerta."

# game/Scenes/Update20/u20n.rpy:6
translate spanish u20n_cd826cbc:

    # "It's late, but I have to see him."
    "Es tarde, pero tengo que verlo."

# game/Scenes/Update20/u20n.rpy:10
translate spanish u20n_435415c3:

    # "After a few moments, Bai opens the door."
    "Al cabo de unos instantes, Bai abre la puerta."

# game/Scenes/Update20/u20n.rpy:11
translate spanish u20n_fce568f9:

    # bai "Holy shit, [pcname]! You're back!"
    bai "¡Joder, [pcname]! ¡Has vuelto!"

# game/Scenes/Update20/u20n.rpy:14
translate spanish u20n_7e7c2a33:

    # "I wrap my arms around Bai, pulling him in tight."
    "Abrazo a Bai con fuerza, apretándolo contra mí."

# game/Scenes/Update20/u20n.rpy:15
translate spanish u20n_e660f3f5:

    # bai "I thought that machine killed you!"
    bai "¡Pensé que esa máquina te había matado!"

# game/Scenes/Update20/u20n.rpy:16
translate spanish u20n_52e92c2d:

    # bai "I thought I might never see you again."
    bai "Pensé que quizá no volvería a verte nunca más."

# game/Scenes/Update20/u20n.rpy:19
translate spanish u20n_e99c4913:

    # bai "So what happened? Did you really go to another universe?"
    bai "¿Qué ha pasado? ¿De verdad te fuiste a otro universo?"

# game/Scenes/Update20/u20n.rpy:20
translate spanish u20n_4859fa2f:

    # pc "Yeah, I did. I saw my dad."
    pc "Sí, lo hice. Vi a mi padre."

# game/Scenes/Update20/u20n.rpy:21
translate spanish u20n_d8ec5a44:

    # bai "Wow. Are you okay?"
    bai "Vaya. ¿Estás bien?"

# game/Scenes/Update20/u20n.rpy:22
translate spanish u20n_3c3fa8e3:

    # pc "Yeah, I'm great. I'll tell you everything tomorrow, I promise."
    pc "Sí, estoy genial. Mañana te lo contaré todo, te lo prometo."

# game/Scenes/Update20/u20n.rpy:25
translate spanish u20n_feac206a:

    # bai "I'm just glad you're back."
    bai "Me alegro de que hayas vuelto."

# game/Scenes/Update20/u20n.rpy:26
translate spanish u20n_03eaad50:

    # pc "Me too."
    pc "Yo también."

# game/Scenes/Update20/u20n.rpy:29
translate spanish u20n_61ae245c:

    # "He leans in and kisses me softly."
    "Se inclina y me besa suavemente."

# game/Scenes/Update20/u20n.rpy:30
translate spanish u20n_8466d1ae:

    # bai "Whoo, damn, you smell pretty bad though."
    bai "Vaya, joder, pero hueles bastante mal."

# game/Scenes/Update20/u20n.rpy:31
translate spanish u20n_dfccd340:

    # bai "Let's take a shower and go to bed."
    bai "Démonos una ducha y vamos a la cama."

