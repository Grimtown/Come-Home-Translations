    # pc "I'll call her real quick. Just a sec."
    pc "La llamaré enseguida. Un momento."

# game/Scenes/Mari/mari13.rpy:83
translate spanish mari13_9c77f5af:

    # rj "I thought so!"
    rj "¡Me lo imaginaba!"

# game/Scenes/Mari/mari13.rpy:85
translate spanish mari13_90e9154b:

    # rj "For now we'll just act like we don't know anybody who can fix Mari's truck."
    rj "Por ahora, vamos a hacer como si no conociéramos a nadie que pueda arreglar la camioneta de Mari."

# game/Scenes/Mari/mari13.rpy:86
