# game/Scenes/Suzy/suzy1.rpy:13
translate spanish suzy1_b52dca5a:

    # "I go to the kitchen and make a plate with what's left, then sit down across from her at the table."
    "Voy a la cocina y me preparo un plato con lo que queda, luego me siento frente a ella en la mesa."

# game/Scenes/Suzy/suzy1.rpy:14
translate spanish suzy1_c4e96a72:

    # "She puts her phone away and looks up at me."
    "Ella guarda el móvil y me mira."

# game/Scenes/Suzy/suzy1.rpy:17
translate spanish suzy1_43f2e75d:

    # ss "So how's it been going [bro]?"
    ss "¿Qué tal te ha ido [bro]?"

# game/Scenes/Suzy/suzy1.rpy:18
translate spanish suzy1_d48b3188:

    # pc "Pretty good, I guess."
    pc "Bastante bien, supongo."

# game/Scenes/Suzy/suzy1.rpy:19
translate spanish suzy1_c84b49b4:

    # ss "Have you found out anything about Dad?"
    ss "¿Has averiguado algo sobre papá?"

# game/Scenes/Suzy/suzy1.rpy:20
translate spanish suzy1_0b7558fc:

    # pc "Not yet."
    pc "Todavía no."

# game/Scenes/Suzy/suzy1.rpy:22
translate spanish suzy1_e47fa0f8:

    # ss "I miss him."
    ss "Lo echo de menos."

# game/Scenes/Suzy/suzy1.rpy:23
translate spanish suzy1_0b941cef:

    # pc "You got along with him well?"
    pc "¿Te llevabas bien con él?"

# game/Scenes/Suzy/suzy1.rpy:24
translate spanish suzy1_0442c0e0:

    # ss "Yeah."
    ss "Sí."

# game/Scenes/Suzy/suzy1.rpy:25
translate spanish suzy1_d244b907:

    # ss "I mean, we didn't spend a lot of time together. He was down in that basement a lot."
    ss "Bueno, no pasábamos mucho tiempo juntos. Se pasaba mucho tiempo en el sótano."

# game/Scenes/Suzy/suzy1.rpy:26
translate spanish suzy1_34edb007:

    # ss "But he would have breakfast with me every morning before school. He was funny. He'd make me laugh every day."
    ss "Pero desayunaba conmigo todas las mañanas antes del colegio. Era divertido. Me hacía reír todos los días."

# game/Scenes/Suzy/suzy1.rpy:27
translate spanish suzy1_85af114e:

    # pc "Kind of like this, huh?"
    pc "Un poco como esto, ¿no?"

# game/Scenes/Suzy/suzy1.rpy:29
translate spanish suzy1_226f4904:

    # ss "I said he was funny, not obnoxious. Plus, he wore pants. Why are you walking around in your boxers?"
    ss "He dicho que era divertido, no que fuera un pesado. Además, él llevaba pantalones. ¿Por qué vas por ahí en calzoncillos?"

# game/Scenes/Suzy/suzy1.rpy:30
translate spanish suzy1_4cc016bf:

    # pc "It's morning, I don't want to get dressed yet. You can eat breakfast in your underwear if you want."
    pc "Es por la mañana, no quiero vestirme todavía. Puedes desayunar en ropa interior si quieres."

# game/Scenes/Suzy/suzy1.rpy:31
translate spanish suzy1_bd01965a:

    # ss "Yeah, I bet you'd like that. You'd just stare at me the whole time."
    ss "Sí, seguro que te gustaría. Te pasarías todo el rato mirándome."

# game/Scenes/Suzy/suzy1.rpy:35
translate spanish suzy1_d7a0aba4:

    # ss "You're such a perv."
    ss "Eres un pervertido."

# game/Scenes/Suzy/suzy1.rpy:38
translate spanish suzy1_0ca3339d:

    # ss "You're such a jerk."
    ss "Eres un idiota."

# game/Scenes/Suzy/suzy1.rpy:39
translate spanish suzy1_a976ce63:

    # pc "Besides, you act like you don't stare at me when I'm in my boxers."
    pc "Además, no es que tú no me quedes mirando cuando estoy en calzoncillos."

# game/Scenes/Suzy/suzy1.rpy:40
translate spanish suzy1_23992985:

    # ss "What!? I do not!"
    ss "¡¿Qué?! ¡No lo hago!"

# game/Scenes/Suzy/suzy1.rpy:41
translate spanish suzy1_25e7a80f:

    # pc "Come on now [sis], I've seen you."
    pc "Venga ya [sis], te he visto."

# game/Scenes/Suzy/suzy1.rpy:43
translate spanish suzy1_873662ce:

    # ss "You're out of your mind. I've never stared at you. Like you have anything to stare at anyways."
    ss "Estás loca. Nunca te he mirado fijamente. Como si tuvieras algo que mirar, de todos modos."

# game/Scenes/Suzy/suzy1.rpy:44
translate spanish suzy1_6e7bc529:

    # pc "Oh I don't have anything to stare at?"
    pc "¿Ah, no tengo nada que mirar?"

# game/Scenes/Suzy/suzy1.rpy:45
translate spanish suzy1_ec7a8238:

    # ss "Nope."
    ss "No."

# game/Scenes/Suzy/suzy1.rpy:48
translate spanish suzy1_7745b76d:

    # ss "Yeah, whatever."
    ss "Sí, da igual."

# game/Scenes/Suzy/suzy1.rpy:51
translate spanish suzy1_24166e5d:

    # ss "No! I don't want to see!"
    ss "¡No! ¡No quiero verlo!"

# game/Scenes/Suzy/suzy1.rpy:52
translate spanish suzy1_483160a9:

    # ss "Sit down. Stop playing around."
    ss "Siéntate. Deja de hacer el tonto."

# game/Scenes/Suzy/suzy1.rpy:53
translate spanish suzy1_ce7899d2:

    # pc "I'm not playing. I'll show you."
    pc "No estoy haciendo el tonto. Te lo voy a enseñar."

# game/Scenes/Suzy/suzy1.rpy:54
translate spanish suzy1_626bbd17:

    # ss "I don't want to see it. I believe you have something there, but I don't want to see it."
    ss "No quiero verlo. Creo que tienes algo ahí, pero no quiero verlo."

# game/Scenes/Suzy/suzy1.rpy:55
translate spanish suzy1_c1226f21:

    # ss "Put it away, sit down."
    ss "Guárdalo, siéntate."

# game/Scenes/Suzy/suzy1.rpy:56
translate spanish suzy1_02b8ec2b:

    # pc "Alright, I'm sitting."
    pc "Vale, me siento."

# game/Scenes/Suzy/suzy1.rpy:58
translate spanish suzy1_c7580a8a:

    # ss "You're such a weirdo."
    ss "Eres un bicho raro."

# game/Scenes/Suzy/suzy1.rpy:59
translate spanish suzy1_086a625f:

    # "We spend the rest of the breakfast talking about school and work and joking around."
    "Pasamos el resto del desayuno hablando del colegio y del trabajo y bromeando."

# game/Scenes/Suzy/suzy1.rpy:60
translate spanish suzy1_74d7aff9:

    # "Then we finish eating and it's time to go to school."
    "Luego terminamos de comer y es hora de ir al colegio."

# game/Scenes/Suzy/suzy1.rpy:65
translate spanish suzy1_74b357a7:

    # ss "Have a good day [bro]. See you later."
    ss "Que tengas un buen día [bro]. Hasta luego."

# game/Scenes/Suzy/suzy1.rpy:66
translate spanish suzy1_7dee10c4:

    # pc "Bye [sis]."
    pc "Adiós [sis]."

# game/Scenes/Suzy/suzy1.rpy:71
translate spanish suzy1_015cad61:

    # "She leaves for school and I follow right after her."
    "Ella se va al colegio y yo la sigo justo después."

