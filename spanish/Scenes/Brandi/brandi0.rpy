    # voice 'voices/brandi 0_1.mp3'
    voice 'voices/brandi 0_1.mp3'

# game/Scenes/Brandi/brandi0.rpy:29
translate spanish brandi0_83069ce5:

    # fd "Hi, I'm Brandi. What's your name?"
    fd "Hola, soy Brandi. ¿Cómo te llamas?"

# game/Scenes/Brandi/brandi0.rpy:30
translate spanish brandi0_55be1fd1:

    # pc "[pcname]."
    pc "[pcname]."

# game/Scenes/Brandi/brandi0.rpy:32
translate spanish brandi0_2a83a288:

    # "I recognize her then as the woman who had set the record for the most burgers eaten here on All-You-Can-Eat Sundays."
    "Entonces la reconozco como la mujer que había batido el récord de hamburguesas consumidas aquí en los domingos de «todo lo que puedas comer»."

# game/Scenes/Brandi/brandi0.rpy:33
translate spanish brandi0_6a2e96f3:

    # "How the hell did she eat 14 burgers?"
    "¿Cómo demonios se comió 14 hamburguesas?"

# game/Scenes/Brandi/brandi0.rpy:36
translate spanish brandi0_09a42674:

    # fd "Well [pcname], I do a food blog and three times a week, for my Kitch subscribers, I do these live dinners where I sit and chat with my followers while I eat some good food."
    fd "Bueno, [pcname], tengo un blog de comida y, tres veces a la semana, para mis suscriptores de Kitch, hago estas cenas en directo en las que me siento a charlar con mis seguidores mientras como buena comida."

# game/Scenes/Brandi/brandi0.rpy:37
translate spanish brandi0_900cc1e0:

    # pc "Wait, so they're just sitting at their computers watching you eat?"
    pc "Espera, ¿así que se sientan delante de sus ordenadores a verte comer?"

# game/Scenes/Brandi/brandi0.rpy:38
translate spanish brandi0_8aa68273:

    # fd "Yeah there's nearly 600 people in chat right now. Say hi."
    fd "Sí, ahora mismo hay casi 600 personas en el chat. Salúdalos."

# game/Scenes/Brandi/brandi0.rpy:41
translate spanish brandi0_73e58957:

    # pc "Uh, hi there."
    pc "Eh, hola a todos."

# game/Scenes/Brandi/brandi0.rpy:42
translate spanish brandi0_d5bcf556:

    # fd "Everybody be nice to [pcname]. He's being a good sport."
    fd "Sed amables con [pcname]. Está siendo muy simpático."

# game/Scenes/Brandi/brandi0.rpy:45
translate spanish brandi0_2f36690d:

    # fd "So I've been telling everybody for a long time how this place has the best burgers in the world, but they don't believe me."
    fd "Llevo mucho tiempo diciéndole a todo el mundo que este sitio tiene las mejores hamburguesas del mundo, pero no me creen."

# game/Scenes/Brandi/brandi0.rpy:46
translate spanish brandi0_4454c371:

    # fd "I figured I'd grab the first random person who walked in the door and have them back up my claim."
    fd "Se me ocurrió coger a la primera persona al azar que entrara por la puerta y que confirmara mi afirmación."

# game/Scenes/Brandi/brandi0.rpy:47
translate spanish brandi0_9706e98a:

    # fd "They're the best, right?"
    fd "Son las mejores, ¿verdad?"

# game/Scenes/Brandi/brandi0.rpy:48
translate spanish brandi0_97b1f955:

    # "Her eyes focus on mine, begging me to agree with her."
    "Sus ojos se clavan en los míos, suplicándome que esté de acuerdo con ella."

# game/Scenes/Brandi/brandi0.rpy:49
translate spanish brandi0_4dab9b69:

    # "She doesn't even have to do that though. She is speaking truths."
    "Aunque ni siquiera tiene que hacerlo. Está diciendo la verdad."

# game/Scenes/Brandi/brandi0.rpy:50
translate spanish brandi0_3091c9ab:

    # pc "They definitely are."
    pc "Sin duda lo son."

# game/Scenes/Brandi/brandi0.rpy:51
translate spanish brandi0_866e846f:

    # pc "I don't know what kind of black magic fuckery Jackson does to make them taste so good,"
    pc "No sé qué tipo de magia negra utiliza Jackson para que sepan tan bien,"

# game/Scenes/Brandi/brandi0.rpy:52
translate spanish brandi0_8b6dd367:

    # pc "But this is seriously the best meat you'll ever put in your mouth."
    pc "pero esta es, en serio, la mejor carne que te llevarás a la boca jamás."

# game/Scenes/Brandi/brandi0.rpy:55
translate spanish brandi0_c69ca1b2:

    # fd "Oh my gods. Haha, that's one way to put it."
    fd "Oh, Dios mío. Jaja, esa es una forma de decirlo."

# game/Scenes/Brandi/brandi0.rpy:58
translate spanish brandi0_51ca4011:

    # fd "I don't know about that though. I've had some pretty great meat in my mouth."
    fd "Aunque no estoy tan seguro. He probado carne bastante buena."

# game/Scenes/Brandi/brandi0.rpy:59
translate spanish brandi0_4b6dcd67:

    # "I suddenly realize the way that I had phrased that and I can feel my cheeks get red."
    "De repente me doy cuenta de cómo he formulado eso y noto que se me enrojecen las mejillas."

# game/Scenes/Brandi/brandi0.rpy:60
translate spanish brandi0_720edf84:

    # fd "Anyways, thanks for backing me up."
    fd "En fin, gracias por apoyarme."

# game/Scenes/Brandi/brandi0.rpy:63
translate spanish brandi0_57dba103:

    # fd "See guys. Best burgers in the world, right here in little Skyhill."
    fd "¿Veis, chicos? Las mejores hamburguesas del mundo, aquí mismo, en la pequeña Skyhill."

# game/Scenes/Brandi/brandi0.rpy:64
translate spanish brandi0_c6c249ec:

    # fd "And with that, it's time for me to sign off. Thanks for hanging out with me and [pcname]."
    fd "Y con esto, es hora de despedirme. Gracias por pasar el rato conmigo y [pcname]."

# game/Scenes/Brandi/brandi0.rpy:66
translate spanish brandi0_d41d8cd9_1:

    # voice 'voices/brandi 0_2.mp3'
    voice 'voices/brandi 0_2.mp3'

# game/Scenes/Brandi/brandi0.rpy:67
translate spanish brandi0_4ac0cb0a:

    # fd "Be sure you like, comment, and subscribe, and don't forget to ring that bell for notifications."
    fd "Aseguraos de darle a «Me gusta», comentar y suscribiros, y no os olvidéis de pulsar la campana para recibir notificaciones."

# game/Scenes/Brandi/brandi0.rpy:70
translate spanish brandi0_326081b3:

    # fd "Say bye, [pcname]."
    fd "Adiós, [pcname]."

# game/Scenes/Brandi/brandi0.rpy:71
translate spanish brandi0_a9138891:

    # pc "Bye!"
    pc "¡Adiós!"

# game/Scenes/Brandi/brandi0.rpy:76
translate spanish brandi0_d41d8cd9_2:

    # voice 'voices/brandi_thanks2.mp3'
    voice 'voices/brandi_thanks2.mp3'

# game/Scenes/Brandi/brandi0.rpy:77
translate spanish brandi0_6583f806:

    # fd "Thanks again for helping me out with that. I'll buy you a burger."
    fd "Gracias de nuevo por echarme una mano con eso. Te invitaré a una hamburguesa."

# game/Scenes/Brandi/brandi0.rpy:81
translate spanish brandi0_90fdbc67:

    # fd "That's what I always say!"
    fd "¡Eso es lo que siempre digo!"

# game/Scenes/Brandi/brandi0.rpy:82
translate spanish brandi0_906d37ca:

    # fd "Anyways, I gotta get going. Hope you enjoy."
    fd "Bueno, me tengo que ir. Espero que lo disfrutes."

# game/Scenes/Brandi/brandi0.rpy:84
translate spanish brandi0_4e279127:

    # fd "Oh, well thanks for doing this for me anyways."
    fd "Ah, bueno, gracias por hacer esto por mí de todos modos."

# game/Scenes/Brandi/brandi0.rpy:85
translate spanish brandi0_0260c184:

    # fd "Anyways, I gotta get going."
    fd "Bueno, me tengo que ir."

# game/Scenes/Brandi/brandi0.rpy:88
translate spanish brandi0_29773f1e:

    # fd "I would, but I gotta run. I have somewhere to be in like ten minutes."
    fd "Lo haría, pero tengo que irme corriendo. Tengo que estar en un sitio dentro de unos diez minutos."

# game/Scenes/Brandi/brandi0.rpy:92
translate spanish brandi0_9645916f:

    # "I stand up and let her slide out of the booth."
    "Me levanto y la dejo salir de la mesa."

# game/Scenes/Brandi/brandi0.rpy:93
translate spanish brandi0_c7c7ca8c:

    # fd "Hope I see you around again. You're a natural on the camera."
    fd "Espero volver a verte por ahí. Se te da muy bien la cámara."

# game/Scenes/Brandi/brandi0.rpy:94
translate spanish brandi0_399bdc0f:

    # pc "Really?"
    pc "¿En serio?"

# game/Scenes/Brandi/brandi0.rpy:96
translate spanish brandi0_7f04ba06:

    # fd "Hah, no, but still, I hope I see you again."
    fd "Ja, no, pero aun así, espero volver a verte."

# game/Scenes/Brandi/brandi0.rpy:97
translate spanish brandi0_012dcbfd:

    # fd "If you want to check out my stream, I'm MagicMouth on Kitch, or you can just go to my website - www.brandiswallows.com."
    fd "Si quieres echar un vistazo a mi stream, soy MagicMouth en Kitch, o simplemente puedes ir a mi página web: www.brandiswallows.com."

# game/Scenes/Brandi/brandi0.rpy:98
translate spanish brandi0_6b3f9108:

    # fd "See it's a double entendre."
    fd "¿Ves? Es un doble sentido."

# game/Scenes/Brandi/brandi0.rpy:100
translate spanish brandi0_9fa5f8e4:

    # fd "Because it's talking about me swallowing food, but also about me swallowing cum."
    fd "Porque habla de mí tragándome la comida, pero también de mí tragándome el semen."

# game/Scenes/Brandi/brandi0.rpy:101
translate spanish brandi0_6a38101b:

    # fd "Get it?"
    fd "¿Lo pillas?"

# game/Scenes/Brandi/brandi0.rpy:102
translate spanish brandi0_6221d019:

    # pc "I got it."
    pc "Lo pillo."

# game/Scenes/Brandi/brandi0.rpy:104
translate spanish brandi0_f75f7c08:

    # fd "Okay, I gotta run. I'll see you around. Thanks again."
    fd "Vale, tengo que irme. Nos vemos por ahí. Gracias de nuevo."

