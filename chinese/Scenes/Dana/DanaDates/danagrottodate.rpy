# game/Scenes/Dana/DanaDates/danagrottodate.rpy:23
translate chinese danagrottostartdate_1563db25:

    # "I drive over and pick Dana up. Then we go out to The Grotto together."
    "我开车过去接达娜，然后我们一起去了“岩洞餐厅”。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:28
translate chinese danagrottostartdate_2095cc55:

    # cw "Wow. This place is amazing."
    cw "哇。这地方太棒了。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:29
translate chinese danagrottostartdate_2ba00ab3:

    # cw "I can't believe I get to go out here. It's so beautiful."
    cw "真不敢相信我能来这里。太美了。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:30
translate chinese danagrottostartdate_05526a72:

    # pc "You're beautiful, Dana. You deserve it."
    pc "你也很美，达娜。你值得拥有这一切。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:31
translate chinese danagrottostartdate_9c4b6956:

    # cw "Thank you, [pcname]."
    cw "谢谢你，[pcname]。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:32
translate chinese danagrottostartdate_37c9d0bf:

    # "We walk in and the host leads us to our seats."
    "我们走进餐厅，领位员带我们入座。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:38
translate chinese danagrottostartdate_80af549c:

    # cw "You can afford this? On what Mrs. Mills pays you?"
    cw "你负担得起这里吗？靠米尔斯太太给你的那点薪水？"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:39
translate chinese danagrottostartdate_0f30c499:

    # pc "Sure. I mean, not every day or anything, but occasionally. I don't have many bills."
    pc "当然。我是说，不是每天都能来，但偶尔来一次没问题。我没什么开销。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:40
translate chinese danagrottostartdate_a4bd3f4d:

    # pc "Don't worry about it though, Dana. I want you to have a great night."
    pc "不过别担心这个，达娜。 我希望你今晚过得尽兴。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:42
translate chinese danagrottostartdate_617347d3:

    # cw "I already am. This is incredible."
    cw "我已经很开心了。这简直太棒了。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:43
translate chinese danagrottostartdate_ecd9ab22:

    # "The server takes our orders and we chat for a while."
    "服务员来点餐，我们聊了一会儿。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:46
translate chinese danagrottostartdate_ac38448c:

    # "Then we eat and chat some more."
    "接着我们边吃边聊。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:52
translate chinese danagrottostartdate_94d3f64e:

    # "Then we get up and dance a bit to the soft music."
    "然后我们起身，随着轻柔的音乐跳了一会儿舞。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:54
translate chinese danagrottostartdate_d0b4cddc:

    # cw "You're so amazing. This is the best date I've ever been on."
    cw "你太棒了。这是我经历过的最棒的约会。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:55
translate chinese danagrottostartdate_1ece43ad:

    # cw "I couldn't want anything more."
    cw "我别无所求。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:56
translate chinese danagrottostartdate_f6634f6b:

    # pc "Anything to make you happy, Dana. That's all I want."
    pc "只要能让你开心，达娜。这就是我唯一的心愿。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:60
translate chinese danagrottostartdate_93db9284:

    # cw "You do make me happy, [pcname]."
    cw "你确实让我很开心，[pcname]。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:61
translate chinese danagrottostartdate_8b92acc5:

    # cw "I'm so very happy."
    cw "我真的非常开心。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:69
translate chinese danagrottostartdate_c8c4e655:

    # cw "I know a way you can make me even happier though."
    cw "不过我知道一个能让我更开心的办法。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:70
translate chinese danagrottostartdate_ae871f39:

    # pc "Oh yeah?"
    pc "哦，是吗？"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:71
translate chinese danagrottostartdate_9a5a9a70:

    # cw "Are you ready to take me home?"
    cw "你准备好带我回家了吗？"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:72
translate chinese danagrottostartdate_69a64407:

    # pc "Yes, I think we should."
    pc "是的，我觉得我们应该回去。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:76
translate chinese danagrottostartdate_4097bbec:

    # "Fifteen minutes later we're in her bedroom and she's naked on the bed, practically begging me to ravage her."
    "十五分钟后，我们到了她的卧室，她赤裸地躺在床上，几乎是在恳求我狠狠占有她。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:80
translate chinese danagrottostartdate_ff3293a2:

    # cw "Do you want to continue this back at my place?"
    cw "你想去我家继续吗？"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:83
translate chinese danagrottostartdate_92e63c5d:

    # cw "Great. Let's go. I can't wait to get my mouth on you."
    cw "太好了。走吧。我等不及要亲吻你了。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:87
translate chinese danagrottostartdate_4097bbec_1:

    # "Fifteen minutes later we're in her bedroom and she's naked on the bed, practically begging me to ravage her."
    "十五分钟后，我们到了她的卧室，她赤裸地躺在床上，简直是在求我占有她。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:91
translate chinese danagrottostartdate_627e2bde:

    # cw "Oh, alright."
    cw "哦，好吧。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:92
translate chinese danagrottostartdate_0128787c:

    # cw "It was still an incredible date. Thank you."
    cw "这依然是一次美妙的约会。谢谢你。"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:95
translate chinese danagrottostartdate_e8cbe586:

    # "I drive Dana home and we say our goodbyes, then she goes inside and I drive away to continue my night."
    "我开车送达娜回家，我们道别后，她走进屋里，我则开车离开，继续我的夜晚。"

