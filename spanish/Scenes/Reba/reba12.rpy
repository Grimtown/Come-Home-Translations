    pc "No pasa nada. No estoy de mal humor. Estar aquí contigo es genial."

# game/Scenes/Reba/reba12.rpy:68
translate spanish reba12_f053b562:

    # rb "Yeah it is. We're gonna have so much fun."
    rb "Sí, lo es. Nos lo vamos a pasar genial."

