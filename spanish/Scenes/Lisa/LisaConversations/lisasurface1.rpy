# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:12
translate spanish lisasurface1_0ee431fc:

    # pc "What do you do in your free time?"
    pc "¿Qué haces en tu tiempo libre?"

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:14
translate spanish lisasurface1_ab575906:

    # sp "I feel like I don't really do a lot. I'm kind of lazy."
    sp "Siento que no hago gran cosa. Soy un poco vaga."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:15
translate spanish lisasurface1_dcfa3f79:

    # sp "If I'm not at work, I'm usually cooking or cleaning around the house."
    sp "Si no estoy en el trabajo, suelo estar cocinando o limpiando por casa."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:16
translate spanish lisasurface1_2533d524:

    # sp "So when I get free time, I tend to just veg in front of the television and watch bad reality TV."
    sp "Así que, cuando tengo tiempo libre, suelo quedarme tirada delante de la tele viendo programas de telerrealidad malos."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:17
translate spanish lisasurface1_b8a72e25:

    # pc "Ugh, I hate that stuff."
    pc "Uf, odio eso."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:19
translate spanish lisasurface1_cb958011:

    # sp "That's the thing. I don't really like it either, but it completely shuts my brain off when I'm watching it."
    sp "Esa es la cuestión. A mí tampoco me gusta mucho, pero me desconecta el cerebro por completo cuando lo veo."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:20
translate spanish lisasurface1_72ebc831:

    # sp "So I can stop thinking about everything else that's going on and just focus on these dumb reality star's lives."
    sp "Así puedo dejar de pensar en todo lo demás que está pasando y centrarme solo en las vidas de esas estrellas de reality tan tontas."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:21
translate spanish lisasurface1_f433d56f:

    # pc "I get it. I don't want to ever watch it, but I get it."
    pc "Lo entiendo. No quiero verlo nunca, pero lo entiendo."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:22
translate spanish lisasurface1_97fe7a58:

    # sp "I watch good television sometimes too though."
    sp "Aunque a veces también veo programas de televisión buenos."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:23
translate spanish lisasurface1_785ed82a:

    # pc "Sure you do."
    pc "Claro que sí."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:25
translate spanish lisasurface1_d3ee5c37:

    # sp "Don't tease me. You're just like your dad, always teasing me about what shows I watch."
    sp "No te burles de mí. Eres igual que tu padre, siempre burlándote de los programas que veo."

# game/Scenes/Lisa/LisaConversations/lisasurface1.rpy:26
translate spanish lisasurface1_4c54c7ef:

    # sp "I know they're dumb. I don't care, I'll watch whatever I want to watch."
    sp "Sé que son tontos. No me importa, veré lo que me dé la gana."

