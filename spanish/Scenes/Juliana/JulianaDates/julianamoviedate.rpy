# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:32
translate spanish julianamovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Llegamos al cine y nos sentamos en las últimas filas."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:33
translate spanish julianamovietheaterstartdate_cd1f1d61:

    # bn "What kind of movie are we watching?"
    bn "¿Qué tipo de película vamos a ver?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:37
translate spanish julianamovietheaterstartdate_9753ecc6:

    # bn "That sounds very nice."
    bn "Suena muy bien."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:38
translate spanish julianamovietheaterstartdate_08edcd3e:

    # bn "I like romantic movies."
    bn "Me gustan las películas románticas."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:43
translate spanish julianamovietheaterstartdate_22be6204:

    # bn "Oh really?"
    bn "¿Ah, sí?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:44
translate spanish julianamovietheaterstartdate_a7aa68a8:

    # bn "I'm not really interested dumb action movies, but okay."
    bn "No me interesan mucho las películas de acción tontas, pero vale."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:50
translate spanish julianamovietheaterstartdate_a36785e7:

    # bn "Oh really? I don't really like scary movies at all."
    bn "¿Ah, sí? A mí no me gustan nada las películas de miedo."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:51
translate spanish julianamovietheaterstartdate_5b88690f:

    # bn "Unless they're about hauntings, or they have some sort of romance in them."
    bn "A menos que sean de fantasmas o tengan algo de romance."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:52
translate spanish julianamovietheaterstartdate_ffedd8a3:

    # bn "Most horror movies are really dumb."
    bn "La mayoría de las películas de terror son muy tontas."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:58
translate spanish julianamovietheaterstartdate_352ba7de:

    # bn "Oh okay."
    bn "Ah, vale."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:59
translate spanish julianamovietheaterstartdate_9c6a96f5:

    # bn "I try to enjoy comedies, but I don't always get the jokes."
    bn "Intento disfrutar de las comedias, pero no siempre pillo los chistes."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:60
translate spanish julianamovietheaterstartdate_74eb3e05:

    # bn "There's a lot of times that I just don't understand what is supposed to be funny and what's not."
    bn "Muchas veces simplemente no entiendo qué se supone que es gracioso y qué no."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:61
translate spanish julianamovietheaterstartdate_cf50250b:

    # bn "But I'll try my best to laugh at the parts I'm supposed to."
    bn "Pero haré todo lo posible por reírme en las partes en las que se supone que debo hacerlo."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:63
translate spanish julianamovietheaterstartdate_2fcc7df5:

    # "There's a little time before the movie starts for us to chat some."
    "Tenemos un rato antes de que empiece la película para charlar un poco."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:67
translate spanish julianamovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Por fin empieza la película y nos quedamos en silencio."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:70
translate spanish julianamovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Ella se inclina y me coge la mano por encima del reposabrazos."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:74
translate spanish julianamovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Los tráilers duran unos quince minutos, y luego empieza la película de verdad."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:78
translate spanish julianamovietheaterstartdate_17eefcb1:

    # "During the movie, she leans on my shoulder, really getting into the story."
    "Durante la película, ella se apoya en mi hombro, metiéndose de lleno en la historia."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:80
translate spanish julianamovietheaterstartdate_1b60b301:

    # "Then during a particularly romantic scene, she raises her head and puts her lips to mine."
    "Luego, durante una escena especialmente romántica, levanta la cabeza y acerca sus labios a los míos."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:81
translate spanish julianamovietheaterstartdate_787192bc:

    # "We don't really watch a lot of the rest of the movie, instead focusing on making out."
    "La verdad es que no vemos gran parte del resto de la película, sino que nos centramos en besarnos."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:84
translate spanish julianamovietheaterstartdate_d17a4ae6:

    # "During the movie, she leans against my shoulder, really getting into the story."
    "Durante la película, ella se apoya en mi hombro, metiéndose de lleno en la historia."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:86
translate spanish julianamovietheaterstartdate_610dce56:

    # "She seems to be liking the movie okay."
    "Parece que la película le está gustando bastante."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:89
translate spanish julianamovietheaterstartdate_dcbaecf4:

    # "Juliana watches the movie, but she looks annoyed the entire time."
    "Juliana ve la película, pero parece molesta todo el tiempo."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:92
translate spanish julianamovietheaterstartdate_40670365:

    # "Eventually, she turns towards me."
    "Al final, se gira hacia mí."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:93
translate spanish julianamovietheaterstartdate_b867ff88:

    # bn "This movie is really bad, isn't it? It might be the worst movie I've ever seen."
    bn "Esta película es muy mala, ¿verdad? Puede que sea la peor película que he visto nunca."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:94
translate spanish julianamovietheaterstartdate_e3d0d8a6:

    # "She does not speak quietly, and some people in front of us turn and look at us."
    "No habla en voz baja, y algunas personas que están delante de nosotros se giran y nos miran."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:95
translate spanish julianamovietheaterstartdate_d58327fc:

    # pc "Do you want to leave?"
    pc "¿Quieres irte?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:97
translate spanish julianamovietheaterstartdate_25b2e9a4:

    # bn "No, can we just kiss or something instead? I don't care about watching this."
    bn "No, ¿podemos simplemente besarnos o algo así? No me importa ver esto."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:98
translate spanish julianamovietheaterstartdate_4f1735dd:

    # pc "Sounds good to me."
    pc "Me parece bien."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:100
translate spanish julianamovietheaterstartdate_d0a52fcf:

    # "I lean in and kiss her and we don't really watch much else of the movie, instead focusing on each other."
    "Me inclino y la beso, y ya no vemos mucho más de la película, sino que nos centramos el uno en el otro."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:103
translate spanish julianamovietheaterstartdate_c1b8c885:

    # "The horror movie was not about hauntings and had no romance in it."
    "La película de terror no trataba sobre fantasmas y no tenía nada de romance."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:104
translate spanish julianamovietheaterstartdate_003c9dc3:

    # "I'm pretty sure Juliana hated it."
    "Estoy bastante seguro de que a Juliana le horrorizó."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:105
translate spanish julianamovietheaterstartdate_27d6edde:

    # "At one point, I even tried holding her hand, but she was not interested."
    "En un momento dado, incluso intenté cogerle la mano, pero no le interesaba."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:106
translate spanish julianamovietheaterstartdate_d58327fc_1:

    # pc "Do you want to leave?"
    pc "¿Quieres irte?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:107
translate spanish julianamovietheaterstartdate_4aa1d16b:

    # bn "We're already too far in. I have to know which of these dumb girls is going to live."
    bn "Ya hemos avanzado demasiado. Tengo que saber cuál de estas chicas tontas va a sobrevivir."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:108
translate spanish julianamovietheaterstartdate_880b4aa8:

    # pc "Okay..."
    pc "Vale..."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:111
translate spanish julianamovietheaterstartdate_92b7555a:

    # "At first, I'm not sure that Juliana is going to like the movie at all."
    "Al principio, no estoy seguro de que a Juliana le vaya a gustar la película en absoluto."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:112
translate spanish julianamovietheaterstartdate_c421db42:

    # "She looks frustrated through the beginning."
    "Parece frustrada durante el comienzo."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:113
translate spanish julianamovietheaterstartdate_4e4b3a2b:

    # "But then..."
    "Pero entonces..."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:115
translate spanish julianamovietheaterstartdate_bd97c290:

    # "During one of the dumb jokes, she bursts into a fit of laughter that seems to go on forever."
    "Durante uno de los chistes tontos, se echa a reír a carcajadas y parece que no va a parar nunca."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:116
translate spanish julianamovietheaterstartdate_fa75bbc3:

    # pc "Are you okay?"
    pc "¿Estás bien?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:117
translate spanish julianamovietheaterstartdate_5b62109c:

    # bn "Yes. I'm sorry. It's so funny though."
    bn "Sí. Lo siento. Es que es muy gracioso."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:118
translate spanish julianamovietheaterstartdate_6ecb5d88:

    # bn "It's funny because he farted in a place where it was awkward to fart."
    bn "Es gracioso porque se tiró un pedo en un lugar donde era incómodo tirárselo."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:119
translate spanish julianamovietheaterstartdate_b59d1ff2:

    # bn "And he couldn't stop farting!"
    bn "¡Y no podía dejar de tirárselos!"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:120
translate spanish julianamovietheaterstartdate_9ef4273c:

    # "Once she starts laughing, she barely stops throughout the rest of the movie."
    "Una vez que empieza a reírse, apenas para durante el resto de la película."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:124
translate spanish julianamovietheaterstartdate_e42d81a7:

    # bn "I really liked that. I love when they go through some hardships, but stay together in the end."
    bn "Me ha gustado mucho. Me encanta cuando pasan por dificultades, pero al final se quedan juntos."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:125
translate spanish julianamovietheaterstartdate_fe15de53:

    # bn "Thank you for bringing me. I enjoyed all of it."
    bn "Gracias por traerme. Lo he disfrutado todo."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:129
translate spanish julianamovietheaterstartdate_71eb6066:

    # bn "Well, thanks for bringing me, but maybe not an action movie next time?"
    bn "Bueno, gracias por traerme, pero ¿quizás la próxima vez no sea una película de acción?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:130
translate spanish julianamovietheaterstartdate_6f6931a9:

    # bn "Even the noise of it was giving me a headache."
    bn "Incluso el ruido me estaba dando dolor de cabeza."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:134
translate spanish julianamovietheaterstartdate_5bf0a9a9:

    # bn "That was the dumbest thing I've ever seen in my life."
    bn "Ha sido lo más tonto que he visto en mi vida."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:135
translate spanish julianamovietheaterstartdate_2f39e364:

    # pc "It was pretty bad."
    pc "Ha sido bastante mala."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:136
translate spanish julianamovietheaterstartdate_02a07558:

    # bn "I hated it."
    bn "La odié."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:137
translate spanish julianamovietheaterstartdate_09c476ba:

    # bn "No more horror movies. They're all trash."
    bn "No más películas de terror. Todas son basura."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:138
translate spanish julianamovietheaterstartdate_459e0f19:

    # pc "Okay. No more horror movies."
    pc "Vale. No más películas de terror."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:141
translate spanish julianamovietheaterstartdate_850f6df3:

    # bn "That was so funny."
    bn "Eso fue muy divertido."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:142
translate spanish julianamovietheaterstartdate_4083c4d8:

    # bn "I'm sorry if I laughed too much."
    bn "Siento si me reí demasiado."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:143
translate spanish julianamovietheaterstartdate_cd4369b1:

    # pc "No, it was fun to see you cut loose like that."
    pc "No, fue divertido verte soltarte así."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:144
translate spanish julianamovietheaterstartdate_f50c4948:

    # bn "I guess I don't laugh very often, huh?"
    bn "Supongo que no me río muy a menudo, ¿eh?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:145
translate spanish julianamovietheaterstartdate_b459f5c7:

    # bn "But when I do... wow, you have to look out."
    bn "Pero cuando lo hago... vaya, hay que tener cuidado."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:146
translate spanish julianamovietheaterstartdate_985a02fd:

    # "We hang out after the movie and chat during the credits."
    "Quedamos después de la película y charlamos durante los créditos."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:150
translate spanish julianamovietheaterstartdate_972891e3:

    # "When the credits end, we walk outside together and out to my car."
    "Cuando terminan los créditos, salimos juntos y nos dirigimos a mi coche."

