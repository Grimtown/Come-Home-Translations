# game/Scenes/Whitney/whitney10.rpy:10
translate chinese whitney10_be5af3f7:

    # "My phone buzzes in my pocket. It's Whitney calling."
    "口袋里的手机震动起来。是惠特尼打来的。"

# game/Scenes/Whitney/whitney10.rpy:15
translate chinese whitney10_cabe2426:

    # pc "Hey, Whitney. What's up?"
    pc "嘿，惠特尼。有什么事吗？"

# game/Scenes/Whitney/whitney10.rpy:16
translate chinese whitney10_b9006bbe:

    # wt "Oh hey. Are you busy?"
    wt "哦，嘿。你忙吗？"

# game/Scenes/Whitney/whitney10.rpy:17
translate chinese whitney10_bc1428f9:

    # pc "Not really."
    pc "倒也不忙。"

# game/Scenes/Whitney/whitney10.rpy:19
translate chinese whitney10_87d76db1:

    # wt "I have this craving for that burger place we went to before. Would you want to go get dinner with me again?"
    wt "我特别想吃之前去过的那家汉堡店。你愿意再和我一起去吃晚饭吗？"

# game/Scenes/Whitney/whitney10.rpy:20
translate chinese whitney10_240f7709:

    # pc "Are you asking me out on a date?"
    pc "你是约我出去吗？"

# game/Scenes/Whitney/whitney10.rpy:22
translate chinese whitney10_b86f93de:

    # wt "You can call it whatever you like. I just want a burger."
    wt "你爱怎么称呼都行。我只是想吃个汉堡。"

# game/Scenes/Whitney/whitney10.rpy:23
translate chinese whitney10_91e1bb14:

    # wt "And your company is nice as well."
    wt "而且有你陪着也很不错。"

# game/Scenes/Whitney/whitney10.rpy:27
translate chinese whitney10_7c538ce6:

    # wt "Great! I'll drive over and pick you up at your place in about half an hour."
    wt "太好了！我半小时后开车去你家接你。"

# game/Scenes/Whitney/whitney10.rpy:28
translate chinese whitney10_ac8c00ba:

    # pc "Sounds good. See you then."
    pc "听起来不错。到时候见。"

# game/Scenes/Whitney/whitney10.rpy:29
translate chinese whitney10_2c71ca5c:

    # "We hang up and I go home and get ready."
    "我们挂了电话，我回家准备一下。"

# game/Scenes/Whitney/whitney10.rpy:33
translate chinese whitney10_2aaf9014:

    # wt "Oh, okay then."
    wt "哦，那好吧。"

# game/Scenes/Whitney/whitney10.rpy:34
translate chinese whitney10_f7a5b1c0:

    # wt "Well, if you want to sometime, just give me a call in the evening. I'm usually free."
    wt "嗯，如果你哪天想去，晚上给我打个电话就行。我通常都有空。"

# game/Scenes/Whitney/whitney10.rpy:35
translate chinese whitney10_bf0c9413:

    # pc "Okay, Whitney. Talk to you later."
    pc "好的，惠特尼。回头聊。"

# game/Scenes/Whitney/whitney10.rpy:36
translate chinese whitney10_a7e7a8bf:

    # wt "Bye, [pcname]."
    wt "拜拜，[pcname]。"

translate chinese strings:

    # game/Scenes/Whitney/whitney10.rpy:2
    old "A few days after you help Whitney pick up supplies and have lunch with her,"
    new "在你帮惠特尼买完日用品并和她共进午餐的几天后，"

    # game/Scenes/Whitney/whitney10.rpy:3
    old "if you've had a few conversations with her on the phone, she'll call and invite you out again."
    new "如果你和她通过几次电话，她会打电话再约你出去。"

