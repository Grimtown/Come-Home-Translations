translate spanish tammy14_815d66b7:

    # "And as soon as she's asleep, she immediately begins snoring loudly."
    "Y en cuanto se duerme, empieza inmediatamente a roncar muy fuerte."

# game/Scenes/Tammy/tammy14.rpy:175
translate spanish tammy14_055d080f:

    # ss "Dang, she's loud, huh?"
    ss "Vaya, qué ruidosa, ¿eh?"

# game/Scenes/Tammy/tammy14.rpy:176
translate spanish tammy14_593f6724:

    # "I nod, trying to stay quiet."
    "Asiento con la cabeza, intentando no hacer ruido."

# game/Scenes/Tammy/tammy14.rpy:177
translate spanish tammy14_536bf33b:

    # ss "When she's really tired like this, she passes out hard. You could shake her and she's not going to wake up."
    ss "Cuando está tan cansada como ahora, se queda profundamente dormida. Podrías sacudirla y no se despertaría."

# game/Scenes/Tammy/tammy14.rpy:178
translate spanish tammy14_20e84dbf:

    # pc "She deserves a good night sleep."
    pc "Se merece una buena noche de sueño."

# game/Scenes/Tammy/tammy14.rpy:179
translate spanish tammy14_e51a7dc2:

    # ss "Yeah. Thanks for being a good boyfriend tonight, [bro]."
    ss "Sí. Gracias por ser un buen novio esta noche, [bro]."

# game/Scenes/Tammy/tammy14.rpy:180
translate spanish tammy14_a248948f:

    # pc "Of course."
    pc "Por supuesto."

# game/Scenes/Tammy/tammy14.rpy:181
translate spanish tammy14_53a16996:

    # ss "Love you."
    ss "Te quiero."

# game/Scenes/Tammy/tammy14.rpy:182
translate spanish tammy14_3213fe29:

    # pc "Love you too, [sis]."
    pc "Yo también te quiero, [sis]."

# game/Scenes/Tammy/tammy14.rpy:185
translate spanish tammy14_87d1006f:

    # "Suzy lies back down again and falls asleep."
    "Suzy se vuelve a tumbar y se queda dormida."

# game/Scenes/Tammy/tammy14.rpy:188
translate spanish tammy14_da5d00b9:

    # "Shortly after, despite Tammy's loud snoring, I fall asleep too."
    "Poco después, a pesar de los fuertes ronquidos de Tammy, yo también me duermo."

# game/Scenes/Tammy/tammy14.rpy:189
translate spanish tammy14_2af8e2e3:

    # "I have great dreams all night, but somehow they don't even compare to my waking life."
    "Tengo sueños maravillosos toda la noche, pero de alguna manera ni siquiera se pueden comparar con mi vida despierto."

# game/Scenes/Tammy/tammy14.rpy:192
translate spanish tammy14_d8050fd9:

    # "I must have slept hard as well, because I don't wake up through the entire night."
    "Debo de haber dormido profundamente también, porque no me despierto en toda la noche."

# game/Scenes/Tammy/tammy14.rpy:195
translate spanish tammy14_6e97274e:

    # "And when I look around in the morning, they are both gone."
    "Y cuando miro a mi alrededor por la mañana, las dos se han ido."

# game/Scenes/Tammy/tammy14.rpy:201
translate spanish tammy14_d1a14932:

    # "I get up and go to the bathroom, then walk downstairs."
    "Me levanto y voy al baño, luego bajo las escaleras."

# game/Scenes/Tammy/tammy14.rpy:204
translate spanish tammy14_7279822b:

    # "In the dining room, Suzy greets me with a kiss."
    "En el comedor, Suzy me saluda con un beso."

# game/Scenes/Tammy/tammy14.rpy:205
translate spanish tammy14_ce46d3ed:

    # ss "There's some breakfast in the kitchen if you want any. Mom made way too much before she left."
    ss "Hay algo de desayuno en la cocina, si quieres. Mamá preparó demasiado antes de irse."

# game/Scenes/Tammy/tammy14.rpy:206
translate spanish tammy14_03e500eb:

    # pc "Where's Tammy?"
    pc "¿Dónde está Tammy?"

# game/Scenes/Tammy/tammy14.rpy:207
translate spanish tammy14_6a080cce:

    # ss "She had to leave early for work. I doubt we'll be seeing her for breakfast very often."
    ss "Tuvo que irse temprano al trabajo. Dudo que la veamos muy a menudo para desayunar."

# game/Scenes/Tammy/tammy14.rpy:208
translate spanish tammy14_34f75a54:

    # pc "Oh, okay."
    pc "Ah, vale."

# game/Scenes/Tammy/tammy14.rpy:211
translate spanish tammy14_eef7b49f:

    # ss "Did you want to eat breakfast with me... or maybe mess around some?"
    ss "¿Querías desayunar conmigo... o quizá hacer el tonto un rato?"

# game/Scenes/Tammy/tammy14.rpy:215
translate spanish tammy14_6ae50746:

    # ss "Oh, alright then."
    ss "Ah, vale, entonces."

# game/Scenes/Tammy/tammy14.rpy:218
translate spanish tammy14_b9e9893b:

    # ss "I was hoping you would say that."
    ss "Esperaba que dijeras eso."

# game/Scenes/Tammy/tammy14.rpy:222
translate spanish tammy14_ca91b2cf:

    # ss "Oh, okay. See you later then, [bro]."
    ss "Ah, vale. Nos vemos luego, [bro]."

translate spanish strings:

    # game/Scenes/Tammy/tammy14.rpy:2
    old "After you have gone out on a few dates with Tammy and Suzy together, including going to the ice-cream parlor,"
    new "Después de haber salido en unas cuantas citas con Tammy y Suzy juntas, incluyendo ir a la heladería,"

    # game/Scenes/Tammy/tammy14.rpy:3
    old "and you have talked to them about Tammy moving out of her parents house, this will happen automatically at home at night."
    new "y de haber hablado con ellas sobre la mudanza de Tammy de la casa de sus padres, esto sucederá automáticamente en casa por la noche."

