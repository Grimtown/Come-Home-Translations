# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:15
translate chinese whitneys2_f8a79e24:

    # wt "Just a little outside of town."
    wt "就在城外不远。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:16
translate chinese whitneys2_d705782d:

    # wt "I have a house out in the country between Skyhill and Whiterock."
    wt "我在乡下有一栋房子，位于斯凯希尔和怀特洛克之间。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:17
translate chinese whitneys2_20899d6b:

    # pc "Oh nice. You live by yourself?"
    pc "哦，不错。你一个人住吗？"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:18
translate chinese whitneys2_3741c3cf:

    # wt "Yes, but people are here with me almost all the time."
    wt "是的，不过几乎整天都有人在我身边。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:19
translate chinese whitneys2_04e02dec:

    # pc "You have a lot of friends?"
    pc "你有好多朋友吗？"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:20
translate chinese whitneys2_4471df1e:

    # wt "Not friends really. Employees."
    wt "倒也不是朋友。是雇员。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:21
translate chinese whitneys2_7e7e2060:

    # wt "I have a maid-slash-cook who is here most of the day, a groundskeeper who comes once a week…"
    wt "我有位兼任厨师的保姆，她一天大部分时间都在这里，还有个园丁，每周来一次……"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:22
translate chinese whitneys2_bfa9a062:

    # wt "… then there's the physical therapist, the psychiatrist, my accountant, and so on and so on."
    wt "……然后还有物理治疗师、精神科医生、我的会计师，等等等等。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:23
translate chinese whitneys2_20aac584:

    # pc "Sounds like you keep pretty busy."
    pc "听起来你挺忙的。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:25
translate chinese whitneys2_87889000:

    # wt "Yeah, I guess so."
    wt "是啊，大概是吧。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:26
translate chinese whitneys2_8ad9b64e:

    # wt "Having all those people to take care of everyday things for me allows me to focus on the things that I really care about in my laboratory."
    wt "有这么多人帮我打理日常琐事，我才能把精力集中在我实验室里真正关心的事情上。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:27
translate chinese whitneys2_6e598717:

    # wt "I'm in there most of the day every day."
    wt "我每天大部分时间都在里面。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:28
translate chinese whitneys2_95cf8e29:

    # pc "What do you do in there?"
    pc "你在里面做什么？"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:30
translate chinese whitneys2_1f645aba:

    # wt "Mostly just experimenting. Electronics, gadgets, inventions. Stuff like that."
    wt "主要是做实验。电子设备、小玩意儿、发明之类的东西。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:31
translate chinese whitneys2_cea18af3:

    # pc "You invent anything that I might have heard of?"
    pc "你发明过什么我可能听说过的东西吗？"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:33
translate chinese whitneys2_0b69c304:

    # wt "I have several patents on devices being used by the government."
    wt "我有几项专利，政府正在使用那些设备。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:34
translate chinese whitneys2_db3a119a:

    # wt "They've paid me quite well not to speak of them."
    wt "他们付给我不菲的报酬，让我对这些保密。"

# game/Scenes/Whitney/WhitneyConversations/whitneys2.rpy:35
translate chinese whitneys2_bdcea22e:

    # pc "Oh. Okay. Got it."
    pc "哦。好吧。明白了。"

