    voice 'voices/izzy_whatsup.mp3'

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:33
translate spanish izzyluigisdatestart_7abda82a:

    # gl "What's up, Twig. Let's go get some fucking pizza."
    gl "¿Qué tal, Twig? Vamos a por una puta pizza."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:37
translate spanish izzyluigisdatestart_008f10b6:

    # gl "Wow, this place is a little more fancy than I expected."
    gl "Vaya, este sitio es un poco más elegante de lo que esperaba."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:38
translate spanish izzyluigisdatestart_8fffd4a0:

    # gl "Maybe I should have put on some makeup or something."
    gl "Quizá debería haberme maquillado un poco o algo así."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:39
translate spanish izzyluigisdatestart_560798c7:

    # pc "You look great. Don't worry about it."
    pc "Estás genial. No te preocupes por eso."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:41
translate spanish izzyluigisdatestart_5efd3620:

    # gl "Alright then. Thanks, Twig."
    gl "Vale, entonces. Gracias, Twig."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:45
translate spanish izzyluigisdatestart_868de71e:

    # "We sit at the booth and order a pizza."
    "Nos sentamos en la mesa y pedimos una pizza."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:46
translate spanish izzyluigisdatestart_a675496b:

    # "We start talking and don't stop the whole time we're there."
    "Empezamos a hablar y no paramos en todo el rato que estamos allí."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:53
translate spanish izzyluigisdatestart_d0143732:

    # "When we're done eating, I drive Izzy back to her house."
    "Cuando terminamos de comer, llevo a Izzy de vuelta a su casa."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:54
translate spanish izzyluigisdatestart_2a5b6b89:

    # "I pull into her driveway and she turns to look at me."
    "Me meto en su camino de entrada y ella se gira para mirarme."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:56
translate spanish izzyluigisdatestart_6dd86d8c:

    # gl "So, do you want to come inside and fuck a little?"
    gl "Oye, ¿quieres entrar y echar un polvo?"

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:63
translate spanish izzyluigisdatestart_dcbc938c:

    # gl "Cool, let's go."
    gl "Genial, vamos."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:66
translate spanish izzyluigisdatestart_dcbc938c_1:

    # gl "Cool, let's go."
    gl "Genial, vamos."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:69
translate spanish izzyluigisdatestart_a9bda5cf:

    # gl "Damn, a girl can hope. Thanks for the food anyway, Twig. See ya later."
    gl "Joder, una chica siempre puede tener esperanzas. Gracias por la comida de todos modos, Twig. Nos vemos luego."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:70
translate spanish izzyluigisdatestart_63fc4244:

    # pc "Bye, Izzy."
    pc "Adiós, Izzy."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:73
translate spanish izzyluigisdatestart_8b93ebfd:

    # "I wait until she gets out and walks into her house before I drive away."
    "Espero a que salga y entre en su casa antes de marcharme."

